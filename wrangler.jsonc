{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "personal-site",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-18",
  "routes": [
    {
      "pattern": "amberns.com",
      "zone_name": "amberns.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "404-page"
  }
}
