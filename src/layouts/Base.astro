---
import '@fontsource-variable/lexend';
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
}
const { title, description, showNav = true } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/taste', label: 'Taste' },
  { href: '/writing', label: 'Writing' },
  { href: '/formalization', label: 'Formalization' },
  { href: '/music', label: 'Music' },
  { href: '/other', label: 'Other' },
];
const pageClass = `page-${path === '/' ? 'home' : path.split('/')[1]}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script is:inline>
      if (new URLSearchParams(window.location.search).get('animation') === '1') {
        document.documentElement.classList.add('animation-only');
      }
      (function () {
        var DEV_KEY = 'site-dev-mode';
        var params = new URLSearchParams(window.location.search);
        var paramVal = params.get('dev');
        var stored = null;
        try { stored = localStorage.getItem(DEV_KEY); } catch (e) {}
        var on;
        if (paramVal === '1') {
          on = true;
          try { localStorage.setItem(DEV_KEY, '1'); } catch (e) {}
        } else if (paramVal === '0') {
          on = false;
          try { localStorage.setItem(DEV_KEY, '0'); } catch (e) {}
        } else {
          on = stored === '1';
        }
        if (on) document.documentElement.classList.add('dev-mode');
        document.addEventListener('keydown', function (e) {
          if (e.shiftKey && (e.key === 'D' || e.key === 'd') && !e.metaKey && !e.ctrlKey && !e.altKey) {
            var t = e.target;
            if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
            var next = !document.documentElement.classList.contains('dev-mode');
            document.documentElement.classList.toggle('dev-mode', next);
            try { localStorage.setItem(DEV_KEY, next ? '1' : '0'); } catch (e2) {}
          }
        });
      })();
    </script>
  </head>
  <body class={pageClass}>
    {showNav && (
      <header class="site-header">
        <nav class="site-nav">
          {navItems.map((item) => (
            <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
          ))}
        </nav>
      </header>
    )}
    <main class="page">
      <slot />
    </main>
  </body>
</html>
