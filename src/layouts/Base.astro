---
import '@fontsource-variable/lexend';
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
}
const { title, description, showNav = true } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (path.startsWith('/essays/')) return href === '/writing';
  return href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
};
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/taste', label: 'Taste' },
  { href: '/writing', label: 'Writing' },
  { href: '/formalization', label: 'Formalization' },
  { href: '/music', label: 'Music' },
  { href: '/other', label: 'Other' },
];
const pageClass = `page-${path === '/' ? 'home' : path.split('/')[1]}`;
const isLanding = path === '/' || path.split('/').length === 2;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script is:inline>
      (function () {
        var params = new URLSearchParams(window.location.search);
        var DEV_KEY = 'site-dev-mode';
        var ANIM_KEY = 'site-animation-only';

        // Dev mode: URL ?dev=1/0 persists to localStorage (intentional opt-in).
        var devParam = params.get('dev');
        if (devParam === '1') { try { localStorage.setItem(DEV_KEY, '1'); } catch (e) {} }
        else if (devParam === '0') { try { localStorage.setItem(DEV_KEY, '0'); } catch (e) {} }
        var devStored = false;
        try { devStored = localStorage.getItem(DEV_KEY) === '1'; } catch (e) {}
        if (devParam === '1' || (devParam !== '0' && devStored)) {
          document.documentElement.classList.add('dev-mode');
        }

        // Animation mode: URL ?animation=1 is per-load (does NOT persist).
        // Shift+A toggles the persistent state.
        var animParam = params.get('animation');
        var animPersisted = false;
        try { animPersisted = localStorage.getItem(ANIM_KEY) === '1'; } catch (e) {}
        if (animParam === '1' || (animParam !== '0' && animPersisted)) {
          document.documentElement.classList.add('animation-only');
        }

        function bindToggle(key, cls, letterUpper, letterLower) {
          document.addEventListener('keydown', function (e) {
            if (!e.shiftKey || e.metaKey || e.ctrlKey || e.altKey) return;
            if (e.key !== letterUpper && e.key !== letterLower) return;
            var t = e.target;
            if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
            var next = !document.documentElement.classList.contains(cls);
            document.documentElement.classList.toggle(cls, next);
            try { localStorage.setItem(key, next ? '1' : '0'); } catch (e2) {}
          });
        }
        bindToggle(DEV_KEY, 'dev-mode', 'D', 'd');
        bindToggle(ANIM_KEY, 'animation-only', 'A', 'a');
        document.addEventListener('keydown', function (e) {
          if (!e.shiftKey || e.metaKey || e.ctrlKey || e.altKey) return;
          if (e.key !== 'R' && e.key !== 'r') return;
          var t = e.target;
          if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
          var resetButton = document.querySelector('.anim-controls button[aria-label^="Reset"], .anim-controls button[id$="-reset"], .anim-controls button[id$="-restart"]');
          if (!resetButton) return;
          e.preventDefault();
          resetButton.click();
        });
      })();
    </script>
  </head>
  <body class:list={[pageClass, { landing: isLanding }]}>
    {showNav && (
      <header class="site-header">
        <nav class="site-nav">
          {navItems.map((item) => (
            <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
          ))}
        </nav>
      </header>
    )}
    <main class="page">
      <slot />
    </main>
  </body>
</html>
