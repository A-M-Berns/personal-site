---
import '@fontsource-variable/lexend';
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
}
const { title, description, showNav = true } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/taste', label: 'Taste' },
  { href: '/writing', label: 'Writing' },
  { href: '/formalization', label: 'Formalization' },
  { href: '/music', label: 'Music' },
  { href: '/other', label: 'Other' },
];
const pageClass = `page-${path === '/' ? 'home' : path.split('/')[1]}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script is:inline>
      if (new URLSearchParams(window.location.search).get('animation') === '1') {
        document.documentElement.classList.add('animation-only');
      }
    </script>
  </head>
  <body class={pageClass}>
    {showNav && (
      <header class="site-header">
        <nav class="site-nav">
          {navItems.map((item) => (
            <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
          ))}
        </nav>
      </header>
    )}
    <main class="page">
      <slot />
    </main>
    <aside id="opacity-tuner-panel" class="opacity-tuner" hidden>
      <label for="opacity-tuner">opacity <span id="opacity-tuner-value">—</span></label>
      <input id="opacity-tuner" type="range" min="0" max="1" step="0.01" />
    </aside>
    <script is:inline>
      (function () {
        const ids = ['bg-canvas', 'wang-tiles', 'wireworld', 'lenia-sim', 'sandpile-sim', 'markov-text'];
        let canvas = null;
        for (const id of ids) {
          const el = document.getElementById(id);
          if (el) { canvas = el; break; }
        }
        const panel = document.getElementById('opacity-tuner-panel');
        if (!canvas || !panel) return;
        const slider = document.getElementById('opacity-tuner');
        const value = document.getElementById('opacity-tuner-value');
        const initial = parseFloat(getComputedStyle(canvas).opacity || '1');
        slider.value = String(initial);
        value.textContent = initial.toFixed(2);
        panel.hidden = false;
        slider.addEventListener('input', () => {
          canvas.style.opacity = slider.value;
          value.textContent = parseFloat(slider.value).toFixed(2);
        });
      })();
    </script>
  </body>
</html>
