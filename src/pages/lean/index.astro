---
import Base from '../../layouts/Base.astro';
---
<Base title="Lean — A. M. Berns" description="Formalization projects in Lean 4.">
  <div class="lean-shell">
    <canvas id="wang-tiles" class="wang-tiles" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Lean</span></h1>
      <p><span class="hl">Formalization projects in Lean 4.</span></p>
    </header>
    <article class="note">
      <ul>
        <li>
          <span class="hl"><a href="https://github.com/leanprover-community/mathlib4/blob/7d71710aa79bdb99d16d25644d1e592501f26c41/Mathlib/Geometry/Polygon/Basic.lean">Mathlib polygon geometry</a></span>
        </li>
        <li>
          <span class="hl"><a href="https://github.com/A-M-Berns/Formalized-Agent-Foundations">Formalized Agent Foundations</a></span>
        </li>
      </ul>
    </article>
    <aside id="wang-label" class="wang-label" aria-live="polite"></aside>
    <div class="wang-controls">
      <button id="wang-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="wang-reset" type="button" aria-label="Reset Wang tiling">Reset</button>
    </div>
    <dialog id="wang-about" aria-labelledby="wang-about-title">
      <button class="wang-about-close" type="button" aria-label="Close">×</button>
      <h2 id="wang-about-title">About this animation</h2>
      <p>
        A seeded Wang-tile generator fills a finite grid with square tiles whose touching edge labels always match. Each cycle chooses a mathematical tileset, a visual skin, an organic growth order, a reveal speed, and a small palette from the site's master color pool.
      </p>
      <p>
        The label shows the active tileset, skin, growth mode, speed, tile size, seed, and palette so variants can be compared while tuning.
      </p>
    </dialog>
  </div>
</Base>

<script>
  const canvas = document.getElementById('wang-tiles') as HTMLCanvasElement | null;
  if (canvas) {
    const label = document.getElementById('wang-label');
    const resetButton = document.getElementById('wang-reset') as HTMLButtonElement | null;
    const infoButton = document.getElementById('wang-info') as HTMLButtonElement | null;
    const aboutDialog = document.getElementById('wang-about') as HTMLDialogElement | null;
    const aboutClose = aboutDialog?.querySelector('.wang-about-close') as HTMLButtonElement | null;
    const ctx = canvas.getContext('2d')!;
    const CELL_PX = 2;
    const MIN_TILE = 7;
    const MAX_TILE = 11;
    const HOLD_FRAMES = 90;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];
    type WangTile = { n: number; e: number; s: number; w: number };
    type TileSet = { name: string; colors: number; tiles: WangTile[] };
    type VisualSkin = 'triangles' | 'edgeBands' | 'cornerCuts' | 'centerGlyphs' | 'diamondWeave' | 'isometric' | 'lozenges' | 'hexCells' | 'beads' | 'scales' | 'ribbons' | 'triangleLattice' | 'hexLattice' | 'kiteMesh';
    type GrowthMode = 'spores' | 'tendrils' | 'river' | 'rings' | 'islands' | 'lightning' | 'roots' | 'vortex' | 'contours';
    type SpeedMode = { name: string; divisor: number; minStep: number };
    type Cycle = {
      seed: number;
      rng: () => number;
      tileset: TileSet;
      skin: VisualSkin;
      growth: GrowthMode;
      speed: SpeedMode;
      revealStep: number;
      tileSize: number;
      cols: number;
      rows: number;
      grid: Int16Array;
      order: number[];
      revealed: number;
      visible: Uint8Array;
      hold: number;
      palette: RGB[];
    };

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    function rgba(c: RGB, a: number): string {
      return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${Math.max(0, Math.min(1, a))})`;
    }

    function hashString(s: string): number {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(seed: number) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pick<T>(items: T[], rng: () => number): T {
      return items[Math.floor(rng() * items.length)];
    }

    function shuffle<T>(items: T[], rng: () => number): T[] {
      const out = items.slice();
      for (let i = out.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [out[i], out[j]] = [out[j], out[i]];
      }
      return out;
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickPalette(count: number, rng: () => number): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < count; i++) {
        const lo = Math.floor((i * colorPool.length) / count);
        const hi = Math.floor(((i + 1) * colorPool.length) / count);
        const c = colorPool[lo + Math.floor(rng() * Math.max(1, hi - lo))];
        stops.push(mix(paper, c, 0.92));
      }
      const root = document.documentElement;
      for (let i = 0; i < Math.min(8, stops.length); i++) root.style.setProperty(`--c${i + 1}`, rgb(stops[i]));
      root.style.setProperty('--accent', rgb(stops[Math.min(stops.length - 1, 2)]));
      return stops;
    }

    function allWang(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let n = 0; n < colors; n++) {
        for (let e = 0; e < colors; e++) {
          for (let s = 0; s < colors; s++) {
            for (let w = 0; w < colors; w++) tiles.push({ n, e, s, w });
          }
        }
      }
      return tiles;
    }

    function flow16(): WangTile[] {
      const tiles: WangTile[] = [];
      for (let n = 0; n < 4; n++) {
        for (let w = 0; w < 4; w++) {
          tiles.push({ n, w, e: (n + w + 1) % 4, s: (n + 2 * w + 1) % 4 });
        }
      }
      return tiles;
    }

    function productSet(colors: number, a: number, b: number, c: number, d: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let n = 0; n < colors; n++) {
        for (let w = 0; w < colors; w++) {
          tiles.push({ n, w, e: (a * n + b * w + 1) % colors, s: (c * n + d * w + 2) % colors });
        }
      }
      return tiles;
    }

    function bandSet(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let a = 0; a < colors; a++) {
        for (let b = 0; b < colors; b++) {
          tiles.push({ n: a, e: b, s: a, w: b });
          tiles.push({ n: a, e: (a + b + 1) % colors, s: (a + 1) % colors, w: b });
        }
      }
      return tiles;
    }

    const tileSets: TileSet[] = [
      {
        name: 'binary16',
        colors: 2,
        tiles: allWang(2),
      },
      {
        name: 'ternary81',
        colors: 3,
        tiles: allWang(3),
      },
      {
        name: 'flow16',
        colors: 4,
        tiles: flow16(),
      },
      {
        name: 'modulo25',
        colors: 5,
        tiles: productSet(5, 2, 1, 1, 3),
      },
      {
        name: 'skew36',
        colors: 6,
        tiles: productSet(6, 1, 5, 4, 1),
      },
      {
        name: 'bands18',
        colors: 3,
        tiles: bandSet(3),
      },
      {
        name: 'jeandelRao11',
        colors: 4,
        tiles: [
          { n: 0, e: 0, s: 1, w: 0 },
          { n: 1, e: 2, s: 3, w: 0 },
          { n: 3, e: 0, s: 3, w: 1 },
          { n: 3, e: 1, s: 0, w: 1 },
          { n: 2, e: 2, s: 3, w: 1 },
          { n: 1, e: 0, s: 1, w: 2 },
          { n: 3, e: 1, s: 3, w: 2 },
          { n: 1, e: 2, s: 2, w: 2 },
          { n: 0, e: 3, s: 1, w: 3 },
          { n: 3, e: 3, s: 0, w: 3 },
          { n: 1, e: 1, s: 1, w: 2 },
        ],
      },
      {
        name: 'machine13',
        colors: 5,
        tiles: [
          { n: 0, e: 1, s: 0, w: 0 },
          { n: 0, e: 2, s: 1, w: 1 },
          { n: 0, e: 3, s: 2, w: 2 },
          { n: 0, e: 4, s: 3, w: 3 },
          { n: 1, e: 1, s: 2, w: 0 },
          { n: 1, e: 3, s: 3, w: 1 },
          { n: 1, e: 4, s: 4, w: 2 },
          { n: 2, e: 0, s: 1, w: 3 },
          { n: 2, e: 2, s: 4, w: 4 },
          { n: 2, e: 4, s: 0, w: 1 },
          { n: 3, e: 0, s: 3, w: 2 },
          { n: 3, e: 2, s: 0, w: 3 },
          { n: 4, e: 1, s: 4, w: 4 },
        ],
      },
    ];

    function legalTiles(tileset: TileSet, north: number | null, west: number | null): WangTile[] {
      return tileset.tiles.filter((tile) =>
        (north === null || tile.n === north) &&
        (west === null || tile.w === west)
      );
    }

    function hasContinuation(tileset: TileSet, tile: WangTile, x: number, y: number, cols: number, rows: number) {
      const rightOk = x === cols - 1 || tileset.tiles.some((next) => next.w === tile.e);
      const downOk = y === rows - 1 || tileset.tiles.some((next) => next.n === tile.s);
      return rightOk && downOk;
    }

    function solvePatch(tileset: TileSet, cols: number, rows: number, rng: () => number): Int16Array | null {
      const total = cols * rows;
      const grid = new Int16Array(total);
      grid.fill(-1);
      const stacks: Array<number[] | null> = new Array(total).fill(null);
      let pos = 0;
      let guard = 0;
      while (pos >= 0 && pos < total && guard++ < total * 180) {
        const x = pos % cols;
        const y = Math.floor(pos / cols);
        if (!stacks[pos]) {
          const north = y > 0 ? tileset.tiles[grid[pos - cols]]?.s : null;
          const west = x > 0 ? tileset.tiles[grid[pos - 1]]?.e : null;
          const candidates = legalTiles(tileset, north, west)
            .map((tile) => tileset.tiles.indexOf(tile))
            .filter((idx) => hasContinuation(tileset, tileset.tiles[idx], x, y, cols, rows));
          stacks[pos] = shuffle(candidates, rng);
        }
        const stack = stacks[pos]!;
        const next = stack.pop();
        if (next === undefined) {
          stacks[pos] = null;
          grid[pos] = -1;
          pos--;
          if (pos >= 0) grid[pos] = -1;
          continue;
        }
        grid[pos] = next;
        pos++;
      }
      return pos === total ? grid : null;
    }

    function makeOrganicOrder(cols: number, rows: number, growth: GrowthMode, rng: () => number): number[] {
      const total = cols * rows;
      const order = Array.from({ length: total }, (_, i) => i);
      const starts = Array.from({ length: 3 + Math.floor(rng() * 4) }, () => ({
        x: Math.floor(rng() * cols),
        y: Math.floor(rng() * rows),
      }));
      const driftX = rng() * 2 - 1;
      const driftY = rng() * 2 - 1;
      const bend = 0.12 + rng() * 0.18;
      const cx = cols * (0.25 + rng() * 0.50);
      const cy = rows * (0.25 + rng() * 0.50);
      const scores = new Float32Array(total);
      for (let idx = 0; idx < total; idx++) {
        const x = idx % cols;
        const y = Math.floor(idx / cols);
        const nearest = Math.min(...starts.map((s) => {
          const dx = x - s.x;
          const dy = y - s.y;
          return Math.sqrt(dx * dx + dy * dy);
        }));
        const wave = Math.sin((x * driftX + y * driftY) * bend) * 2.8;
        const eddy = Math.sin((x * 1.7 - y * 1.3 + starts.length) * bend * 0.7) * 1.6;
        if (growth === 'tendrils') {
          const angle = Math.atan2(y - cy, x - cx);
          scores[idx] = nearest + Math.sin(angle * 5 + nearest * 0.55) * 5 + rng() * 6;
        } else if (growth === 'river') {
          const along = x * driftX + y * driftY;
          const cross = x * -driftY + y * driftX;
          const river = Math.sin(along * bend) * rows * 0.13;
          scores[idx] = along * 0.18 + Math.abs(cross - river) * 0.72 + rng() * 5;
        } else if (growth === 'rings') {
          const dx = x - cx;
          const dy = y - cy;
          const r = Math.sqrt(dx * dx + dy * dy);
          scores[idx] = r + Math.sin(r * 0.9 + Math.atan2(dy, dx) * 4) * 4 + rng() * 4;
        } else if (growth === 'islands') {
          scores[idx] = nearest + wave * 1.4 + eddy * 1.8 + rng() * 8;
        } else if (growth === 'lightning') {
          const branch = Math.abs(Math.sin((x * 0.7 + y * 1.9) * bend + Math.sin(y * 0.33) * 2));
          scores[idx] = nearest * 0.35 + branch * 18 + y * 0.10 + rng() * 5;
        } else if (growth === 'roots') {
          const roots = Math.min(...starts.map((s) => Math.abs(x - s.x) * 0.38 + Math.max(0, y - s.y) * 0.75));
          scores[idx] = roots + Math.sin(x * bend * 2.4 + y * 0.2) * 4 + rng() * 5;
        } else if (growth === 'vortex') {
          const dx = x - cx;
          const dy = y - cy;
          const r = Math.sqrt(dx * dx + dy * dy);
          const angle = Math.atan2(dy, dx);
          scores[idx] = r * 0.55 + Math.sin(angle * 7 + r * 0.42) * 7 + rng() * 5;
        } else if (growth === 'contours') {
          const band = Math.abs(Math.sin((x * driftX + y * driftY) * bend));
          scores[idx] = nearest * 0.55 + band * 12 + eddy + rng() * 4;
        } else {
          scores[idx] = nearest + wave + eddy + rng() * 4.5;
        }
      }
      return order.sort((a, b) => scores[a] - scores[b]);
    }

    let W = 0;
    let H = 0;
    let cycle: Cycle | null = null;
    let speedBoost = 1;

    function makeCycle() {
      const seed = hashString(`${Date.now()}:${Math.random()}`);
      const rng = mulberry32(seed);
      const skins: VisualSkin[] = ['triangles', 'edgeBands', 'cornerCuts', 'centerGlyphs', 'diamondWeave', 'isometric', 'lozenges', 'hexCells', 'beads', 'scales', 'ribbons', 'triangleLattice', 'hexLattice', 'kiteMesh'];
      const growthModes: GrowthMode[] = ['spores', 'tendrils', 'river', 'rings', 'islands', 'lightning', 'roots', 'vortex', 'contours'];
      const speeds: SpeedMode[] = [
        { name: 'slow', divisor: 480, minStep: 1 },
        { name: 'medium', divisor: 340, minStep: 2 },
        { name: 'quick', divisor: 230, minStep: 3 },
      ];
      const tileSize = MIN_TILE + Math.floor(rng() * (MAX_TILE - MIN_TILE + 1));
      const skin = pick(skins, rng);
      const latticePad = skin === 'triangleLattice' || skin === 'kiteMesh' || skin === 'hexLattice';
      const cols = Math.ceil(W / tileSize) + (latticePad ? 8 : 1);
      const rows = Math.ceil(H / tileSize) + (latticePad ? 8 : 1);
      const growth = pick(growthModes, rng);
      const speed = pick(speeds, rng);
      let tileset = pick(tileSets, rng);
      let grid: Int16Array | null = null;
      for (let tries = 0; tries < 8 && !grid; tries++) {
        grid = solvePatch(tileset, cols, rows, rng);
        if (!grid) tileset = pick(tileSets, rng);
      }
      if (!grid) {
        tileset = tileSets[1];
        grid = solvePatch(tileset, cols, rows, rng)!;
      }
      cycle = {
        seed,
        rng,
        tileset,
        skin,
        growth,
        speed,
        revealStep: Math.max(speed.minStep, Math.ceil((cols * rows) / speed.divisor)),
        tileSize,
        cols,
        rows,
        grid,
        order: makeOrganicOrder(cols, rows, growth, rng),
        revealed: reduce ? cols * rows : 0,
        visible: new Uint8Array(cols * rows),
        hold: 0,
        palette: pickPalette(Math.max(3, Math.min(5, tileset.colors)), rng),
      };
      if (reduce) cycle.visible.fill(1);
      updateLabel();
    }

    function updateLabel() {
      if (!cycle || !label) return;
      const swatches = cycle.palette
        .map((c) => `<span class="wang-swatch" style="background:${rgb(c)}"></span>`)
        .join('');
      label.innerHTML = `
        <span>tileset: ${cycle.tileset.name}</span>
        <span>skin: ${cycle.skin}</span>
        <span>growth: ${cycle.growth}</span>
        <span>speed: ${cycle.speed.name}</span>
        <span>tile: ${cycle.tileSize * CELL_PX}px</span>
        <span>seed: ${cycle.seed.toString(16).padStart(8, '0')}</span>
        <span class="wang-swatches">${swatches}</span>
      `;
    }

    function colorFor(label: number, palette: RGB[]): RGB {
      return palette[label % palette.length];
    }

    function fillPoly(points: Array<[number, number]>, color: RGB, alpha = 1) {
      ctx.fillStyle = rgba(color, alpha);
      ctx.beginPath();
      ctx.moveTo(points[0][0], points[0][1]);
      for (let i = 1; i < points.length; i++) ctx.lineTo(points[i][0], points[i][1]);
      ctx.closePath();
      ctx.fill();
    }

    function drawTriangleLattice(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      const side = size * 1.55;
      const h = side * 0.86;
      const x = col * side * 0.50 - side;
      const y = row * h - h;
      const up = ((col + row) & 1) === 0;
      const points: Array<[number, number]> = up
        ? [[x, y + h], [x + side, y + h], [x + side * 0.5, y]]
        : [[x, y], [x + side, y], [x + side * 0.5, y + h]];
      const center: [number, number] = [
        (points[0][0] + points[1][0] + points[2][0]) / 3,
        (points[0][1] + points[1][1] + points[2][1]) / 3,
      ];
      const north = colorFor(tile.n, palette);
      const east = colorFor(tile.e, palette);
      const south = colorFor(tile.s, palette);
      const west = colorFor(tile.w, palette);
      if (skin === 'kiteMesh') {
        fillPoly([points[0], center, points[2]], mix(west, north, 0.45), 0.94);
        fillPoly([points[2], center, points[1]], mix(north, east, 0.45), 0.94);
        fillPoly([points[1], center, points[0]], mix(south, east, 0.45), 0.94);
      } else {
        fillPoly([points[0], points[1], center], up ? south : north, 0.96);
        fillPoly([points[1], points[2], center], east, 0.88);
        fillPoly([points[2], points[0], center], west, 0.88);
      }
    }

    function drawHexLattice(tile: WangTile, col: number, row: number, size: number, palette: RGB[]) {
      const r = size * 0.72;
      const cx = col * r * 1.5 - r;
      const cy = row * r * 1.72 + (col & 1 ? r * 0.86 : 0) - r;
      const points: Array<[number, number]> = [];
      for (let i = 0; i < 6; i++) {
        const a = Math.PI / 6 + i * Math.PI / 3;
        points.push([cx + Math.cos(a) * r, cy + Math.sin(a) * r]);
      }
      const north = colorFor(tile.n, palette);
      const east = colorFor(tile.e, palette);
      const south = colorFor(tile.s, palette);
      const west = colorFor(tile.w, palette);
      fillPoly([points[5], points[0], [cx, cy]], north, 0.92);
      fillPoly([points[0], points[1], [cx, cy]], mix(north, east, 0.50), 0.88);
      fillPoly([points[1], points[2], [cx, cy]], east, 0.88);
      fillPoly([points[2], points[3], [cx, cy]], south, 0.92);
      fillPoly([points[3], points[4], [cx, cy]], mix(south, west, 0.50), 0.88);
      fillPoly([points[4], points[5], [cx, cy]], west, 0.88);
    }

    function drawTile(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      if (skin === 'triangleLattice' || skin === 'kiteMesh') {
        drawTriangleLattice(tile, col, row, size, palette, skin);
        return;
      }
      if (skin === 'hexLattice') {
        drawHexLattice(tile, col, row, size, palette);
        return;
      }
      const x = col * size;
      const y = row * size;
      const x2 = x + size;
      const y2 = y + size;
      const cx = x + size / 2;
      const cy = y + size / 2;
      const north = colorFor(tile.n, palette);
      const east = colorFor(tile.e, palette);
      const south = colorFor(tile.s, palette);
      const west = colorFor(tile.w, palette);
      const dark = mix(paper, palette[0], 0.10);
      ctx.fillStyle = rgb(dark);
      ctx.fillRect(x, y, size, size);

      if (skin === 'triangles') {
        fillPoly([[x, y], [x2, y], [cx, cy]], north, 0.96);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], east, 0.96);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], south, 0.96);
        fillPoly([[x, y2], [x, y], [cx, cy]], west, 0.96);
      } else if (skin === 'edgeBands') {
        const band = Math.max(2, Math.floor(size * 0.24));
        ctx.fillStyle = rgba(north, 0.95);
        ctx.fillRect(x, y, size, band);
        ctx.fillStyle = rgba(east, 0.95);
        ctx.fillRect(x2 - band, y, band, size);
        ctx.fillStyle = rgba(south, 0.95);
        ctx.fillRect(x, y2 - band, size, band);
        ctx.fillStyle = rgba(west, 0.95);
        ctx.fillRect(x, y, band, size);
        ctx.fillStyle = rgba(mix(palette[(tile.n + tile.s) % palette.length], paper, 0.35), 0.78);
        ctx.fillRect(Math.round(cx) - 1, Math.round(cy) - 1, 3, 3);
      } else if (skin === 'cornerCuts') {
        fillPoly([[x, y], [x2, y], [x2, cy], [cx, cy]], north, 0.86);
        fillPoly([[x2, y], [x2, y2], [cx, y2], [cx, cy]], east, 0.86);
        fillPoly([[x2, y2], [x, y2], [x, cy], [cx, cy]], south, 0.86);
        fillPoly([[x, y2], [x, y], [cx, y], [cx, cy]], west, 0.86);
      } else if (skin === 'centerGlyphs') {
        fillPoly([[x, y], [x2, y], [cx, cy]], north, 0.70);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], east, 0.70);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], south, 0.70);
        fillPoly([[x, y2], [x, y], [cx, cy]], west, 0.70);
        ctx.fillStyle = rgba(mix(palette[(tile.e + tile.w) % palette.length], paper, 0.18), 0.95);
        const dot = Math.max(2, Math.floor(size * 0.22));
        ctx.fillRect(Math.round(cx - dot / 2), Math.round(cy - dot / 2), dot, dot);
      } else if (skin === 'diamondWeave') {
        const q = size * 0.26;
        fillPoly([[x, y], [cx, y], [x + q, cy], [x, cy]], west, 0.90);
        fillPoly([[cx, y], [x2, y], [x2, cy], [x2 - q, cy]], north, 0.90);
        fillPoly([[x2, cy], [x2, y2], [cx, y2], [x2 - q, cy]], east, 0.90);
        fillPoly([[x, cy], [x + q, cy], [cx, y2], [x, y2]], south, 0.90);
        fillPoly([[cx, y], [x2 - q, cy], [cx, y2], [x + q, cy]], mix(north, south, 0.50), 0.78);
      } else if (skin === 'isometric') {
        fillPoly([[x, y], [x2, y], [cx, cy]], mix(north, east, 0.35), 0.88);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], mix(east, south, 0.35), 0.88);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], mix(south, west, 0.35), 0.88);
        fillPoly([[x, y2], [x, y], [cx, cy]], mix(west, north, 0.35), 0.88);
        const rib = Math.max(1, Math.floor(size * 0.10));
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.42);
        ctx.fillRect(Math.round(cx - rib / 2), y, rib, size);
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.34);
        ctx.fillRect(x, Math.round(cy - rib / 2), size, rib);
      } else if (skin === 'lozenges') {
        fillPoly([[cx, y], [x2, cy], [cx, y2], [x, cy]], mix(north, south, 0.35), 0.96);
        fillPoly([[x, cy], [cx, y], [cx, cy]], west, 0.72);
        fillPoly([[cx, y], [x2, cy], [cx, cy]], north, 0.72);
        fillPoly([[x2, cy], [cx, y2], [cx, cy]], east, 0.72);
        fillPoly([[cx, y2], [x, cy], [cx, cy]], south, 0.72);
      } else if (skin === 'hexCells') {
        const q = size * 0.22;
        fillPoly([[x + q, y], [x2 - q, y], [x2, cy], [x2 - q, y2], [x + q, y2], [x, cy]], mix(north, south, 0.50), 0.94);
        fillPoly([[x + q, y], [x2 - q, y], [cx, cy]], north, 0.60);
        fillPoly([[x2 - q, y], [x2, cy], [cx, cy]], east, 0.60);
        fillPoly([[x2, cy], [x2 - q, y2], [cx, cy]], south, 0.60);
        fillPoly([[x + q, y2], [x, cy], [cx, cy]], west, 0.60);
      } else if (skin === 'beads') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.84);
        ctx.beginPath();
        ctx.arc(cx, cy, size * 0.48, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = rgba(west, 0.92);
        ctx.fillRect(x, Math.round(cy - 1), Math.ceil(size * 0.42), 2);
        ctx.fillStyle = rgba(east, 0.92);
        ctx.fillRect(Math.floor(x2 - size * 0.42), Math.round(cy - 1), Math.ceil(size * 0.42), 2);
        ctx.fillStyle = rgba(north, 0.92);
        ctx.fillRect(Math.round(cx - 1), y, 2, Math.ceil(size * 0.42));
      } else if (skin === 'scales') {
        fillPoly([[x, y2], [cx, y], [x2, y2]], mix(north, east, 0.45), 0.90);
        fillPoly([[x, y2], [cx, cy], [cx, y], [x, y]], west, 0.50);
        fillPoly([[x2, y2], [cx, cy], [cx, y], [x2, y]], east, 0.50);
        fillPoly([[x, y2], [cx, cy], [x2, y2]], south, 0.64);
      } else {
        const band = Math.max(2, Math.floor(size * 0.20));
        fillPoly([[x, y], [x2, y], [x, y2]], north, 0.78);
        fillPoly([[x2, y], [x2, y2], [x, y2]], south, 0.78);
        ctx.fillStyle = rgba(west, 0.66);
        ctx.fillRect(x, y, band, size);
        ctx.fillStyle = rgba(east, 0.66);
        ctx.fillRect(x2 - band, y, band, size);
      }
    }

    function draw() {
      if (!cycle) return;
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      for (let pos = 0; pos < cycle.visible.length; pos++) {
        if (!cycle.visible[pos]) continue;
        const tileIdx = cycle.grid[pos];
        if (tileIdx < 0) continue;
        const col = pos % cycle.cols;
        const row = Math.floor(pos / cycle.cols);
        drawTile(cycle.tileset.tiles[tileIdx], col, row, cycle.tileSize, cycle.palette, cycle.skin);
      }
    }

    function step() {
      if (!cycle) return;
      const total = cycle.cols * cycle.rows;
      if (cycle.revealed < total) {
        const next = Math.min(total, cycle.revealed + cycle.revealStep * speedBoost);
        for (let i = cycle.revealed; i < next; i++) cycle.visible[cycle.order[i]] = 1;
        cycle.revealed = next;
      } else if (++cycle.hold > HOLD_FRAMES) {
        makeCycle();
      }
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      makeCycle();
      draw();
    }

    resize();
    if (!reduce) {
      let last = 0;
      const loop = (now: number) => {
        if (now - last >= 33) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    resetButton?.addEventListener('click', () => {
      makeCycle();
      draw();
    });
    canvas.addEventListener('pointerdown', () => { speedBoost = 2; });
    canvas.addEventListener('pointerup', () => { speedBoost = 1; });
    canvas.addEventListener('pointercancel', () => { speedBoost = 1; });
    canvas.addEventListener('pointerleave', () => { speedBoost = 1; });
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutClose?.addEventListener('click', () => aboutDialog?.close());
    aboutDialog?.addEventListener('click', (event) => {
      if (event.target === aboutDialog) aboutDialog.close();
    });
  }
</script>
