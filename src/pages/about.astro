---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="memory-net" class="memory-net" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('memory-net') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 3;
    const TAU = Math.PI * 2;
    const K_NEIGHBORS = 3;
    const REWIRE_PROB = 0.085;
    const ACTIVITY_DECAY = 0.91;
    const EDGE_DECAY = 0.945;
    const REFRACTORY_FRAMES = 22;
    const AUTO_SEED_MIN = 52;
    const AUTO_SEED_RANGE = 64;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];
    type Cluster = { x: number; y: number; color: RGB; hub: number };
    type Node = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      cluster: number;
      hub: boolean;
      activity: number;
      flash: number;
      refractory: number;
      color: RGB;
      edges: number[];
    };
    type Edge = {
      a: number;
      b: number;
      weight: number;
      length: number;
      trail: number;
      color: RGB;
      shortcut: boolean;
    };
    type Pulse = {
      edge: number;
      from: number;
      to: number;
      route: number;
      t: number;
      speed: number;
      strength: number;
      color: RGB;
    };

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    function rgba(c: RGB, a: number): string {
      return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${Math.max(0, Math.min(1, a))})`;
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let nodes: Node[] = [];
    let edges: Edge[] = [];
    let pulses: Pulse[] = [];
    let clusters: Cluster[] = [];
    let attractors: number[] = [];
    let routeDistances: number[][] = [];
    let routeGlow: number[] = [];
    let cycleStops: RGB[] = [];
    let stepCount = 0;
    let nextSeedAt = 0;
    let pointerX = -1;
    let pointerY = -1;

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function syncAccent(stops: RGB[]) {
      const root = document.documentElement;
      for (let i = 0; i < stops.length; i++) root.style.setProperty(`--c${i + 1}`, rgb(stops[i]));
      root.style.setProperty('--accent', rgb(stops[Math.min(stops.length - 1, 4)]));
    }

    function resetSeedTimer() {
      nextSeedAt = stepCount + AUTO_SEED_MIN + ((Math.random() * AUTO_SEED_RANGE) | 0);
    }

    function edgeKey(a: number, b: number): string {
      return a < b ? `${a}:${b}` : `${b}:${a}`;
    }

    function clamp(v: number, lo: number, hi: number): number {
      return v < lo ? lo : v > hi ? hi : v;
    }

    function addNode(x: number, y: number, cluster: number, hub: boolean): number {
      const c = clusters[cluster]?.color ?? cycleStops[cluster % cycleStops.length];
      nodes.push({
        x,
        y,
        vx: 0,
        vy: 0,
        cluster,
        hub,
        activity: 0,
        flash: 0,
        refractory: 0,
        color: mix(paper, c, hub ? 0.86 : 0.58 + Math.random() * 0.20),
        edges: [],
      });
      return nodes.length - 1;
    }

    function addEdge(a: number, b: number, seen: Set<string>, shortcut = false) {
      if (a === b) return;
      const key = edgeKey(a, b);
      if (seen.has(key)) return;
      seen.add(key);
      const na = nodes[a];
      const nb = nodes[b];
      const dx = na.x - nb.x;
      const dy = na.y - nb.y;
      const d = Math.max(1, Math.sqrt(dx * dx + dy * dy));
      const sameCluster = na.cluster === nb.cluster;
      const closeness = Math.max(0, 1 - d / Math.max(W, H));
      const colorBase = sameCluster ? clusters[na.cluster]?.color : cycleStops[(na.cluster + nb.cluster) % cycleStops.length];
      const color = mix(paper, colorBase ?? cycleStops[0], sameCluster ? 0.48 + closeness * 0.18 : 0.38 + closeness * 0.16);
      const idx = edges.length;
      edges.push({
        a,
        b,
        weight: (sameCluster ? 0.70 : 0.48) + closeness * 0.24 + (shortcut ? 0.12 : 0) + Math.random() * 0.10,
        length: d,
        trail: 0,
        color,
        shortcut,
      });
      na.edges.push(idx);
      nb.edges.push(idx);
    }

    function connectSmallWorld(seen: Set<string>) {
      for (let cluster = 0; cluster < clusters.length; cluster++) {
        const group = nodes
          .map((node, idx) => ({ node, idx }))
          .filter(({ node }) => node.cluster === cluster && !node.hub)
          .sort((a, b) => Math.atan2(a.node.y - clusters[cluster].y, a.node.x - clusters[cluster].x) - Math.atan2(b.node.y - clusters[cluster].y, b.node.x - clusters[cluster].x))
          .map(({ idx }) => idx);

        if (group.length === 0) continue;
        for (let i = 0; i < group.length; i++) {
          for (let j = 1; j <= K_NEIGHBORS; j++) {
            const a = group[i];
            const ringTarget = group[(i + j) % group.length];
            let target = ringTarget;
            let shortcut = false;
            if (Math.random() < REWIRE_PROB) {
              const longRange = nodes
                .map((node, idx) => ({ node, idx }))
                .filter(({ node, idx }) => idx !== a && node.cluster !== cluster);
              if (longRange.length > 0) {
                target = longRange[(Math.random() * longRange.length) | 0].idx;
                shortcut = true;
              }
            }
            addEdge(a, target, seen, shortcut);
          }
          addEdge(group[i], clusters[cluster].hub, seen);
        }
      }

      for (let i = 0; i < clusters.length; i++) {
        const a = clusters[i].hub;
        const b = clusters[(i + 1) % clusters.length].hub;
        addEdge(a, b, seen, true);
        const c = clusters[(i + 3) % clusters.length].hub;
        addEdge(a, c, seen, true);
      }
    }

    function refreshEdgeLengths() {
      for (const edge of edges) {
        const a = nodes[edge.a];
        const b = nodes[edge.b];
        const dx = a.x - b.x;
        const dy = a.y - b.y;
        edge.length = Math.max(1, Math.sqrt(dx * dx + dy * dy));
      }
    }

    function settleLayout(iterations: number) {
      const count = Math.max(1, nodes.length);
      const k = Math.sqrt((W * H) / count) * 0.92;
      const margin = 4;

      for (let iter = 0; iter < iterations; iter++) {
        const temp = Math.max(0.55, k * 0.16 * (1 - iter / iterations));
        for (const node of nodes) {
          node.vx = 0;
          node.vy = 0;
        }

        for (let i = 0; i < nodes.length; i++) {
          const a = nodes[i];
          for (let j = i + 1; j < nodes.length; j++) {
            const b = nodes[j];
            let dx = a.x - b.x;
            let dy = a.y - b.y;
            let d = Math.sqrt(dx * dx + dy * dy) || 1;
            dx /= d;
            dy /= d;
            const force = Math.min(k * 0.48, (k * k) / d) * 0.045;
            a.vx += dx * force;
            a.vy += dy * force;
            b.vx -= dx * force;
            b.vy -= dy * force;
          }
        }

        for (const edge of edges) {
          const a = nodes[edge.a];
          const b = nodes[edge.b];
          let dx = a.x - b.x;
          let dy = a.y - b.y;
          let d = Math.sqrt(dx * dx + dy * dy) || 1;
          dx /= d;
          dy /= d;
          const desired = edge.shortcut ? k * 3.1 : k * 1.24;
          const force = (d - desired) * 0.014 * edge.weight;
          a.vx -= dx * force;
          a.vy -= dy * force;
          b.vx += dx * force;
          b.vy += dy * force;
        }

        for (const node of nodes) {
          const cluster = clusters[node.cluster];
          const pull = node.hub ? 0.032 : 0.0065;
          node.vx += (cluster.x - node.x) * pull;
          node.vy += (cluster.y - node.y) * pull;
          const dx = clamp(node.vx, -temp, temp);
          const dy = clamp(node.vy, -temp, temp);
          node.x = clamp(node.x + dx, margin, W - margin);
          node.y = clamp(node.y + dy, margin, H - margin);
        }
      }
      refreshEdgeLengths();
    }

    function buildNetwork() {
      nodes = [];
      edges = [];
      pulses = [];
      clusters = [];
      attractors = [];
      routeDistances = [];
      routeGlow = [];

      const area = W * H;
      const count = Math.max(150, Math.min(420, Math.round(area / 760)));
      const clusterCount = 8 + ((Math.random() * 3) | 0);
      const marginX = Math.max(10, W * 0.06);
      const marginY = Math.max(10, H * 0.08);
      const span = Math.max(12, Math.min(W, H));

      for (let i = 0; i < clusterCount; i++) {
        const angle = (i / clusterCount) * TAU + Math.random() * 0.32;
        const radial = 0.18 + Math.random() * 0.23;
        clusters.push({
          x: clamp(W * 0.5 + Math.cos(angle) * W * radial, marginX, W - marginX),
          y: clamp(H * 0.5 + Math.sin(angle) * H * radial, marginY, H - marginY),
          color: mix(paper, cycleStops[(i * 2 + 1) % cycleStops.length], 0.88),
          hub: -1,
        });
      }

      for (let i = 0; i < clusters.length; i++) {
        const c = clusters[i];
        c.hub = addNode(c.x, c.y, i, true);
        attractors.push(c.hub);
      }

      while (nodes.length < count) {
        const cluster = (Math.random() * clusters.length) | 0;
        const c = clusters[cluster];
        let x: number;
        let y: number;
        if (Math.random() < 0.82) {
          const a = Math.random() * TAU;
          const r = Math.sqrt(Math.random()) * span * (0.12 + Math.random() * 0.16);
          x = clamp(c.x + Math.cos(a) * r, marginX * 0.5, W - marginX * 0.5);
          y = clamp(c.y + Math.sin(a) * r, marginY * 0.5, H - marginY * 0.5);
        } else {
          x = marginX * 0.5 + Math.random() * Math.max(1, W - marginX);
          y = marginY * 0.5 + Math.random() * Math.max(1, H - marginY);
        }
        addNode(x, y, cluster, false);
      }

      const seen = new Set<string>();
      connectSmallWorld(seen);
      settleLayout(reduce ? 54 : 118);
      rebuildRouteDistances();
    }

    function rebuildRouteDistances() {
      routeDistances = attractors.map((target) => {
        const dist = new Array(nodes.length).fill(Infinity);
        const used = new Array(nodes.length).fill(false);
        dist[target] = 0;
        for (let n = 0; n < nodes.length; n++) {
          let best = -1;
          let bestD = Infinity;
          for (let i = 0; i < nodes.length; i++) {
            if (!used[i] && dist[i] < bestD) {
              best = i;
              bestD = dist[i];
            }
          }
          if (best < 0) break;
          used[best] = true;
          for (const edgeIdx of nodes[best].edges) {
            const edge = edges[edgeIdx];
            const to = edge.a === best ? edge.b : edge.a;
            const nd = bestD + edge.length / Math.max(0.2, edge.weight);
            if (nd < dist[to]) dist[to] = nd;
          }
        }
        return dist;
      });
      routeGlow = new Array(attractors.length).fill(0);
    }

    function rerollNetwork() {
      cycleStops = pickStops();
      syncAccent(cycleStops);
      buildNetwork();
      for (let i = 0; i < Math.min(10, attractors.length); i++) nodes[attractors[i]].activity = 0.22;
      stepCount = 0;
      resetSeedTimer();
    }

    function nearestNode(x: number, y: number): number {
      let best = 0;
      let bestD = Infinity;
      for (let i = 0; i < nodes.length; i++) {
        const dx = nodes[i].x - x;
        const dy = nodes[i].y - y;
        const d = dx * dx + dy * dy;
        if (d < bestD) {
          bestD = d;
          best = i;
        }
      }
      return best;
    }

    function chooseRouteFrom(source: number): number {
      if (attractors.length === 0) return 0;
      const ranked = attractors
        .map((target, route) => ({
          route,
          d: routeDistances[route]?.[source] ?? 0,
          load: nodes[target]?.activity ?? 0,
        }))
        .sort((a, b) => b.d - a.d);
      const top = ranked.slice(0, Math.min(4, ranked.length));
      top.sort((a, b) => (b.d - b.load * 80) - (a.d - a.load * 80));
      const pick = Math.min(top.length - 1, ((Math.random() ** 1.9) * top.length) | 0);
      return top[pick].route;
    }

    function otherNode(edge: Edge, idx: number): number {
      return edge.a === idx ? edge.b : edge.a;
    }

    function fireNode(idx: number, color: RGB, strength: number, route: number, forceFanout = false) {
      if (nodes.length === 0 || attractors.length === 0) return;
      const node = nodes[idx];
      node.activity = Math.max(node.activity, strength);
      node.flash = 1;
      node.refractory = Math.max(node.refractory, REFRACTORY_FRAMES + ((Math.random() * 12) | 0));
      node.color = mix(node.color, color, 0.58);
      const here = routeDistances[route]?.[idx] ?? Infinity;
      routeGlow[route] = Math.min(1, (routeGlow[route] ?? 0) + strength * 0.18);
      const scored = node.edges.map((edgeIdx) => {
        const edge = edges[edgeIdx];
        const to = otherNode(edge, idx);
        const next = routeDistances[route]?.[to] ?? Infinity;
        const progress = here - next;
        const score =
          progress * 0.090 +
          edge.weight * 0.44 +
          edge.trail * 0.20 +
          (nodes[to].hub ? 0.26 : 0) +
          (edge.shortcut ? 0.10 : 0) -
          (nodes[to].refractory > 0 ? 0.18 : 0) +
          Math.random() * 0.08;
        return { edgeIdx, to, score, progress };
      }).sort((a, b) => b.score - a.score);
      const keep = Math.max(2, Math.min(scored.length, forceFanout || node.hub ? 5 : 3));
      for (let k = 0; k < keep; k++) {
        const choice = scored[k];
        if (!choice || (choice.progress < -4 && Math.random() > 0.06)) continue;
        const edge = edges[choice.edgeIdx];
        edge.trail = Math.max(edge.trail, strength * edge.weight);
        edge.color = mix(edge.color, color, 0.34);
        pulses.push({
          edge: choice.edgeIdx,
          from: idx,
          to: choice.to,
          route,
          t: 0,
          speed: 0.034 + Math.random() * 0.026,
          strength: strength * edge.weight * (0.70 + Math.random() * 0.18),
          color,
        });
      }
      if (pulses.length > 760) pulses.splice(0, pulses.length - 760);
    }

    function seedAt(x: number, y: number, strong = false) {
      if (nodes.length === 0) return;
      const idx = nearestNode(x, y);
      const route = chooseRouteFrom(idx);
      const c = mix(paper, cycleStops[(route * 2 + 3) % cycleStops.length], 0.90);
      fireNode(idx, c, strong ? 1.20 : 0.92, route, true);
      for (const edgeIdx of nodes[idx].edges) {
        edges[edgeIdx].trail = Math.max(edges[edgeIdx].trail, strong ? 0.82 : 0.56);
      }
    }

    function autoSeed() {
      const usePointer = pointerX >= 0 && Math.random() < 0.78;
      seedAt(usePointer ? pointerX : Math.random() * W, usePointer ? pointerY : Math.random() * H);
      if (Math.random() < 0.28) {
        const source = attractors[(Math.random() * attractors.length) | 0];
        const route = chooseRouteFrom(source);
        fireNode(source, mix(paper, cycleStops[(route + 5) % cycleStops.length], 0.76), 0.42, route, true);
      }
      resetSeedTimer();
    }

    function step() {
      stepCount++;
      if (stepCount > 6000) rerollNetwork();
      if (stepCount >= nextSeedAt) autoSeed();
      if (stepCount % 34 === 0 && attractors.length > 0) {
        const source = attractors[((stepCount / 34) | 0) % attractors.length];
        const route = chooseRouteFrom(source);
        fireNode(source, mix(paper, cycleStops[(route + 2) % cycleStops.length], 0.68), 0.34, route);
      }

      for (const node of nodes) {
        node.activity *= ACTIVITY_DECAY;
        node.flash *= 0.78;
        if (node.refractory > 0) node.refractory--;
      }
      for (const edge of edges) edge.trail *= EDGE_DECAY;
      for (let i = 0; i < routeGlow.length; i++) routeGlow[i] *= 0.944;

      for (let i = pulses.length - 1; i >= 0; i--) {
        const pulse = pulses[i];
        pulse.t += pulse.speed;
        const edge = edges[pulse.edge];
        edge.trail = Math.max(edge.trail, pulse.strength * (1 - Math.abs(pulse.t - 0.5) * 0.62));
        if (pulse.t >= 1) {
          const target = nodes[pulse.to];
          target.activity += pulse.strength * 0.62;
          target.color = mix(target.color, pulse.color, 0.26);
          const routeTarget = attractors[pulse.route];
          if (pulse.to === routeTarget && target.refractory <= 0) {
            const nextRoute = chooseRouteFrom(pulse.to);
            const nextColor = mix(pulse.color, cycleStops[(nextRoute * 2 + 1) % cycleStops.length], 0.38);
            fireNode(pulse.to, nextColor, Math.min(1.05, pulse.strength + 0.28), nextRoute, true);
          } else if (target.refractory <= 0 && target.activity > 0.38) {
            fireNode(pulse.to, pulse.color, Math.min(0.82, target.activity), pulse.route);
          }
          pulses.splice(i, 1);
        }
      }
    }

    function drawLine(ax: number, ay: number, bx: number, by: number, color: RGB, alpha: number, width: number) {
      ctx.strokeStyle = rgba(color, alpha);
      ctx.lineWidth = width;
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(bx, by);
      ctx.stroke();
    }

    function draw() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      ctx.lineCap = 'square';

      for (const edge of edges) {
        const a = nodes[edge.a];
        const b = nodes[edge.b];
        const ax = a.x;
        const ay = a.y;
        const bx = b.x;
        const by = b.y;
        drawLine(ax, ay, bx, by, edge.color, edge.shortcut ? 0.034 : 0.024, 1);
        if (edge.trail > 0.015) {
          drawLine(ax, ay, bx, by, edge.color, Math.min(0.36, edge.trail * 0.30), 1);
        }
      }

      for (const pulse of pulses) {
        const edge = edges[pulse.edge];
        const a = nodes[pulse.from];
        const b = nodes[pulse.to];
        const ax = a.x;
        const ay = a.y;
        const bx = b.x;
        const by = b.y;
        const x = ax + (bx - ax) * pulse.t;
        const y = ay + (by - ay) * pulse.t;
        const tailT = Math.max(0, pulse.t - 0.10);
        drawLine(
          ax + (bx - ax) * tailT,
          ay + (by - ay) * tailT,
          x,
          y,
          pulse.color,
          Math.min(0.54, pulse.strength * 0.48),
          1,
        );
        ctx.fillStyle = rgba(pulse.color, Math.min(0.76, pulse.strength * 0.80));
        ctx.fillRect(Math.round(x) - 1, Math.round(y) - 1, 2, 2);
      }

      for (let i = 0; i < nodes.length; i++) {
        const node = nodes[i];
        const a = Math.min(1, node.activity + node.flash);
        const x = Math.round(node.x);
        const y = Math.round(node.y);
        const glow = node.hub ? (routeGlow[attractors.indexOf(i)] ?? 0) : 0;
        const base = node.hub ? 0.15 + glow * 0.18 : node.refractory > 0 ? 0.08 : 0.040;
        ctx.fillStyle = rgba(node.color, base + a * 0.42);
        const size = node.hub ? (a > 0.50 || glow > 0.20 ? 4 : 3) : a > 0.55 ? 3 : a > 0.16 ? 2 : 1;
        ctx.fillRect(x - (size >> 1), y - (size >> 1), size, size);
        if (node.hub) {
          ctx.fillStyle = rgba(mix(node.color, cycleStops[cycleStops.length - 1], 0.28), 0.08 + glow * 0.36 + a * 0.18);
          ctx.fillRect(x - 4, y, 9, 1);
          ctx.fillRect(x, y - 4, 1, 9);
        } else if (a > 0.55) {
          ctx.fillStyle = rgba(mix(node.color, cycleStops[cycleStops.length - 1], 0.45), 0.24);
          ctx.fillRect(x - 2, y, 5, 1);
          ctx.fillRect(x, y - 2, 1, 5);
        }
      }
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      rerollNetwork();
    }

    function setPointerFromEvent(e: PointerEvent) {
      const rect = canvas.getBoundingClientRect();
      pointerX = ((e.clientX - rect.left) / rect.width) * W;
      pointerY = ((e.clientY - rect.top) / rect.height) * H;
    }

    resize();
    if (reduce) {
      seedAt(W * 0.5, H * 0.5, true);
      for (let i = 0; i < 140; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 33;
      const loop = (now: number) => {
        if (now - last >= targetMs) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    window.addEventListener('pointermove', setPointerFromEvent);
    window.addEventListener('pointerdown', (e) => {
      setPointerFromEvent(e);
      seedAt(pointerX, pointerY, true);
      resetSeedTimer();
    });
    window.addEventListener('pointerleave', () => { pointerX = -1; pointerY = -1; });
    window.addEventListener('pointerout', (e) => {
      if (!e.relatedTarget) { pointerX = -1; pointerY = -1; }
    });
  }
</script>
