        ctx.fillStyle = rgba(west, 0.44);
        fillRectBleed(x, y, size * 0.55, size * 0.55);
        ctx.fillStyle = rgba(east, 0.44);
        fillRectBleed(x + size * 0.45, y + size * 0.45, size * 0.55, size * 0.55);
      } else if (skin === 'frame') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.82);
        fillRectBleed(x, y, size, size);
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.54);
        fillRectBleed(x + size * 0.22, y + size * 0.22, size * 0.56, size * 0.56);
