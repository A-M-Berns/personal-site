---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="wang-tiles" class="wang-tiles" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
    </header>
    <div class="about-panes">
      <section class="writing-pane">
        <h2>About me</h2>
        <p>
          I'm <span class="anson">Anson</span>, an independent AI researcher and contractor. My research interests
          include formal verification, AI cooperation, agent foundations, logical induction,
          and applications of moral philosophy to AI alignment. More broadly, I am
          interested in formal systems, abstract beauty, and the Good. My projects on
          these and other topics have taken the form of <a href="/writing">writing</a>,
          <a href="/formalization">formalization</a>, and <a href="/music">music</a>.
          Various dimensions of my taste are documented <a href="/taste">here</a>.
        </p>
      </section>
      <section class="writing-pane">
        <h2>About this site</h2>
        <p>
          This site is a <a href="https://en.wikipedia.org/wiki/Generative_art">generative
          art</a> gallery of algorithmically generated animations. A few of the animations
          demonstrate the beautiful emergent complexity of <a href="https://en.wikipedia.org/wiki/Cellular_automaton">cellular
          automata</a>: the <a href="/">cyclic automaton</a>, the <a href="/taste">Abelian
          sandpile</a>, and the <a href="/formalization">turmites</a>. Other animations
          implement <a href="/music">Particle Lenia</a>, a simple <a href="/writing">Markov
          text model</a>, and <a href="/other">diffusion-limited aggregation</a>. This
          page's background uses a random <a href="https://en.wikipedia.org/wiki/Wang_tile">Wang
          tiling</a> generator. The site's code was written in Astro by Claude Code and
          Codex under my direction. All the text on the site is written by me.
        </p>
      </section>
    </div>
    <aside id="wang-label" class="wang-label" aria-live="polite"></aside>
    <div id="wang-boost" class="wang-boost" aria-hidden="true">
      <span></span><span></span>
    </div>
    <div class="wang-controls">
      <label>
        <span>Shape</span>
        <select id="wang-shape" aria-label="Select tiling shape"></select>
      </label>
      <label>
        <span>Skin</span>
        <select id="wang-skin" aria-label="Select visual skin"></select>
      </label>
    </div>
    <div class="anim-controls">
      <button id="wang-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="wang-reset" type="button" aria-label="Reset Wang tiling">Reset</button>
    </div>
    <dialog id="wang-about" aria-labelledby="wang-about-title">
      <button class="wang-about-close" type="button" aria-label="Close">×</button>
      <h2 id="wang-about-title">About this animation</h2>
      <p>
        Each cycle of this animation displays a tiling created with <a href="https://en.wikipedia.org/wiki/Wang_tile">Wang tiles</a>. The animation samples from various sets of Wang tiles, including ones that generate <a href="https://en.wikipedia.org/wiki/Aperiodic_tiling">aperiodic tilings</a>. Aperiodic Wang tiles are sometimes used in video games to procedurally generate realistic terrain textures. I think other patterns this page generates end up looking like fancy sweaters or beautiful QR codes. Hold your mouse down on the right side of the screen to fast forward, hold on the left to rewind.
      </p>
    </dialog>
  </div>
</Base>

<script>
  const canvas = document.getElementById('wang-tiles') as HTMLCanvasElement | null;
  if (canvas) {
    const label = document.getElementById('wang-label');
    const boostIndicator = document.getElementById('wang-boost');
    const resetButton = document.getElementById('wang-reset') as HTMLButtonElement | null;
    const shapeSelect = document.getElementById('wang-shape') as HTMLSelectElement | null;
    const skinSelect = document.getElementById('wang-skin') as HTMLSelectElement | null;
    const infoButton = document.getElementById('wang-info') as HTMLButtonElement | null;
    const aboutDialog = document.getElementById('wang-about') as HTMLDialogElement | null;
    const aboutClose = aboutDialog?.querySelector('.wang-about-close') as HTMLButtonElement | null;
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const CELL_PX = 1;
    const MIN_TILE = 10;
    const MAX_TILE = 30;
    const HOLD_FRAMES = 60;
    const BLACK_FRAMES = 10;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];
    type ShapeKind = 'square' | 'triangle' | 'hexagon' | 'circle' | 'parallelogram' | 'rectangle';
    type WangTile = { edges: number[] };
    type TileSet = { name: string; colors: number; edgeCount: number; tiles: WangTile[] };
    type VisualSkin = 'triangles' | 'edgeBands' | 'cornerCuts' | 'centerGlyphs' | 'diamondWeave' | 'isometric' | 'lozenges' | 'beads' | 'scales' | 'ribbons' | 'chevrons' | 'insetDiamonds' | 'pixelGlyphs' | 'quarterArcs' | 'ladder' | 'facets' | 'kite' | 'mesh' | 'blocks' | 'mosaic' | 'bands' | 'brickwork' | 'diagonalBars' | 'checker' | 'orbit' | 'splitBands' | 'pinwheel' | 'crosshatch' | 'plusGlyph' | 'nestedBox' | 'strata' | 'zigzag' | 'wedges' | 'petals' | 'target' | 'shards' | 'caps' | 'spokes' | 'rays' | 'slats' | 'steps' | 'frame' | 'arcBands' | 'splitDiag' | 'edgeCorners' | 'iris' | 'triad' | 'hexFan' | 'lanes';
    type GrowthMode = 'spores' | 'tendrils' | 'river' | 'rings' | 'islands' | 'lightning' | 'roots' | 'vortex' | 'contours' | 'maze' | 'faults' | 'braid' | 'nebula';
    type SpeedMode = { name: string; divisor: number; minStep: number };
    type Cycle = {
      seed: number;
      rng: () => number;
      tileset: TileSet;
      shape: ShapeKind;
      skin: VisualSkin;
      growth: GrowthMode;
      speed: SpeedMode;
      revealStep: number;
      tileSize: number;
      cols: number;
      rows: number;
      grid: Int16Array;
      order: number[];
      revealed: number;
      visible: Uint8Array;
      hold: number;
      blackHold: number;
      palette: RGB[];
    };

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    function rgba(c: RGB, a: number): string {
      return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${Math.max(0, Math.min(1, a))})`;
    }

    function hashString(s: string): number {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(seed: number) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pick<T>(items: T[], rng: () => number): T {
      return items[Math.floor(rng() * items.length)];
    }

    function shuffle<T>(items: T[], rng: () => number): T[] {
      const out = items.slice();
      for (let i = out.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [out[i], out[j]] = [out[j], out[i]];
      }
      return out;
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickPalette(count: number, rng: () => number): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < count; i++) {
        const lo = Math.floor((i * colorPool.length) / count);
        const hi = Math.floor(((i + 1) * colorPool.length) / count);
        const c = colorPool[lo + Math.floor(rng() * Math.max(1, hi - lo))];
        stops.push(mix(paper, c, 0.92));
      }
      const root = document.documentElement;
      for (let i = 0; i < Math.min(8, stops.length); i++) root.style.setProperty(`--c${i + 1}`, rgb(stops[i]));
      root.style.setProperty('--accent', rgb(stops[Math.min(stops.length - 1, 2)]));
      return stops;
    }

    function makeTile(edges: number[]): WangTile {
      return { edges };
    }

    function allWang(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let n = 0; n < colors; n++) {
        for (let e = 0; e < colors; e++) {
          for (let s = 0; s < colors; s++) {
            for (let w = 0; w < colors; w++) tiles.push(makeTile([n, e, s, w]));
          }
        }
      }
      return tiles;
    }

    function flow16(): WangTile[] {
      const tiles: WangTile[] = [];
      for (let n = 0; n < 4; n++) {
        for (let w = 0; w < 4; w++) {
          tiles.push(makeTile([n, (n + w + 1) % 4, (n + 2 * w + 1) % 4, w]));
        }
      }
      return tiles;
    }

    function productSet(colors: number, a: number, b: number, c: number, d: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let n = 0; n < colors; n++) {
        for (let w = 0; w < colors; w++) {
          tiles.push(makeTile([n, (a * n + b * w + 1) % colors, (c * n + d * w + 2) % colors, w]));
        }
      }
      return tiles;
    }

    function bandSet(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let a = 0; a < colors; a++) {
        for (let b = 0; b < colors; b++) {
          tiles.push(makeTile([a, b, a, b]));
          tiles.push(makeTile([a, (a + b + 1) % colors, (a + 1) % colors, b]));
        }
      }
      return tiles;
    }

    function allTriangle(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let a = 0; a < colors; a++) {
        for (let b = 0; b < colors; b++) {
          for (let c = 0; c < colors; c++) tiles.push(makeTile([a, b, c]));
        }
      }
      return tiles;
    }

    function allHex(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let ne = 0; ne < colors; ne++) {
        for (let e = 0; e < colors; e++) {
          for (let se = 0; se < colors; se++) {
            for (let sw = 0; sw < colors; sw++) {
              for (let w = 0; w < colors; w++) {
                for (let nw = 0; nw < colors; nw++) tiles.push(makeTile([ne, e, se, sw, w, nw]));
              }
            }
          }
        }
      }
      return tiles;
    }

    function triangleFlow(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let left = 0; left < colors; left++) {
        for (let base = 0; base < colors; base++) {
          tiles.push(makeTile([left, (left + base + 1) % colors, base]));
        }
      }
      return tiles;
    }

    function hexFlow(colors: number, twist = 1): WangTile[] {
      const tiles: WangTile[] = [];
      for (let w = 0; w < colors; w++) {
        for (let nw = 0; nw < colors; nw++) {
          const ne = (w + nw + twist) % colors;
          const e = (2 * w + nw + 1) % colors;
          const se = (w + 2 * nw + twist + 1) % colors;
          const sw = (w + 3 * nw + 2) % colors;
          tiles.push(makeTile([ne, e, se, sw, w, nw]));
        }
      }
      return tiles;
    }

    function hexBand(colors: number): WangTile[] {
      const tiles: WangTile[] = [];
      for (let a = 0; a < colors; a++) {
        for (let b = 0; b < colors; b++) {
          for (let c = 0; c < colors; c++) tiles.push(makeTile([a, b, c, a, b, c]));
        }
      }
      return tiles;
    }

    const squareTileSets: TileSet[] = [
      {
        name: 'binary16',
        colors: 2,
        edgeCount: 4,
        tiles: allWang(2),
      },
      {
        name: 'ternary81',
        colors: 3,
        edgeCount: 4,
        tiles: allWang(3),
      },
      {
        name: 'flow16',
        colors: 4,
        edgeCount: 4,
        tiles: flow16(),
      },
      {
        name: 'modulo25',
        colors: 5,
        edgeCount: 4,
        tiles: productSet(5, 2, 1, 1, 3),
      },
      {
        name: 'skew36',
        colors: 6,
        edgeCount: 4,
        tiles: productSet(6, 1, 5, 4, 1),
      },
      {
        name: 'bands18',
        colors: 3,
        edgeCount: 4,
        tiles: bandSet(3),
      },
      {
        name: 'jeandelRao11',
        colors: 4,
        edgeCount: 4,
        tiles: [
          makeTile([0, 0, 1, 0]),
          makeTile([1, 2, 3, 0]),
          makeTile([3, 0, 3, 1]),
          makeTile([3, 1, 0, 1]),
          makeTile([2, 2, 3, 1]),
          makeTile([1, 0, 1, 2]),
          makeTile([3, 1, 3, 2]),
          makeTile([1, 2, 2, 2]),
          makeTile([0, 3, 1, 3]),
          makeTile([3, 3, 0, 3]),
          makeTile([1, 1, 1, 2]),
        ],
      },
      {
        name: 'machine13',
        colors: 5,
        edgeCount: 4,
        tiles: [
          makeTile([0, 1, 0, 0]),
          makeTile([0, 2, 1, 1]),
          makeTile([0, 3, 2, 2]),
          makeTile([0, 4, 3, 3]),
          makeTile([1, 1, 2, 0]),
          makeTile([1, 3, 3, 1]),
          makeTile([1, 4, 4, 2]),
          makeTile([2, 0, 1, 3]),
          makeTile([2, 2, 4, 4]),
          makeTile([2, 4, 0, 1]),
          makeTile([3, 0, 3, 2]),
          makeTile([3, 2, 0, 3]),
          makeTile([4, 1, 4, 4]),
        ],
      },
    ];

    const triangleTileSets: TileSet[] = [
      { name: 'tri27', colors: 3, edgeCount: 3, tiles: allTriangle(3) },
      { name: 'triFlow16', colors: 4, edgeCount: 3, tiles: triangleFlow(4) },
      { name: 'triFlow25', colors: 5, edgeCount: 3, tiles: triangleFlow(5) },
    ];

    const hexTileSets: TileSet[] = [
      { name: 'hex729', colors: 3, edgeCount: 6, tiles: allHex(3) },
      { name: 'hexFlow16', colors: 4, edgeCount: 6, tiles: hexFlow(4, 1) },
      { name: 'hexFlow25', colors: 5, edgeCount: 6, tiles: hexFlow(5, 2) },
      { name: 'hexBands27', colors: 3, edgeCount: 6, tiles: hexBand(3) },
    ];

    function tileSetsFor(shape: ShapeKind): TileSet[] {
      if (shape === 'triangle') return triangleTileSets;
      if (shape === 'hexagon' || shape === 'circle') return hexTileSets;
      return squareTileSets;
    }

    function previousConstraints(shape: ShapeKind, x: number, y: number, cols: number): Array<{ edge: number; neighbor: number; neighborEdge: number }> {
      if (shape === 'triangle') {
        const up = ((x + y) & 1) === 0;
        const constraints: Array<{ edge: number; neighbor: number; neighborEdge: number }> = [];
        if (x > 0) constraints.push({ edge: 0, neighbor: y * cols + x - 1, neighborEdge: 1 });
        if (!up && y > 0) constraints.push({ edge: 2, neighbor: (y - 1) * cols + x, neighborEdge: 2 });
        return constraints;
      }
      if (shape === 'hexagon' || shape === 'circle') {
        const constraints: Array<{ edge: number; neighbor: number; neighborEdge: number }> = [];
        if (x > 0) constraints.push({ edge: 4, neighbor: y * cols + x - 1, neighborEdge: 1 });
        if (y > 0) {
          if (y & 1) {
            constraints.push({ edge: 5, neighbor: (y - 1) * cols + x, neighborEdge: 2 });
            if (x < cols - 1) constraints.push({ edge: 0, neighbor: (y - 1) * cols + x + 1, neighborEdge: 3 });
          } else {
            if (x > 0) constraints.push({ edge: 5, neighbor: (y - 1) * cols + x - 1, neighborEdge: 2 });
            constraints.push({ edge: 0, neighbor: (y - 1) * cols + x, neighborEdge: 3 });
          }
        }
        return constraints;
      }
      const constraints: Array<{ edge: number; neighbor: number; neighborEdge: number }> = [];
      if (y > 0) constraints.push({ edge: 0, neighbor: (y - 1) * cols + x, neighborEdge: 2 });
      if (x > 0) constraints.push({ edge: 3, neighbor: y * cols + x - 1, neighborEdge: 1 });
      return constraints;
    }

    function solvePatch(shape: ShapeKind, tileset: TileSet, cols: number, rows: number, rng: () => number): Int16Array | null {
      const total = cols * rows;
      const grid = new Int16Array(total);
      grid.fill(-1);
      for (let pos = 0; pos < total; pos++) {
        const x = pos % cols;
        const y = Math.floor(pos / cols);
        const constraints = previousConstraints(shape, x, y, cols);
        const candidates = tileset.tiles
          .map((tile, idx) => ({ tile, idx }))
          .filter(({ tile }) => constraints.every(({ edge, neighbor, neighborEdge }) =>
            grid[neighbor] >= 0 && tile.edges[edge] === tileset.tiles[grid[neighbor]].edges[neighborEdge]
          ))
          .map(({ idx }) => idx);
        if (!candidates.length) return null;
        grid[pos] = candidates[Math.floor(rng() * candidates.length)];
      }
      return grid;
    }

    function validatePatch(shape: ShapeKind, tileset: TileSet, grid: Int16Array, cols: number, rows: number): boolean {
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const idx = y * cols + x;
          const tile = tileset.tiles[grid[idx]];
          if (!tile || tile.edges.length !== tileset.edgeCount) return false;
          const constraints = previousConstraints(shape, x, y, cols);
          for (const { edge, neighbor, neighborEdge } of constraints) {
            const neighborTile = tileset.tiles[grid[neighbor]];
            if (!neighborTile || tile.edges[edge] !== neighborTile.edges[neighborEdge]) return false;
          }
        }
      }
      return true;
    }

    function makeOrganicOrder(cols: number, rows: number, growth: GrowthMode, rng: () => number): number[] {
      const total = cols * rows;
      const order = Array.from({ length: total }, (_, i) => i);
      const starts = Array.from({ length: 3 + Math.floor(rng() * 4) }, () => ({
        x: Math.floor(rng() * cols),
        y: Math.floor(rng() * rows),
      }));
      const driftX = rng() * 2 - 1;
      const driftY = rng() * 2 - 1;
      const bend = 0.12 + rng() * 0.18;
      const cx = cols * (0.25 + rng() * 0.50);
      const cy = rows * (0.25 + rng() * 0.50);
      const faultA = cols * (0.15 + rng() * 0.7);
      const faultB = rows * (0.15 + rng() * 0.7);
      const scores = new Float32Array(total);
      for (let idx = 0; idx < total; idx++) {
        const x = idx % cols;
        const y = Math.floor(idx / cols);
        const nearest = Math.min(...starts.map((s) => {
          const dx = x - s.x;
          const dy = y - s.y;
          return Math.sqrt(dx * dx + dy * dy);
        }));
        const wave = Math.sin((x * driftX + y * driftY) * bend) * 2.8;
        const eddy = Math.sin((x * 1.7 - y * 1.3 + starts.length) * bend * 0.7) * 1.6;
        if (growth === 'tendrils') {
          const angle = Math.atan2(y - cy, x - cx);
          scores[idx] = nearest + Math.sin(angle * 5 + nearest * 0.55) * 5 + rng() * 6;
        } else if (growth === 'river') {
          const along = x * driftX + y * driftY;
          const cross = x * -driftY + y * driftX;
          const river = Math.sin(along * bend) * rows * 0.13;
          scores[idx] = along * 0.18 + Math.abs(cross - river) * 0.72 + rng() * 5;
        } else if (growth === 'rings') {
          const dx = x - cx;
          const dy = y - cy;
          const r = Math.sqrt(dx * dx + dy * dy);
          scores[idx] = r + Math.sin(r * 0.9 + Math.atan2(dy, dx) * 4) * 4 + rng() * 4;
        } else if (growth === 'islands') {
          scores[idx] = nearest + wave * 1.4 + eddy * 1.8 + rng() * 8;
        } else if (growth === 'lightning') {
          const branch = Math.abs(Math.sin((x * 0.7 + y * 1.9) * bend + Math.sin(y * 0.33) * 2));
          scores[idx] = nearest * 0.35 + branch * 18 + y * 0.10 + rng() * 5;
        } else if (growth === 'roots') {
          const roots = Math.min(...starts.map((s) => Math.abs(x - s.x) * 0.38 + Math.max(0, y - s.y) * 0.75));
          scores[idx] = roots + Math.sin(x * bend * 2.4 + y * 0.2) * 4 + rng() * 5;
        } else if (growth === 'vortex') {
          const dx = x - cx;
          const dy = y - cy;
          const r = Math.sqrt(dx * dx + dy * dy);
          const angle = Math.atan2(dy, dx);
          scores[idx] = r * 0.55 + Math.sin(angle * 7 + r * 0.42) * 7 + rng() * 5;
        } else if (growth === 'contours') {
          const band = Math.abs(Math.sin((x * driftX + y * driftY) * bend));
          scores[idx] = nearest * 0.55 + band * 12 + eddy + rng() * 4;
        } else if (growth === 'maze') {
          const cell = Math.sin(x * bend * 3.1) * Math.cos(y * bend * 2.7);
          const corridor = Math.abs(cell + Math.sin((x + y) * bend * 1.4) * 0.5);
          scores[idx] = nearest * 0.42 + corridor * 16 + rng() * 4;
        } else if (growth === 'faults') {
          const lineA = x * driftX + y * driftY - faultA;
          const lineB = x * -driftY + y * driftX - faultB;
          const fracture = Math.min(Math.abs(lineA), Math.abs(lineB)) * 0.55;
          scores[idx] = nearest * 0.35 + fracture + Math.sin((lineA - lineB) * bend) * 4 + rng() * 5;
        } else if (growth === 'braid') {
          const along = x * driftX + y * driftY;
          const cross = x * -driftY + y * driftX;
          const strand = Math.sin(along * bend * 1.8) * 6 + Math.sin(along * bend * 0.9 + 2.1) * 4;
          scores[idx] = along * 0.12 + Math.abs(cross - strand) * 0.85 + nearest * 0.22 + rng() * 4;
        } else if (growth === 'nebula') {
          const dx = x - cx;
          const dy = y - cy;
          const cloud = Math.sin(x * bend * 2.2 + Math.sin(y * bend) * 3) + Math.cos(y * bend * 2.6 + Math.sin(x * bend) * 2);
          scores[idx] = nearest * 0.50 + Math.sqrt(dx * dx + dy * dy) * 0.18 - cloud * 5 + rng() * 7;
        } else {
          scores[idx] = nearest + wave + eddy + rng() * 4.5;
        }
      }
      return order.sort((a, b) => scores[a] - scores[b]);
    }

    let W = 0;
    let H = 0;
    let cycle: Cycle | null = null;
    let playbackDirection = 1;
    let playbackSpeed = 1;
    let selectedShape: ShapeKind | 'random' = 'random';
    let selectedSkin: VisualSkin | 'random' = 'random';

    const shapes: ShapeKind[] = ['square', 'triangle', 'hexagon', 'circle', 'parallelogram', 'rectangle'];
    const skinsByShape: Record<ShapeKind, VisualSkin[]> = {
      square: ['triangles', 'edgeBands', 'cornerCuts', 'diamondWeave', 'isometric', 'lozenges', 'scales', 'chevrons', 'insetDiamonds', 'diagonalBars', 'checker', 'splitBands', 'pinwheel', 'crosshatch', 'shards', 'caps', 'slats', 'steps', 'splitDiag', 'edgeCorners', 'lanes'],
      triangle: ['facets', 'kite', 'bands', 'strata', 'zigzag', 'splitBands', 'pinwheel', 'shards', 'rays', 'triad', 'lanes'],
      hexagon: ['facets', 'bands', 'mosaic', 'wedges', 'splitBands', 'shards', 'spokes', 'rays', 'hexFan', 'edgeCorners'],
      circle: ['bands', 'mosaic', 'facets', 'splitBands', 'spokes', 'rays', 'arcBands', 'caps', 'iris', 'hexFan'],
      parallelogram: ['facets', 'blocks', 'bands', 'ribbons', 'diagonalBars', 'strata', 'splitBands', 'shards', 'slats', 'steps', 'splitDiag', 'lanes'],
      rectangle: ['bands', 'brickwork', 'mosaic', 'edgeBands', 'splitBands', 'checker', 'crosshatch', 'slats', 'steps', 'caps', 'splitDiag', 'edgeCorners', 'lanes'],
    };

    function option(label: string, value: string): HTMLOptionElement {
      const item = document.createElement('option');
      item.value = value;
      item.textContent = label;
      return item;
    }

    function syncSkinOptions() {
      if (!skinSelect) return;
      const current = skinSelect.value as VisualSkin | 'random';
      skinSelect.replaceChildren(option('Random', 'random'));
      const available = selectedShape === 'random' ? [] : skinsByShape[selectedShape];
      for (const skin of available) skinSelect.append(option(skin, skin));
      selectedSkin = current !== 'random' && available.includes(current as VisualSkin) ? current : 'random';
      skinSelect.value = selectedSkin;
      skinSelect.disabled = selectedShape === 'random';
    }

    function setupSelectors() {
      if (!shapeSelect || !skinSelect) return;
      shapeSelect.replaceChildren(option('Random', 'random'));
      for (const shape of shapes) shapeSelect.append(option(shape, shape));
      shapeSelect.value = selectedShape;
      syncSkinOptions();
      shapeSelect.addEventListener('change', () => {
        selectedShape = shapeSelect.value as ShapeKind | 'random';
        syncSkinOptions();
        makeCycle();
        draw();
      });
      skinSelect.addEventListener('change', () => {
        selectedSkin = skinSelect.value as VisualSkin | 'random';
        makeCycle();
        draw();
      });
    }

    function setPlayback(direction: -1 | 1, boosted: boolean) {
      playbackDirection = direction;
      playbackSpeed = boosted ? 4 : 1;
      if (boostIndicator) {
        boostIndicator.className = `wang-boost${boosted ? ' is-active' : ''}${boosted && direction < 0 ? ' is-reverse' : ''}`;
      }
    }

    function inRewindZone(clientX: number): boolean {
      const textLeft = document.querySelector('.about-shell > .section-head')?.getBoundingClientRect().left ?? window.innerWidth * 0.18;
      return clientX < Math.max(56, textLeft - 12);
    }

    function makeCycle() {
      const seed = hashString(`${Date.now()}:${Math.random()}`);
      const rng = mulberry32(seed);
      const growthModes: GrowthMode[] = ['spores', 'tendrils', 'river', 'rings', 'islands', 'lightning', 'roots', 'vortex', 'contours', 'maze', 'faults', 'braid', 'nebula'];
      const speeds: SpeedMode[] = [
        { name: 'slow', divisor: 480, minStep: 1 },
        { name: 'medium', divisor: 340, minStep: 2 },
        { name: 'quick', divisor: 230, minStep: 3 },
      ];
      const tileSize = MIN_TILE + Math.floor(rng() * (MAX_TILE - MIN_TILE + 1));
      const randomShapes = shapes.filter((shape) => shape !== cycle?.shape);
      const shape = selectedShape === 'random' ? pick(randomShapes.length ? randomShapes : shapes, rng) : selectedShape;
      const skin = selectedSkin === 'random' ? pick(skinsByShape[shape], rng) : selectedSkin;
      const triangleShape = shape === 'triangle';
      const hexShape = shape === 'hexagon';
      const circleShape = shape === 'circle';
      const rectangleShape = shape === 'rectangle';
      const parallelogramShape = shape === 'parallelogram';
      const cols = rectangleShape
        ? Math.ceil(W / (tileSize * 1.55)) + 8
        : triangleShape
          ? Math.ceil(W / (tileSize * 0.74)) + 16
          : parallelogramShape
          ? Math.ceil(W / (tileSize * 1.18)) + Math.ceil(H / (tileSize * 2.2)) + 18
          : Math.ceil(W / tileSize) + (hexShape || circleShape ? 10 : 1);
      const rows = rectangleShape
        ? Math.ceil(H / (tileSize * 0.72)) + 8
        : triangleShape
          ? Math.ceil(H / (tileSize * 1.33)) + 8
        : parallelogramShape
          ? Math.ceil(H / tileSize) + 12
          : Math.ceil(H / tileSize) + (hexShape || circleShape ? 10 : 1);
      const growth = pick(growthModes, rng);
      const speed = pick(speeds, rng);
      const candidateTileSets = tileSetsFor(shape);
      let tileset = pick(candidateTileSets, rng);
      let grid: Int16Array | null = null;
      for (let tries = 0; tries < 8 && !grid; tries++) {
        grid = solvePatch(shape, tileset, cols, rows, rng);
        if (grid && !validatePatch(shape, tileset, grid, cols, rows)) grid = null;
        if (!grid) tileset = pick(candidateTileSets, rng);
      }
      if (!grid) {
        tileset = candidateTileSets[0];
        grid = solvePatch(shape, tileset, cols, rows, rng)!;
        if (!validatePatch(shape, tileset, grid, cols, rows)) throw new Error(`Invalid ${shape} tile patch`);
      }
      cycle = {
        seed,
        rng,
        tileset,
        shape,
        skin,
        growth,
        speed,
        revealStep: Math.ceil(Math.max(speed.minStep, Math.ceil((cols * rows) / speed.divisor)) * 1.5),
        tileSize,
        cols,
        rows,
        grid,
        order: makeOrganicOrder(cols, rows, growth, rng),
        revealed: reduce ? cols * rows : 0,
        visible: new Uint8Array(cols * rows),
        hold: 0,
        blackHold: reduce ? 0 : BLACK_FRAMES,
        palette: pickPalette(Math.max(3, Math.min(5, tileset.colors)), rng),
      };
      if (reduce) cycle.visible.fill(1);
      updateLabel();
    }

    function updateLabel() {
      if (!cycle || !label) return;
      const swatches = cycle.palette
        .map((c) => `<span class="wang-swatch" style="background:${rgb(c)}"></span>`)
        .join('');
      label.innerHTML = `
        <span>tileset: ${cycle.tileset.name}</span>
        <span>shape: ${cycle.shape}</span>
        <span>edges: ${cycle.tileset.edgeCount}</span>
        <span>skin: ${cycle.skin}</span>
        <span>growth: ${cycle.growth}</span>
        <span>speed: ${cycle.speed.name}</span>
        <span>tile: ${cycle.tileSize * CELL_PX}px</span>
        <span>seed: ${cycle.seed.toString(16).padStart(8, '0')}</span>
        <span class="wang-swatches">${swatches}</span>
      `;
    }

    function colorFor(label: number, palette: RGB[]): RGB {
      return palette[label % palette.length];
    }

    function edgeColors(tile: WangTile, palette: RGB[]): RGB[] {
      return tile.edges.map((edge) => colorFor(edge, palette));
    }

    function squareColors(tile: WangTile, palette: RGB[]) {
      const colors = edgeColors(tile, palette);
      return { north: colors[0], east: colors[1], south: colors[2], west: colors[3] };
    }

    function fillPoly(points: Array<[number, number]>, color: RGB, alpha = 1) {
      const cx = points.reduce((sum, point) => sum + point[0], 0) / points.length;
      const cy = points.reduce((sum, point) => sum + point[1], 0) / points.length;
      const bleed = 0.38;
      const expanded = points.map(([x, y]) => {
        const dx = x - cx;
        const dy = y - cy;
        const d = Math.sqrt(dx * dx + dy * dy) || 1;
        return [x + (dx / d) * bleed, y + (dy / d) * bleed] as [number, number];
      });
      ctx.fillStyle = rgba(color, alpha);
      ctx.beginPath();
      ctx.moveTo(expanded[0][0], expanded[0][1]);
      for (let i = 1; i < expanded.length; i++) ctx.lineTo(expanded[i][0], expanded[i][1]);
      ctx.closePath();
      ctx.fill();
    }

    function fillRectBleed(x: number, y: number, w: number, h: number) {
      ctx.fillRect(Math.floor(x) - 0.5, Math.floor(y) - 0.5, Math.ceil(w) + 1, Math.ceil(h) + 1);
    }

    function drawTriangleLattice(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      const side = size * 1.55;
      const h = side * 0.86;
      const x = col * side * 0.50 - side;
      const y = row * h - h;
      const up = ((col + row) & 1) === 0;
      const points: Array<[number, number]> = up
        ? [[x, y + h], [x + side, y + h], [x + side * 0.5, y]]
        : [[x, y], [x + side, y], [x + side * 0.5, y + h]];
      const center: [number, number] = [
        (points[0][0] + points[1][0] + points[2][0]) / 3,
        (points[0][1] + points[1][1] + points[2][1]) / 3,
      ];
      const [west, east, base] = edgeColors(tile, palette);
      const north = base;
      const south = base;
      if (skin === 'kite') {
        fillPoly([points[0], center, points[2]], mix(west, north, 0.45), 0.94);
        fillPoly([points[2], center, points[1]], mix(north, east, 0.45), 0.94);
        fillPoly([points[1], center, points[0]], mix(south, east, 0.45), 0.94);
      } else if (skin === 'bands') {
        fillPoly([points[0], points[1], center], mix(north, south, 0.50), 0.90);
        fillPoly([points[1], points[2], center], east, 0.72);
        fillPoly([points[2], points[0], center], west, 0.72);
      } else if (skin === 'strata') {
        fillPoly(points, mix(north, south, 0.50), 0.88);
        fillPoly([points[0], points[1], center], north, 0.42);
        fillPoly([points[1], points[2], center], mix(east, south, 0.45), 0.55);
      } else if (skin === 'zigzag') {
        fillPoly([points[0], points[1], center], mix(west, east, 0.50), 0.82);
        fillPoly([points[1], points[2], center], north, 0.68);
        fillPoly([points[2], points[0], center], south, 0.68);
      } else if (skin === 'splitBands') {
        fillPoly(points, mix(north, south, 0.50), 0.86);
        fillPoly([points[0], center, points[2]], west, 0.48);
        fillPoly([points[1], center, points[2]], east, 0.48);
      } else if (skin === 'pinwheel') {
        fillPoly([points[0], center, points[2]], north, 0.84);
        fillPoly([points[2], center, points[1]], east, 0.74);
        fillPoly([points[1], center, points[0]], south, 0.64);
      } else if (skin === 'shards') {
        fillPoly(points, mix(west, east, 0.50), 0.82);
        fillPoly([points[0], center, points[1]], base, 0.50);
        fillPoly([points[1], center, points[2]], east, 0.58);
      } else if (skin === 'caps') {
        fillPoly(points, mix(base, west, 0.45), 0.82);
        fillPoly([points[0], points[1], center], base, 0.60);
      } else if (skin === 'rays') {
        fillPoly([points[0], center, points[1]], base, 0.78);
        fillPoly([points[1], center, points[2]], east, 0.58);
        fillPoly([points[2], center, points[0]], west, 0.58);
      } else if (skin === 'slats') {
        fillPoly(points, mix(base, east, 0.45), 0.84);
        fillPoly([points[0], points[2], center], west, 0.42);
        fillPoly([points[1], points[2], center], east, 0.42);
      } else if (skin === 'triad') {
        fillPoly([points[0], points[1], center], base, 0.82);
        fillPoly([points[1], points[2], center], east, 0.70);
        fillPoly([points[2], points[0], center], west, 0.70);
        fillPoly([points[0], points[1], points[2]], mix(base, mix(east, west, 0.50), 0.25), 0.26);
      } else if (skin === 'lanes') {
        fillPoly(points, mix(base, mix(east, west, 0.50), 0.35), 0.86);
        fillPoly([points[0], points[1], center], base, 0.44);
        fillPoly([points[1], points[2], center], east, 0.44);
        fillPoly([points[2], points[0], center], west, 0.44);
      } else {
        fillPoly([points[0], points[1], center], up ? south : north, 0.96);
        fillPoly([points[1], points[2], center], east, 0.88);
        fillPoly([points[2], points[0], center], west, 0.88);
      }
    }

    function drawHexLattice(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      const r = size * 1.02;
      const stepX = Math.sqrt(3) * r;
      const stepY = 1.5 * r;
      const cx = col * stepX + (row & 1 ? stepX * 0.5 : 0) - stepX * 2;
      const cy = row * stepY - stepY * 2;
      const points: Array<[number, number]> = [];
      for (let i = 0; i < 6; i++) {
        const angle = -Math.PI / 2 + i * Math.PI / 3;
        points.push([cx + Math.cos(angle) * r, cy + Math.sin(angle) * r]);
      }
      const [ne, east, se, sw, west, nw] = edgeColors(tile, palette);
      const north = mix(nw, ne, 0.50);
      const south = mix(sw, se, 0.50);
      fillPoly(points, mix(north, south, 0.50), 0.92);
      ctx.save();
      ctx.beginPath();
      ctx.moveTo(points[0][0], points[0][1]);
      for (let i = 1; i < points.length; i++) ctx.lineTo(points[i][0], points[i][1]);
      ctx.closePath();
      ctx.clip();
      if (skin === 'bands') {
        for (let i = 0; i < 6; i++) fillPoly([points[i], points[(i + 1) % 6], [cx, cy]], [ne, east, se, sw, west, nw][i], i % 2 ? 0.54 : 0.70);
      } else if (skin === 'mosaic') {
        fillPoly([points[5], points[0], [cx, cy]], nw, 0.92);
        fillPoly([points[0], points[1], [cx, cy]], ne, 0.88);
        fillPoly([points[1], points[2], [cx, cy]], east, 0.88);
        fillPoly([points[2], points[3], [cx, cy]], se, 0.92);
        fillPoly([points[3], points[4], [cx, cy]], sw, 0.88);
        fillPoly([points[4], points[5], [cx, cy]], west, 0.88);
      } else if (skin === 'beads') {
        fillPoly(points, mix(east, west, 0.50), 0.82);
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.92);
        ctx.beginPath();
        ctx.arc(cx, cy, r * 0.42, 0, Math.PI * 2);
        ctx.fill();
      } else if (skin === 'wedges') {
        for (let i = 0; i < 6; i++) {
          fillPoly([points[i], points[(i + 1) % 6], [cx, cy]], [ne, east, se, sw, west, nw][i], 0.76);
        }
      } else if (skin === 'orbit') {
        fillPoly([points[0], points[1], points[2], [cx, cy]], mix(ne, east, 0.45), 0.58);
        fillPoly([points[3], points[4], points[5], [cx, cy]], mix(sw, west, 0.45), 0.58);
        ctx.strokeStyle = rgba(mix(east, west, 0.50), 0.62);
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.arc(cx, cy, r * 0.48, 0, Math.PI * 2);
        ctx.stroke();
      } else if (skin === 'petals') {
        for (let i = 0; i < 3; i++) {
          fillPoly([points[i], points[(i + 1) % 6], points[(i + 3) % 6], points[(i + 4) % 6]], [ne, east, se][i], 0.42);
        }
      } else if (skin === 'splitBands') {
        fillPoly([points[5], points[0], points[1], points[2], [cx, cy]], mix(nw, east, 0.45), 0.58);
        fillPoly([points[2], points[3], points[4], points[5], [cx, cy]], mix(se, west, 0.45), 0.58);
      } else if (skin === 'shards') {
        fillPoly([points[5], points[0], points[2], [cx, cy]], mix(nw, east, 0.45), 0.66);
        fillPoly([points[2], points[3], points[5], [cx, cy]], mix(se, west, 0.45), 0.58);
      } else if (skin === 'spokes') {
        for (let i = 0; i < 6; i += 2) fillPoly([points[i], points[(i + 1) % 6], [cx, cy]], [ne, se, west][i / 2], 0.70);
      } else if (skin === 'rays') {
        for (let i = 0; i < 6; i++) fillPoly([points[i], points[(i + 1) % 6], [cx, cy]], [ne, east, se, sw, west, nw][i], 0.48 + (i % 2) * 0.22);
      } else if (skin === 'caps') {
        fillPoly([points[5], points[0], points[1], [cx, cy]], mix(nw, ne, 0.50), 0.64);
        fillPoly([points[2], points[3], points[4], [cx, cy]], mix(se, sw, 0.50), 0.64);
      } else if (skin === 'hexFan') {
        for (let i = 0; i < 6; i++) {
          const color = [ne, east, se, sw, west, nw][i];
          fillPoly([points[i], points[(i + 1) % 6], [cx, cy]], mix(color, palette[(i + 1) % palette.length], 0.18), 0.66);
        }
        fillPoly([[cx, cy - r * 0.28], [cx + r * 0.24, cy + r * 0.14], [cx - r * 0.24, cy + r * 0.14]], mix(ne, sw, 0.50), 0.64);
      } else if (skin === 'edgeCorners') {
        fillPoly(points, mix(north, south, 0.50), 0.84);
        for (let i = 0; i < 6; i += 2) {
          fillPoly([points[i], points[(i + 1) % 6], [cx, cy]], [ne, se, west][i / 2], 0.72);
        }
      } else {
        fillPoly([points[0], points[1], points[2], [cx, cy]], east, 0.48);
        fillPoly([points[3], points[4], points[5], [cx, cy]], west, 0.48);
      }
      ctx.restore();
    }

    function drawCirclePacking(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      const r = size * 0.82;
      const gap = r * 0.08;
      const h = Math.sqrt(3) * (r + gap);
      const cx = col * (r + gap) * 1.5 - r * 2;
      const cy = row * h + (col & 1 ? h * 0.5 : 0) - h * 2;
      const [ne, east, se, sw, west, nw] = edgeColors(tile, palette);
      const north = mix(nw, ne, 0.50);
      const south = mix(sw, se, 0.50);
      ctx.save();
      ctx.beginPath();
      ctx.arc(cx, cy, r + 0.25, 0, Math.PI * 2);
      ctx.clip();
      ctx.fillStyle = rgba(mix(east, west, 0.50), 0.84);
      ctx.beginPath();
      ctx.arc(cx, cy, r + 0.25, 0, Math.PI * 2);
      ctx.fill();
      for (let i = 0; i < 6; i++) {
        const a0 = -Math.PI / 2 + i * Math.PI / 3;
        const a1 = a0 + Math.PI / 3;
        ctx.fillStyle = rgba([ne, east, se, sw, west, nw][i], 0.66);
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, a0, a1);
        ctx.closePath();
        ctx.fill();
      }
      if (skin === 'bands') {
        fillPoly([[cx - r, cy - r * 0.12], [cx + r, cy - r * 0.12], [cx + r, cy - r], [cx - r, cy - r]], north, 0.34);
        fillPoly([[cx - r, cy + r * 0.12], [cx + r, cy + r * 0.12], [cx + r, cy + r], [cx - r, cy + r]], south, 0.34);
      } else if (skin === 'mosaic') {
        for (let i = 0; i < 6; i++) {
          const a0 = -Math.PI / 2 + i * Math.PI / 3;
          const a1 = a0 + Math.PI / 3;
          const color = [ne, east, se, sw, west, nw][i];
          ctx.fillStyle = rgba(color, 0.58);
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, r, a0, a1);
          ctx.closePath();
          ctx.fill();
        }
      } else if (skin === 'orbit') {
        ctx.strokeStyle = rgba(north, 0.76);
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.ellipse(cx, cy, r * 0.76, r * 0.34, Math.PI * 0.18, 0, Math.PI * 2);
        ctx.stroke();
        ctx.strokeStyle = rgba(south, 0.64);
        ctx.beginPath();
        ctx.ellipse(cx, cy, r * 0.76, r * 0.34, -Math.PI * 0.18, 0, Math.PI * 2);
        ctx.stroke();
      } else if (skin === 'petals') {
        for (let i = 0; i < 6; i++) {
          const a = -Math.PI / 2 + i * Math.PI / 3;
          ctx.fillStyle = rgba([ne, east, se, sw, west, nw][i], 0.46);
          ctx.beginPath();
          ctx.ellipse(cx + Math.cos(a) * r * 0.25, cy + Math.sin(a) * r * 0.25, r * 0.42, r * 0.18, a, 0, Math.PI * 2);
          ctx.fill();
        }
      } else if (skin === 'splitBands') {
        fillPoly([[cx - r, cy - r], [cx, cy - r], [cx, cy + r], [cx - r, cy + r]], west, 0.42);
        fillPoly([[cx, cy - r], [cx + r, cy - r], [cx + r, cy + r], [cx, cy + r]], east, 0.42);
      } else if (skin === 'target') {
        for (let i = 0; i < 3; i++) {
          ctx.strokeStyle = rgba([ne, se, west][i], 0.56);
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.arc(cx, cy, r * (0.32 + i * 0.2), 0, Math.PI * 2);
          ctx.stroke();
        }
      } else if (skin === 'spokes') {
        for (let i = 0; i < 6; i++) {
          const a = -Math.PI / 3 + i * Math.PI / 3;
          ctx.strokeStyle = rgba([ne, east, se, sw, west, nw][i], 0.72);
          ctx.lineWidth = 1.2;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(a) * r, cy + Math.sin(a) * r);
          ctx.stroke();
        }
      } else if (skin === 'rays') {
        for (let i = 0; i < 6; i++) {
          const a0 = -Math.PI / 2 + i * Math.PI / 3;
          fillPoly([[cx, cy], [cx + Math.cos(a0) * r, cy + Math.sin(a0) * r], [cx + Math.cos(a0 + 0.34) * r, cy + Math.sin(a0 + 0.34) * r]], [ne, east, se, sw, west, nw][i], 0.54);
        }
      } else if (skin === 'arcBands') {
        for (let i = 0; i < 6; i++) {
          ctx.strokeStyle = rgba([ne, east, se, sw, west, nw][i], 0.82);
          ctx.lineWidth = Math.max(1, r * 0.16);
          ctx.beginPath();
          ctx.arc(cx, cy, r * 0.64, -Math.PI / 2 + i * Math.PI / 3, -Math.PI / 2 + (i + 0.72) * Math.PI / 3);
          ctx.stroke();
        }
      } else if (skin === 'caps') {
        fillPoly([[cx - r, cy - r], [cx + r, cy - r], [cx, cy]], north, 0.36);
        fillPoly([[cx - r, cy + r], [cx + r, cy + r], [cx, cy]], south, 0.36);
      } else if (skin === 'iris') {
        for (let i = 0; i < 6; i++) {
          const a = -Math.PI / 2 + i * Math.PI / 3;
          const color = [ne, east, se, sw, west, nw][i];
          fillPoly([[cx, cy], [cx + Math.cos(a) * r, cy + Math.sin(a) * r], [cx + Math.cos(a + Math.PI / 3) * r, cy + Math.sin(a + Math.PI / 3) * r]], color, 0.62);
        }
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.72);
        ctx.beginPath();
        ctx.arc(cx, cy, r * 0.32, 0, Math.PI * 2);
        ctx.fill();
      } else if (skin === 'hexFan') {
        for (let i = 0; i < 6; i += 2) {
          const a0 = -Math.PI / 2 + i * Math.PI / 3;
          ctx.fillStyle = rgba([ne, se, west][i / 2], 0.62);
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.arc(cx, cy, r, a0, a0 + Math.PI * 2 / 3);
          ctx.closePath();
          ctx.fill();
        }
      } else {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.72);
        ctx.beginPath();
        ctx.arc(cx, cy, r * 0.58, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }

    function drawParallelogramTile(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      const w = size * 1.24;
      const skew = size * 0.46;
      const x = col * w + row * skew - H * 0.62 - size * 6;
      const y = row * size - size * 6;
      const points: Array<[number, number]> = [[x, y], [x + w, y], [x + w + skew, y + size], [x + skew, y + size]];
      const center: [number, number] = [x + w * 0.5 + skew * 0.5, y + size * 0.5];
      const { north, east, south, west } = squareColors(tile, palette);
      if (skin === 'blocks') {
        fillPoly(points, mix(north, south, 0.45), 0.94);
        fillPoly([points[0], points[1], center], north, 0.55);
        fillPoly([points[1], points[2], center], east, 0.55);
        fillPoly([points[2], points[3], center], south, 0.55);
        fillPoly([points[3], points[0], center], west, 0.55);
      } else if (skin === 'diagonalBars') {
        fillPoly(points, mix(north, south, 0.45), 0.90);
        fillPoly([points[0], points[1], center], north, 0.62);
        fillPoly([points[2], points[3], center], south, 0.62);
      } else if (skin === 'strata') {
        fillPoly(points, mix(west, east, 0.50), 0.90);
        fillPoly([points[0], points[1], [center[0] + skew * 0.3, center[1]]], north, 0.44);
        fillPoly([points[2], points[3], [center[0] - skew * 0.3, center[1]]], south, 0.44);
      } else if (skin === 'crosshatch') {
        fillPoly(points, mix(north, south, 0.45), 0.88);
        fillPoly([points[0], points[1], points[2], center], east, 0.36);
        fillPoly([points[2], points[3], points[0], center], west, 0.36);
      } else if (skin === 'splitBands') {
        fillPoly([points[0], points[1], points[2], center], mix(north, east, 0.50), 0.82);
        fillPoly([points[2], points[3], points[0], center], mix(south, west, 0.50), 0.82);
      } else if (skin === 'shards') {
        fillPoly(points, mix(north, south, 0.45), 0.88);
        fillPoly([points[0], points[1], points[3]], west, 0.34);
        fillPoly([points[1], points[2], points[3]], east, 0.34);
      } else if (skin === 'slats') {
        fillPoly(points, mix(east, west, 0.50), 0.86);
        fillPoly([points[0], points[1], center], north, 0.46);
        fillPoly([points[2], points[3], center], south, 0.46);
      } else if (skin === 'steps') {
        fillPoly(points, mix(north, south, 0.45), 0.86);
        fillPoly([points[0], [center[0], points[0][1]], center, points[3]], west, 0.44);
        fillPoly([[center[0], points[1][1]], points[1], points[2], center], east, 0.44);
      } else if (skin === 'frame') {
        fillPoly(points, mix(north, south, 0.45), 0.84);
        fillPoly([points[0], points[1], center], north, 0.36);
        fillPoly([points[2], points[3], center], south, 0.36);
      } else if (skin === 'splitDiag') {
        fillPoly([points[0], points[1], points[2]], mix(north, east, 0.45), 0.88);
        fillPoly([points[2], points[3], points[0]], mix(south, west, 0.45), 0.88);
        fillPoly([points[1], points[2], center], east, 0.42);
        fillPoly([points[3], points[0], center], west, 0.42);
      } else if (skin === 'lanes') {
        fillPoly(points, mix(north, south, 0.50), 0.86);
        fillPoly([points[0], points[1], center], north, 0.44);
        fillPoly([points[1], points[2], center], east, 0.44);
        fillPoly([points[2], points[3], center], south, 0.44);
        fillPoly([points[3], points[0], center], west, 0.44);
      } else {
        fillPoly([points[0], points[1], center], north, 0.90);
        fillPoly([points[1], points[2], center], east, 0.86);
        fillPoly([points[2], points[3], center], south, 0.90);
        fillPoly([points[3], points[0], center], west, 0.86);
      }
    }

    function drawRectangleTile(tile: WangTile, col: number, row: number, size: number, palette: RGB[], skin: VisualSkin) {
      const w = size * 1.55;
      const h = size * 0.72;
      const offset = skin === 'brickwork' && (row & 1) ? w * 0.5 : 0;
      const x = col * w - offset - w * 3;
      const y = row * h - h * 3;
      const x2 = x + w;
      const y2 = y + h;
      const cx = x + w * 0.5;
      const cy = y + h * 0.5;
      const { north, east, south, west } = squareColors(tile, palette);
      if (skin === 'bands') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.88);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(west, 0.76);
        fillRectBleed(x, y, Math.max(2, w * 0.18), h);
        ctx.fillStyle = rgba(east, 0.76);
        fillRectBleed(x2 - Math.max(2, w * 0.18), y, Math.max(2, w * 0.18), h);
      } else if (skin === 'brickwork') {
        ctx.fillStyle = rgba(mix(north, east, 0.45), 0.92);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(south, 0.52);
        fillRectBleed(x, y2 - Math.max(1, h * 0.24), w, Math.max(1, h * 0.24));
      } else if (skin === 'splitBands') {
        ctx.fillStyle = rgba(mix(north, west, 0.45), 0.86);
        fillRectBleed(x, y, w * 0.5, h);
        ctx.fillStyle = rgba(mix(south, east, 0.45), 0.86);
        fillRectBleed(cx, y, w * 0.5, h);
      } else if (skin === 'checker') {
        ctx.fillStyle = rgba(north, 0.84);
        fillRectBleed(x, y, w * 0.5, h * 0.5);
        ctx.fillStyle = rgba(east, 0.84);
        fillRectBleed(cx, y, w * 0.5, h * 0.5);
        ctx.fillStyle = rgba(west, 0.84);
        fillRectBleed(x, cy, w * 0.5, h * 0.5);
        ctx.fillStyle = rgba(south, 0.84);
        fillRectBleed(cx, cy, w * 0.5, h * 0.5);
      } else if (skin === 'crosshatch') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.86);
        fillRectBleed(x, y, w, h);
        fillPoly([[x, y], [x2, y], [x, y2]], east, 0.34);
        fillPoly([[x2, y], [x2, y2], [x, y2]], west, 0.34);
      } else if (skin === 'nestedBox') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.86);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(mix(east, west, 0.5), 0.62);
        fillRectBleed(x + w * 0.24, y + h * 0.22, w * 0.52, h * 0.56);
      } else if (skin === 'slats') {
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.86);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(north, 0.38);
        fillRectBleed(x, y, w, h * 0.34);
        ctx.fillStyle = rgba(south, 0.38);
        fillRectBleed(x, y2 - h * 0.34, w, h * 0.34);
      } else if (skin === 'steps') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.84);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(west, 0.46);
        fillRectBleed(x, y, w * 0.55, h * 0.55);
        ctx.fillStyle = rgba(east, 0.46);
        fillRectBleed(x + w * 0.45, y + h * 0.45, w * 0.55, h * 0.55);
      } else if (skin === 'frame') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.84);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.48);
        fillRectBleed(x + w * 0.18, y + h * 0.22, w * 0.64, h * 0.56);
      } else if (skin === 'caps') {
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.84);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(north, 0.52);
        fillRectBleed(x, y, w, h * 0.28);
        ctx.fillStyle = rgba(south, 0.52);
        fillRectBleed(x, y2 - h * 0.28, w, h * 0.28);
      } else if (skin === 'splitDiag') {
        fillPoly([[x, y], [x2, y], [x, y2]], mix(north, west, 0.45), 0.86);
        fillPoly([[x2, y], [x2, y2], [x, y2]], mix(east, south, 0.45), 0.86);
      } else if (skin === 'edgeCorners') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.82);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(north, 0.48);
        fillRectBleed(x, y, w, h * 0.24);
        ctx.fillStyle = rgba(east, 0.48);
        fillRectBleed(x2 - w * 0.22, y, w * 0.22, h);
      } else if (skin === 'lanes') {
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.82);
        fillRectBleed(x, y, w, h);
        ctx.fillStyle = rgba(north, 0.36);
        fillRectBleed(x, y, w, h * 0.22);
        ctx.fillStyle = rgba(south, 0.36);
        fillRectBleed(x, y2 - h * 0.22, w, h * 0.22);
      } else {
        fillPoly([[x, y], [x2, y], [cx, cy]], north, 0.82);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], east, 0.82);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], south, 0.82);
        fillPoly([[x, y2], [x, y], [cx, cy]], west, 0.82);
      }
    }

    function drawTile(tile: WangTile, col: number, row: number, size: number, palette: RGB[], shape: ShapeKind, skin: VisualSkin) {
      if (shape === 'triangle') {
        drawTriangleLattice(tile, col, row, size, palette, skin);
        return;
      }
      if (shape === 'hexagon') {
        drawHexLattice(tile, col, row, size, palette, skin);
        return;
      }
      if (shape === 'circle') {
        drawCirclePacking(tile, col, row, size, palette, skin);
        return;
      }
      if (shape === 'parallelogram') {
        drawParallelogramTile(tile, col, row, size, palette, skin);
        return;
      }
      if (shape === 'rectangle') {
        drawRectangleTile(tile, col, row, size, palette, skin);
        return;
      }
      const x = col * size;
      const y = row * size;
      const x2 = x + size;
      const y2 = y + size;
      const cx = x + size / 2;
      const cy = y + size / 2;
      const { north, east, south, west } = squareColors(tile, palette);
      const dark = mix(paper, palette[0], 0.10);
      ctx.fillStyle = rgb(dark);
      fillRectBleed(x, y, size, size);

      if (skin === 'triangles') {
        fillPoly([[x, y], [x2, y], [cx, cy]], north, 0.96);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], east, 0.96);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], south, 0.96);
        fillPoly([[x, y2], [x, y], [cx, cy]], west, 0.96);
      } else if (skin === 'edgeBands') {
        const band = Math.max(2, Math.floor(size * 0.24));
        ctx.fillStyle = rgba(north, 0.95);
        fillRectBleed(x, y, size, band);
        ctx.fillStyle = rgba(east, 0.95);
        fillRectBleed(x2 - band, y, band, size);
        ctx.fillStyle = rgba(south, 0.95);
        fillRectBleed(x, y2 - band, size, band);
        ctx.fillStyle = rgba(west, 0.95);
        fillRectBleed(x, y, band, size);
        ctx.fillStyle = rgba(mix(palette[(tile.edges[0] + tile.edges[2]) % palette.length], paper, 0.35), 0.78);
        ctx.fillRect(Math.round(cx) - 1, Math.round(cy) - 1, 3, 3);
      } else if (skin === 'cornerCuts') {
        fillPoly([[x, y], [x2, y], [x2, cy], [cx, cy]], north, 0.86);
        fillPoly([[x2, y], [x2, y2], [cx, y2], [cx, cy]], east, 0.86);
        fillPoly([[x2, y2], [x, y2], [x, cy], [cx, cy]], south, 0.86);
        fillPoly([[x, y2], [x, y], [cx, y], [cx, cy]], west, 0.86);
      } else if (skin === 'centerGlyphs') {
        fillPoly([[x, y], [x2, y], [cx, cy]], north, 0.70);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], east, 0.70);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], south, 0.70);
        fillPoly([[x, y2], [x, y], [cx, cy]], west, 0.70);
        ctx.fillStyle = rgba(mix(palette[(tile.edges[1] + tile.edges[3]) % palette.length], paper, 0.18), 0.95);
        const dot = Math.max(2, Math.floor(size * 0.22));
        ctx.fillRect(Math.round(cx - dot / 2), Math.round(cy - dot / 2), dot, dot);
      } else if (skin === 'diamondWeave') {
        const q = size * 0.26;
        fillPoly([[x, y], [cx, y], [x + q, cy], [x, cy]], west, 0.90);
        fillPoly([[cx, y], [x2, y], [x2, cy], [x2 - q, cy]], north, 0.90);
        fillPoly([[x2, cy], [x2, y2], [cx, y2], [x2 - q, cy]], east, 0.90);
        fillPoly([[x, cy], [x + q, cy], [cx, y2], [x, y2]], south, 0.90);
        fillPoly([[cx, y], [x2 - q, cy], [cx, y2], [x + q, cy]], mix(north, south, 0.50), 0.78);
      } else if (skin === 'isometric') {
        fillPoly([[x, y], [x2, y], [cx, cy]], mix(north, east, 0.35), 0.88);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], mix(east, south, 0.35), 0.88);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], mix(south, west, 0.35), 0.88);
        fillPoly([[x, y2], [x, y], [cx, cy]], mix(west, north, 0.35), 0.88);
        const rib = Math.max(1, Math.floor(size * 0.10));
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.42);
        ctx.fillRect(Math.round(cx - rib / 2), y, rib, size);
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.34);
        ctx.fillRect(x, Math.round(cy - rib / 2), size, rib);
      } else if (skin === 'lozenges') {
        fillPoly([[cx, y], [x2, cy], [cx, y2], [x, cy]], mix(north, south, 0.35), 0.96);
        fillPoly([[x, cy], [cx, y], [cx, cy]], west, 0.72);
        fillPoly([[cx, y], [x2, cy], [cx, cy]], north, 0.72);
        fillPoly([[x2, cy], [cx, y2], [cx, cy]], east, 0.72);
        fillPoly([[cx, y2], [x, cy], [cx, cy]], south, 0.72);
      } else if (skin === 'beads') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.84);
        ctx.beginPath();
        ctx.arc(cx, cy, size * 0.48, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = rgba(west, 0.92);
        ctx.fillRect(x, Math.round(cy - 1), Math.ceil(size * 0.42), 2);
        ctx.fillStyle = rgba(east, 0.92);
        ctx.fillRect(Math.floor(x2 - size * 0.42), Math.round(cy - 1), Math.ceil(size * 0.42), 2);
        ctx.fillStyle = rgba(north, 0.92);
        ctx.fillRect(Math.round(cx - 1), y, 2, Math.ceil(size * 0.42));
      } else if (skin === 'scales') {
        fillPoly([[x, y2], [cx, y], [x2, y2]], mix(north, east, 0.45), 0.90);
        fillPoly([[x, y2], [cx, cy], [cx, y], [x, y]], west, 0.50);
        fillPoly([[x2, y2], [cx, cy], [cx, y], [x2, y]], east, 0.50);
        fillPoly([[x, y2], [cx, cy], [x2, y2]], south, 0.64);
      } else if (skin === 'chevrons') {
        fillPoly([[x, y], [cx, cy], [x, y2]], west, 0.88);
        fillPoly([[x2, y], [cx, cy], [x2, y2]], east, 0.88);
        fillPoly([[x, y], [cx, cy], [x2, y]], north, 0.62);
        fillPoly([[x, y2], [cx, cy], [x2, y2]], south, 0.62);
      } else if (skin === 'diagonalBars') {
        fillPoly([[x, y], [x2, y], [x, y2]], mix(north, west, 0.45), 0.88);
        fillPoly([[x2, y], [x2, y2], [x, y2]], mix(east, south, 0.45), 0.88);
        fillPoly([[x + size * 0.24, y], [x2, y], [x2, y + size * 0.24], [x + size * 0.24, y2], [x, y2], [x, y2 - size * 0.24]], mix(north, south, 0.50), 0.46);
      } else if (skin === 'checker') {
        ctx.fillStyle = rgba(north, 0.84);
        fillRectBleed(x, y, size * 0.5, size * 0.5);
        ctx.fillStyle = rgba(east, 0.84);
        fillRectBleed(cx, y, size * 0.5, size * 0.5);
        ctx.fillStyle = rgba(west, 0.84);
        fillRectBleed(x, cy, size * 0.5, size * 0.5);
        ctx.fillStyle = rgba(south, 0.84);
        fillRectBleed(cx, cy, size * 0.5, size * 0.5);
      } else if (skin === 'orbit') {
        fillPoly([[x, y], [x2, y], [x2, y2], [x, y2]], mix(east, west, 0.50), 0.78);
        ctx.strokeStyle = rgba(north, 0.72);
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.ellipse(cx, cy, size * 0.34, size * 0.18, Math.PI * 0.25, 0, Math.PI * 2);
        ctx.stroke();
        ctx.strokeStyle = rgba(south, 0.62);
        ctx.beginPath();
        ctx.ellipse(cx, cy, size * 0.34, size * 0.18, -Math.PI * 0.25, 0, Math.PI * 2);
        ctx.stroke();
      } else if (skin === 'splitBands') {
        ctx.fillStyle = rgba(mix(north, west, 0.45), 0.86);
        fillRectBleed(x, y, size * 0.5, size);
        ctx.fillStyle = rgba(mix(south, east, 0.45), 0.86);
        fillRectBleed(cx, y, size * 0.5, size);
      } else if (skin === 'pinwheel') {
        fillPoly([[x, y], [x2, y], [cx, cy]], north, 0.84);
        fillPoly([[x2, y], [x2, y2], [cx, cy]], east, 0.74);
        fillPoly([[x2, y2], [x, y2], [cx, cy]], south, 0.84);
        fillPoly([[x, y2], [x, y], [cx, cy]], west, 0.74);
      } else if (skin === 'crosshatch') {
        fillPoly([[x, y], [x2, y], [x2, y2], [x, y2]], mix(north, south, 0.50), 0.82);
        fillPoly([[x, y], [x2, y], [x, y2]], east, 0.30);
        fillPoly([[x2, y], [x2, y2], [x, y2]], west, 0.30);
      } else if (skin === 'plusGlyph') {
        fillPoly([[x, y], [x2, y], [x2, y2], [x, y2]], mix(north, south, 0.50), 0.82);
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.72);
        fillRectBleed(cx - size * 0.11, y, size * 0.22, size);
        fillRectBleed(x, cy - size * 0.11, size, size * 0.22);
      } else if (skin === 'nestedBox') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.82);
        fillRectBleed(x, y, size, size);
        ctx.fillStyle = rgba(mix(east, west, 0.5), 0.60);
        fillRectBleed(x + size * 0.24, y + size * 0.24, size * 0.52, size * 0.52);
      } else if (skin === 'shards') {
        fillPoly([[x, y], [x2, y], [x, y2]], mix(north, west, 0.45), 0.84);
        fillPoly([[x2, y], [x2, y2], [x, y2]], mix(east, south, 0.45), 0.84);
        fillPoly([[x, y], [cx, cy], [x2, y]], north, 0.36);
        fillPoly([[x, y2], [cx, cy], [x2, y2]], south, 0.36);
