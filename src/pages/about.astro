---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="rain-sim" class="rain-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('rain-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 3;
    const DRAIN_START = 0.94;
    const RESET_LEVEL = 0.65;
    const DRAIN_RATE = 0.9992;
    const FLOW_PASSES = 8;
    const FLOW_RATE = 0.16;
    const FLOW_CAP = 0.42;
    const SURFACE_LAG = 0.11;
    const RAIN_RATE = 0.006;
    const RAIN_MAX_DROPS = 2.2;
    const GOLDEN_RATIO_STEP = 0.6180339887498949;
    // Wind drifts drops sideways and advects column color in the same
    // direction. COLOR_DIFFUSE is symmetric lateral mixing; COLOR_ADVECT
    // scales how much wind drags color from upwind columns each step.
    const WIND_MAX = 0.34;     // peak instantaneous wind
    const WIND_VAR_MAX = 0.20; // peak amplitude of in-cycle wind drift
    const COLOR_DIFFUSE = 0.06;
    const COLOR_ADVECT = 0.55;
    // Wind-driven traveling surface wave: spatial wavenumber and temporal
    // angular frequency, scaled by the current wind magnitude so calm
    // cycles stay flat and gusty ones ripple visibly.
    const WAVE_K = 0.10;
    const WAVE_OMEGA = 0.42;
    const WAVE_AMP = 0.18;
    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    function pickRainColors(palette: RGB[]): RGB[] {
      // Pick 4–5 stops spanning the palette so drops can carry visibly
      // distinct colors that still come from the same harmonious cycle
      // palette. Uses the bottom/mid/top luma bands so a downpour reads as
      // multicolored rather than tinted-monochrome.
      const count = 4 + ((Math.random() * 2) | 0); // 4 or 5
      const bands = [
        [1, 2],          // bottom (deep)
        [2, 3],          // lower-mid
        [3, 4, 5],       // mid
        [5, 6],          // upper-mid
        [6, 7],          // top (bright)
      ];
      const used = new Set<number>();
      const colors: RGB[] = [];
      const last = palette.length - 1;
      for (const band of bands) {
        if (colors.length >= count) break;
        const candidates = band.filter((i) => i <= last && !used.has(i));
        if (candidates.length === 0) continue;
        const idx = candidates[(Math.random() * candidates.length) | 0];
        used.add(idx);
        colors.push(mix(paper, palette[idx], 0.82));
      }
      // Top up if any band missed.
      for (let k = 1; k < palette.length && colors.length < count; k++) {
        if (used.has(k)) continue;
        used.add(k);
        colors.push(mix(paper, palette[k], 0.82));
      }
      return colors;
    }

    function pickWaterColor(palette: RGB[]): RGB {
      const idx = 2 + ((Math.random() * 3) | 0);
      return mix(paper, palette[Math.min(idx, palette.length - 1)], 0.62);
    }

    type Drop = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      shape: number;
      color: number;
    };
    // A short-lived spray ring at a drop's impact point. Two wings spread
    // outward from (x, y) over its lifetime — gives drops visual feedback
    // when they hit the surface.
    type Splash = {
      x: number;
      y: number;
      age: number;
      color: number;
      size: number;
    };
    const SPLASH_LIFE = 6;

    // Wind-driven mist particles: short-lived dots that drift downwind off
    // the water surface. Spawned proportional to wind magnitude.
    type Spray = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      age: number;
      color: number;
    };
    const SPRAY_LIFE = 28;
    const SPRAY_WIND_THRESHOLD = 0.10;

    let W = 0;
    let H = 0;
    let height = new Float32Array(0);
    let renderHeight = new Float32Array(0);
    let smoothHeight = new Float32Array(0);
    let flow = new Float32Array(0);
    // Per-column color is stored as extensive "color mass" (concentration ×
    // height); intensive RGB is recovered as colMass / height when rendering.
    // Storing it extensive lets the column-equalization pass move color in
    // proportion to the water it carries — same physics as the height flow.
    let colMassR = new Float32Array(0);
    let colMassG = new Float32Array(0);
    let colMassB = new Float32Array(0);
    let columnR = new Float32Array(0);
    let columnG = new Float32Array(0);
    let columnB = new Float32Array(0);
    // Snapshot + per-pass accumulators reused across equalization and the
    // separate diffuse/advect pass to avoid per-frame allocations.
    let scratchH = new Float32Array(0);
    let scratchR = new Float32Array(0);
    let scratchG = new Float32Array(0);
    let scratchB = new Float32Array(0);
    let flowH = new Float32Array(0);
    let flowR = new Float32Array(0);
    let flowG = new Float32Array(0);
    let flowB = new Float32Array(0);
    let drops: Drop[] = [];
    let splashes: Splash[] = [];
    let spray: Spray[] = [];
    // Lightning: integer count of remaining flash frames. Each step counts
    // down; a rare random trigger sets it to LIGHTNING_FRAMES.
    let lightningFrame = 0;
    const LIGHTNING_FRAMES = 5;
    const LIGHTNING_PROB = 0.0009;
    let lightningTint: RGB = [255, 255, 255];
    let img: ImageData | null = null;
    let waterPalette = buildPalette(pickStops());
    let waterColor = pickWaterColor(waterPalette);
    let rainColors = pickRainColors(waterPalette);
    let rainCarry = 0;
    let rainCursor = Math.random();
    let draining = false;
    let cycleWindBase = 0;
    let cycleWindAmp = 0;
    let cycleWindFreq = 0;
    let cycleWind = 0;
    let stepCount = 0;
    function rerollWind() {
      cycleWindBase = (Math.random() - 0.5) * 2 * WIND_MAX;
      cycleWindAmp = Math.random() * WIND_VAR_MAX;
      cycleWindFreq = 0.0015 + Math.random() * 0.004;
    }
    rerollWind();

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      height = new Float32Array(W);
      renderHeight = new Float32Array(W);
      smoothHeight = new Float32Array(W);
      flow = new Float32Array(W);
      colMassR = new Float32Array(W);
      colMassG = new Float32Array(W);
      colMassB = new Float32Array(W);
      columnR = new Float32Array(W);
      columnG = new Float32Array(W);
      columnB = new Float32Array(W);
      scratchH = new Float32Array(W);
      scratchR = new Float32Array(W);
      scratchG = new Float32Array(W);
      scratchB = new Float32Array(W);
      flowH = new Float32Array(W);
      flowR = new Float32Array(W);
      flowG = new Float32Array(W);
      flowB = new Float32Array(W);
      drops = [];
      img = ctx.createImageData(W, H);
      rainCarry = 0;
      rainCursor = Math.random();
      draining = false;
      waterPalette = buildPalette(pickStops());
      waterColor = pickWaterColor(waterPalette);
      rainColors = pickRainColors(waterPalette);
      rerollWind();
      stepCount = 0;
    }

    function surfaceY(x: number): number {
      const ix = ((((x | 0) % W) + W) % W);
      let sum = 0;
      for (let dx = -2; dx <= 2; dx++) {
        const j = ((ix + dx) % W + W) % W;
        sum += height[j];
      }
      return H - 1 - sum / 5;
    }

    function splash(x: number, amount: number, dropColor: RGB) {
      const mid = ((((x | 0) % W) + W) % W);
      for (let dx = -5; dx <= 5; dx++) {
        const ix = ((mid + dx) % W + W) % W;
        const falloff = Math.max(0, 1 - Math.abs(dx) / 5.8);
        const deposit = amount * falloff;
        height[ix] = Math.min(H - 2, height[ix] + deposit);
        colMassR[ix] += dropColor[0] * deposit;
        colMassG[ix] += dropColor[1] * deposit;
        colMassB[ix] += dropColor[2] * deposit;
      }
    }

    function spawnDrop() {
      rainCursor = (rainCursor + GOLDEN_RATIO_STEP) % 1;
      const x = Math.max(0, Math.min(W - 1, rainCursor * W + (Math.random() - 0.5) * 5));
      // Weight roll: 4% chance of a fat drop (size 3, ~2× splash mass and
      // a bigger spray on impact); 16% chance of medium (size 2); rest size 1.
      const roll = Math.random();
      const size = roll < 0.04 ? 3 : roll < 0.20 ? 2 : 1;
      drops.push({
        x,
        y: -2 - Math.random() * Math.min(48, H * 0.18),
        vx: cycleWind + (Math.random() - 0.5) * 0.04,
        vy: 0.1 + Math.random() * 0.18 + (size === 3 ? 0.05 : 0),
        size,
        shape: (Math.random() * 4) | 0,
        color: (Math.random() * rainColors.length) | 0,
      });
    }

    function addRain(rate: number) {
      rainCarry = Math.min(rainCarry + W * rate, W * rate * 2);
      const room = Math.max(0, Math.floor(W * RAIN_MAX_DROPS - drops.length));
      if (room <= 0) {
        rainCarry = Math.min(rainCarry, 0.99);
        return;
      }
      const count = Math.min(room, Math.floor(rainCarry));
      rainCarry -= count;
      for (let k = 0; k < count; k++) spawnDrop();
    }

    function equalizeColumns() {
      // Adjacent columns exchange water volume; repeated capped passes level the
      // pool without introducing springy surface oscillation. Color mass moves
      // with the water it rides — extracting that fraction of the *sender's*
      // color so equalizing levels naturally mixes their tints together.
      for (let pass = 0; pass < FLOW_PASSES; pass++) {
        scratchH.set(height);
        scratchR.set(colMassR);
        scratchG.set(colMassG);
        scratchB.set(colMassB);
        flowH.fill(0);
        flowR.fill(0);
        flowG.fill(0);
        flowB.fill(0);
        for (let x = 0; x < W; x++) {
          const nx = (x + 1) % W; // torus wraparound
          const diff = scratchH[x] - scratchH[nx];
          const transfer = Math.max(-FLOW_CAP, Math.min(FLOW_CAP, diff * FLOW_RATE));
          flowH[x] -= transfer;
          flowH[nx] += transfer;
          if (transfer > 0 && scratchH[x] > 1e-6) {
            const f = transfer / scratchH[x];
            const dR = scratchR[x] * f;
            const dG = scratchG[x] * f;
            const dB = scratchB[x] * f;
            flowR[x] -= dR; flowR[nx] += dR;
            flowG[x] -= dG; flowG[nx] += dG;
            flowB[x] -= dB; flowB[nx] += dB;
          } else if (transfer < 0 && scratchH[nx] > 1e-6) {
            const f = -transfer / scratchH[nx];
            const dR = scratchR[nx] * f;
            const dG = scratchG[nx] * f;
            const dB = scratchB[nx] * f;
            flowR[nx] -= dR; flowR[x] += dR;
            flowG[nx] -= dG; flowG[x] += dG;
            flowB[nx] -= dB; flowB[x] += dB;
          }
        }
        for (let x = 0; x < W; x++) {
          height[x] = Math.max(0, Math.min(H - 2, height[x] + flowH[x]));
          colMassR[x] = Math.max(0, colMassR[x] + flowR[x]);
          colMassG[x] = Math.max(0, colMassG[x] + flowG[x]);
          colMassB[x] = Math.max(0, colMassB[x] + flowB[x]);
        }
      }
    }

    function diffuseAndAdvectColor() {
      // Symmetric lateral diffusion gently blends neighboring columns even
      // when their water levels match (which is most of the time in the
      // settled pool, where equalizeColumns transfers nothing). Wind biases
      // the diffusion so color visibly drifts in the wind direction.
      scratchR.set(colMassR);
      scratchG.set(colMassG);
      scratchB.set(colMassB);
      const advect = cycleWind * COLOR_ADVECT;
      const advT = Math.min(0.35, Math.abs(advect));
      const advDir = advect > 0 ? -1 : advect < 0 ? 1 : 0;
      for (let x = 0; x < W; x++) {
        const left = (x - 1 + W) % W;  // torus wraparound
        const right = (x + 1) % W;
        let dR = COLOR_DIFFUSE * (scratchR[left] + scratchR[right] - 2 * scratchR[x]);
        let dG = COLOR_DIFFUSE * (scratchG[left] + scratchG[right] - 2 * scratchG[x]);
        let dB = COLOR_DIFFUSE * (scratchB[left] + scratchB[right] - 2 * scratchB[x]);
        if (advDir !== 0) {
          const upX = advDir < 0 ? right : left;
          dR += advT * (scratchR[upX] - scratchR[x]);
          dG += advT * (scratchG[upX] - scratchG[x]);
          dB += advT * (scratchB[upX] - scratchB[x]);
        }
        colMassR[x] = Math.max(0, scratchR[x] + dR);
        colMassG[x] = Math.max(0, scratchG[x] + dG);
        colMassB[x] = Math.max(0, scratchB[x] + dB);
      }
    }

    function smoothVisibleSurface() {
      for (let x = 0; x < W; x++) {
        const a = height[(x - 2 + W) % W];
        const b = height[(x - 1 + W) % W];
        const c = height[x];
        const d = height[(x + 1) % W];
        const e = height[(x + 2) % W];
        smoothHeight[x] = (a + b * 2 + c * 3 + d * 2 + e) / 9;
      }
      for (let x = 0; x < W; x++) {
        renderHeight[x] += (smoothHeight[x] - renderHeight[x]) * SURFACE_LAG;
      }
    }

    function step() {
      // Slowly modulate wind within the cycle so it isn't a fixed force.
      cycleWind = cycleWindBase + cycleWindAmp * Math.sin(stepCount * cycleWindFreq);
      stepCount++;

      // Storm tempo: rain rate ramps up early in the cycle, peaks midway,
      // tapers off as the pool fills. Reads as a single rainstorm with
      // structure rather than a constant downpour.
      let preTotal = 0;
      for (let x = 0; x < W; x++) preTotal += height[x];
      const fillFrac = preTotal / (W * H);
      let stormScale = 1;
      if (!draining) {
        const t = Math.min(1, fillFrac / DRAIN_START);
        stormScale = Math.max(0.25, 4 * t * (1 - t) + 0.18);
      } else {
        stormScale = 0.35;
      }
      addRain(RAIN_RATE * stormScale);

      for (let i = drops.length - 1; i >= 0; i--) {
        const d = drops[i];
        d.vy += 0.0035;
        d.x += d.vx;
        d.y += d.vy;
        // Horizontal torus: drops carried off one side reappear on the other.
        if (d.x < 0) d.x += W;
        else if (d.x >= W) d.x -= W;
        if (d.y >= surfaceY(d.x)) {
          // Fat drops deposit ~2× the mass and spawn a couple of extra
          // surface spray particles on top of the regular splash.
          const baseMass = 0.72 + Math.random() * 0.46;
          const mass = d.size === 3 ? baseMass * 2 : baseMass;
          splash(d.x, mass, rainColors[d.color]);
          splashes.push({
            x: Math.round(d.x),
            y: Math.round(surfaceY(d.x)),
            age: 0,
            color: d.color,
            size: d.size,
          });
          if (d.size === 3) {
            for (let k = 0; k < 4; k++) {
              spray.push({
                x: d.x,
                y: surfaceY(d.x) - 1,
                vx: (Math.random() - 0.5) * 1.0 + cycleWind * 1.2,
                vy: -0.4 - Math.random() * 0.4,
                age: 0,
                color: d.color,
              });
            }
          }
          drops.splice(i, 1);
        } else if (d.y > H + 4) {
          drops.splice(i, 1);
        }
      }

      // Age splashes; drop dead ones.
      for (let i = splashes.length - 1; i >= 0; i--) {
        splashes[i].age++;
        if (splashes[i].age >= SPLASH_LIFE) splashes.splice(i, 1);
      }

      // Wind spray: spawn drifting mist particles when the wind is strong.
      // Spawn count grows linearly with |wind| beyond a small threshold.
      const sprayWind = Math.abs(cycleWind);
      if (sprayWind > SPRAY_WIND_THRESHOLD) {
        const spawnRate = (sprayWind - SPRAY_WIND_THRESHOLD) * 0.55 * W * 0.04;
        let budget = spawnRate;
        while (budget > 0 && spray.length < W) {
          if (Math.random() >= Math.min(1, budget)) break;
          budget -= 1;
          const sx = Math.random() * W;
          const sy = surfaceY(sx) - 1;
          if (sy < 0) continue;
          spray.push({
            x: sx,
            y: sy,
            vx: cycleWind * (1.5 + Math.random() * 0.8),
            vy: -0.1 - Math.random() * 0.3,
            age: 0,
            color: (Math.random() * rainColors.length) | 0,
          });
        }
      }
      for (let i = spray.length - 1; i >= 0; i--) {
        const s = spray[i];
        s.x += s.vx;
        s.y += s.vy;
        s.vy += 0.012;
        if (s.x < 0) s.x += W;
        else if (s.x >= W) s.x -= W;
        s.age++;
        if (s.age >= SPRAY_LIFE || s.y > H) spray.splice(i, 1);
      }

      // Lightning: rare bright flash. Trigger on a low probability per step,
      // counts down each frame to fade. Tint pulled from the brightest
      // palette stop so it matches the cycle.
      if (lightningFrame > 0) {
        lightningFrame--;
      } else if (Math.random() < LIGHTNING_PROB) {
        lightningFrame = LIGHTNING_FRAMES;
        const top = waterPalette[Math.min(N - 1, waterPalette.length - 1)];
        lightningTint = mix(paper, top, 0.95);
      }

      equalizeColumns();
      diffuseAndAdvectColor();
      // Wind drives a small traveling sinusoidal ripple along the surface.
      // Multiplied by a smooth ramp on existing height so empty columns stay
      // empty (the previous additive form was clamped at 0, which let the
      // positive half of each sin cycle accumulate water from nothing).
      const windMag = Math.abs(cycleWind);
      if (windMag > 0.04) {
        const phase = stepCount * WAVE_OMEGA;
        const dir = cycleWind >= 0 ? 1 : -1;
        const amp = WAVE_AMP * windMag;
        for (let x = 0; x < W; x++) {
          // Tanh-like ramp keyed on existing height so the wave amplitude
          // grows smoothly with the water depth and is exactly 0 in dry
          // columns. WAVE_RAMP_DEPTH controls the cross-over point.
          const ramp = height[x] <= 0
            ? 0
            : 1 - 1 / (1 + height[x] * 0.4);
          if (ramp <= 0) continue;
          const v = amp * ramp * Math.sin(x * WAVE_K - phase * dir);
          height[x] = Math.max(0, Math.min(H - 2, height[x] + v));
        }
      }

      let total = 0;
      for (let x = 0; x < W; x++) {
        if (draining) {
          height[x] *= DRAIN_RATE;
          colMassR[x] *= DRAIN_RATE;
          colMassG[x] *= DRAIN_RATE;
          colMassB[x] *= DRAIN_RATE;
        }
        total += height[x];
      }
      smoothVisibleSurface();

      const avg = total / W;
      if (!draining && avg > H * DRAIN_START) draining = true;
      if (draining && avg < RESET_LEVEL) {
        draining = false;
        drops = [];
        splashes = [];
        spray = [];
        lightningFrame = 0;
        height.fill(0);
        renderHeight.fill(0);
        smoothHeight.fill(0);
        flow.fill(0);
        colMassR.fill(0);
        colMassG.fill(0);
        colMassB.fill(0);
        waterPalette = buildPalette(pickStops());
        waterColor = pickWaterColor(waterPalette);
        rainColors = pickRainColors(waterPalette);
        rerollWind();
        stepCount = 0;
      }
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      // Resolve each column's intensive RGB once, then fill the column. Use
      // the actual sim height for the concentration ratio (rendered surface
      // is lagged via renderHeight, but the color is column-stable either
      // way so the lag doesn't bleed wrong concentrations).
      for (let x = 0; x < W; x++) {
        const h = height[x];
        if (h > 1e-6) {
          const inv = 1 / h;
          let r = colMassR[x] * inv;
          let g = colMassG[x] * inv;
          let b = colMassB[x] * inv;
          if (r > 255) r = 255;
          if (g > 255) g = 255;
          if (b > 255) b = 255;
          columnR[x] = r;
          columnG[x] = g;
          columnB[x] = b;
        } else {
          columnR[x] = waterColor[0];
          columnG[x] = waterColor[1];
          columnB[x] = waterColor[2];
        }
      }
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const depth = renderHeight[x] - (H - 1 - y);
          const j = (y * W + x) * 4;
          if (depth > 0) {
            // Top of water is full saturation; deeper columns fade toward
            // paper so the pool reads with a sense of depth instead of a
            // flat horizontal stripe. The first water row (depth < 1) is
            // the visible surface — we add a small specular highlight there
            // so the pool reads as wet rather than as a solid block.
            const surface = renderHeight[x];
            const submerged = surface > 0 ? depth / surface : 0;
            const shade = 1 - submerged * 0.45;
            const isSurface = depth < 1;
            const lift = isSurface ? 1.18 : 1;
            const r = columnR[x] * shade + paper[0] * (1 - shade);
            const g = columnG[x] * shade + paper[1] * (1 - shade);
            const b = columnB[x] * shade + paper[2] * (1 - shade);
            data[j]     = Math.min(255, r * lift);
            data[j + 1] = Math.min(255, g * lift);
            data[j + 2] = Math.min(255, b * lift);
          } else {
            data[j] = paper[0];
            data[j + 1] = paper[1];
            data[j + 2] = paper[2];
          }
          data[j + 3] = 255;
        }
      }

      function paintDropPixel(x: number, y: number, c: RGB) {
        if (y < 0 || y >= H) return;
        const wx = ((x % W) + W) % W; // horizontal torus
        const j = (y * W + wx) * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }

      // Bresenham line so the drop's tail is a connected stroke from its
      // previous to current rounded position — eliminates the jitter caused
      // by independently rounding several trail samples per frame.
      function paintDropLine(x0: number, y0: number, x1: number, y1: number, c: RGB) {
        let x = x0;
        let y = y0;
        const dx = Math.abs(x1 - x0);
        const dy = Math.abs(y1 - y0);
        const sx = x0 < x1 ? 1 : -1;
        const sy = y0 < y1 ? 1 : -1;
        let err = dx - dy;
        for (let i = 0; i < dx + dy + 1; i++) {
          paintDropPixel(x, y, c);
          if (x === x1 && y === y1) break;
          const e2 = err * 2;
          if (e2 > -dy) { err -= dy; x += sx; }
          if (e2 < dx)  { err += dx;  y += sy; }
        }
      }

      // Splash spray: two wings spread outward from each impact point and
      // fade over SPLASH_LIFE frames. Bigger drops get extra plume / wings.
      for (const s of splashes) {
        const r = s.age + 1;
        const fade = 1 - s.age / SPLASH_LIFE;
        const c = rainColors[s.color];
        const tint = mix(paper, c, 0.85 * fade);
        paintDropPixel(s.x - r, s.y - 1, tint);
        paintDropPixel(s.x + r, s.y - 1, tint);
        if (s.size > 1 && s.age < 3) {
          paintDropPixel(s.x, s.y - 2 - s.age, mix(paper, c, 0.65 * fade));
        }
        // Fat drops: a wider, brighter ring of wings.
        if (s.size === 3) {
          const r2 = Math.floor(r * 1.8);
          paintDropPixel(s.x - r2, s.y - 2, mix(paper, c, 0.7 * fade));
          paintDropPixel(s.x + r2, s.y - 2, mix(paper, c, 0.7 * fade));
        }
      }

      // Wind spray particles. Fade as they age; slightly varied tints from
      // the cycle's drop palette.
      for (const s of spray) {
        const fade = 1 - s.age / SPRAY_LIFE;
        if (fade <= 0) continue;
        const c = rainColors[s.color];
        paintDropPixel(Math.round(s.x), Math.round(s.y), mix(paper, c, 0.45 * fade));
      }

      for (const d of drops) {
        const c = rainColors[d.color];
        const headTint = mix(paper, c, 0.92);
        const trailTint = mix(paper, c, 0.55);
        const x0 = Math.round(d.x);
        const y0 = Math.round(d.y);
        // Trail length scaled to the drop's own velocity — fast wind makes
        // longer streaks, calm drops stay tight teardrops.
        const trailScale = d.size > 1 ? 2.4 : d.size === 3 ? 3.0 : 1.8;
        const x1 = Math.round(d.x - d.vx * trailScale);
        const y1 = Math.round(d.y - d.vy * trailScale);
        paintDropLine(x0, y0, x1, y1, trailTint);
        // Bright head over the connected trail.
        paintDropPixel(x0, y0, headTint);
        if (d.size > 1) {
          paintDropPixel(x0, y0 - 1, mix(paper, c, 0.65));
        }
        if (d.size === 3) {
          paintDropPixel(x0, y0 - 2, mix(paper, c, 0.5));
          paintDropPixel(x0 + (cycleWind > 0 ? -1 : 1), y0 - 1, mix(paper, c, 0.55));
        }
      }

      // Lightning: full-frame additive flash that fades over LIGHTNING_FRAMES.
      if (lightningFrame > 0) {
        const k = lightningFrame / LIGHTNING_FRAMES;
        const addR = lightningTint[0] * 0.55 * k;
        const addG = lightningTint[1] * 0.55 * k;
        const addB = lightningTint[2] * 0.55 * k;
        for (let i = 0; i < data.length; i += 4) {
          data[i]     = Math.min(255, data[i]     + addR);
          data[i + 1] = Math.min(255, data[i + 1] + addG);
          data[i + 2] = Math.min(255, data[i + 2] + addB);
        }
      }

      ctx.putImageData(img, 0, 0);
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 260; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
  }
</script>
