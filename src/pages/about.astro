---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="memory-net" class="memory-net" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('memory-net') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 4;
    const TAU = Math.PI * 2;
    const ACTIVITY_DECAY = 0.88;
    const EDGE_DECAY = 0.90;
    const REFRACTORY_FRAMES = 46;
    const AUTO_SEED_MIN = 90;
    const AUTO_SEED_RANGE = 90;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];
    type Node = {
      x: number;
      y: number;
      phase: number;
      drift: number;
      activity: number;
      flash: number;
      refractory: number;
      color: RGB;
      edges: number[];
    };
    type Edge = {
      a: number;
      b: number;
      weight: number;
      trail: number;
      color: RGB;
    };
    type Pulse = {
      edge: number;
      from: number;
      to: number;
      t: number;
      speed: number;
      strength: number;
      color: RGB;
    };

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    function rgba(c: RGB, a: number): string {
      return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${Math.max(0, Math.min(1, a))})`;
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let nodes: Node[] = [];
    let edges: Edge[] = [];
    let pulses: Pulse[] = [];
    let cycleStops: RGB[] = [];
    let stepCount = 0;
    let nextSeedAt = 0;
    let pointerX = -1;
    let pointerY = -1;

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function syncAccent(stops: RGB[]) {
      const root = document.documentElement;
      for (let i = 0; i < stops.length; i++) root.style.setProperty(`--c${i + 1}`, rgb(stops[i]));
      root.style.setProperty('--accent', rgb(stops[Math.min(stops.length - 1, 4)]));
    }

    function resetSeedTimer() {
      nextSeedAt = stepCount + AUTO_SEED_MIN + ((Math.random() * AUTO_SEED_RANGE) | 0);
    }

    function edgeKey(a: number, b: number): string {
      return a < b ? `${a}:${b}` : `${b}:${a}`;
    }

    function addEdge(a: number, b: number, seen: Set<string>) {
      if (a === b) return;
      const key = edgeKey(a, b);
      if (seen.has(key)) return;
      seen.add(key);
      const na = nodes[a];
      const nb = nodes[b];
      const dx = na.x - nb.x;
      const dy = na.y - nb.y;
      const d = Math.sqrt(dx * dx + dy * dy);
      const closeness = Math.max(0, 1 - d / Math.max(W, H));
      const color = mix(paper, cycleStops[(a + b) % cycleStops.length], 0.55 + closeness * 0.30);
      const idx = edges.length;
      edges.push({
        a,
        b,
        weight: 0.44 + closeness * 0.42 + Math.random() * 0.22,
        trail: 0,
        color,
      });
      na.edges.push(idx);
      nb.edges.push(idx);
    }

    function buildNetwork() {
      nodes = [];
      edges = [];
      pulses = [];
      const area = W * H;
      const count = Math.max(56, Math.min(150, Math.round(area / 760)));
      const marginX = Math.max(6, W * 0.04);
      const marginY = Math.max(6, H * 0.06);
      for (let i = 0; i < count; i++) {
        const band = i / Math.max(1, count - 1);
        const x = marginX + Math.random() * Math.max(1, W - marginX * 2);
        const y = marginY + Math.random() * Math.max(1, H - marginY * 2);
        nodes.push({
          x,
          y,
          phase: Math.random() * TAU,
          drift: 0.004 + Math.random() * 0.008,
          activity: 0,
          flash: 0,
          refractory: 0,
          color: mix(paper, cycleStops[Math.min(cycleStops.length - 1, 1 + Math.floor(band * (cycleStops.length - 1)))], 0.82),
          edges: [],
        });
      }

      const seen = new Set<string>();
      for (let i = 0; i < nodes.length; i++) {
        const distances: Array<{ j: number; d: number }> = [];
        for (let j = 0; j < nodes.length; j++) {
          if (i === j) continue;
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          distances.push({ j, d: dx * dx + dy * dy });
        }
        distances.sort((a, b) => a.d - b.d);
        const localCount = 2 + ((Math.random() * 2) | 0);
        for (let k = 0; k < Math.min(localCount, distances.length); k++) addEdge(i, distances[k].j, seen);
        if (Math.random() < 0.18 && distances.length > 8) {
          const start = Math.min(distances.length - 1, 8 + ((Math.random() * 18) | 0));
          addEdge(i, distances[start].j, seen);
        }
      }
    }

    function rerollNetwork() {
      cycleStops = pickStops();
      syncAccent(cycleStops);
      buildNetwork();
      for (let i = 0; i < Math.min(8, nodes.length); i++) {
        const n = nodes[(Math.random() * nodes.length) | 0];
        n.activity = Math.random() * 0.25;
      }
      stepCount = 0;
      resetSeedTimer();
    }

    function nearestNode(x: number, y: number): number {
      let best = 0;
      let bestD = Infinity;
      for (let i = 0; i < nodes.length; i++) {
        const dx = nodes[i].x - x;
        const dy = nodes[i].y - y;
        const d = dx * dx + dy * dy;
        if (d < bestD) {
          bestD = d;
          best = i;
        }
      }
      return best;
    }

    function fireNode(idx: number, color: RGB, strength: number) {
      const node = nodes[idx];
      node.activity = Math.max(node.activity, strength);
      node.flash = 1;
      node.refractory = REFRACTORY_FRAMES + ((Math.random() * 18) | 0);
      node.color = mix(node.color, color, 0.65);
      const fanout = node.edges.slice().sort(() => Math.random() - 0.5);
      const keep = Math.max(2, Math.min(fanout.length, 3 + ((Math.random() * 3) | 0)));
      for (let k = 0; k < keep; k++) {
        const edgeIdx = fanout[k];
        const edge = edges[edgeIdx];
        const to = edge.a === idx ? edge.b : edge.a;
        edge.trail = Math.max(edge.trail, strength * edge.weight);
        edge.color = mix(edge.color, color, 0.38);
        pulses.push({
          edge: edgeIdx,
          from: idx,
          to,
          t: 0,
          speed: 0.045 + Math.random() * 0.035,
          strength: strength * edge.weight * (0.70 + Math.random() * 0.25),
          color,
        });
      }
      if (pulses.length > 360) pulses.splice(0, pulses.length - 360);
    }

    function seedAt(x: number, y: number, strong = false) {
      if (nodes.length === 0) return;
      const idx = nearestNode(x, y);
      const c = mix(paper, cycleStops[2 + ((Math.random() * Math.max(1, cycleStops.length - 3)) | 0)], 0.96);
      fireNode(idx, c, strong ? 1.25 : 0.95);
      const n = nodes[idx];
      for (const edgeIdx of n.edges) {
        const edge = edges[edgeIdx];
        edge.trail = Math.max(edge.trail, strong ? 0.95 : 0.65);
      }
    }

    function autoSeed() {
      const usePointer = pointerX >= 0 && Math.random() < 0.82;
      const x = usePointer ? pointerX : Math.random() * W;
      const y = usePointer ? pointerY : Math.random() * H;
      seedAt(x, y);
      resetSeedTimer();
    }

    function step() {
      stepCount++;
      if (stepCount > 2400) rerollNetwork();
      if (stepCount >= nextSeedAt) autoSeed();

      for (const node of nodes) {
        node.activity *= ACTIVITY_DECAY;
        node.flash *= 0.78;
        if (node.refractory > 0) node.refractory--;
      }
      for (const edge of edges) edge.trail *= EDGE_DECAY;

      for (let i = pulses.length - 1; i >= 0; i--) {
        const pulse = pulses[i];
        pulse.t += pulse.speed;
        const edge = edges[pulse.edge];
        edge.trail = Math.max(edge.trail, pulse.strength * (1 - Math.abs(pulse.t - 0.5) * 0.7));
        if (pulse.t >= 1) {
          const target = nodes[pulse.to];
          target.activity += pulse.strength * 0.55;
          target.color = mix(target.color, pulse.color, 0.28);
          if (target.refractory <= 0 && target.activity > 0.52) {
            fireNode(pulse.to, pulse.color, Math.min(1.05, target.activity));
          }
          pulses.splice(i, 1);
        }
      }
    }

    function nodeX(node: Node): number {
      return node.x + Math.sin(stepCount * node.drift + node.phase) * 0.55;
    }

    function nodeY(node: Node): number {
      return node.y + Math.cos(stepCount * node.drift * 0.83 + node.phase * 1.7) * 0.55;
    }

    function drawLine(ax: number, ay: number, bx: number, by: number, color: RGB, alpha: number, width: number) {
      ctx.strokeStyle = rgba(color, alpha);
      ctx.lineWidth = width;
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(bx, by);
      ctx.stroke();
    }

    function draw() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      ctx.lineCap = 'square';

      for (const edge of edges) {
        const a = nodes[edge.a];
        const b = nodes[edge.b];
        const ax = nodeX(a);
        const ay = nodeY(a);
        const bx = nodeX(b);
        const by = nodeY(b);
        drawLine(ax, ay, bx, by, edge.color, 0.10, 1);
        if (edge.trail > 0.02) {
          drawLine(ax, ay, bx, by, edge.color, Math.min(0.62, edge.trail * 0.42), edge.trail > 0.65 ? 2 : 1);
        }
      }

      for (const pulse of pulses) {
        const edge = edges[pulse.edge];
        const a = nodes[pulse.from];
        const b = nodes[pulse.to];
        const ax = nodeX(a);
        const ay = nodeY(a);
        const bx = nodeX(b);
        const by = nodeY(b);
        const x = ax + (bx - ax) * pulse.t;
        const y = ay + (by - ay) * pulse.t;
        const tailT = Math.max(0, pulse.t - 0.10);
        drawLine(
          ax + (bx - ax) * tailT,
          ay + (by - ay) * tailT,
          x,
          y,
          pulse.color,
          Math.min(0.72, pulse.strength * 0.62),
          2,
        );
        ctx.fillStyle = rgba(pulse.color, Math.min(0.95, pulse.strength));
        ctx.fillRect(Math.round(x) - 1, Math.round(y) - 1, 3, 3);
      }

      for (const node of nodes) {
        const a = Math.min(1, node.activity + node.flash);
        const x = Math.round(nodeX(node));
        const y = Math.round(nodeY(node));
        const refractoryGlow = node.refractory > 0 ? 0.16 : 0.08;
        ctx.fillStyle = rgba(node.color, refractoryGlow + a * 0.70);
        const size = a > 0.55 ? 4 : a > 0.16 ? 3 : 2;
        ctx.fillRect(x - (size >> 1), y - (size >> 1), size, size);
        if (a > 0.55) {
          ctx.fillStyle = rgba(mix(node.color, cycleStops[cycleStops.length - 1], 0.45), 0.45);
          ctx.fillRect(x - 2, y, 5, 1);
          ctx.fillRect(x, y - 2, 1, 5);
        }
      }
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      rerollNetwork();
    }

    function setPointerFromEvent(e: PointerEvent) {
      const rect = canvas.getBoundingClientRect();
      pointerX = ((e.clientX - rect.left) / rect.width) * W;
      pointerY = ((e.clientY - rect.top) / rect.height) * H;
    }

    resize();
    if (reduce) {
      seedAt(W * 0.5, H * 0.5, true);
      for (let i = 0; i < 120; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 33;
      const loop = (now: number) => {
        if (now - last >= targetMs) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    window.addEventListener('pointermove', setPointerFromEvent);
    window.addEventListener('pointerdown', (e) => {
      setPointerFromEvent(e);
      seedAt(pointerX, pointerY, true);
      resetSeedTimer();
    });
    window.addEventListener('pointerleave', () => { pointerX = -1; pointerY = -1; });
    window.addEventListener('pointerout', (e) => {
      if (!e.relatedTarget) { pointerX = -1; pointerY = -1; }
    });
  }
</script>
