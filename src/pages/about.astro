---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="rain-sim" class="rain-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('rain-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 3;
    const DRAIN_START = 0.94;
    const RESET_LEVEL = 0.65;
    const DRAIN_RATE = 0.9992;
    const FLOW_PASSES = 8;
    const FLOW_RATE = 0.16;
    const FLOW_CAP = 0.42;
    const SURFACE_LAG = 0.11;
    const RAIN_RATE = 0.006;
    const RAIN_MAX_DROPS = 2.2;
    const GOLDEN_RATIO_STEP = 0.6180339887498949;
    // Wind drifts drops sideways and advects column color in the same
    // direction. COLOR_DIFFUSE is symmetric lateral mixing; COLOR_ADVECT
    // scales how much wind drags color from upwind columns each step.
    const WIND_MAX = 0.22;
    const COLOR_DIFFUSE = 0.06;
    const COLOR_ADVECT = 0.55;
    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    function pickRainColors(palette: RGB[]): RGB[] {
      const count = Math.random() < 0.5 ? 2 : 3;
      const colors: RGB[] = [];
      const picked = new Set<number>();
      const first = 2;
      const last = Math.min(palette.length - 1, 5);
      while (colors.length < count) {
        const idx = first + ((Math.random() * (last - first + 1)) | 0);
        if (picked.has(idx)) continue;
        picked.add(idx);
        colors.push(mix(paper, palette[idx], 0.72));
      }
      return colors;
    }

    function pickWaterColor(palette: RGB[]): RGB {
      const idx = 1 + ((Math.random() * 2) | 0);
      return mix(paper, palette[Math.min(idx, palette.length - 1)], 0.48);
    }

    type Drop = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      shape: number;
      color: number;
    };

    let W = 0;
    let H = 0;
    let height = new Float32Array(0);
    let renderHeight = new Float32Array(0);
    let smoothHeight = new Float32Array(0);
    let flow = new Float32Array(0);
    // Per-column color is stored as extensive "color mass" (concentration ×
    // height); intensive RGB is recovered as colMass / height when rendering.
    // Storing it extensive lets the column-equalization pass move color in
    // proportion to the water it carries — same physics as the height flow.
    let colMassR = new Float32Array(0);
    let colMassG = new Float32Array(0);
    let colMassB = new Float32Array(0);
    let columnR = new Float32Array(0);
    let columnG = new Float32Array(0);
    let columnB = new Float32Array(0);
    // Snapshot + per-pass accumulators reused across equalization and the
    // separate diffuse/advect pass to avoid per-frame allocations.
    let scratchH = new Float32Array(0);
    let scratchR = new Float32Array(0);
    let scratchG = new Float32Array(0);
    let scratchB = new Float32Array(0);
    let flowH = new Float32Array(0);
    let flowR = new Float32Array(0);
    let flowG = new Float32Array(0);
    let flowB = new Float32Array(0);
    let drops: Drop[] = [];
    let img: ImageData | null = null;
    let waterPalette = buildPalette(pickStops());
    let waterColor = pickWaterColor(waterPalette);
    let rainColors = pickRainColors(waterPalette);
    let rainCarry = 0;
    let rainCursor = Math.random();
    let draining = false;
    let cycleWind = (Math.random() - 0.5) * 2 * WIND_MAX;

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      height = new Float32Array(W);
      renderHeight = new Float32Array(W);
      smoothHeight = new Float32Array(W);
      flow = new Float32Array(W);
      colMassR = new Float32Array(W);
      colMassG = new Float32Array(W);
      colMassB = new Float32Array(W);
      columnR = new Float32Array(W);
      columnG = new Float32Array(W);
      columnB = new Float32Array(W);
      scratchH = new Float32Array(W);
      scratchR = new Float32Array(W);
      scratchG = new Float32Array(W);
      scratchB = new Float32Array(W);
      flowH = new Float32Array(W);
      flowR = new Float32Array(W);
      flowG = new Float32Array(W);
      flowB = new Float32Array(W);
      drops = [];
      img = ctx.createImageData(W, H);
      rainCarry = 0;
      rainCursor = Math.random();
      draining = false;
      waterPalette = buildPalette(pickStops());
      waterColor = pickWaterColor(waterPalette);
      rainColors = pickRainColors(waterPalette);
      cycleWind = (Math.random() - 0.5) * 2 * WIND_MAX;
    }

    function surfaceY(x: number): number {
      const ix = Math.max(0, Math.min(W - 1, x | 0));
      let sum = 0;
      let count = 0;
      for (let dx = -2; dx <= 2; dx++) {
        const j = ix + dx;
        if (j < 0 || j >= W) continue;
        sum += height[j];
        count++;
      }
      return H - 1 - sum / count;
    }

    function splash(x: number, amount: number, dropColor: RGB) {
      const mid = Math.max(0, Math.min(W - 1, x | 0));
      for (let dx = -5; dx <= 5; dx++) {
        const ix = mid + dx;
        if (ix < 0 || ix >= W) continue;
        const falloff = Math.max(0, 1 - Math.abs(dx) / 5.8);
        const deposit = amount * falloff;
        height[ix] = Math.min(H - 2, height[ix] + deposit);
        // Add color in proportion to deposited mass — RGB · volume.
        colMassR[ix] += dropColor[0] * deposit;
        colMassG[ix] += dropColor[1] * deposit;
        colMassB[ix] += dropColor[2] * deposit;
      }
    }

    function spawnDrop() {
      rainCursor = (rainCursor + GOLDEN_RATIO_STEP) % 1;
      const x = Math.max(0, Math.min(W - 1, rainCursor * W + (Math.random() - 0.5) * 5));
      drops.push({
        x,
        y: -2 - Math.random() * Math.min(48, H * 0.18),
        vx: cycleWind + (Math.random() - 0.5) * 0.04,
        vy: 0.1 + Math.random() * 0.18,
        size: Math.random() < 0.16 ? 2 : 1,
        shape: (Math.random() * 4) | 0,
        color: (Math.random() * rainColors.length) | 0,
      });
    }

    function addRain() {
      rainCarry = Math.min(rainCarry + W * RAIN_RATE, W * RAIN_RATE * 2);
      const room = Math.max(0, Math.floor(W * RAIN_MAX_DROPS - drops.length));
      if (room <= 0) {
        rainCarry = Math.min(rainCarry, 0.99);
        return;
      }
      const count = Math.min(room, Math.floor(rainCarry));
      rainCarry -= count;
      for (let k = 0; k < count; k++) spawnDrop();
    }

    function equalizeColumns() {
      // Adjacent columns exchange water volume; repeated capped passes level the
      // pool without introducing springy surface oscillation. Color mass moves
      // with the water it rides — extracting that fraction of the *sender's*
      // color so equalizing levels naturally mixes their tints together.
      for (let pass = 0; pass < FLOW_PASSES; pass++) {
        scratchH.set(height);
        scratchR.set(colMassR);
        scratchG.set(colMassG);
        scratchB.set(colMassB);
        flowH.fill(0);
        flowR.fill(0);
        flowG.fill(0);
        flowB.fill(0);
        for (let x = 0; x < W - 1; x++) {
          const diff = scratchH[x] - scratchH[x + 1];
          const transfer = Math.max(-FLOW_CAP, Math.min(FLOW_CAP, diff * FLOW_RATE));
          flowH[x] -= transfer;
          flowH[x + 1] += transfer;
          if (transfer > 0 && scratchH[x] > 1e-6) {
            const f = transfer / scratchH[x];
            const dR = scratchR[x] * f;
            const dG = scratchG[x] * f;
            const dB = scratchB[x] * f;
            flowR[x] -= dR; flowR[x + 1] += dR;
            flowG[x] -= dG; flowG[x + 1] += dG;
            flowB[x] -= dB; flowB[x + 1] += dB;
          } else if (transfer < 0 && scratchH[x + 1] > 1e-6) {
            const f = -transfer / scratchH[x + 1];
            const dR = scratchR[x + 1] * f;
            const dG = scratchG[x + 1] * f;
            const dB = scratchB[x + 1] * f;
            flowR[x + 1] -= dR; flowR[x] += dR;
            flowG[x + 1] -= dG; flowG[x] += dG;
            flowB[x + 1] -= dB; flowB[x] += dB;
          }
        }
        for (let x = 0; x < W; x++) {
          height[x] = Math.max(0, Math.min(H - 2, height[x] + flowH[x]));
          colMassR[x] = Math.max(0, colMassR[x] + flowR[x]);
          colMassG[x] = Math.max(0, colMassG[x] + flowG[x]);
          colMassB[x] = Math.max(0, colMassB[x] + flowB[x]);
        }
      }
    }

    function diffuseAndAdvectColor() {
      // Symmetric lateral diffusion gently blends neighboring columns even
      // when their water levels match (which is most of the time in the
      // settled pool, where equalizeColumns transfers nothing). Wind biases
      // the diffusion so color visibly drifts in the wind direction.
      scratchR.set(colMassR);
      scratchG.set(colMassG);
      scratchB.set(colMassB);
      const advect = cycleWind * COLOR_ADVECT;
      const advT = Math.min(0.35, Math.abs(advect));
      const advDir = advect > 0 ? -1 : advect < 0 ? 1 : 0;
      for (let x = 0; x < W; x++) {
        const left = x > 0 ? x - 1 : x;
        const right = x < W - 1 ? x + 1 : x;
        let dR = COLOR_DIFFUSE * (scratchR[left] + scratchR[right] - 2 * scratchR[x]);
        let dG = COLOR_DIFFUSE * (scratchG[left] + scratchG[right] - 2 * scratchG[x]);
        let dB = COLOR_DIFFUSE * (scratchB[left] + scratchB[right] - 2 * scratchB[x]);
        if (advDir !== 0) {
          const upX = advDir < 0 ? right : left;
          dR += advT * (scratchR[upX] - scratchR[x]);
          dG += advT * (scratchG[upX] - scratchG[x]);
          dB += advT * (scratchB[upX] - scratchB[x]);
        }
        colMassR[x] = Math.max(0, scratchR[x] + dR);
        colMassG[x] = Math.max(0, scratchG[x] + dG);
        colMassB[x] = Math.max(0, scratchB[x] + dB);
      }
    }

    function smoothVisibleSurface() {
      for (let x = 0; x < W; x++) {
        const a = height[Math.max(0, x - 2)];
        const b = height[Math.max(0, x - 1)];
        const c = height[x];
        const d = height[Math.min(W - 1, x + 1)];
        const e = height[Math.min(W - 1, x + 2)];
        smoothHeight[x] = (a + b * 2 + c * 3 + d * 2 + e) / 9;
      }
      for (let x = 0; x < W; x++) {
        renderHeight[x] += (smoothHeight[x] - renderHeight[x]) * SURFACE_LAG;
      }
    }

    function step() {
      addRain();

      for (let i = drops.length - 1; i >= 0; i--) {
        const d = drops[i];
        d.vy += 0.0035;
        d.x += d.vx;
        d.y += d.vy;
        if (d.y >= surfaceY(d.x)) {
          splash(d.x, 0.72 + Math.random() * 0.46, rainColors[d.color]);
          drops.splice(i, 1);
        } else if (d.x < -3 || d.x > W + 3 || d.y > H + 4) {
          drops.splice(i, 1);
        }
      }

      equalizeColumns();
      diffuseAndAdvectColor();

      let total = 0;
      for (let x = 0; x < W; x++) {
        if (draining) {
          height[x] *= DRAIN_RATE;
          colMassR[x] *= DRAIN_RATE;
          colMassG[x] *= DRAIN_RATE;
          colMassB[x] *= DRAIN_RATE;
        }
        total += height[x];
      }
      smoothVisibleSurface();

      const avg = total / W;
      if (!draining && avg > H * DRAIN_START) draining = true;
      if (draining && avg < RESET_LEVEL) {
        draining = false;
        drops = [];
        height.fill(0);
        renderHeight.fill(0);
        smoothHeight.fill(0);
        flow.fill(0);
        colMassR.fill(0);
        colMassG.fill(0);
        colMassB.fill(0);
        waterPalette = buildPalette(pickStops());
        waterColor = pickWaterColor(waterPalette);
        rainColors = pickRainColors(waterPalette);
        cycleWind = (Math.random() - 0.5) * 2 * WIND_MAX;
      }
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      // Resolve each column's intensive RGB once, then fill the column. Use
      // the actual sim height for the concentration ratio (rendered surface
      // is lagged via renderHeight, but the color is column-stable either
      // way so the lag doesn't bleed wrong concentrations).
      for (let x = 0; x < W; x++) {
        const h = height[x];
        if (h > 1e-6) {
          const inv = 1 / h;
          let r = colMassR[x] * inv;
          let g = colMassG[x] * inv;
          let b = colMassB[x] * inv;
          if (r > 255) r = 255;
          if (g > 255) g = 255;
          if (b > 255) b = 255;
          columnR[x] = r;
          columnG[x] = g;
          columnB[x] = b;
        } else {
          columnR[x] = waterColor[0];
          columnG[x] = waterColor[1];
          columnB[x] = waterColor[2];
        }
      }
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const depth = renderHeight[x] - (H - 1 - y);
          const j = (y * W + x) * 4;
          if (depth > 0) {
            data[j] = columnR[x];
            data[j + 1] = columnG[x];
            data[j + 2] = columnB[x];
          } else {
            data[j] = paper[0];
            data[j + 1] = paper[1];
            data[j + 2] = paper[2];
          }
          data[j + 3] = 255;
        }
      }

      function paintDropPixel(x: number, y: number, c: RGB) {
        if (x < 0 || x >= W || y < 0 || y >= H) return;
        const j = (y * W + x) * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }

      for (const d of drops) {
        const c = rainColors[d.color];
        // Trail follows the drop's own velocity, so wind-blown drops lean
        // visibly in the wind direction. Tail tapers toward paper.
        const trailLen = d.size > 1 ? 4 : 3;
        for (let t = 0; t < trailLen; t++) {
          const tx = Math.round(d.x - d.vx * t * 1.6);
          const ty = Math.round(d.y - d.vy * t * 1.6);
          const tint = mix(paper, c, Math.max(0.28, 0.86 - t * 0.18));
          paintDropPixel(tx, ty, tint);
          if (d.size > 1 && t > 0) {
            paintDropPixel(tx + (cycleWind > 0 ? 1 : -1), ty, mix(paper, c, 0.34));
          }
        }
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 260; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
  }
</script>
