---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="fluid-sim" class="fluid-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('fluid-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 4;
    const TAU = Math.PI * 2;
    const CYCLE_FRAMES = 1800;
    const DYE_DECAY = 0.989;
    const VELOCITY_BLEND = 0.24;
    const ADVECT_DT = 0.82;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];
    type Vortex = {
      cx: number;
      cy: number;
      rx: number;
      ry: number;
      sx: number;
      sy: number;
      phase: number;
      radius: number;
      spin: number;
      breathe: number;
      pull: number;
      x: number;
      y: number;
    };
    type Emitter = {
      cx: number;
      cy: number;
      rx: number;
      ry: number;
      sx: number;
      sy: number;
      phase: number;
      radius: number;
      amount: number;
      color: RGB;
    };

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let img: ImageData | null = null;
    let dyeR = new Float32Array(0);
    let dyeG = new Float32Array(0);
    let dyeB = new Float32Array(0);
    let nextR = new Float32Array(0);
    let nextG = new Float32Array(0);
    let nextB = new Float32Array(0);
    let velX = new Float32Array(0);
    let velY = new Float32Array(0);
    let palette: RGB[] = [];
    let cycleStops: RGB[] = [];
    let vortices: Vortex[] = [];
    let emitters: Emitter[] = [];
    let stepCount = 0;
    let pointerX = -1;
    let pointerY = -1;
    let pointerDX = 0;
    let pointerDY = 0;

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push(mix(a, b, lt));
      }
      return out;
    }

    function syncAccent(stops: RGB[]) {
      const root = document.documentElement;
      for (let i = 0; i < stops.length; i++) root.style.setProperty(`--c${i + 1}`, rgb(stops[i]));
      root.style.setProperty('--accent', rgb(stops[Math.min(stops.length - 1, 4)]));
    }

    function wrap(v: number, max: number): number {
      return ((v % max) + max) % max;
    }

    function addDye(cx: number, cy: number, radius: number, color: RGB, amount: number) {
      const r = Math.max(1, Math.ceil(radius));
      const rr = radius * radius;
      for (let dy = -r; dy <= r; dy++) {
        const yy = (Math.round(cy) + dy + H) % H;
        const row = yy * W;
        for (let dx = -r; dx <= r; dx++) {
          const d2 = dx * dx + dy * dy;
          if (d2 > rr) continue;
          const x = (Math.round(cx) + dx + W) % W;
          const q = 1 - d2 / rr;
          const w = q * q * amount;
          const i = row + x;
          dyeR[i] = Math.min(520, dyeR[i] + color[0] * w);
          dyeG[i] = Math.min(520, dyeG[i] + color[1] * w);
          dyeB[i] = Math.min(520, dyeB[i] + color[2] * w);
        }
      }
    }

    function addVelocity(cx: number, cy: number, vx: number, vy: number, radius: number) {
      const r = Math.max(1, Math.ceil(radius));
      const rr = radius * radius;
      for (let dy = -r; dy <= r; dy++) {
        const yy = (Math.round(cy) + dy + H) % H;
        const row = yy * W;
        for (let dx = -r; dx <= r; dx++) {
          const d2 = dx * dx + dy * dy;
          if (d2 > rr) continue;
          const x = (Math.round(cx) + dx + W) % W;
          const q = 1 - d2 / rr;
          const i = row + x;
          velX[i] += vx * q * q;
          velY[i] += vy * q * q;
        }
      }
    }

    function rerollCycle(clear: boolean) {
      cycleStops = pickStops();
      palette = buildPalette(cycleStops);
      syncAccent(cycleStops);
      vortices = [];
      emitters = [];
      const span = Math.max(12, Math.min(W, H));
      const vortexCount = 6 + ((Math.random() * 4) | 0);
      for (let i = 0; i < vortexCount; i++) {
        const spinSign = Math.random() < 0.5 ? -1 : 1;
        vortices.push({
          cx: Math.random() * W,
          cy: Math.random() * H,
          rx: W * (0.08 + Math.random() * 0.22),
          ry: H * (0.08 + Math.random() * 0.22),
          sx: (0.0015 + Math.random() * 0.0045) * (Math.random() < 0.5 ? -1 : 1),
          sy: (0.0015 + Math.random() * 0.0045) * (Math.random() < 0.5 ? -1 : 1),
          phase: Math.random() * TAU,
          radius: span * (0.11 + Math.random() * 0.14),
          spin: spinSign * (0.55 + Math.random() * 0.75),
          breathe: 0.006 + Math.random() * 0.014,
          pull: (Math.random() - 0.5) * 0.0015,
          x: 0,
          y: 0,
        });
      }
      const emitterCount = 4 + ((Math.random() * 3) | 0);
      for (let i = 0; i < emitterCount; i++) {
        const c = mix(paper, cycleStops[(i * 2 + ((Math.random() * 2) | 0)) % cycleStops.length], 0.96);
        emitters.push({
          cx: W * (0.18 + Math.random() * 0.64),
          cy: H * (0.18 + Math.random() * 0.64),
          rx: W * (0.10 + Math.random() * 0.28),
          ry: H * (0.10 + Math.random() * 0.28),
          sx: 0.003 + Math.random() * 0.008,
          sy: 0.003 + Math.random() * 0.008,
          phase: Math.random() * TAU,
          radius: span * (0.026 + Math.random() * 0.028),
          amount: 0.020 + Math.random() * 0.020,
          color: c,
        });
      }
      if (clear) {
        dyeR.fill(0); dyeG.fill(0); dyeB.fill(0);
        velX.fill(0); velY.fill(0);
        for (let i = 0; i < 34; i++) {
          const c = mix(paper, cycleStops[(Math.random() * cycleStops.length) | 0], 0.88);
          addDye(Math.random() * W, Math.random() * H, span * (0.025 + Math.random() * 0.06), c, 0.18);
        }
      }
      stepCount = 0;
    }

    function updateVortices(t: number) {
      for (const v of vortices) {
        v.x = wrap(
          v.cx + Math.cos(t * v.sx + v.phase) * v.rx +
          Math.sin(t * v.sy * 0.43 + v.phase * 1.7) * v.rx * 0.35,
          W,
        );
        v.y = wrap(
          v.cy + Math.sin(t * v.sy + v.phase * 1.3) * v.ry +
          Math.cos(t * v.sx * 0.51 + v.phase) * v.ry * 0.35,
          H,
        );
      }
    }

    function updateVelocity(t: number) {
      updateVortices(t);
      for (let y = 0; y < H; y++) {
        const row = y * W;
        const baseU = Math.sin(y * 0.035 + t * 0.010) * 0.08;
        for (let x = 0; x < W; x++) {
          const i = row + x;
          let u = baseU + Math.sin((x + y) * 0.021 - t * 0.007) * 0.035;
          let v = Math.cos(x * 0.030 - t * 0.009) * 0.055;
          for (const vortex of vortices) {
            let dx = x - vortex.x;
            let dy = y - vortex.y;
            if (dx > W * 0.5) dx -= W;
            else if (dx < -W * 0.5) dx += W;
            if (dy > H * 0.5) dy -= H;
            else if (dy < -H * 0.5) dy += H;
            const r2 = dx * dx + dy * dy;
            const qBase = 1 / (1 + r2 / (vortex.radius * vortex.radius));
            const q = qBase * qBase;
            const spin = vortex.spin * (0.74 + 0.26 * Math.sin(t * vortex.breathe + vortex.phase));
            const curl = q * spin / Math.max(8, vortex.radius);
            u += -dy * curl + dx * vortex.pull * q;
            v += dx * curl + dy * vortex.pull * q;
          }
          velX[i] = velX[i] * (1 - VELOCITY_BLEND) + u * VELOCITY_BLEND;
          velY[i] = velY[i] * (1 - VELOCITY_BLEND) + v * VELOCITY_BLEND;
        }
      }
    }

    function emitDye(t: number) {
      for (const e of emitters) {
        const x = wrap(
          e.cx + Math.cos(t * e.sx + e.phase) * e.rx +
          Math.sin(t * e.sy * 0.37 + e.phase * 2.1) * e.rx * 0.25,
          W,
        );
        const y = wrap(
          e.cy + Math.sin(t * e.sy + e.phase) * e.ry +
          Math.cos(t * e.sx * 0.41 + e.phase * 0.7) * e.ry * 0.25,
          H,
        );
        const pulse = 0.75 + 0.25 * Math.sin(t * 0.017 + e.phase);
        addDye(x, y, e.radius * (0.85 + pulse * 0.35), e.color, e.amount * pulse);
      }
      if (pointerX >= 0) {
        const color = mix(paper, palette[Math.max(2, palette.length - 2)], 0.96);
        addDye(pointerX, pointerY, Math.max(5, Math.min(W, H) * 0.035), color, 0.026);
        addVelocity(pointerX, pointerY, pointerDX * 0.06, pointerDY * 0.06, Math.max(6, Math.min(W, H) * 0.045));
        pointerDX *= 0.68;
        pointerDY *= 0.68;
      }
    }

    function advect() {
      for (let y = 0; y < H; y++) {
        const row = y * W;
        for (let x = 0; x < W; x++) {
          const i = row + x;
          let px = x - velX[i] * ADVECT_DT;
          let py = y - velY[i] * ADVECT_DT;
          px = wrap(px, W);
          py = wrap(py, H);
          const x0 = px | 0;
          const y0 = py | 0;
          const x1 = (x0 + 1) % W;
          const y1 = (y0 + 1) % H;
          const tx = px - x0;
          const ty = py - y0;
          const a = (1 - tx) * (1 - ty);
          const b = tx * (1 - ty);
          const c = (1 - tx) * ty;
          const d = tx * ty;
          const i00 = y0 * W + x0;
          const i10 = y0 * W + x1;
          const i01 = y1 * W + x0;
          const i11 = y1 * W + x1;
          nextR[i] = (dyeR[i00] * a + dyeR[i10] * b + dyeR[i01] * c + dyeR[i11] * d) * DYE_DECAY;
          nextG[i] = (dyeG[i00] * a + dyeG[i10] * b + dyeG[i01] * c + dyeG[i11] * d) * DYE_DECAY;
          nextB[i] = (dyeB[i00] * a + dyeB[i10] * b + dyeB[i01] * c + dyeB[i11] * d) * DYE_DECAY;
        }
      }
      let tmp = dyeR; dyeR = nextR; nextR = tmp;
      tmp = dyeG; dyeG = nextG; nextG = tmp;
      tmp = dyeB; dyeB = nextB; nextB = tmp;
    }

    function step() {
      const t = stepCount;
      updateVelocity(t);
      emitDye(t);
      advect();
      stepCount++;
      if (stepCount >= CYCLE_FRAMES) rerollCycle(false);
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let y = 0; y < H; y++) {
        const row = y * W;
        const yU = ((y - 1 + H) % H) * W;
        const yD = ((y + 1) % H) * W;
        for (let x = 0; x < W; x++) {
          const i = row + x;
          const xL = (x - 1 + W) % W;
          const xR = (x + 1) % W;
          const sum = dyeR[i] + dyeG[i] + dyeB[i];
          const density = Math.min(1, sum / 420);
          const curl = Math.min(
            1,
            Math.abs((velY[row + xR] - velY[row + xL]) - (velX[yD + x] - velX[yU + x])) * 0.45,
          );
          const band = density <= 0.02 ? 0 : Math.floor((density + curl * 0.16) * 7) / 7;
          const alpha = Math.min(1, band * 0.88 + curl * 0.12);
          const inv = sum > 1 ? Math.min(1, 360 / sum) : 1;
          const shimmer = 0.90 + 0.18 * Math.sin(x * 0.17 + y * 0.11 + stepCount * 0.025);
          const cr = Math.min(255, dyeR[i] * inv * shimmer);
          const cg = Math.min(255, dyeG[i] * inv * shimmer);
          const cb = Math.min(255, dyeB[i] * inv * shimmer);
          const j = i * 4;
          data[j] = Math.round(paper[0] * (1 - alpha) + cr * alpha);
          data[j + 1] = Math.round(paper[1] * (1 - alpha) + cg * alpha);
          data[j + 2] = Math.round(paper[2] * (1 - alpha) + cb * alpha);
          data[j + 3] = 255;
        }
      }
      ctx.putImageData(img, 0, 0);
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      const cells = W * H;
      dyeR = new Float32Array(cells);
      dyeG = new Float32Array(cells);
      dyeB = new Float32Array(cells);
      nextR = new Float32Array(cells);
      nextG = new Float32Array(cells);
      nextB = new Float32Array(cells);
      velX = new Float32Array(cells);
      velY = new Float32Array(cells);
      img = ctx.createImageData(W, H);
      rerollCycle(true);
    }

    function setPointerFromEvent(e: PointerEvent) {
      const rect = canvas.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * W;
      const y = ((e.clientY - rect.top) / rect.height) * H;
      if (pointerX >= 0) {
        pointerDX = x - pointerX;
        pointerDY = y - pointerY;
      }
      pointerX = x;
      pointerY = y;
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 220; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 33;
      const loop = (now: number) => {
        if (now - last >= targetMs) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    window.addEventListener('pointermove', setPointerFromEvent);
    window.addEventListener('pointerleave', () => { pointerX = -1; pointerY = -1; });
    window.addEventListener('pointerout', (e) => {
      if (!e.relatedTarget) { pointerX = -1; pointerY = -1; }
    });
  }
</script>
