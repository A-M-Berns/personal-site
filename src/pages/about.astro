        fillPoly([[x, y], [x2, y], [x, y2]], mix(north, west, 0.45), 0.88);
        fillPoly([[x2, y], [x2, y2], [x, y2]], mix(east, south, 0.45), 0.88);
        fillPoly([[x, y], [cx, cy], [x2, y]], north, 0.34);
        fillPoly([[x2, y], [cx, cy], [x2, y2]], east, 0.34);
      } else if (skin === 'edgeCorners') {
        fillPoly([[x, y], [x2, y], [x2, y2], [x, y2]], mix(north, south, 0.50), 0.78);
        fillPoly([[x, y], [cx, y], [x, cy]], north, 0.58);
        fillPoly([[x2, y], [x2, cy], [cx, y]], east, 0.58);
        fillPoly([[x2, y2], [cx, y2], [x2, cy]], south, 0.58);
        fillPoly([[x, y2], [x, cy], [cx, y2]], west, 0.58);
      } else if (skin === 'lanes') {
        ctx.fillStyle = rgba(mix(east, west, 0.50), 0.82);
        fillRectBleed(x, y, size, size);
        ctx.fillStyle = rgba(north, 0.40);
        fillRectBleed(x, y, size, size * 0.24);
        ctx.fillStyle = rgba(south, 0.40);
        fillRectBleed(x, y2 - size * 0.24, size, size * 0.24);
      } else if (skin === 'insetDiamonds') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.82);
        fillRectBleed(x, y, size, size);
        fillPoly([[cx, y + 1], [x2 - 1, cy], [cx, y2 - 1], [x + 1, cy]], mix(east, west, 0.5), 0.92);
      } else if (skin === 'pixelGlyphs') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.80);
        fillRectBleed(x, y, size, size);
        ctx.fillStyle = rgba(west, 0.95);
        ctx.fillRect(x + 1, y + 1, Math.max(1, size * 0.22), Math.max(1, size * 0.22));
        ctx.fillStyle = rgba(east, 0.95);
        ctx.fillRect(x2 - Math.max(2, size * 0.28), y2 - Math.max(2, size * 0.28), Math.max(1, size * 0.22), Math.max(1, size * 0.22));
      } else if (skin === 'quarterArcs') {
        ctx.fillStyle = rgba(mix(north, south, 0.5), 0.86);
        fillRectBleed(x, y, size, size);
        ctx.fillStyle = rgba(east, 0.55);
        ctx.beginPath();
        ctx.arc(x2, y, size * 0.82, Math.PI * 0.5, Math.PI, false);
        ctx.lineTo(x2, y);
        ctx.fill();
        ctx.fillStyle = rgba(west, 0.55);
        ctx.beginPath();
        ctx.arc(x, y2, size * 0.82, -Math.PI * 0.5, 0, false);
        ctx.lineTo(x, y2);
        ctx.fill();
      } else {
        const band = Math.max(2, Math.floor(size * 0.20));
        fillPoly([[x, y], [x2, y], [x, y2]], north, 0.78);
        fillPoly([[x2, y], [x2, y2], [x, y2]], south, 0.78);
        ctx.fillStyle = rgba(west, 0.66);
        fillRectBleed(x, y, band, size);
        ctx.fillStyle = rgba(east, 0.66);
        fillRectBleed(x2 - band, y, band, size);
      }
    }

    function draw() {
      if (!cycle) return;
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      for (let pos = 0; pos < cycle.visible.length; pos++) {
        if (!cycle.visible[pos]) continue;
        const tileIdx = cycle.grid[pos];
        if (tileIdx < 0) continue;
        const col = pos % cycle.cols;
        const row = Math.floor(pos / cycle.cols);
        drawTile(cycle.tileset.tiles[tileIdx], col, row, cycle.tileSize, cycle.palette, cycle.shape, cycle.skin);
      }
    }

    function step() {
      if (!cycle) return;
      const total = cycle.cols * cycle.rows;
      const amount = cycle.revealStep * playbackSpeed;
      if (cycle.blackHold > 0) {
        cycle.blackHold--;
      } else if (playbackDirection < 0) {
        if (cycle.revealed > 0) {
          const next = Math.max(0, cycle.revealed - amount);
          for (let i = next; i < cycle.revealed; i++) cycle.visible[cycle.order[i]] = 0;
          cycle.revealed = next;
          cycle.hold = 0;
        }
      } else if (cycle.revealed < total) {
        const next = Math.min(total, cycle.revealed + amount);
        for (let i = cycle.revealed; i < next; i++) cycle.visible[cycle.order[i]] = 1;
        cycle.revealed = next;
        cycle.hold = 0;
      } else if (++cycle.hold > HOLD_FRAMES) {
        makeCycle();
      }
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      makeCycle();
      draw();
    }

    setupSelectors();
    resize();
    if (!reduce) {
      let last = 0;
      const loop = (now: number) => {
        if (now - last >= 33) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    resetButton?.addEventListener('click', () => {
      makeCycle();
      draw();
    });
    let pointerHeld = false;
    let ffLatched = false;
    document.addEventListener('pointerdown', (event) => {
      const target = event.target as Element | null;
      if (target?.closest('a, button, dialog')) return;
      pointerHeld = true;
      setPlayback(inRewindZone(event.clientX) ? -1 : 1, true);
    });
    window.addEventListener('pointerup', () => {
      pointerHeld = false;
      if (!ffLatched) setPlayback(1, false);
    });
    window.addEventListener('pointercancel', () => {
      pointerHeld = false;
      if (!ffLatched) setPlayback(1, false);
    });
    window.addEventListener('blur', () => {
      pointerHeld = false;
      ffLatched = false;
      setPlayback(1, false);
    });
    window.addEventListener('keydown', (event) => {
      if (event.key !== 'f' && event.key !== 'F') return;
      if (event.repeat) return;
      const target = event.target as Element | null;
      if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement) return;
      ffLatched = !ffLatched;
      setPlayback(playbackDirection, pointerHeld || ffLatched);
    });
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutClose?.addEventListener('click', () => aboutDialog?.close());
    aboutDialog?.addEventListener('click', (event) => {
      if (event.target === aboutDialog) aboutDialog.close();
    });
  }
</script>
