---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="rain-sim" class="rain-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('rain-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 4;
    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    let W = 0;
    let H = 0;
    let water = new Uint8Array(0);
    let next = new Uint8Array(0);
    let rain = new Uint8Array(0);
    let img: ImageData | null = null;
    let palette = buildPalette(pickStops());
    let draining = false;
    let cycle = 0;

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      water = new Uint8Array(W * H);
      next = new Uint8Array(W * H);
      rain = new Uint8Array(W * H);
      img = ctx.createImageData(W, H);
      draining = false;
      cycle = 0;
      palette = buildPalette(pickStops());
    }

    function addRain() {
      const drops = Math.max(2, Math.floor(W / 80));
      for (let k = 0; k < drops; k++) {
        if (Math.random() > 0.72) continue;
        const x = (Math.random() * W) | 0;
        const len = 2 + ((Math.random() * 8) | 0);
        for (let y = 0; y < len; y++) {
          const idx = y * W + x;
          rain[idx] = Math.max(rain[idx], N - 1 - Math.min(3, y));
        }
      }
    }

    function step() {
      addRain();

      next.fill(0);
      for (let y = H - 1; y >= 0; y--) {
        for (let x = 0; x < W; x++) {
          const idx = y * W + x;
          const mass = water[idx];
          if (!mass) continue;
          if (draining) {
            if (Math.random() < 0.06) continue;
          }
          if (y + 1 < H && next[(y + 1) * W + x] < N - 1) {
            next[(y + 1) * W + x] = Math.min(N - 1, next[(y + 1) * W + x] + mass);
          } else {
            const dirs = Math.random() < 0.5 ? [-1, 1] : [1, -1];
            let placed = false;
            for (const dx of dirs) {
              const xx = x + dx;
              if (xx < 0 || xx >= W) continue;
              const nidx = y * W + xx;
              if (next[nidx] < mass) {
                next[nidx] = mass;
                placed = true;
                break;
              }
            }
            if (!placed) next[idx] = Math.max(next[idx], mass);
          }
        }
      }

      for (let y = H - 1; y >= 0; y--) {
        for (let x = 0; x < W; x++) {
          const idx = y * W + x;
          if (rain[idx]) {
            if (y + 1 < H && !next[(y + 1) * W + x]) {
              rain[(y + 1) * W + x] = rain[idx];
            } else {
              next[idx] = Math.max(next[idx], rain[idx]);
            }
            rain[idx] = 0;
          }
        }
      }

      const tmp = water;
      water = next;
      next = tmp;

      let filled = 0;
      for (let i = 0; i < water.length; i++) if (water[i]) filled++;
      if (!draining && filled > water.length * 0.62) draining = true;
      if (draining && filled < water.length * 0.03) {
        draining = false;
        rain.fill(0);
        water.fill(0);
        palette = buildPalette(pickStops());
      }
      cycle++;
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let i = 0; i < water.length; i++) {
        const v = Math.max(water[i], rain[i]);
        const c = v ? palette[Math.min(N - 1, v)] : paper;
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 260; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
  }
</script>
