---
import Base from '../layouts/Base.astro';
---
<Base title="About — A. M. Berns" description="About A. M. Berns.">
  <div class="about-shell">
    <canvas id="rain-sim" class="rain-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">About</span></h1>
      <p><span class="hl">A short bio goes here.</span></p>
    </header>
    <article class="note">
      <p><span class="hl">More to come.</span></p>
    </article>
  </div>
</Base>

<script>
  const canvas = document.getElementById('rain-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 4;
    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    function pickRainColors(palette: RGB[]): RGB[] {
      const count = Math.random() < 0.5 ? 2 : 3;
      const colors: RGB[] = [];
      while (colors.length < count) {
        const idx = 3 + ((Math.random() * (palette.length - 3)) | 0);
        const c = palette[idx];
        if (!colors.includes(c)) colors.push(c);
      }
      return colors;
    }

    type Drop = {
      x: number;
      y: number;
      vy: number;
      tail: number;
      color: number;
    };

    let W = 0;
    let H = 0;
    let height = new Float32Array(0);
    let flow = new Float32Array(0);
    let drops: Drop[] = [];
    let img: ImageData | null = null;
    let waterPalette = buildPalette(pickStops());
    let rainColors = pickRainColors(waterPalette);
    let draining = false;

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      height = new Float32Array(W);
      flow = new Float32Array(W);
      drops = [];
      img = ctx.createImageData(W, H);
      draining = false;
      waterPalette = buildPalette(pickStops());
      rainColors = pickRainColors(waterPalette);
    }

    function surfaceY(x: number): number {
      const ix = Math.max(0, Math.min(W - 1, x | 0));
      return H - 1 - height[ix];
    }

    function splash(x: number, amount: number) {
      const mid = Math.max(0, Math.min(W - 1, x | 0));
      for (let dx = -5; dx <= 5; dx++) {
        const ix = mid + dx;
        if (ix < 0 || ix >= W) continue;
        const falloff = Math.max(0, 1 - Math.abs(dx) / 5.8);
        height[ix] = Math.min(H - 2, height[ix] + amount * falloff);
      }
    }

    function addRain() {
      if (draining) return;
      const attempts = Math.max(3, Math.floor(W / 40));
      for (let k = 0; k < attempts; k++) {
        if (drops.length > W * 1.8 || Math.random() > 0.45) continue;
        drops.push({
          x: Math.random() * W,
          y: -2 - Math.random() * H * 0.4,
          vy: 0.24 + Math.random() * 0.38,
          tail: 5 + ((Math.random() * 8) | 0),
          color: (Math.random() * rainColors.length) | 0,
        });
      }
    }

    function equalizeColumns() {
      // Conservative 1D shallow-water approximation: adjacent columns exchange
      // volume proportional to their height difference. Repeating the pass
      // gives a stable rising pool without the unstable springy surface motion
      // from the previous version.
      for (let pass = 0; pass < 4; pass++) {
        flow.fill(0);
        for (let x = 0; x < W - 1; x++) {
          const diff = height[x] - height[x + 1];
          const transfer = Math.max(-0.72, Math.min(0.72, diff * 0.22));
          flow[x] -= transfer;
          flow[x + 1] += transfer;
        }
        for (let x = 0; x < W; x++) {
          height[x] = Math.max(0, Math.min(H - 2, height[x] + flow[x]));
        }
      }
    }

    function step() {
      addRain();

      for (let i = drops.length - 1; i >= 0; i--) {
        const d = drops[i];
        d.vy += 0.012;
        d.y += d.vy;
        if (d.y >= surfaceY(d.x)) {
          splash(d.x, 1.12 + Math.random() * 0.72);
          drops.splice(i, 1);
        } else if (d.y > H + d.tail + 4) {
          drops.splice(i, 1);
        }
      }

      equalizeColumns();

      let total = 0;
      for (let x = 0; x < W; x++) {
        if (draining) height[x] *= 0.987;
        total += height[x];
      }

      const avg = total / W;
      if (!draining && avg > H * 0.68) draining = true;
      if (draining && avg < 1) {
        draining = false;
        drops = [];
        height.fill(0);
        flow.fill(0);
        waterPalette = buildPalette(pickStops());
        rainColors = pickRainColors(waterPalette);
      }
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const depth = height[x] - (H - 1 - y);
          const c = depth > 0
            ? waterPalette[Math.min(N - 1, Math.max(1, Math.floor(depth * 0.55) + 1))]
            : paper;
          const j = (y * W + x) * 4;
          data[j] = c[0];
          data[j + 1] = c[1];
          data[j + 2] = c[2];
          data[j + 3] = 255;
        }
      }

      for (const d of drops) {
        const x = d.x | 0;
        for (let t = 0; t < d.tail; t++) {
          const y = (d.y - t) | 0;
          if (x < 0 || x >= W || y < 0 || y >= H) continue;
          const c = rainColors[d.color];
          const j = (y * W + x) * 4;
          data[j] = c[0];
          data[j + 1] = c[1];
          data[j + 2] = c[2];
          data[j + 3] = 255;
        }
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 260; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
  }
</script>
