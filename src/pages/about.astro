        ctx.fillStyle = rgba(north, 0.50);
        fillRectBleed(x, y, size, size * 0.25);
        ctx.fillStyle = rgba(south, 0.50);
        fillRectBleed(x, y2 - size * 0.25, size, size * 0.25);
      } else if (skin === 'slats') {
        ctx.fillStyle = rgba(mix(north, south, 0.50), 0.82);
        fillRectBleed(x, y, size, size);
        ctx.fillStyle = rgba(west, 0.42);
        fillRectBleed(x, y, size * 0.34, size);
        ctx.fillStyle = rgba(east, 0.42);
        fillRectBleed(x2 - size * 0.34, y, size * 0.34, size);
