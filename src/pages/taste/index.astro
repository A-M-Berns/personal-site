---
import Base from '../../layouts/Base.astro';
---
<Base title="Taste — A. M. Berns" description="Taste, lists, and visual collections.">
  <div class="other-shell taste-shell">
    <canvas id="sandpile-sim" class="sandpile-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Taste</span></h1>
    </header>
    <div class="taste-panes">
      <div class="taste-column">
        <section class="writing-pane">
          <h2>Music</h2>
          <p>
            A lot of my music taste can be seen on my
            <a href="https://rateyourmusic.com/~hautboy">Rate Your Music profile</a>, although I
            don't necessarily stand by every rating. In particular, you can see a list of my
            favorite albums of all time <a href="https://rateyourmusic.com/collection/hautboy/r5.0">here</a>.
          </p>
        </section>
        <section class="writing-pane">
          <h2>Fiction</h2>
          <p>
            <a href="/taste/fiction">This page</a> catalogs some films, novels, and short stories
            that I like.
          </p>
        </section>
      </div>
      <div class="taste-column">
        <section class="writing-pane">
          <h2>Art</h2>
          <p>
            <a href="https://www.are.na/anson-berns/art-n3r49vapnpc">This list</a> shows
            some paintings I enjoy, and <a href="/taste/covers">this page</a> displays
            albums with covers that I like.
          </p>
        </section>
        <section class="writing-pane">
          <h2>Philosophy</h2>
          <p>
            <a href="/taste/philosophy">This page</a> documents some works of philosophy and theory
            that were particularly formative for me. I also briefly sketch some of my most deeply
            held philosophical views there.
          </p>
        </section>
      </div>
    </div>
    <div class="anim-controls">
      <button id="sandpile-info" type="button" aria-label="About">About</button>
      <button id="sandpile-restart" type="button" aria-label="Reset sandpile">Reset</button>
    </div>
    <dialog id="sandpile-about" class="anim-about" aria-labelledby="sandpile-about-title">
      <h2 id="sandpile-about-title">About</h2>
      <p>
        This page implements an <a href="https://en.wikipedia.org/wiki/Abelian_sandpile_model">Abelian sandpile model</a>.
      </p>
    </dialog>
    <aside class="sandpile-panel" aria-label="Sandpile controls">
      <div class="sandpile-panel-head">
        <h2>Sandpile</h2>
        <div class="sandpile-panel-head-actions">
          <button id="sandpile-reset" type="button">Reset</button>
          <button id="sandpile-collapse" type="button" aria-label="Collapse panel" aria-expanded="true">−</button>
        </div>
      </div>
      <div class="sandpile-panel-body">
      <label class="sandpile-panel-field" for="sandpile-mode-select">
        <span>mode</span>
        <select id="sandpile-mode-select">
          <option value="random" selected>random</option>
          <optgroup label="symmetric">
            <option value="center">center</option>
            <option value="radial">radial</option>
            <option value="axial-mirror">axial-mirror</option>
            <option value="grid">grid</option>
            <option value="concentric">concentric</option>
          </optgroup>
          <optgroup label="asymmetric">
            <option value="off-center">off-center</option>
            <option value="scatter">scatter</option>
            <option value="cluster">cluster</option>
            <option value="line">line</option>
          </optgroup>
        </select>
      </label>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-passes">passes</label>
        <input id="sandpile-passes" type="range" min="5" max="10" step="1" value="8" />
        <span id="sandpile-passes-value">8</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-mass">mass</label>
        <input id="sandpile-mass" type="range" min="0.3" max="2.4" step="0.1" value="1" />
        <span id="sandpile-mass-value">1.0</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-cadence">cadence</label>
        <input id="sandpile-cadence" type="range" min="30" max="90" step="1" value="90" />
        <span id="sandpile-cadence-value">90</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-ease">ease</label>
        <input id="sandpile-ease" type="range" min="0.25" max="0.75" step="0.05" value="0.25" />
        <span id="sandpile-ease-value">0.25</span>
      </div>
      <dl class="sandpile-stats">
        <div><dt>seed</dt><dd id="sandpile-seed">-</dd></div>
        <div><dt>iterations</dt><dd id="sandpile-frame">-</dd></div>
      </dl>
      </div>
    </aside>
  </div>
</Base>

<script>
  const canvas = document.getElementById('sandpile-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const resetButton = document.getElementById('sandpile-reset') as HTMLButtonElement | null;
    const collapseButton = document.getElementById('sandpile-collapse') as HTMLButtonElement | null;
    const panelEl = document.querySelector('.sandpile-panel') as HTMLElement | null;
    const modeSelect = document.getElementById('sandpile-mode-select') as HTMLSelectElement | null;
    const passesInput = document.getElementById('sandpile-passes') as HTMLInputElement | null;
    const massInput = document.getElementById('sandpile-mass') as HTMLInputElement | null;
    const cadenceInput = document.getElementById('sandpile-cadence') as HTMLInputElement | null;
    const easeInput = document.getElementById('sandpile-ease') as HTMLInputElement | null;
    const passesValue = document.getElementById('sandpile-passes-value');
    const massValue = document.getElementById('sandpile-mass-value');
    const cadenceValue = document.getElementById('sandpile-cadence-value');
    const easeValue = document.getElementById('sandpile-ease-value');
    const seedLabel = document.getElementById('sandpile-seed');
    const frameLabel = document.getElementById('sandpile-frame');

    const CELL_PX = 3;
    const ACTIVE_DECAY = 18;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex(styles.getPropertyValue('--paper').trim() || '#0e0e10');
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let grains = new Uint32Array();
    let nextGrains = new Uint32Array();
    let active = new Uint8Array();
    let display = new Float32Array();
    let image = new ImageData(1, 1);
    let rng = mulberry32(1);
    let frame = 0;
    let seed = 0;
    let topplePassesPerFrame = Number(passesInput?.value ?? 8);
    const PULSE_CYCLE_FRAMES = 2700;
    let pulseCadence = Math.max(1, Number(cadenceInput?.value ?? 90));
    type InjectionMode =
      | 'random'
      | 'center' | 'radial' | 'axial-mirror' | 'grid' | 'concentric'
      | 'off-center' | 'scatter' | 'cluster' | 'line';
    const VALID_MODES: ReadonlyArray<InjectionMode> = [
      'random',
      'center', 'radial', 'axial-mirror', 'grid', 'concentric',
      'off-center', 'scatter', 'cluster', 'line',
    ];
    function parseMode(v: string | undefined): InjectionMode {
      return (VALID_MODES as readonly string[]).includes(v ?? '') ? (v as InjectionMode) : 'random';
    }
    let injectionMode: InjectionMode = parseMode(modeSelect?.value);
    let massScale = Number(massInput?.value ?? 1);
    let easeAlpha = Number(easeInput?.value ?? 0.25);
    let palette: number[][] = [];

    function parseHex(h: string) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: number[]) {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: number[], b: number[], t: number) {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function hashString(s: string) {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(n: number) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function idx(x: number, y: number) {
      return y * W + x;
    }

    function choosePalette() {
      const Lp = luma(paper);
      const usable: number[][] = [];
      for (const c of colorPool) if (luma(c) >= Lp + 30) usable.push(c);
      const buckets = 4;
      const stops: number[][] = [paper];
      for (let i = 0; i < buckets; i++) {
        const lo = Math.floor((i * usable.length) / buckets);
        const hi = Math.floor(((i + 1) * usable.length) / buckets);
        const idx = lo + Math.floor(rng() * Math.max(1, hi - lo));
        stops.push(usable[idx]);
      }
      palette = stops;
      document.documentElement.style.setProperty('--accent', `rgb(${stops[stops.length - 1].join(', ')})`);
    }

    function seedCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      choosePalette();
      nextGrains.fill(0);
      active.fill(0);
      display.fill(0);
      frame = 0;
      pulseAccumulator = 0;
      sourceState = {};
      clickSources.length = 0;
      cycleStartTime = performance.now();
      massScale = Math.round((0.3 + Math.floor(rng() * 22) * 0.1) * 10) / 10;
      if (massInput) massInput.value = massScale.toFixed(1);
      if (massValue) massValue.textContent = massScale.toFixed(1);
      topplePassesPerFrame = 5 + Math.floor(rng() * 6);
      if (passesInput) passesInput.value = String(topplePassesPerFrame);
      if (passesValue) passesValue.textContent = String(topplePassesPerFrame);
      pulseCadence = 30 + Math.floor(rng() * 61);
      if (cadenceInput) cadenceInput.value = String(pulseCadence);
      if (cadenceValue) cadenceValue.textContent = String(pulseCadence);
      easeAlpha = Math.round((0.25 + Math.floor(rng() * 11) * 0.05) * 100) / 100;
      if (easeInput) easeInput.value = easeAlpha.toFixed(2);
      if (easeValue) easeValue.textContent = easeAlpha.toFixed(2);
      grains.fill(3);
      for (let i = 0; i < grains.length; i++) display[i] = Math.min(3, grains[i]);
      updatePanel();
    }

    type SourceState = { positions?: number[][] };
    let sourceState: SourceState = {};
    type ClickSource = { x: number; y: number; framesLeft: number };
    const clickSources: ClickSource[] = [];
    const CLICK_LIFETIME_FRAMES = 300;
    const CLICK_WEIGHT = 5;
    const CLICK_BURST_GRAINS = 8;
    const AUTO_RESET_MS = 120_000;
    let cycleStartTime = 0;

    function clamp(v: number, lo: number, hi: number) {
      return v < lo ? lo : v > hi ? hi : v;
    }

    function gauss() {
      const u1 = Math.max(1e-6, rng());
      const u2 = rng();
      return Math.sqrt(-2 * Math.log(u1)) * Math.cos(2 * Math.PI * u2);
    }

    const TEMPLATES: Record<InjectionMode, () => number[][]> = {
      random: () => {
        const choices = VALID_MODES.filter((m) => m !== 'random');
        const pick = choices[Math.floor(rng() * choices.length)];
        return TEMPLATES[pick]();
      },
      center: () => [[W >> 1, H >> 1]],
      'off-center': () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const r = (0.20 + rng() * 0.20) * Math.min(W, H);
        const a = rng() * Math.PI * 2;
        return [[Math.round(cx + r * Math.cos(a)), Math.round(cy + r * Math.sin(a))]];
      },
      radial: () => {
        const n = 3 + Math.floor(rng() * 6);
        const r = (0.18 + rng() * 0.22) * Math.min(W, H);
        const phase = rng() * Math.PI * 2;
        const cx = W >> 1;
        const cy = H >> 1;
        const out: number[][] = [];
        for (let i = 0; i < n; i++) {
          const a = phase + (i / n) * Math.PI * 2;
          out.push([Math.round(cx + r * Math.cos(a)), Math.round(cy + r * Math.sin(a))]);
        }
        return out;
      },
      'axial-mirror': () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const dx = (0.10 + rng() * 0.30) * (W >> 1);
        const dy = (rng() - 0.5) * H * 0.55;
        return [
          [Math.round(cx - dx), Math.round(cy + dy)],
          [Math.round(cx + dx), Math.round(cy + dy)],
        ];
      },
      grid: () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const nx = 2 + 2 * Math.floor(rng() * 3);
        const ny = 2 + 2 * Math.floor(rng() * 3);
        const sx = (0.5 + rng() * 0.5) * (W * 0.8) / nx;
        const sy = (0.5 + rng() * 0.5) * (H * 0.8) / ny;
        const out: number[][] = [];
        for (let i = 0; i < nx; i++) {
          for (let j = 0; j < ny; j++) {
            const x = cx + (i - (nx - 1) / 2) * sx;
            const y = cy + (j - (ny - 1) / 2) * sy;
            out.push([Math.round(x), Math.round(y)]);
          }
        }
        return out;
      },
      concentric: () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const m = Math.min(W, H);
        const r1 = (0.08 + rng() * 0.10) * m;
        const r2 = r1 + (0.12 + rng() * 0.12) * m;
        const n1 = 3 + Math.floor(rng() * 4);
        const n2 = 5 + Math.floor(rng() * 4);
        const phase1 = rng() * Math.PI * 2;
        const phase2 = rng() * Math.PI * 2;
        const out: number[][] = [];
        for (let i = 0; i < n1; i++) {
          const a = phase1 + (i / n1) * Math.PI * 2;
          out.push([Math.round(cx + r1 * Math.cos(a)), Math.round(cy + r1 * Math.sin(a))]);
        }
        for (let i = 0; i < n2; i++) {
          const a = phase2 + (i / n2) * Math.PI * 2;
          out.push([Math.round(cx + r2 * Math.cos(a)), Math.round(cy + r2 * Math.sin(a))]);
        }
        return out;
      },
      scatter: () => {
        const n = 3 + Math.floor(rng() * 5);
        const pad = 6;
        const out: number[][] = [];
        for (let i = 0; i < n; i++) {
          out.push([
            Math.round(rng() * (W - 2 * pad) + pad),
            Math.round(rng() * (H - 2 * pad) + pad),
          ]);
        }
        return out;
      },
      cluster: () => {
        const cx = W * (0.25 + rng() * 0.5);
        const cy = H * (0.25 + rng() * 0.5);
        const n = 4 + Math.floor(rng() * 5);
        const r = (0.05 + rng() * 0.10) * Math.min(W, H);
        const out: number[][] = [];
        for (let i = 0; i < n; i++) {
          out.push([
            Math.round(clamp(cx + gauss() * r, 1, W - 2)),
            Math.round(clamp(cy + gauss() * r, 1, H - 2)),
          ]);
        }
        return out;
      },
      line: () => {
        const n = 3 + Math.floor(rng() * 4);
        const angle = rng() * Math.PI;
        const cx = W * (0.35 + rng() * 0.3);
        const cy = H * (0.35 + rng() * 0.3);
        const length = (0.4 + rng() * 0.3) * Math.min(W, H);
        const dxs = Math.cos(angle);
        const dys = Math.sin(angle);
        const out: number[][] = [];
        for (let i = 0; i < n; i++) {
          const t = (i / Math.max(1, n - 1) - 0.5) * length;
          out.push([
            Math.round(clamp(cx + dxs * t, 1, W - 2)),
            Math.round(clamp(cy + dys * t, 1, H - 2)),
          ]);
        }
        return out;
      },
    };

    function getSourcePositions() {
      if (!sourceState.positions) sourceState.positions = TEMPLATES[injectionMode]();
      return sourceState.positions;
    }

    let pulseAccumulator = 0;

    function pulsePoints(positions: number[][]) {
      const n = positions.length;
      if (n === 0) return;
      const totalPerCycle = 32000 * massScale;
      const totalPerPulse = totalPerCycle * pulseCadence / PULSE_CYCLE_FRAMES;
      pulseAccumulator += totalPerPulse;
      let weightSum = 0;
      for (const p of positions) weightSum += (p[2] ?? 1);
      if (weightSum <= 0) return;
      const massThisPulse = Math.floor(pulseAccumulator);
      if (massThisPulse <= 0) return;
      pulseAccumulator -= massThisPulse;
      let allocated = 0;
      for (let i = 0; i < n; i++) {
        const x = positions[i][0];
        const y = positions[i][1];
        const w = positions[i][2] ?? 1;
        const isLast = i === n - 1;
        const share = isLast
          ? massThisPulse - allocated
          : Math.floor(massThisPulse * (w / weightSum));
        allocated += share;
        if (share > 0 && x >= 0 && x < W && y >= 0 && y < H) {
          grains[idx(x, y)] += share;
        }
      }
    }

    function topplePass() {
      let topples = 0;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const i = idx(x, y);
          const q = Math.floor(grains[i] / 4);
          let value = grains[i] - q * 4;
          if (x > 0) value += Math.floor(grains[i - 1] / 4);
          if (x < W - 1) value += Math.floor(grains[i + 1] / 4);
          if (y > 0) value += Math.floor(grains[i - W] / 4);
          if (y < H - 1) value += Math.floor(grains[i + W] / 4);
          nextGrains[i] = value;
          if (q > 0) {
            active[i] = 255;
            topples += q;
          }
        }
      }
      [grains, nextGrains] = [nextGrains, grains];
      return topples;
    }

    function step() {
      if (performance.now() - cycleStartTime >= AUTO_RESET_MS) {
        seedCycle();
        return;
      }
      for (let i = clickSources.length - 1; i >= 0; i--) {
        if (--clickSources[i].framesLeft <= 0) clickSources.splice(i, 1);
      }
      if (frame % pulseCadence === 0) {
        const positions: number[][] = getSourcePositions().slice();
        for (const cs of clickSources) positions.push([cs.x, cs.y, CLICK_WEIGHT]);
        pulsePoints(positions);
      }
      for (let i = 0; i < topplePassesPerFrame; i++) topplePass();
      for (let i = 0; i < active.length; i++) {
        if (active[i] > ACTIVE_DECAY) active[i] -= ACTIVE_DECAY;
        else active[i] = 0;
      }
      frame++;
      if (frame % 12 === 0) updatePanel();
    }

    function updatePanel() {
      if (!seedLabel) return;
      seedLabel.textContent = seed.toString(16).padStart(8, '0');
      if (frameLabel) frameLabel.textContent = frame.toLocaleString();
    }

    function draw() {
      const data = image.data;
      const a = easeAlpha;
      for (let i = 0; i < grains.length; i++) {
        const target = grains[i] < 3 ? grains[i] : 3;
        display[i] += (target - display[i]) * a;
        const v = display[i];
        const lo = v < 0 ? 0 : v > 3 ? 3 : Math.floor(v);
        const hi = lo < 3 ? lo + 1 : 3;
        const t = v - lo;
        const c0 = palette[lo];
        const c1 = palette[hi];
        const o = i * 4;
        data[o]     = c0[0] + (c1[0] - c0[0]) * t;
        data[o + 1] = c0[1] + (c1[1] - c0[1]) * t;
        data[o + 2] = c0[2] + (c1[2] - c0[2]) * t;
        data[o + 3] = v >= 1 ? 255 : 150 + 105 * v;
      }
      ctx.putImageData(image, 0, 0);
    }

    function resize() {
      W = Math.max(48, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(36, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      grains = new Uint32Array(W * H);
      nextGrains = new Uint32Array(W * H);
      active = new Uint8Array(W * H);
      display = new Float32Array(W * H);
      image = new ImageData(W, H);
      seedCycle();
      draw();
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 300; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    canvas.addEventListener('click', (evt) => {
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      const cx = Math.floor((evt.clientX - rect.left) / rect.width * W);
      const cy = Math.floor((evt.clientY - rect.top) / rect.height * H);
      if (cx < 0 || cx >= W || cy < 0 || cy >= H) return;
      clickSources.push({ x: cx, y: cy, framesLeft: CLICK_LIFETIME_FRAMES });
      grains[idx(cx, cy)] += CLICK_BURST_GRAINS;
    });
    resetButton?.addEventListener('click', () => {
      seedCycle();
      draw();
    });
    const restartButton = document.getElementById('sandpile-restart') as HTMLButtonElement | null;
    restartButton?.addEventListener('click', () => {
      seedCycle();
      draw();
    });
    const aboutDlg = document.getElementById('sandpile-about') as HTMLDialogElement | null;
    const infoButton = document.getElementById('sandpile-info') as HTMLButtonElement | null;
    infoButton?.addEventListener('click', () => aboutDlg?.showModal());
    aboutDlg?.addEventListener('click', (e) => {
      if (e.target === aboutDlg) aboutDlg.close();
    });
    const COLLAPSE_KEY = 'sandpile-panel-collapsed';
    function applyCollapsed(collapsed: boolean) {
      if (!panelEl || !collapseButton) return;
      panelEl.classList.toggle('collapsed', collapsed);
      collapseButton.textContent = collapsed ? '+' : '−';
      collapseButton.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      collapseButton.setAttribute('aria-label', collapsed ? 'Expand panel' : 'Collapse panel');
    }
    try {
      applyCollapsed(localStorage.getItem(COLLAPSE_KEY) === '1');
    } catch {}
    collapseButton?.addEventListener('click', () => {
      const next = !panelEl?.classList.contains('collapsed');
      applyCollapsed(next);
      try { localStorage.setItem(COLLAPSE_KEY, next ? '1' : '0'); } catch {}
    });
    modeSelect?.addEventListener('change', () => {
      injectionMode = parseMode(modeSelect.value);
      sourceState = {};
      pulseAccumulator = 0;
    });
    passesInput?.addEventListener('input', () => {
      topplePassesPerFrame = Number(passesInput.value);
      if (passesValue) passesValue.textContent = passesInput.value;
    });
    massInput?.addEventListener('input', () => {
      massScale = Number(massInput.value);
      if (massValue) massValue.textContent = massScale.toFixed(1);
    });
    cadenceInput?.addEventListener('input', () => {
      pulseCadence = Math.max(1, Number(cadenceInput.value));
      if (cadenceValue) cadenceValue.textContent = String(pulseCadence);
    });
    easeInput?.addEventListener('input', () => {
      easeAlpha = Number(easeInput.value);
      if (easeValue) easeValue.textContent = easeAlpha.toFixed(2);
    });
  }
</script>
