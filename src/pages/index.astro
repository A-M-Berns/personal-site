---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short', day: 'numeric' });
const latest = notes.slice(0, 3);
---
<Base title="A. M. Berns" description="Independent research, personal writing, and music.">
  <section class="hero">
    <h1>A<span class="dot">.</span> M<span class="dot">.</span> Berns</h1>
    <p class="lede">
      Independent research, personal writing, and music.
    </p>
  </section>

  <section class="home-section">
    <header>
      <h2>Recent writing</h2>
      <a class="more" href="/writing">All writing →</a>
    </header>
    {latest.length > 0 ? (
      <ul class="note-list">
        {latest.map((n) => (
          <li>
            <time datetime={n.data.date.toISOString()}>{fmt.format(n.data.date)}</time>
            <a href={`/notes/${n.id}/`}>{n.data.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">Nothing posted yet.</p>
    )}
  </section>
</Base>
