---
import Base from '../layouts/Base.astro';
---
<Base title="A. M. Berns" description="Independent research, personal writing, Lean, and other." showNav={false}>
  <canvas id="bg-canvas" class="bg-canvas" aria-hidden="true"></canvas>

  <section class="hero">
    <h1>A<span class="dot">.</span> M<span class="dot">.</span> Berns</h1>
    <p class="lede">
      Independent research, personal writing, Lean, and other.
    </p>
  </section>

  <nav class="home-nav" aria-label="Sections">
    <a href="/about">About</a>
    <a href="/writing">Writing</a>
    <a href="/lean">Lean</a>
    <a href="/other">Other</a>
  </nav>
</Base>

<script>
  // Cyclic CA (Moore neighborhood, 8 states). Each cycle pairs one of several
  // multi-stop palettes with a different seeding pattern, so the field looks
  // qualitatively different on every reseed instead of just re-rolling noise.
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 5;
    let W = 0;
    let H = 0;
    let grid = new Uint8Array(0);
    let next = new Uint8Array(0);
    let img: ImageData | null = null;

    type RGB = [number, number, number];

    const styles = getComputedStyle(document.documentElement);
    const paperHex = (styles.getPropertyValue('--paper').trim() || '#0e0e10');

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    const paper = parseHex(paperHex);

    // Each scheme is paper + 4 hot stops (5 colors total). All visit cyan but
    // diverge through different secondary harmonies.
    const schemes: string[][] = [
      // ice: deep navy → cobalt → cyan → pale ice
      ['#142a6e', '#2a6fd6', '#4ad6ff', '#d6f5ff'],
      // tropic: deep teal → cyan → mint → pale yellow
      ['#0e5a5a', '#4ad6ff', '#9af7c8', '#fff5b3'],
      // dusk: indigo → magenta → cyan → pale sky
      ['#3b1a8a', '#e54adc', '#4ad6ff', '#cfe9ff'],
      // neon: violet → cyan → emerald → lime
      ['#5b2bd6', '#4ad6ff', '#3ad48a', '#d6ff5a'],
      // coral: deep blue → cyan → coral → amber
      ['#0a3a6e', '#4ad6ff', '#ff7a85', '#ffc14a'],
    ];

    function buildPalette(stops: RGB[]): RGB[] {
      // stops[0] is paper; the rest are hot stops. Returns N entries.
      const segments = stops.length - 1;
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * segments;
        const seg = Math.min(Math.floor(segF), segments - 1);
        const lt = segF - seg;
        const a = stops[seg];
        const b = stops[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    type Seeder = { name: string; fn: (g: Uint8Array) => void };
    const seeders: Seeder[] = [
      {
        name: 'noise',
        fn: (g) => { for (let i = 0; i < g.length; i++) g[i] = (Math.random() * N) | 0; },
      },
      {
        name: 'sparse',
        fn: (g) => {
          g.fill(0);
          const k = Math.floor(g.length * 0.02);
          for (let i = 0; i < k; i++) g[(Math.random() * g.length) | 0] = (Math.random() * N) | 0;
        },
      },
      {
        name: 'bands',
        fn: (g) => {
          const bands = 6 + ((Math.random() * 6) | 0);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const b = ((x / W) * bands) | 0;
              g[y * W + x] = (b + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'blobs',
        fn: (g) => {
          g.fill(0);
          const blobs = 3 + ((Math.random() * 4) | 0);
          for (let k = 0; k < blobs; k++) {
            const cx = (Math.random() * W) | 0;
            const cy = (Math.random() * H) | 0;
            const r = 8 + ((Math.random() * 18) | 0);
            const r2 = r * r;
            for (let dy = -r; dy <= r; dy++) {
              for (let dx = -r; dx <= r; dx++) {
                if (dx * dx + dy * dy > r2) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                g[y * W + x] = (Math.random() * N) | 0;
              }
            }
          }
        },
      },
      {
        name: 'diagonal',
        fn: (g) => {
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const t = (x + y) / (W + H);
              const base = (t * N) | 0;
              g[y * W + x] = (base + ((Math.random() * 3) | 0)) % N;
            }
          }
        },
      },
    ];

    let schemeIdx = (Math.random() * schemes.length) | 0;
    let seedIdx = (Math.random() * seeders.length) | 0;
    let palette: RGB[] = buildPalette([paper, ...schemes[schemeIdx].map(parseHex)]);

    function applyCycle() {
      palette = buildPalette([paper, ...schemes[schemeIdx].map(parseHex)]);
      seeders[seedIdx].fn(grid);
    }

    function advanceCycle() {
      schemeIdx = (schemeIdx + 1) % schemes.length;
      // step seed by 2 so the (scheme, seed) pairing isn't locked.
      seedIdx = (seedIdx + 2) % seeders.length;
      applyCycle();
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      grid = new Uint8Array(W * H);
      next = new Uint8Array(W * H);
      img = ctx.createImageData(W, H);
      applyCycle();
    }

    function step() {
      for (let y = 0; y < H; y++) {
        const yU = ((y - 1 + H) % H) * W;
        const yD = ((y + 1) % H) * W;
        const yC = y * W;
        for (let x = 0; x < W; x++) {
          const xL = (x - 1 + W) % W;
          const xR = (x + 1) % W;
          const s = grid[yC + x];
          const t = (s + 1) % N;
          const found =
            grid[yU + xL] === t || grid[yU + x] === t || grid[yU + xR] === t ||
            grid[yC + xL] === t ||                       grid[yC + xR] === t ||
            grid[yD + xL] === t || grid[yD + x] === t || grid[yD + xR] === t;
          next[yC + x] = found ? t : s;
        }
      }
      const tmp = grid;
      grid = next;
      next = tmp;
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let i = 0; i < grid.length; i++) {
        const c = palette[grid[i]];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    draw();

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { resize(); draw(); }, 200);
    });

    // Hover paints a trail of max-state cells; the simulation step picks
    // them up on the next tick. No draw() call here — the animation loop
    // handles redraw within ~80ms.
    let lastPaintTs = 0;
    canvas.addEventListener('pointermove', (e) => {
      const now = performance.now();
      if (now - lastPaintTs < 16) return;
      lastPaintTs = now;
      const rect = canvas.getBoundingClientRect();
      const gx = Math.floor(((e.clientX - rect.left) / rect.width) * W);
      const gy = Math.floor(((e.clientY - rect.top) / rect.height) * H);
      if (gx < 0 || gx >= W || gy < 0 || gy >= H) return;
      grid[gy * W + gx] = N - 1;
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      let last = 0;
      const targetMs = 80;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);

      const RESEED_MS = 75000;
      const FADE_MS = 1500;
      setInterval(() => {
        canvas.style.opacity = '0';
        window.setTimeout(() => {
          advanceCycle();
          canvas.style.opacity = '';
        }, FADE_MS);
      }, RESEED_MS);
    }
  }
</script>
