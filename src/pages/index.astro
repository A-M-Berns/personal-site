---
import Base from '../layouts/Base.astro';
---
<Base title="A. M. Berns" description="Personal website and generative art gallery." showNav={false}>
  <canvas id="bg-canvas" class="bg-canvas" aria-hidden="true"></canvas>

  <section class="hero">
    <h1><span class="hl">A<span class="dot">.</span> M<span class="dot">.</span> Berns</span></h1>
    <p class="lede">
      <span class="hl">Personal website and generative art gallery.</span>
    </p>
  </section>

  <nav class="home-nav" aria-label="Sections">
    <a href="/about">About</a>
    <a href="/taste">Taste</a>
    <a href="/writing">Writing</a>
    <a href="/formalization">Formalization</a>
    <a href="/music">Music</a>
    <a href="/other">Other</a>
  </nav>

  <div class="anim-controls">
    <button id="bg-info" type="button" aria-label="About this animation">About this animation</button>
    <button id="bg-restart" type="button" aria-label="Reset background">Reset</button>
  </div>

  <dialog id="bg-about" aria-labelledby="bg-about-title">
    <button class="bg-about-close" type="button" aria-label="Close">×</button>
    <h2 id="bg-about-title">About this animation</h2>
    <p>
      This animation is generated by a <a href="https://en.wikipedia.org/wiki/Cyclic_cellular_automaton">cyclic cellular automaton</a>. Each iteration of the automaton, a cell of color <em>i</em> becomes color <em>i+1</em> exactly when one of its neighbors (in the Moore neighborhood) is color <em>i+1</em>, and otherwise does nothing. Each cycle of the animation is initialized using a random seed and a randomly chosen template. Moving the mouse around leaves a trail by incrementing the color of the area underneath. Most runs of this animation end up with radiating "devil" spirals that compete for dominance of the screen.
    </p>
  </dialog>
</Base>

<script>
  // Cyclic CA (Moore neighborhood, 8 states). Each cycle pairs one of several
  // multi-stop palettes with a different seeding pattern, so the field looks
  // qualitatively different on every reseed instead of just re-rolling noise.
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 1;
    // Brush radius in cells, sized so the trail reads as ~18 screen px.
    const BRUSH = Math.max(2, Math.round(18 / CELL_PX));
    let W = 0;
    let H = 0;
    let grid = new Uint8Array(0);
    let next = new Uint8Array(0);
    let img: ImageData | null = null;

    type RGB = [number, number, number];

    const styles = getComputedStyle(document.documentElement);
    const paperHex = (styles.getPropertyValue('--paper').trim() || '#0e0e10');

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    const paper = parseHex(paperHex);

    // Full-wheel jewel-tone pool, warm-skewed but spanning every hue so
    // successive cycles vary widely. Each cycle samples one color per luma
    // quartile to keep the dark→light ramp smooth.
    const colorPool: string[] = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ];

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    const sortedPool: RGB[] = colorPool
      .map(parseHex)
      .sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      const len = sortedPool.length;
      const buckets = 8;
      for (let i = 0; i < buckets; i++) {
        const lo = Math.floor((i * len) / buckets);
        const hi = Math.floor(((i + 1) * len) / buckets);
        const idx = lo + ((Math.random() * Math.max(1, hi - lo)) | 0);
        stops.push(sortedPool[idx]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      // stops[0] is paper; the rest are hot stops. Returns N entries.
      const segments = stops.length - 1;
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * segments;
        const seg = Math.min(Math.floor(segF), segments - 1);
        const lt = segF - seg;
        const a = stops[seg];
        const b = stops[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    type Seeder = { name: string; fn: (g: Uint8Array) => void };
    const seeders: Seeder[] = [
      {
        name: 'noise',
        fn: (g) => { for (let i = 0; i < g.length; i++) g[i] = (Math.random() * N) | 0; },
      },
      {
        name: 'sparse',
        fn: (g) => {
          g.fill(0);
          const k = Math.floor(g.length * 0.02);
          for (let i = 0; i < k; i++) g[(Math.random() * g.length) | 0] = (Math.random() * N) | 0;
        },
      },
      {
        name: 'bands',
        fn: (g) => {
          const bands = 6 + ((Math.random() * 6) | 0);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const b = ((x / W) * bands) | 0;
              g[y * W + x] = (b + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'blobs',
        fn: (g) => {
          g.fill(0);
          const blobs = 3 + ((Math.random() * 4) | 0);
          for (let k = 0; k < blobs; k++) {
            const cx = (Math.random() * W) | 0;
            const cy = (Math.random() * H) | 0;
            const r = 8 + ((Math.random() * 18) | 0);
            const r2 = r * r;
            for (let dy = -r; dy <= r; dy++) {
              for (let dx = -r; dx <= r; dx++) {
                if (dx * dx + dy * dy > r2) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                g[y * W + x] = (Math.random() * N) | 0;
              }
            }
          }
        },
      },
      {
        name: 'diagonal',
        fn: (g) => {
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const t = (x + y) / (W + H);
              const base = (t * N) | 0;
              g[y * W + x] = (base + ((Math.random() * 3) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'dense',
        fn: (g) => {
          for (let i = 0; i < g.length; i++) {
            g[i] = Math.random() < 0.5 ? (N - 1) : ((Math.random() * N) | 0);
          }
        },
      },
      {
        name: 'stripes-h',
        fn: (g) => {
          const stripes = 5 + ((Math.random() * 6) | 0);
          for (let y = 0; y < H; y++) {
            const s = (((y / H) * stripes) | 0) % N;
            for (let x = 0; x < W; x++) {
              g[y * W + x] = (s + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'checker',
        fn: (g) => {
          const a = (Math.random() * N) | 0;
          let b = a;
          while (b === a) b = (Math.random() * N) | 0;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const cell = ((x + y) & 1) ? a : b;
              // Replace ~12% of cells with random states so the checker has
              // nucleation sites everywhere instead of stalling after a step.
              g[y * W + x] = Math.random() < 0.12 ? ((Math.random() * N) | 0) : cell;
            }
          }
        },
      },
      {
        name: 'rings',
        fn: (g) => {
          const cx = W / 2;
          const cy = H / 2;
          const ringW = Math.max(2, Math.min(W, H) / (8 + Math.random() * 6));
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const dx = x - cx;
              const dy = y - cy;
              const r = Math.sqrt(dx * dx + dy * dy);
              const base = ((r / ringW) | 0) % N;
              g[y * W + x] = (base + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'quadrants',
        fn: (g) => {
          const a = (Math.random() * N) | 0;
          const b = (a + 2) % N;
          const c = (a + 4) % N;
          const d = (a + 6) % N;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const top = y < H / 2;
              const left = x < W / 2;
              const cell = top ? (left ? a : b) : (left ? c : d);
              g[y * W + x] = (cell + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'dots',
        fn: (g) => {
          for (let i = 0; i < g.length; i++) g[i] = (Math.random() * 3) | 0;
          const spacing = 8 + ((Math.random() * 12) | 0);
          for (let y = spacing >> 1; y < H; y += spacing) {
            for (let x = spacing >> 1; x < W; x += spacing) {
              g[y * W + x] = (Math.random() * N) | 0;
            }
          }
        },
      },
      {
        name: 'waves',
        fn: (g) => {
          const freq = 0.05 + Math.random() * 0.1;
          const amp = 6 + Math.random() * 12;
          const scale = 6;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const v = x + Math.sin(y * freq) * amp;
              const idx = Math.floor(v / scale);
              const base = ((idx % N) + N) % N;
              g[y * W + x] = (base + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'voronoi',
        fn: (g) => {
          const k = 6 + ((Math.random() * 8) | 0);
          const sx = new Int32Array(k);
          const sy = new Int32Array(k);
          const ss = new Uint8Array(k);
          for (let i = 0; i < k; i++) {
            sx[i] = (Math.random() * W) | 0;
            sy[i] = (Math.random() * H) | 0;
            ss[i] = (Math.random() * N) | 0;
          }
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let bestD = Infinity;
              let best = 0;
              for (let i = 0; i < k; i++) {
                const dx = x - sx[i];
                const dy = y - sy[i];
                const d = dx * dx + dy * dy;
                if (d < bestD) { bestD = d; best = ss[i]; }
              }
              g[y * W + x] = (best + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'spokes',
        fn: (g) => {
          const cx = W / 2;
          const cy = H / 2;
          const spokes = 7 + ((Math.random() * 10) | 0);
          const jitter = Math.random() * Math.PI;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const a = Math.atan2(y - cy, x - cx) + Math.PI + jitter;
              const band = ((a / (Math.PI * 2)) * spokes) | 0;
              g[y * W + x] = (band + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'nested-boxes',
        fn: (g) => {
          const cx = W / 2;
          const cy = H / 2;
          const step = 5 + ((Math.random() * 8) | 0);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const box = Math.max(Math.abs(x - cx), Math.abs(y - cy));
              const base = ((box / step) | 0) % N;
              g[y * W + x] = (base + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'crosshatch',
        fn: (g) => {
          const stepA = 5 + ((Math.random() * 7) | 0);
          const stepB = 5 + ((Math.random() * 7) | 0);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const a = (((x + y) / stepA) | 0) % N;
              const b = (((x - y + H) / stepB) | 0) % N;
              g[y * W + x] = (a + b + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'chevrons',
        fn: (g) => {
          const step = 6 + ((Math.random() * 8) | 0);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const folded = Math.abs((x % (step * 2)) - step);
              const base = (((folded + y) / step) | 0) % N;
              g[y * W + x] = (base + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'patchwork',
        fn: (g) => {
          const block = 6 + ((Math.random() * 10) | 0);
          const bw = Math.ceil(W / block);
          const bh = Math.ceil(H / block);
          const states = new Uint8Array(bw * bh);
          for (let i = 0; i < states.length; i++) states[i] = (Math.random() * N) | 0;
          for (let y = 0; y < H; y++) {
            const by = (y / block) | 0;
            for (let x = 0; x < W; x++) {
              const bx = (x / block) | 0;
              const cell = states[by * bw + bx];
              g[y * W + x] = (cell + (Math.random() < 0.08 ? ((Math.random() * N) | 0) : 0)) % N;
            }
          }
        },
      },
      {
        name: 'gradient-noise',
        fn: (g) => {
          // Coarse-cell noise: 4×4 block of pixels share a state, so the seed
          // looks chunky/painterly compared to the per-cell uniform noise.
          const block = 4;
          const cw = Math.ceil(W / block);
          const ch = Math.ceil(H / block);
          const coarse = new Uint8Array(cw * ch);
          for (let i = 0; i < coarse.length; i++) coarse[i] = (Math.random() * N) | 0;
          for (let y = 0; y < H; y++) {
            const cy = (y / block) | 0;
            for (let x = 0; x < W; x++) {
              const cx = (x / block) | 0;
              g[y * W + x] = coarse[cy * cw + cx];
            }
          }
        },
      },
      {
        name: 'phase-gradient',
        fn: (g) => {
          // Smooth phase ramp aligned with the rule: along the gradient
          // direction, neighbors differ by exactly one state per period, so
          // the rule immediately propagates traveling waves across the field.
          const angle = Math.random() * Math.PI * 2;
          const fx = Math.cos(angle);
          const fy = Math.sin(angle);
          const period = 4 + Math.random() * 6;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const v = (x * fx + y * fy) / period;
              const base = ((Math.floor(v) % N) + N) % N;
              g[y * W + x] = (base + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'defect-pairs',
        fn: (g) => {
          // Phase singularities: state cycles 0..N-1 around each center.
          // Canonical spiral-core seed for cyclic CA — every center spawns
          // a stable rotating wavefront immediately. Per-defect arm count
          // (1–4) makes mixed-arm fields, with a chance of a sole 1-arm
          // configuration so the simple spiral case still appears.
          const k = 3 + ((Math.random() * 4) | 0);
          const cxs = new Int32Array(k);
          const cys = new Int32Array(k);
          const sign = new Int8Array(k);
          const offset = new Uint8Array(k);
          const arms = new Uint8Array(k);
          const uniformOneArm = Math.random() < 0.2;
          for (let i = 0; i < k; i++) {
            cxs[i] = (Math.random() * W) | 0;
            cys[i] = (Math.random() * H) | 0;
            sign[i] = Math.random() < 0.5 ? 1 : -1;
            offset[i] = (Math.random() * N) | 0;
            arms[i] = uniformOneArm ? 1 : 1 + ((Math.random() * 4) | 0);
          }
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let bestD = Infinity;
              let bestI = 0;
              for (let i = 0; i < k; i++) {
                const dx = x - cxs[i];
                const dy = y - cys[i];
                const d = dx * dx + dy * dy;
                if (d < bestD) { bestD = d; bestI = i; }
              }
              const dx = x - cxs[bestI];
              const dy = y - cys[bestI];
              const a = Math.atan2(dy, dx) * sign[bestI];
              const phase = (a / (Math.PI * 2) + 1) * N * arms[bestI];
              g[y * W + x] = ((Math.floor(phase) + offset[bestI]) % N + N) % N;
            }
          }
        },
      },
      {
        name: 'reaction',
        fn: (g) => {
          // Two interpenetrating fields: a "hot" region drawing from high
          // states and a "cool" region drawing from low states, separated
          // by a coarse mask. Their boundary spawns colliding wavefronts.
          const block = 18 + ((Math.random() * 18) | 0);
          const cw = Math.ceil(W / block);
          const ch = Math.ceil(H / block);
          const mask = new Uint8Array(cw * ch);
          for (let i = 0; i < mask.length; i++) mask[i] = Math.random() < 0.5 ? 1 : 0;
          const hi = (N >> 1) + 1;
          for (let y = 0; y < H; y++) {
            const by = (y / block) | 0;
            for (let x = 0; x < W; x++) {
              const bx = (x / block) | 0;
              const m = mask[by * cw + bx];
              g[y * W + x] = m
                ? hi + ((Math.random() * (N - hi)) | 0)
                : ((Math.random() * hi) | 0);
            }
          }
        },
      },
      {
        name: 'value-noise',
        fn: (g) => {
          // Multi-octave bilinear value noise — smooth, organic gradients
          // in state space (vs. gradient-noise's blocky 4×4 cells).
          const octaves = 3;
          type Layer = { vals: Float32Array; cw: number; block: number };
          const layers: Layer[] = [];
          for (let o = 0; o < octaves; o++) {
            const block = 32 >> o;
            const lcw = Math.ceil(W / block) + 1;
            const lch = Math.ceil(H / block) + 1;
            const vals = new Float32Array(lcw * lch);
            for (let i = 0; i < vals.length; i++) vals[i] = Math.random();
            layers.push({ vals, cw: lcw, block });
          }
          let totalAmp = 0;
          for (let o = 0; o < octaves; o++) totalAmp += 1 / (1 << o);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let v = 0;
              for (let o = 0; o < octaves; o++) {
                const { vals, cw: lcw, block } = layers[o];
                const fx = x / block;
                const fy = y / block;
                const ix = fx | 0;
                const iy = fy | 0;
                const tx = fx - ix;
                const ty = fy - iy;
                const a = vals[iy * lcw + ix];
                const b = vals[iy * lcw + ix + 1];
                const c = vals[(iy + 1) * lcw + ix];
                const d = vals[(iy + 1) * lcw + ix + 1];
                const ab = a + (b - a) * tx;
                const cd = c + (d - c) * tx;
                v += (ab + (cd - ab) * ty) / (1 << o);
              }
              v /= totalAmp;
              g[y * W + x] = ((v * N) | 0) % N;
            }
          }
        },
      },
      {
        name: 'swirl',
        fn: (g) => {
          // Log-spiral phase: combines angular and radial phase so that
          // following any spiral arm advances state monotonically — already
          // most of the way to the rule's natural attractor.
          const cx = W / 2 + (Math.random() - 0.5) * W * 0.3;
          const cy = H / 2 + (Math.random() - 0.5) * H * 0.3;
          const k = 0.3 + Math.random() * 0.7;
          // Wider arm range with occasional higher counts; the |0 plus the
          // ramping random keeps small-arm fields common while still landing
          // on 5–7 arms once in a while.
          const arms = 1 + ((Math.random() * Math.random() * 7) | 0);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const dx = x - cx;
              const dy = y - cy;
              const r = Math.sqrt(dx * dx + dy * dy) + 1;
              const a = Math.atan2(dy, dx);
              const phase = a * arms + Math.log(r) * k;
              const base = Math.floor(phase * N / (Math.PI * 2));
              g[y * W + x] = (((base % N) + N) % N + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'interference',
        fn: (g) => {
          // Sum of 3 plane waves at random angles, quantized into states.
          // Produces hex-like phase landscapes with nucleation sites where
          // the sum has its sharpest gradient.
          const waves = 3;
          const dirs: { fx: number; fy: number; period: number }[] = [];
          for (let i = 0; i < waves; i++) {
            const a = Math.random() * Math.PI * 2;
            dirs.push({
              fx: Math.cos(a),
              fy: Math.sin(a),
              period: 6 + Math.random() * 10,
            });
          }
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let v = 0;
              for (let i = 0; i < waves; i++) {
                const d = dirs[i];
                v += Math.sin((x * d.fx + y * d.fy) / d.period * Math.PI * 2);
              }
              const t = (v / waves + 1) / 2;
              g[y * W + x] = (((t * N) | 0) + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'wavefronts',
        fn: (g) => {
          // 2-4 emitter points, each surrounded by concentric arcs whose
          // state advances outward — so each emitter is already a fully
          // formed expanding wave train.
          const k = 2 + ((Math.random() * 3) | 0);
          const ex = new Float32Array(k);
          const ey = new Float32Array(k);
          const ringW = new Float32Array(k);
          for (let i = 0; i < k; i++) {
            ex[i] = Math.random() * W;
            ey[i] = Math.random() * H;
            ringW[i] = 4 + Math.random() * 6;
          }
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let bestD = Infinity;
              let bestI = 0;
              for (let i = 0; i < k; i++) {
                const dx = x - ex[i];
                const dy = y - ey[i];
                const d = dx * dx + dy * dy;
                if (d < bestD) { bestD = d; bestI = i; }
              }
              const r = Math.sqrt(bestD);
              const idx = (r / ringW[bestI]) | 0;
              g[y * W + x] = (idx % N + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'plasma',
        fn: (g) => {
          // Diamond-square / midpoint displacement — produces a smoother,
          // more cloud-like noise than value-noise's bilinear octaves.
          // Power-of-two grid sized to cover the canvas.
          let size = 1;
          const need = Math.max(W, H) + 1;
          while (size + 1 < need) size *= 2;
          const stride = size + 1;
          const buf = new Float32Array(stride * stride);
          buf[0] = Math.random();
          buf[size] = Math.random();
          buf[size * stride] = Math.random();
          buf[size * stride + size] = Math.random();
          let step = size;
          let scale = 0.5;
          while (step > 1) {
            const half = step >> 1;
            for (let y = half; y < size; y += step) {
              for (let x = half; x < size; x += step) {
                const a = buf[(y - half) * stride + (x - half)];
                const b = buf[(y - half) * stride + (x + half)];
                const c = buf[(y + half) * stride + (x - half)];
                const d = buf[(y + half) * stride + (x + half)];
                buf[y * stride + x] = (a + b + c + d) / 4 + (Math.random() - 0.5) * scale;
              }
            }
            for (let y = 0; y <= size; y += half) {
              const xStart = ((y / half) & 1) === 0 ? half : 0;
              for (let x = xStart; x <= size; x += step) {
                let s = 0, n = 0;
                if (y >= half) { s += buf[(y - half) * stride + x]; n++; }
                if (y + half <= size) { s += buf[(y + half) * stride + x]; n++; }
                if (x >= half) { s += buf[y * stride + (x - half)]; n++; }
                if (x + half <= size) { s += buf[y * stride + (x + half)]; n++; }
                buf[y * stride + x] = s / n + (Math.random() - 0.5) * scale;
              }
            }
            step = half;
            scale *= 0.55;
          }
          // Normalize and quantize.
          let lo = Infinity;
          let hi = -Infinity;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const v = buf[y * stride + x];
              if (v < lo) lo = v;
              if (v > hi) hi = v;
            }
          }
          const range = hi - lo || 1;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const t = (buf[y * stride + x] - lo) / range;
              g[y * W + x] = (((t * N) | 0) % N + N) % N;
            }
          }
        },
      },
      {
        name: 'vortex-pair',
        fn: (g) => {
          // Two counter-rotating phase singularities placed close together.
          // The dipole phase (a1 - a2) gives a coherent wavefront emitted
          // perpendicular to the axis between them.
          const dist = 30 + Math.random() * 60;
          const angle = Math.random() * Math.PI * 2;
          const cx = W / 2 + (Math.random() - 0.5) * W * 0.3;
          const cy = H / 2 + (Math.random() - 0.5) * H * 0.3;
          const ax = cx + Math.cos(angle) * dist / 2;
          const ay = cy + Math.sin(angle) * dist / 2;
          const bx = cx - Math.cos(angle) * dist / 2;
          const by = cy - Math.sin(angle) * dist / 2;
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const a1 = Math.atan2(y - ay, x - ax);
              const a2 = Math.atan2(y - by, x - bx);
              const phase = (a1 - a2) / (Math.PI * 2);
              const v = Math.floor(phase * N) % N;
              g[y * W + x] = ((v + N) % N + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'moire',
        fn: (g) => {
          // Two plane sine waves with close frequencies — their sum has a
          // beat envelope, so quantizing produces wide bands of fringes
          // separated by quieter intervals.
          const a1 = Math.random() * Math.PI * 2;
          const a2 = a1 + (Math.random() - 0.5) * 0.4;
          const p1 = 6 + Math.random() * 6;
          const p2 = p1 * (0.92 + Math.random() * 0.06);
          const fx1 = Math.cos(a1), fy1 = Math.sin(a1);
          const fx2 = Math.cos(a2), fy2 = Math.sin(a2);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const v = Math.sin((x * fx1 + y * fy1) / p1 * Math.PI * 2)
                      + Math.sin((x * fx2 + y * fy2) / p2 * Math.PI * 2);
              const t = (v + 2) / 4;
              g[y * W + x] = (((t * N) | 0) + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
      {
        name: 'basins',
        fn: (g) => {
          // Voronoi cells, but state inside each cell forms concentric
          // rings around its seed — every cell becomes a small target,
          // already most of the way to a stable wave source.
          const k = 8 + ((Math.random() * 10) | 0);
          const sx = new Int32Array(k);
          const sy = new Int32Array(k);
          const ringW = new Float32Array(k);
          const offset = new Uint8Array(k);
          for (let i = 0; i < k; i++) {
            sx[i] = (Math.random() * W) | 0;
            sy[i] = (Math.random() * H) | 0;
            ringW[i] = 3 + Math.random() * 4;
            offset[i] = (Math.random() * N) | 0;
          }
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let bestD = Infinity;
              let bestI = 0;
              for (let i = 0; i < k; i++) {
                const dx = x - sx[i];
                const dy = y - sy[i];
                const d = dx * dx + dy * dy;
                if (d < bestD) { bestD = d; bestI = i; }
              }
              const r = Math.sqrt(bestD);
              g[y * W + x] = (((r / ringW[bestI]) | 0) + offset[bestI]) % N;
            }
          }
        },
      },
      {
        name: 'stratified',
        fn: (g) => {
          // Horizontal strata, each with its own phase-gradient direction
          // and period. Strata boundaries become high-contrast interfaces
          // that nucleate fronts.
          const layers = 4 + ((Math.random() * 4) | 0);
          type Dir = { fx: number; fy: number; period: number; offset: number };
          const dirs: Dir[] = [];
          for (let i = 0; i < layers; i++) {
            const a = Math.random() * Math.PI * 2;
            dirs.push({
              fx: Math.cos(a),
              fy: Math.sin(a),
              period: 5 + Math.random() * 6,
              offset: Math.random() * N,
            });
          }
          for (let y = 0; y < H; y++) {
            const layer = Math.min(layers - 1, ((y / H) * layers) | 0);
            const d = dirs[layer];
            for (let x = 0; x < W; x++) {
              const v = (x * d.fx + y * d.fy) / d.period + d.offset;
              const base = ((Math.floor(v) % N) + N) % N;
              g[y * W + x] = (base + ((Math.random() * 2) | 0)) % N;
            }
          }
        },
      },
    ];

    // Shuffled-deck picker: every cycle pops the next seeder from a
    // shuffled deck of all indices, and the deck is reshuffled once empty.
    // Guarantees every seeder is shown before any repeats, while ordering
    // within each deck stays random. The first card of a fresh deck is
    // swapped if it would replay the seeder that just ended.
    let deck: number[] = [];
    function refillDeck(avoidFirst: number) {
      const idxs: number[] = [];
      for (let i = 0; i < seeders.length; i++) idxs.push(i);
      for (let i = idxs.length - 1; i > 0; i--) {
        const j = (Math.random() * (i + 1)) | 0;
        const tmp = idxs[i]; idxs[i] = idxs[j]; idxs[j] = tmp;
      }
      if (avoidFirst >= 0 && idxs.length > 1 && idxs[0] === avoidFirst) {
        const tmp = idxs[0]; idxs[0] = idxs[1]; idxs[1] = tmp;
      }
      deck = idxs;
    }
    function nextSeederIdx(current: number): number {
      if (deck.length === 0) refillDeck(current);
      return deck.shift()!;
    }

    let seedIdx = nextSeederIdx(-1);
    let currentStops: RGB[] = pickStops();
    let palette: RGB[] = buildPalette([paper, ...currentStops]);

    // The canvas is rendered at opacity 0.5, so the on-screen color of any
    // cell is the palette color blended 50/50 with paper. Mirror that blend
    // when exposing the current palette stops as CSS variables.
    const canvasOpacity = parseFloat(getComputedStyle(canvas).opacity) || 1;
    function blendOnPaper(c: RGB): string {
      const a = canvasOpacity;
      const r = Math.round(a * c[0] + (1 - a) * paper[0]);
      const g = Math.round(a * c[1] + (1 - a) * paper[1]);
      const b = Math.round(a * c[2] + (1 - a) * paper[2]);
      return `rgb(${r}, ${g}, ${b})`;
    }
    function syncAccent() {
      // Expose each picked stop as --c1..--cN so the homepage can colorize
      // dots, tagline, and per-link nav hovers with distinct palette entries.
      // --accent tracks the brightest stop for the rest of the site.
      const root = document.documentElement.style;
      for (let i = 0; i < currentStops.length; i++) {
        root.setProperty(`--c${i + 1}`, blendOnPaper(currentStops[i]));
      }
      root.setProperty('--accent', blendOnPaper(currentStops[currentStops.length - 1]));
    }
    syncAccent();

    function applyCycle() {
      currentStops = pickStops();
      palette = buildPalette([paper, ...currentStops]);
      seeders[seedIdx].fn(grid);
      syncAccent();
    }

    function advanceCycle() {
      seedIdx = nextSeederIdx(seedIdx);
      applyCycle();
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      grid = new Uint8Array(W * H);
      next = new Uint8Array(W * H);
      img = ctx.createImageData(W, H);
      applyCycle();
    }

    function step() {
      for (let y = 0; y < H; y++) {
        const yU = ((y - 1 + H) % H) * W;
        const yD = ((y + 1) % H) * W;
        const yC = y * W;
        for (let x = 0; x < W; x++) {
          const xL = (x - 1 + W) % W;
          const xR = (x + 1) % W;
          const s = grid[yC + x];
          const t = (s + 1) % N;
          const found =
            grid[yU + xL] === t || grid[yU + x] === t || grid[yU + xR] === t ||
            grid[yC + xL] === t ||                       grid[yC + xR] === t ||
            grid[yD + xL] === t || grid[yD + x] === t || grid[yD + xR] === t;
          next[yC + x] = found ? t : s;
        }
      }
      const tmp = grid;
      grid = next;
      next = tmp;
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let i = 0; i < grid.length; i++) {
        const c = palette[grid[i]];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    draw();

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { resize(); draw(); }, 200);
    });

    // Bumps each covered cell forward by one cyclic state. A per-event
    // dedup set keeps fast moves with brush overlap from bumping the same
    // cell multiple times within one pointermove.
    const paintedThisEvent = new Set<number>();
    function paintBrush(gx: number, gy: number) {
      const r2 = BRUSH * BRUSH;
      for (let dy = -BRUSH; dy <= BRUSH; dy++) {
        const y = gy + dy;
        if (y < 0 || y >= H) continue;
        const row = y * W;
        for (let dx = -BRUSH; dx <= BRUSH; dx++) {
          if (dx * dx + dy * dy > r2) continue;
          const x = gx + dx;
          if (x < 0 || x >= W) continue;
          const idx = row + x;
          if (paintedThisEvent.has(idx)) continue;
          paintedThisEvent.add(idx);
          grid[idx] = (grid[idx] + 1) % N;
        }
      }
    }

    // Continuous hover trail: interpolate cells between successive pointer
    // events so fast moves stay solid. Each visited cell is advanced to its
    // next cyclic state, so the trail color depends on what was underneath.
    let lastGx = -1;
    let lastGy = -1;
    function trailFromPointer(e: PointerEvent) {
      paintedThisEvent.clear();
      const rect = canvas.getBoundingClientRect();
      const gx = Math.floor(((e.clientX - rect.left) / rect.width) * W);
      const gy = Math.floor(((e.clientY - rect.top) / rect.height) * H);
      if (lastGx >= 0) {
        const dx = gx - lastGx;
        const dy = gy - lastGy;
        const steps = Math.max(Math.abs(dx), Math.abs(dy));
        for (let i = 0; i <= steps; i++) {
          const t = steps === 0 ? 0 : i / steps;
          paintBrush(Math.round(lastGx + dx * t), Math.round(lastGy + dy * t));
        }
      } else {
        paintBrush(gx, gy);
      }
      lastGx = gx;
      lastGy = gy;
    }
    window.addEventListener('pointermove', trailFromPointer);
    window.addEventListener('pointerleave', () => { lastGx = -1; lastGy = -1; });
    window.addEventListener('pointerout', (e) => {
      if (!e.relatedTarget) { lastGx = -1; lastGy = -1; }
    });

    const RESEED_MS = 60000;
    const FADE_MS = 150;
    let cycleTimer: number | undefined;

    function triggerCycle() {
      canvas.style.opacity = '0';
      window.setTimeout(() => {
        advanceCycle();
        canvas.style.opacity = '';
      }, FADE_MS);
    }

    function scheduleAutoCycle() {
      window.clearInterval(cycleTimer);
      cycleTimer = window.setInterval(triggerCycle, RESEED_MS);
    }

    const restartBtn = document.getElementById('bg-restart');
    restartBtn?.addEventListener('click', () => {
      triggerCycle();
      scheduleAutoCycle();
    });

    const aboutDlg = document.getElementById('bg-about') as HTMLDialogElement | null;
    const infoBtn = document.getElementById('bg-info');
    infoBtn?.addEventListener('click', () => aboutDlg?.showModal());
    aboutDlg?.querySelector('.bg-about-close')?.addEventListener('click', () => aboutDlg.close());
    aboutDlg?.addEventListener('click', (e) => {
      // Click on the backdrop (outside the dialog box) closes it.
      if (e.target === aboutDlg) aboutDlg.close();
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      let last = 0;
      const targetMs = 80;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);

      scheduleAutoCycle();
    }
  }
</script>
