---
import Base from '../layouts/Base.astro';
---
<Base title="A. M. Berns" description="Independent research, personal writing, Lean, and other." showNav={false}>
  <canvas id="bg-canvas" class="bg-canvas" aria-hidden="true"></canvas>

  <section class="hero">
    <h1>A<span class="dot">.</span> M<span class="dot">.</span> Berns</h1>
    <p class="lede">
      Independent research, personal writing, Lean, and other.
    </p>
  </section>

  <nav class="home-nav" aria-label="Sections">
    <a href="/about">About</a>
    <a href="/writing">Writing</a>
    <a href="/lean">Lean</a>
    <a href="/other">Other</a>
  </nav>
</Base>

<script>
  // Cyclic cellular automaton (Belousov-Zhabotinsky-style):
  // a cell at state s advances to (s+1) mod N if any 4-neighbor is at (s+1) mod N.
  // From random noise the field self-organizes into rotating spirals.
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 14;
    const CELL_PX = 10; // CSS-pixel size of one cell after pixelated upscale
    let W = 0;
    let H = 0;
    let grid = new Uint8Array(0);
    let next = new Uint8Array(0);
    let img: ImageData | null = null;

    const styles = getComputedStyle(document.documentElement);
    const parseHex = (h: string): [number, number, number] => {
      const s = h.trim().replace('#', '');
      const n = parseInt(s.length === 3 ? s.split('').map((c) => c + c).join('') : s, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    const c0 = parseHex(styles.getPropertyValue('--paper') || '#0e0e10');
    const c1 = parseHex(styles.getPropertyValue('--accent') || '#ff6648');
    const palette: [number, number, number][] = [];
    for (let i = 0; i < N; i++) {
      const t = i / (N - 1);
      const e = Math.pow(t, 0.85);
      palette.push([
        Math.round(c0[0] + (c1[0] - c0[0]) * e),
        Math.round(c0[1] + (c1[1] - c0[1]) * e),
        Math.round(c0[2] + (c1[2] - c0[2]) * e),
      ]);
    }

    function reseed() {
      for (let i = 0; i < grid.length; i++) grid[i] = (Math.random() * N) | 0;
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      grid = new Uint8Array(W * H);
      next = new Uint8Array(W * H);
      img = ctx.createImageData(W, H);
      reseed();
    }

    function step() {
      for (let y = 0; y < H; y++) {
        const yU = ((y - 1 + H) % H) * W;
        const yD = ((y + 1) % H) * W;
        const yC = y * W;
        for (let x = 0; x < W; x++) {
          const xL = (x - 1 + W) % W;
          const xR = (x + 1) % W;
          const s = grid[yC + x];
          const target = (s + 1) % N;
          next[yC + x] = (
            grid[yU + x] === target ||
            grid[yD + x] === target ||
            grid[yC + xL] === target ||
            grid[yC + xR] === target
          ) ? target : s;
        }
      }
      const tmp = grid;
      grid = next;
      next = tmp;
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let i = 0; i < grid.length; i++) {
        const c = palette[grid[i]];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    draw();

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        resize();
        draw();
      }, 200);
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      let last = 0;
      const targetMs = 80;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);

      // Periodically fade out, reseed, and fade back in so the field never
      // sits in a converged state for long.
      const RESEED_MS = 75000;
      const FADE_MS = 800;
      setInterval(() => {
        canvas.style.opacity = '0';
        window.setTimeout(() => {
          reseed();
          canvas.style.opacity = '';
        }, FADE_MS);
      }, RESEED_MS);
    }
  }
</script>
