---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { otherWriting, published } from '../../data/published';

const sequences: Record<string, { title: string; href?: string }> = {
  cooperation: {
    title: 'Verification for Cooperation',
    href: '/essays/verification-for-cooperation/',
  },
};

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const sequenceGroups = Object.entries(sequences)
  .map(([id, meta]) => ({
    id,
    meta,
    items: essays
      .filter((n) => n.data.sequence === id && n.data.sequenceOrder !== 0)
      .sort((a, b) => (a.data.sequenceOrder ?? 0) - (b.data.sequenceOrder ?? 0)),
  }))
  .filter((g) => g.items.length > 0);

const otherEssays = essays.filter((n) => !n.data.sequence);

const fmt = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const publishedSorted = [...published].sort((a, b) => b.sortDate.valueOf() - a.sortDate.valueOf());
const otherWritingSorted = [...otherWriting].sort((a, b) => b.sortDate.valueOf() - a.sortDate.valueOf());
---
<Base title="Writing — A. M. Berns" description="Notes, essays, and cross-posts.">
  <div class="writing-shell">
    <canvas id="symbol-evolver" class="symbol-evolver" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1>Writing</h1>
    </header>
    <div class="writing-panes">
      <section class="writing-pane">
        <h2>Published</h2>
        {publishedSorted.length > 0 ? (
          <ul class="note-list">
            {publishedSorted.map((p) => (
              <li>
                <time datetime={p.sortDate.toISOString()}>{p.displayDate}</time>
                <a href={p.url}>{p.title}</a>
                {p.venue && <span class="venue">{p.venue}</span>}
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Nothing here yet.</p>
        )}
      </section>

      <section class="writing-pane">
        <h2>Essays</h2>
        {sequenceGroups.length > 0 ? (
          <div class="sequence-groups">
            {sequenceGroups.map((g) => (
              <div class="sequence-group">
                <h3>
                  {g.meta.href ? <a href={g.meta.href}>{g.meta.title}</a> : g.meta.title}
                </h3>
                <ol class="note-list note-list--ordered">
                  {g.items.map((n) => (
                    <li>
                      <a href={`/essays/${n.id}/`}>{n.data.title}</a>
                    </li>
                  ))}
                </ol>
              </div>
            ))}
          </div>
        ) : (
          <p class="empty">Nothing here yet.</p>
        )}
      </section>

      <section class="writing-pane">
        <h2>Other</h2>
        {otherWritingSorted.length > 0 || otherEssays.length > 0 ? (
          <ul class="note-list">
            {otherWritingSorted.map((p) => (
              <li>
                <time datetime={p.sortDate.toISOString()}>{p.displayDate}</time>
                <a href={p.url}>{p.title}</a>
                {p.venue && <span class="venue">{p.venue}</span>}
              </li>
            ))}
            {otherEssays.map((n) => (
              <li>
                <time datetime={n.data.date.toISOString()}>{fmt.format(n.data.date)}</time>
                <a href={`/essays/${n.id}/`}>{n.data.title}</a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Nothing here yet.</p>
        )}
      </section>
    </div>
  </div>
</Base>

<script>
  const canvas = document.getElementById('symbol-evolver') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const targets = [
      'VERIFY BUT TRUST',
      'PRECOMMITMENTS',
      'VERIFICATION FOR COOPERATION',
      'POPULAR CONSTITUTIONALISM',
      'KANTIAN PRACTICAL ETHICS',
    ];
    const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789[]{}<>/\\|+-=*.:;?!#@$%&λ∀∃⊢→↔∧∨¬□◇ ';
    const styles = getComputedStyle(document.documentElement);
    const ink = styles.getPropertyValue('--ink').trim() || '#ececec';
    const muted = styles.getPropertyValue('--muted').trim() || '#8e8e88';
    const accent = styles.getPropertyValue('--accent').trim() || '#c8c4ba';
    const fontFamily = 'ui-monospace, SFMono-Regular, Menlo, Consolas, monospace';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const populationSize = 34;
    const eliteCount = 6;
    const mutationRate = 0.05;
    let targetIndex = 0;
    let target = targets[targetIndex];
    let population: string[] = [];
    let holdFrames = 0;
    let w = 0;
    let h = 0;
    let dpr = 1;
    let lastStep = 0;

    function randomChar(i: number): string {
      if (target[i] === ' ' && Math.random() < 0.7) return ' ';
      return alphabet[(Math.random() * alphabet.length) | 0];
    }

    function randomGenome(): string {
      let out = '';
      for (let i = 0; i < target.length; i++) out += randomChar(i);
      return out;
    }

    function resetPopulation() {
      population = Array.from({ length: populationSize }, randomGenome);
      holdFrames = 0;
    }

    function fitness(genome: string): number {
      let score = 0;
      for (let i = 0; i < target.length; i++) {
        if (genome[i] === target[i]) score += 4;
        else if (target[i] !== ' ' && genome[i] !== ' ') score += 1 / (1 + Math.abs(genome.charCodeAt(i) - target.charCodeAt(i)) / 16);
      }
      return score;
    }

    function sortedPopulation(): string[] {
      return [...population].sort((a, b) => fitness(b) - fitness(a));
    }

    function selectParent(sorted: string[]): string {
      const cutoff = Math.max(eliteCount, Math.floor(populationSize * 0.45));
      return sorted[Math.floor((Math.random() ** 1.8) * cutoff)];
    }

    function mutateAt(i: number): string {
      if (Math.random() < 0.22) return target[i];
      return randomChar(i);
    }

    function breed(a: string, b: string): string {
      const pivot = 1 + ((Math.random() * Math.max(1, target.length - 2)) | 0);
      let out = '';
      for (let i = 0; i < target.length; i++) {
        const inherited = i < pivot ? a[i] : b[i];
        out += Math.random() < mutationRate ? mutateAt(i) : inherited;
      }
      return out;
    }

    function nextTarget() {
      targetIndex = (targetIndex + 1) % targets.length;
      target = targets[targetIndex];
      resetPopulation();
    }

    function evolve() {
      const sorted = sortedPopulation();
      const maxFitness = target.length * 4;
      if (fitness(sorted[0]) >= maxFitness) {
        holdFrames++;
        if (holdFrames > 26) nextTarget();
        return;
      }

      const next = sorted.slice(0, eliteCount);
      while (next.length < populationSize) {
        next.push(breed(selectParent(sorted), selectParent(sorted)));
      }
      population = next;
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = Math.max(1, rect.width);
      h = Math.max(1, rect.height);
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw() {
      const sorted = sortedPopulation();
      const fontSize = w < 520 ? 12 : 14;
      const lineHeight = fontSize * 1.55;
      const charWidth = fontSize * 0.66;
      const rows = Math.min(sorted.length, Math.max(8, Math.floor((h - 12) / lineHeight)));
      const x0 = Math.max(4, w - target.length * charWidth - 12);

      ctx.clearRect(0, 0, w, h);
      ctx.textBaseline = 'middle';
      ctx.font = `${fontSize}px ${fontFamily}`;

      for (let row = 0; row < rows; row++) {
        const genome = sorted[row] ?? randomGenome();
        const y = 8 + row * lineHeight;
        const alpha = row === 0 ? 0.86 : Math.max(0.14, 0.46 - row * 0.026);

        for (let i = 0; i < target.length; i++) {
          const matched = genome[i] === target[i];
          ctx.globalAlpha = matched ? Math.min(0.95, alpha + 0.22) : alpha;
          ctx.fillStyle = matched ? accent : (row === 0 ? ink : muted);
          ctx.fillText(genome[i], x0 + i * charWidth, y);
        }
      }

      ctx.globalAlpha = 1;
    }

    resetPopulation();
    resize();
    draw();
    window.addEventListener('resize', resize);

    if (reduce) {
      for (let i = 0; i < 90; i++) evolve();
      draw();
    } else {
      const loop = (t: number) => {
        if (t - lastStep > 70) {
          evolve();
          lastStep = t;
        }
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>
