---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { published } from '../../data/published';
import markovModel from '../../data/markov_model.json';

const sequences: Record<string, { title: string; href?: string }> = {
  cooperation: {
    title: 'Verification for Cooperation',
    href: '/essays/verification-for-cooperation/',
  },
};

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const sequenceGroups = Object.entries(sequences)
  .map(([id, meta]) => ({
    id,
    meta,
    items: essays
      .filter((n) => n.data.sequence === id && n.data.sequenceOrder !== 0)
      .sort((a, b) => (a.data.sequenceOrder ?? 0) - (b.data.sequenceOrder ?? 0)),
  }))
  .filter((g) => g.items.length > 0);

const otherEssays = essays.filter((n) => !n.data.sequence);

const publishedSorted = [...published].sort((a, b) => b.sortDate.valueOf() - a.sortDate.valueOf());
---
<Base title="Writing — A. M. Berns" description="Notes, essays, and cross-posts.">
  <div class="writing-shell">
    <canvas id="markov-text" class="markov-text" aria-hidden="true"></canvas>
    <div class="anim-controls" aria-label="Writing animation controls">
      <button id="writing-info" type="button" aria-label="About">About</button>
      <button id="writing-reset" type="button" aria-label="Reset Writing animation">Reset</button>
    </div>
    <dialog id="writing-about" class="anim-about" aria-labelledby="writing-about-title">
      <h2 id="writing-about-title">About</h2>
      <p>
        A word-level Markov chain (order 6 with backoff to 1) trained on a small
        library of public-domain philosophy and 19th-century literature: Carlyle,
        Spinoza, Melville, Blake, Plotinus, Schopenhauer, Lindsay, Swedenborg,
        Shelley, Butler, Voltaire, Erasmus, Carroll. The model picks the longest
        matching context it can find, samples weighted by training counts, and
        falls back to shorter contexts when the long ones are unfamiliar. Press
        <kbd>Shift</kbd>+<kbd>D</kbd> for the dev panel.
      </p>
    </dialog>
    <aside class="markov-panel" aria-label="Markov controls">
      <div class="markov-panel-head">
        <h2>Markov</h2>
        <button id="markov-restart" type="button">Restart</button>
      </div>
      <div class="markov-panel-body">
        <div class="markov-panel-row">
          <label for="markov-order">order</label>
          <input id="markov-order" type="range" min="1" max="6" step="1" value="6" />
          <span id="markov-order-value">6</span>
        </div>
        <div class="markov-panel-row">
          <label for="markov-temp">temp</label>
          <input id="markov-temp" type="range" min="0.20" max="1.40" step="0.02" value="0.78" />
          <span id="markov-temp-value">0.78</span>
        </div>
        <div class="markov-panel-row">
          <label for="markov-speed">speed</label>
          <input id="markov-speed" type="range" min="1" max="14" step="1" value="6" />
          <span id="markov-speed-value">6</span>
        </div>
        <div class="markov-panel-row">
          <label for="markov-pixel">size</label>
          <input id="markov-pixel" type="range" min="1" max="3" step="1" value="2" />
          <span id="markov-pixel-value">2</span>
        </div>
        <div class="markov-panel-row">
          <label for="markov-contrast">lift</label>
          <input id="markov-contrast" type="range" min="140" max="240" step="2" value="190" />
          <span id="markov-contrast-value">190</span>
        </div>
        <label class="markov-panel-toggle" for="markov-repguard">
          <input id="markov-repguard" type="checkbox" checked />
          <span>repetition guard</span>
        </label>
        <dl class="markov-stats">
          <div><dt>order used</dt><dd id="markov-used">-</dd></div>
          <div><dt>tokens</dt><dd id="markov-tokens">0</dd></div>
        </dl>
      </div>
    </aside>
    <header class="section-head">
      <h1>Writing</h1>
    </header>
    <div class="writing-panes">
      <section class="writing-pane">
        <h2>Published</h2>
        {publishedSorted.length > 0 ? (
          <ul class="note-list">
            {publishedSorted.map((p) => (
              <li>
                <a href={p.url}>{p.title}</a>
                {p.venue && <span class="venue">{p.venue}</span>}
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Nothing here yet.</p>
        )}
      </section>

      <section class="writing-pane">
        <h2>Blog</h2>
        {sequenceGroups.length > 0 || otherEssays.length > 0 ? (
          <div class="sequence-groups">
            {sequenceGroups.map((g) => (
              <div class="sequence-group">
                <h3>
                  {g.meta.href ? <a href={g.meta.href}>{g.meta.title}</a> : g.meta.title}
                </h3>
                <ol class="note-list note-list--ordered">
                  {g.items.map((n) => (
                    <li>
                      <a href={`/essays/${n.id}/`}>{n.data.title}</a>
                    </li>
                  ))}
                </ol>
              </div>
            ))}
            {otherEssays.length > 0 && (
              <div class="sequence-group">
                <ul class="note-list">
                  {otherEssays.map((n) => (
                    <li>
                      <a href={`/essays/${n.id}/`}>{n.data.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ) : (
          <p class="empty">Nothing here yet.</p>
        )}
      </section>
    </div>
  </div>
</Base>

<style>
  .markov-panel {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 3;
    width: 16rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .markov-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .markov-panel-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .markov-panel button {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
  }
  .markov-panel button:hover { color: var(--ink); border-color: var(--muted); }
  .markov-panel-row {
    display: grid;
    grid-template-columns: 4rem 1fr 3.3rem;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .markov-panel-row label { font-size: 0.7rem; color: var(--muted); }
  .markov-panel-row input[type="range"] { width: 100%; accent-color: var(--accent); margin: 0; }
  .markov-panel-row span {
    font-size: 0.68rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .markov-panel-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.45rem 0 0.1rem;
    font-size: 0.7rem;
    color: var(--muted);
    cursor: pointer;
  }
  .markov-panel-toggle input[type="checkbox"] {
    accent-color: var(--accent);
    margin: 0;
    cursor: pointer;
  }
  .markov-panel-toggle:hover { color: var(--ink); }
  .markov-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin: 0.6rem 0 0;
    font-size: 0.65rem;
  }
  .markov-stats div {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.3rem;
    overflow: hidden;
  }
  .markov-stats dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .markov-stats dd {
    margin: 0;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  html:not(.dev-mode) .markov-panel { display: none !important; }
</style>

<script define:vars={{ markovModel }}>
  // ---------------------------------------------------------------
  // Word-level higher-order Markov backoff renderer.
  //
  // The model JSON is shaped:
  //   { kind, order, startToken, endToken, orders: { "1": {...}, ..., "6": {...} } }
  // Each `orders[N]` maps a tab-joined N-gram to [[nextToken, count], ...].
  // ---------------------------------------------------------------
  const canvas = document.getElementById('markov-text');
  const resetButton = document.getElementById('writing-reset');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    ctx.imageSmoothingEnabled = false;

    // ---------- Tunables (mirrored by the dev panel) ----------
    const MODEL_ORDER = markovModel.order ?? 6;
    let maxEffectiveOrder = MODEL_ORDER;
    let TEMPERATURE = 0.78;
    let TYPING_RATE = 6;        // tokens per animation tick
    let PIXEL = 2;
    let MIN_LUMA = 190;          // brightest "lift floor" for paint colors
    let useRepGuard = true;

    const orders = markovModel.orders ?? { [String(MODEL_ORDER)]: markovModel.states ?? {} };
    const START = markovModel.startToken ?? '<S>';
    const END   = markovModel.endToken   ?? '<E>';

    // ---------- Layout ----------
    const GLYPH_W = 5;
    const GLYPH_H = 7;
    const LETTER_GAP = 1;
    const LINE_GAP = 3;
    const HOLD_FRAMES = 90;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---------- Pixel font ----------
    const FONT = {
      A: ['01110', '10001', '10001', '11111', '10001', '10001', '10001'],
      B: ['11110', '10001', '10001', '11110', '10001', '10001', '11110'],
      C: ['01111', '10000', '10000', '10000', '10000', '10000', '01111'],
      D: ['11110', '10001', '10001', '10001', '10001', '10001', '11110'],
      E: ['11111', '10000', '10000', '11110', '10000', '10000', '11111'],
      F: ['11111', '10000', '10000', '11110', '10000', '10000', '10000'],
      G: ['01111', '10000', '10000', '10111', '10001', '10001', '01111'],
      H: ['10001', '10001', '10001', '11111', '10001', '10001', '10001'],
      I: ['11111', '00100', '00100', '00100', '00100', '00100', '11111'],
      J: ['00111', '00010', '00010', '00010', '10010', '10010', '01100'],
      K: ['10001', '10010', '10100', '11000', '10100', '10010', '10001'],
      L: ['10000', '10000', '10000', '10000', '10000', '10000', '11111'],
      M: ['10001', '11011', '10101', '10101', '10001', '10001', '10001'],
      N: ['10001', '11001', '10101', '10011', '10001', '10001', '10001'],
      O: ['01110', '10001', '10001', '10001', '10001', '10001', '01110'],
      P: ['11110', '10001', '10001', '11110', '10000', '10000', '10000'],
      Q: ['01110', '10001', '10001', '10001', '10101', '10010', '01101'],
      R: ['11110', '10001', '10001', '11110', '10100', '10010', '10001'],
      S: ['01111', '10000', '10000', '01110', '00001', '00001', '11110'],
      T: ['11111', '00100', '00100', '00100', '00100', '00100', '00100'],
      U: ['10001', '10001', '10001', '10001', '10001', '10001', '01110'],
      V: ['10001', '10001', '10001', '10001', '10001', '01010', '00100'],
      W: ['10001', '10001', '10001', '10101', '10101', '10101', '01010'],
      X: ['10001', '10001', '01010', '00100', '01010', '10001', '10001'],
      Y: ['10001', '10001', '01010', '00100', '00100', '00100', '00100'],
      Z: ['11111', '00001', '00010', '00100', '01000', '10000', '11111'],
      '0': ['01110', '10001', '10011', '10101', '11001', '10001', '01110'],
      '1': ['00100', '01100', '00100', '00100', '00100', '00100', '01110'],
      '2': ['01110', '10001', '00001', '00010', '00100', '01000', '11111'],
      '3': ['11110', '00001', '00001', '01110', '00001', '00001', '11110'],
      '4': ['00010', '00110', '01010', '10010', '11111', '00010', '00010'],
      '5': ['11111', '10000', '10000', '11110', '00001', '00001', '11110'],
      '6': ['01110', '10000', '10000', '11110', '10001', '10001', '01110'],
      '7': ['11111', '00001', '00010', '00100', '01000', '01000', '01000'],
      '8': ['01110', '10001', '10001', '01110', '10001', '10001', '01110'],
      '9': ['01110', '10001', '10001', '01111', '00001', '00001', '01110'],
      '.': ['00000', '00000', '00000', '00000', '00000', '01100', '01100'],
      ',': ['00000', '00000', '00000', '00000', '01100', '00100', '01000'],
      ';': ['00000', '01100', '01100', '00000', '01100', '00100', '01000'],
      ':': ['00000', '01100', '01100', '00000', '01100', '01100', '00000'],
      '!': ['00100', '00100', '00100', '00100', '00100', '00000', '00100'],
      '?': ['01110', '10001', '00001', '00010', '00100', '00000', '00100'],
      "'": ['00100', '00100', '01000', '00000', '00000', '00000', '00000'],
      '"': ['01010', '01010', '00000', '00000', '00000', '00000', '00000'],
      '-': ['00000', '00000', '00000', '11110', '00000', '00000', '00000'],
      '(': ['00010', '00100', '01000', '01000', '01000', '00100', '00010'],
      ')': ['01000', '00100', '00010', '00010', '00010', '00100', '01000'],
      ' ': ['00000', '00000', '00000', '00000', '00000', '00000', '00000'],
    };

    // ---------- Color helpers ----------
    function parseHex(h) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }
    function rgb(c) { return `rgb(${c[0]} ${c[1]} ${c[2]})`; }
    function mix(a, b, t) {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }
    function luma(c) { return c[0] * 0.2126 + c[1] * 0.7152 + c[2] * 0.0722; }

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex(styles.getPropertyValue('--paper').trim() || '#0e0e10');
    const ink   = parseHex(styles.getPropertyValue('--ink').trim()   || '#ececec');
    // A wider, more saturated palette than before.  Ordered light→dark; we
    // re-sort by luma after bright-lifting so the gradient stays monotone.
    const colorPool = [
      '#fff8d8', '#fff0a8', '#ffe57a', '#ffc14a', '#ffa645',
      '#ff7a4a', '#ff5a5a', '#e54a8a', '#c83a8a', '#9a2bd6',
      '#6a4ad6', '#4a7aff', '#2cc7e0', '#3ad48a', '#a4ff5a',
      '#d6ff5a',
    ].map(parseHex);

    function liftColor(c) {
      // Push every paint colour up to MIN_LUMA, mixing toward white.  Keeps
      // hues distinguishable but lifts the dim end so contrast with paper
      // stays strong.
      let out = c;
      let guard = 0;
      while (luma(out) < MIN_LUMA && guard++ < 24) {
        out = mix(out, [255, 255, 255], 0.18);
      }
      return out;
    }

    // ---------- State ----------
    let W = 0, H = 0;
    let cols = 0, rows = 0;
    let x = 0, y = 0;
    let hold = 0;
    let ctxTokens = [];
    let recentTokens = [];      // sliding window for repetition guard
    let totalTokens = 0;
    let sentenceTokens = 0;
    let needCapitalNext = true; // capitalize the first letter after sentence break
    let palette = [];
    let seed = 0;
    let rng = mulberry32(1);

    function hashString(s) {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }
    function mulberry32(seed) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function startCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      ctxTokens = [];
      for (let i = 0; i < MODEL_ORDER; i++) ctxTokens.push(START);
      recentTokens = [];
      totalTokens = 0;
      sentenceTokens = 0;
      insideQuotes = false;
      stickToPrev = false;
      needCapitalNext = true;
      x = 0; y = 0; hold = 0;
      palette = pickPalette(6);
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      updateStats();
    }

    function pickPalette(count) {
      const lifted = colorPool.map(liftColor).sort((a, b) => luma(a) - luma(b));
      const stops = [];
      for (let i = 0; i < count; i++) {
        const lo = Math.floor((i * lifted.length) / count);
        const hi = Math.floor(((i + 1) * lifted.length) / count);
        stops.push(lifted[lo + Math.floor(rng() * Math.max(1, hi - lo))]);
      }
      document.documentElement.style.setProperty('--accent', rgb(stops[Math.floor(stops.length * 0.6)]));
      return stops;
    }

    function colorForOrder(orderUsed) {
      // Higher matched order = brighter, more confident colour; backoff to
      // order 1 lands at the dim end of the palette.
      const t = Math.max(0, Math.min(1, (orderUsed - 1) / Math.max(1, MODEL_ORDER - 1)));
      const idx = Math.min(palette.length - 1, Math.floor(t * (palette.length - 1) + 0.0001));
      return palette[idx];
    }

    // ---------- Backoff sampler ----------
    function backoffLookup(ctxArr) {
      const cap = Math.min(maxEffectiveOrder, ctxArr.length);
      for (let n = cap; n >= 1; n--) {
        const slice = ctxArr.slice(ctxArr.length - n);
        const key = slice.join('\t');
        const table = orders[String(n)];
        if (!table) continue;
        const entries = table[key];
        if (entries && entries.length) return { entries, order: n };
      }
      return null;
    }

    function sampleWeighted(entries) {
      let total = 0;
      for (let i = 0; i < entries.length; i++) total += entries[i][1];
      const t = Math.max(0.05, TEMPERATURE);
      let weightSum = 0;
      const weights = new Array(entries.length);
      for (let i = 0; i < entries.length; i++) {
        const p = entries[i][1] / total;
        weights[i] = Math.pow(p, 1 / t);
        weightSum += weights[i];
      }
      let roll = rng() * weightSum;
      for (let i = 0; i < entries.length; i++) {
        roll -= weights[i];
        if (roll <= 0) return entries[i][0];
      }
      return entries[entries.length - 1][0];
    }

    function violatesRepGuard(candidate) {
      if (!useRepGuard) return false;
      // Reject candidate if the (last-N tokens + candidate) sequence has
      // already appeared earlier in the recent window.  Catches both
      // immediate cycles and slower phrase-loops.
      const N = 4;
      if (recentTokens.length < N) return false;
      const probe = recentTokens.slice(-N).concat([candidate]).join('\t');
      for (let i = 0; i + N + 1 <= recentTokens.length; i++) {
        const slice = recentTokens.slice(i, i + N + 1).join('\t');
        if (slice === probe) return true;
      }
      return false;
    }

    function nextToken() {
      let look = backoffLookup(ctxTokens);
      if (!look) {
        // Reseed with sentence-start padding.
        ctxTokens = [];
        for (let i = 0; i < MODEL_ORDER; i++) ctxTokens.push(START);
        look = backoffLookup(ctxTokens);
        if (!look) return { token: END, order: 0 };
      }
      let token = sampleWeighted(look.entries);
      // Repetition guard: try a couple of resamples, otherwise fall back
      // to a shorter context to escape a loop.
      if (violatesRepGuard(token)) {
        for (let tries = 0; tries < 3 && violatesRepGuard(token); tries++) {
          token = sampleWeighted(look.entries);
        }
        if (violatesRepGuard(token) && look.order > 1) {
          const shorter = backoffLookup(ctxTokens.slice(0, ctxTokens.length - 1));
          if (shorter) { look = shorter; token = sampleWeighted(shorter.entries); }
        }
      }
      ctxTokens.push(token);
      if (ctxTokens.length > MODEL_ORDER) ctxTokens.shift();
      return { token, order: look.order };
    }

    // ---------- Detokenization for display ----------
    // We track an "inside quotes" toggle and an "after opener" flag so that
    // the renderer knows whether the next token glues to the previous one
    // (no leading space) or is preceded by a space.
    const SENTENCE_PUNCT = /^[.,;:!?]$/;
    let insideQuotes = false;
    let stickToPrev  = false;     // true right after `(`, `[`, or opening `"`

    function renderTokenString(token, justAfterSentenceBreak) {
      if (token === START || token === END) return null;
      let text = token;
      let leadingSpace = true;

      if (SENTENCE_PUNCT.test(text)) {
        leadingSpace = false;
        stickToPrev = false;
      } else if (text === ')' || text === ']') {
        leadingSpace = false;
        stickToPrev = false;
      } else if (text === '(' || text === '[') {
        // Open paren: normal leading space, but next token sticks.
        stickToPrev = true;
      } else if (text === '"') {
        if (insideQuotes) {
          // closing quote
          leadingSpace = false;
          insideQuotes = false;
          stickToPrev = false;
        } else {
          // opening quote
          insideQuotes = true;
          stickToPrev = true;
        }
      } else {
        if (stickToPrev) leadingSpace = false;
        stickToPrev = false;
      }

      if (justAfterSentenceBreak && /^[a-z]/.test(text)) {
        text = text[0].toUpperCase() + text.slice(1);
      }
      return { text, leadingSpace };
    }

    // ---------- Rendering ----------
    function drawChar(ch, col, row, color) {
      const glyph = FONT[ch] ?? FONT[ch.toUpperCase()] ?? FONT['?'];
      const ox = col * (GLYPH_W + LETTER_GAP) * PIXEL;
      const oy = row * (GLYPH_H + LINE_GAP) * PIXEL;
      ctx.fillStyle = rgb(color);
      for (let gy = 0; gy < GLYPH_H; gy++) {
        for (let gx = 0; gx < GLYPH_W; gx++) {
          if (glyph[gy][gx] === '1') ctx.fillRect(ox + gx * PIXEL, oy + gy * PIXEL, PIXEL, PIXEL);
        }
      }
    }

    function emitString(str, color) {
      // Stream characters into the typewriter grid.  Wrap rule: we keep
      // emitting characters of a word past the right edge of the screen up
      // to one column past `cols` (so visually exactly one word straddles
      // the right edge before continuing on the next line).  When emitting
      // a *space* past the edge we wrap, ensuring the space is the break
      // point and the next word starts at column 0.
      for (let i = 0; i < str.length; i++) {
        const ch = str[i];
        if (ch === ' ') {
          if (x >= cols) { x = 0; y++; if (y >= rows) return; continue; }
          x += 1;
          if (x >= cols) { x = 0; y++; if (y >= rows) return; }
          continue;
        }
        if (y >= rows) return;
        drawChar(ch, x, y, color);
        x += 1;
        // We DO NOT wrap mid-word here.  The line bleeds; the next space
        // will trigger the wrap on the next iteration.
      }
    }

    function updateStats() {
      const tEl = document.getElementById('markov-tokens');
      if (tEl) tEl.textContent = String(totalTokens);
    }

    function typeStep(count) {
      for (let i = 0; i < count; i++) {
        if (y >= rows) {
          if (++hold > HOLD_FRAMES) startCycle();
          return;
        }
        const { token, order: orderUsed } = nextToken();
        const usedEl = document.getElementById('markov-used');
        if (usedEl) usedEl.textContent = String(orderUsed);
        totalTokens++;
        if (totalTokens % 4 === 0) updateStats();

        if (token === END) {
          // sentence ended.  start a fresh padded context, with a hint to
          // capitalize the next word and a leading space if mid-line.
          ctxTokens = [];
          for (let k = 0; k < MODEL_ORDER; k++) ctxTokens.push(START);
          needCapitalNext = true;
          sentenceTokens = 0;
          continue;
        }
        const piece = renderTokenString(token, needCapitalNext);
        if (!piece) continue;
        needCapitalNext = false;
        sentenceTokens++;
        recentTokens.push(token);
        if (recentTokens.length > 20) recentTokens.shift();

        const str = (piece.leadingSpace && (x > 0 || y > 0)) ? ' ' + piece.text : piece.text;
        emitString(str, colorForOrder(orderUsed));
      }
    }

    // ---------- Resize / layout ----------
    function resize() {
      const dpr = Math.max(1, window.devicePixelRatio || 1);
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = Math.ceil(W * dpr);
      canvas.height = Math.ceil(H * dpr);
      canvas.style.width = `${W}px`;
      canvas.style.height = `${H}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.imageSmoothingEnabled = false;
      const cellW = (GLYPH_W + LETTER_GAP) * PIXEL;
      const cellH = (GLYPH_H + LINE_GAP) * PIXEL;
      // cols = number of full character cells fitting on screen.  We do
      // NOT pad +1 here — we want the wrap point to be the screen edge so
      // that exactly one word straddles it before wrapping.
      cols = Math.max(1, Math.floor(W / cellW));
      rows = Math.max(1, Math.ceil(H / cellH) + 1);
      startCycle();
      if (reduce) typeStep(cols * rows);
    }

    // ---------- Dev panel wiring ----------
    function bindRange(id, valId, onChange, format = (v) => v) {
      const el = document.getElementById(id);
      const lab = document.getElementById(valId);
      if (!el || !lab) return;
      const sync = () => {
        const v = Number(el.value);
        lab.textContent = String(format(v));
        onChange(v);
      };
      el.addEventListener('input', sync);
      sync();
    }
    bindRange('markov-order', 'markov-order-value', (v) => { maxEffectiveOrder = Math.max(1, Math.min(MODEL_ORDER, v)); });
    bindRange('markov-temp',  'markov-temp-value',  (v) => { TEMPERATURE = v; }, (v) => v.toFixed(2));
    bindRange('markov-speed', 'markov-speed-value', (v) => { TYPING_RATE = v; });
    bindRange('markov-pixel', 'markov-pixel-value', (v) => { PIXEL = v; resize(); });
    bindRange('markov-contrast', 'markov-contrast-value', (v) => { MIN_LUMA = v; palette = pickPalette(6); });
    const repEl = document.getElementById('markov-repguard');
    repEl?.addEventListener('change', () => { useRepGuard = !!repEl.checked; });
    document.getElementById('markov-restart')?.addEventListener('click', startCycle);

    resize();
    resetButton?.addEventListener('click', startCycle);
    const infoButton = document.getElementById('writing-info');
    const aboutDialog = document.getElementById('writing-about');
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutDialog?.addEventListener('click', (event) => {
      if (event.target === aboutDialog) aboutDialog.close();
    });
    if (!reduce) {
      let last = 0;
      const loop = (now) => {
        if (now - last >= 42) {
          typeStep(TYPING_RATE);
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
  }
</script>
