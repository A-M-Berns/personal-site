---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Writing — A. M. Berns" description="Notes, essays, and cross-posts.">
  <a class="home-link" href="/">Home</a>
  <header class="section-head">
    <h1>Writing</h1>
    <p>Notes, essays, and cross-posts from LessWrong.</p>
  </header>
  {notes.length > 0 ? (
    <ul class="note-list">
      {notes.map((n) => (
        <li>
          <time datetime={n.data.date.toISOString()}>{fmt.format(n.data.date)}</time>
          <a href={`/notes/${n.id}/`}>{n.data.title}</a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">Nothing posted yet.</p>
  )}
</Base>
