---
import Base from '../../layouts/Base.astro';

const animations = [
  { title: 'Home',          href: '/?animation=1' },
  { title: 'About',         href: '/about/?animation=1' },
  { title: 'Writing',       href: '/writing/?animation=1' },
  { title: 'Formalization', href: '/formalization/?animation=1' },
  { title: 'Music',         href: '/music/?animation=1' },
  { title: 'Other',         href: '/other/?animation=1' },
];
---
<Base title="Animations — A. M. Berns" description="Textless animation views.">
  <header class="section-head">
    <h1><span class="hl">Animations</span></h1>
  </header>
  <div class="animation-grid">
    {animations.map((animation) => (
      <a class="animation-card" href={animation.href} aria-label={`${animation.title} animation`}>
        <iframe title={`${animation.title} animation`} src={animation.href} loading="lazy"></iframe>
      </a>
    ))}
  </div>
</Base>
