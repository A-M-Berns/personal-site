<script>
  // ===== Types =====
  type Quality = 'maj' | 'min' | '7' | 'maj7' | 'min7' | 'sus' | 'dim';
  type DrumRow = 'bd' | 'sd' | 'hh' | 'cp';

  interface ChordSlot { root: string; quality: Quality; octave: number; }

  interface PartFx { lpf: number; hpf: number; drop: number; vary: boolean; every: string; pan: number; crush: number; }
  const defaultFx = (): PartFx => ({ lpf: 8000, hpf: 0, drop: 0, vary: false, every: '', pan: 0.5, crush: 0 });

  interface MidiNote { pitch: number; start: number; length: number; }

  interface State {
    bpm: number;
    master: number;
    swing: number;
    key: string;
    scale: string;
    drums: { enabled: boolean; gain: number; bank: string; steps: Record<DrumRow, boolean[]>; fx: PartFx };
    chords: { enabled: boolean; gain: number; sound: string; slots: ChordSlot[]; room: number; attack: number; fx: PartFx };
    bass: { enabled: boolean; gain: number; sound: string; rhythm: string; follow: boolean; fx: PartFx };
    arp: { enabled: boolean; gain: number; sound: string; speed: number; follow: boolean; cells: boolean[][]; fx: PartFx };
    lead: {
      enabled: boolean; gain: number; sound: string;
      notes: MidiNote[];
      attack: number;
      effects: { delay: boolean; room: boolean; jux: boolean; ghost: boolean; shape: boolean };
      fx: PartFx;
    };
    sample: { enabled: boolean; gain: number; name: string; url: string | null };
  }

  // ===== Music helpers =====
  const NOTE_NAMES = ['c', 'db', 'd', 'eb', 'e', 'f', 'gb', 'g', 'ab', 'a', 'bb', 'b'];
  const SCALES: Record<string, number[]> = {
    minor: [0, 2, 3, 5, 7, 8, 10],
    major: [0, 2, 4, 5, 7, 9, 11],
    dorian: [0, 2, 3, 5, 7, 9, 10],
    mixolydian: [0, 2, 4, 5, 7, 9, 10],
    'harmonic minor': [0, 2, 3, 5, 7, 8, 11],
  };
  const QUALITY_INTERVALS: Record<Quality, number[]> = {
    maj: [0, 4, 7],
    min: [0, 3, 7],
    '7': [0, 4, 7, 10],
    maj7: [0, 4, 7, 11],
    min7: [0, 3, 7, 10],
    sus: [0, 5, 7],
    dim: [0, 3, 6],
  };

  function rootIndex(root: string) {
    const idx = NOTE_NAMES.indexOf(root);
    return idx < 0 ? 0 : idx;
  }
  function midiToName(midi: number) {
    const n = ((midi % 12) + 12) % 12;
    const oct = Math.floor(midi / 12);
    return `${NOTE_NAMES[n]}${oct}`;
  }
  function chordNotes(slot: ChordSlot) {
    const intervals = QUALITY_INTERVALS[slot.quality] ?? QUALITY_INTERVALS.min;
    const baseMidi = (slot.octave + 1) * 12 + rootIndex(slot.root);
    return intervals.map((i) => midiToName(baseMidi + i));
  }
  function chordLabel(slot: ChordSlot) {
    const root = slot.root.replace('b', '♭').toUpperCase();
    const q = slot.quality === 'maj' ? '' : slot.quality === 'min' ? 'm' : slot.quality;
    return `${root}${q}`;
  }
  function scaleDegreeMidi(keyRoot: string, scaleName: string, degree: number, octave = 4) {
    const intervals = SCALES[scaleName] ?? SCALES.minor;
    const len = intervals.length;
    const wrap = ((degree % len) + len) % len;
    const oct = octave + Math.floor(degree / len);
    return oct * 12 + rootIndex(keyRoot) + intervals[wrap];
  }

  // ===== State =====
  const DRUMS: DrumRow[] = ['bd', 'sd', 'hh', 'cp'];
  const STEPS = 16;
  const ROLL_PITCHES = 12;
  const ARP_STEPS = 16;
  const LEAD_STEPS = 16;

  function emptySteps(): Record<DrumRow, boolean[]> {
    return Object.fromEntries(DRUMS.map((d) => [d, new Array(STEPS).fill(false)])) as Record<DrumRow, boolean[]>;
  }
  function emptyCells(steps: number): boolean[][] {
    return Array.from({ length: ROLL_PITCHES }, () => new Array(steps).fill(false));
  }
  function defaultDrums() {
    const s = emptySteps();
    [0, 4, 8, 12].forEach((i) => (s.bd[i] = true));
    [4, 12].forEach((i) => (s.sd[i] = true));
    [2, 6, 10, 14].forEach((i) => (s.hh[i] = true));
    return s;
  }
  function defaultArp(): boolean[][] {
    const c = emptyCells(ARP_STEPS);
    [0, 2, 4, 6, 8, 10, 12, 14].forEach((step, idx) => {
      const pitch = [0, 2, 4, 7, 4, 2, 4, 0][idx]; // simple ascending/descending
      c[ROLL_PITCHES - 1 - pitch][step] = true;
    });
    return c;
  }
  function defaultLeadNotes(): MidiNote[] {
    return [
      { pitch: 7, start: 0, length: 4 },
      { pitch: 9, start: 4, length: 4 },
      { pitch: 11, start: 8, length: 4 },
      { pitch: 9, start: 12, length: 4 },
    ];
  }

  const initialState: State = {
    bpm: 110,
    master: 0.85,
    swing: 0,
    key: 'c',
    scale: 'minor',
    drums: { enabled: true, gain: 0.65, bank: 'RolandTR909', steps: defaultDrums(), fx: defaultFx() },
    chords: {
      enabled: true,
      gain: 0.4,
      sound: 'piano',
      room: 0.5,
      attack: 0,
      slots: [
        { root: 'c', quality: 'min', octave: 3 },
        { root: 'ab', quality: 'maj', octave: 3 },
        { root: 'eb', quality: 'maj', octave: 3 },
        { root: 'bb', quality: 'maj', octave: 3 },
      ],
      fx: defaultFx(),
    },
    bass: { enabled: true, gain: 0.55, sound: 'sawtooth', rhythm: 'syncopated', follow: true, fx: { ...defaultFx(), lpf: 800 } },
    arp: { enabled: false, gain: 0.42, sound: 'sine', speed: 2, follow: true, cells: defaultArp(), fx: defaultFx() },
    lead: { enabled: false, gain: 0.42, sound: 'square', notes: defaultLeadNotes(), attack: 0, effects: { delay: false, room: false, jux: false, ghost: false, shape: false }, fx: defaultFx() },
    sample: { enabled: false, gain: 0.55, name: '', url: null },
  };

  const presets: Record<string, Partial<State>> = {
    empty: {
      drums: { ...initialState.drums, enabled: false, steps: emptySteps() },
      chords: { ...initialState.chords, enabled: false },
      bass: { ...initialState.bass, enabled: false },
      arp: { ...initialState.arp, enabled: false },
      lead: { ...initialState.lead, enabled: false },
    },
    lofi: {
      bpm: 82,
      swing: 0.18,
      key: 'eb',
      scale: 'minor',
      drums: { ...initialState.drums, gain: 0.55, bank: 'RolandTR808', steps: (() => { const s = emptySteps(); [0, 8].forEach((i) => (s.bd[i] = true)); [4, 12].forEach((i) => (s.sd[i] = true)); [0, 2, 4, 6, 8, 10, 12, 14].forEach((i) => (s.hh[i] = true)); return s; })(), fx: { ...defaultFx(), lpf: 3000, drop: 0.1, vary: false } },
      chords: { ...initialState.chords, gain: 0.42, sound: 'piano', room: 0.7, slots: [
        { root: 'eb', quality: 'min7', octave: 3 },
        { root: 'ab', quality: 'maj7', octave: 3 },
        { root: 'gb', quality: 'maj7', octave: 3 },
        { root: 'bb', quality: 'min7', octave: 3 },
      ], fx: { ...defaultFx(), lpf: 4000, drop: 0, vary: false } },
      bass: { ...initialState.bass, gain: 0.5, sound: 'sine', rhythm: 'root', follow: true, fx: { ...defaultFx(), lpf: 600, drop: 0, vary: false } },
    },
    techno: {
      bpm: 128,
      swing: 0,
      key: 'a',
      scale: 'minor',
      drums: { ...initialState.drums, gain: 0.7, bank: 'RolandTR909', steps: (() => { const s = emptySteps(); [0, 4, 8, 12].forEach((i) => (s.bd[i] = true)); [4, 12].forEach((i) => (s.sd[i] = true)); for (let i = 0; i < 16; i += 2) s.hh[i] = true; [3, 11].forEach((i) => (s.cp[i] = true)); return s; })(), fx: defaultFx() },
      chords: { ...initialState.chords, enabled: false },
      bass: { ...initialState.bass, gain: 0.6, sound: 'sawtooth', rhythm: 'octaves', follow: false, fx: { ...defaultFx(), lpf: 1200, drop: 0, vary: false } },
      arp: { ...initialState.arp, enabled: true, gain: 0.4, sound: 'square', speed: 4, follow: false, cells: (() => { const c = emptyCells(ARP_STEPS); [0, 4, 8, 12].forEach((s, i) => (c[ROLL_PITCHES - 1 - [7, 5, 7, 4][i]][s] = true)); return c; })(), fx: { ...defaultFx(), lpf: 2000, drop: 0.15, vary: true } },
    },
    ambient: {
      bpm: 70,
      swing: 0,
      key: 'd',
      scale: 'dorian',
      drums: { ...initialState.drums, enabled: false },
      chords: { ...initialState.chords, gain: 0.32, sound: 'triangle', room: 0.85, slots: [
        { root: 'd', quality: 'min7', octave: 3 },
        { root: 'g', quality: 'maj7', octave: 3 },
        { root: 'a', quality: 'min7', octave: 3 },
        { root: 'f', quality: 'maj7', octave: 3 },
      ], fx: { ...defaultFx(), lpf: 5000, drop: 0, vary: false } },
      bass: { ...initialState.bass, gain: 0.42, sound: 'sine', rhythm: 'root', follow: true, fx: { ...defaultFx(), lpf: 500, drop: 0, vary: false } },
      arp: { ...initialState.arp, enabled: true, gain: 0.32, sound: 'sine', speed: 1, follow: true, cells: (() => { const c = emptyCells(ARP_STEPS); [0, 3, 6, 9, 12, 15].forEach((s, i) => (c[ROLL_PITCHES - 1 - [0, 2, 4, 7, 4, 2][i]][s] = true)); return c; })(), fx: { ...defaultFx(), lpf: 4000, drop: 0.2, vary: true } },
    },
  };

  function clone<T>(value: T): T { return JSON.parse(JSON.stringify(value)); }
  function migrateLead(saved: any) {
    if (!saved || saved.notes) return saved;
    if (Array.isArray(saved.cells)) {
      const notes: MidiNote[] = [];
      for (let p = 0; p < saved.cells.length; p++) {
        const row = saved.cells[p];
        if (!Array.isArray(row)) continue;
        for (let s = 0; s < row.length; s++) {
          if (row[s]) notes.push({ pitch: ROLL_PITCHES - 1 - p, start: s, length: 1 });
        }
      }
      return { ...saved, notes, cells: undefined };
    }
    return saved;
  }
  function mergeState(saved: any): State {
    const base = clone(initialState) as any;
    if (!saved || typeof saved !== 'object') return base;
    if (saved.lead) saved = { ...saved, lead: migrateLead(saved.lead) };
    for (const k of Object.keys(base)) {
      if (saved[k] === undefined) continue;
      if (typeof base[k] === 'object' && base[k] !== null && !Array.isArray(base[k])) {
        base[k] = { ...base[k], ...saved[k] };
        if (base[k].fx) base[k].fx = { ...defaultFx(), ...(saved[k].fx ?? {}) };
        if (k === 'lead' && !Array.isArray(base[k].notes)) base[k].notes = clone(initialState.lead.notes);
      } else {
        base[k] = saved[k];
      }
    }
    return base as State;
  }
  let state: State = clone(initialState);
  function loadFromHash(): State | null {
    if (!window.location.hash || window.location.hash.length < 2) return null;
    try {
      const raw = decodeURIComponent(window.location.hash.slice(1));
      const decoded = atob(raw);
      return mergeState(JSON.parse(decoded));
    } catch (e) { return null; }
  }
  const fromHash = loadFromHash();
  if (fromHash) {
    state = fromHash;
  } else {
    try {
      const saved = window.localStorage.getItem('strudel-state-v4');
      if (saved) state = mergeState(JSON.parse(saved));
    } catch (e) {}
  }

  // ===== Code generation =====
  function indent(code: string, n = 2) {
    const pad = ' '.repeat(n);
    return code.split('\n').map((l) => pad + l).join('\n');
  }
  function applyFx(code: string, fx: PartFx): string {
    let out = code;
    if (fx.lpf < 8000) out += `\n  .lpf(${fx.lpf})`;
    if (fx.hpf > 0) out += `\n  .hpf(${fx.hpf})`;
    if (fx.drop > 0) out += `\n  .degradeBy(${fx.drop.toFixed(2)})`;
    if (fx.crush > 0) out += `\n  .crush(${fx.crush})`;
    if (Math.abs(fx.pan - 0.5) > 0.001) out += `\n  .pan(${fx.pan.toFixed(2)})`;
    if (fx.vary) out += `\n  .sometimes(rev)`;
    if (fx.every === '4fast') out += `\n  .every(4, x => x.fast(2))`;
    else if (fx.every === '8jux') out += `\n  .every(8, x => x.jux(rev))`;
    else if (fx.every === '4rev') out += `\n  .every(4, rev)`;
    else if (fx.every === '8slow') out += `\n  .every(8, x => x.slow(2))`;
    return out;
  }
  // Slider value 0..1 → audible gain via a perceptual curve. Below the
  // floor the part is dropped from the stack entirely so slider=0 is
  // truly silent (strudel's per-part .gain(0) doesn't always silence
  // soundfonts cleanly — masking via omission is more reliable).
  const GAIN_FLOOR = 0.01;
  function curveGain(v: number): number {
    return Math.pow(Math.max(0, Math.min(1, v)), 1.7);
  }
  function isAudible(v: number): boolean {
    return v >= GAIN_FLOOR;
  }
  function gainTail(v: number): string {
    return `.gain(${curveGain(v).toFixed(3)})`;
  }
  function drumCode(): string | null {
    if (!state.drums.enabled || !isAudible(state.drums.gain)) return null;
    const tokens: string[] = [];
    for (let s = 0; s < STEPS; s++) {
      const hits = DRUMS.filter((d) => state.drums.steps[d][s]);
      tokens.push(hits.length === 0 ? '~' : hits.length === 1 ? hits[0] : `[${hits.join(',')}]`);
    }
    let code = `s("${tokens.join(' ')}")`;
    if (state.drums.bank) code += `\n  .bank("${state.drums.bank}")`;
    code = applyFx(code, state.drums.fx);
    code += `\n  .gain(${(state.drums.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function soundChain(sound: string): string {
    if (sound === 'piano') return '.piano()';
    return `.s("${sound}")`;
  }
  function chordCode(): string | null {
    if (!state.chords.enabled || !isAudible(state.chords.gain)) return null;
    const slotStrs = state.chords.slots.map((s) => `<${chordNotes(s).join(',')}>`);
    let code = `note("${slotStrs.join(' ')}")`;
    code += `\n  ${soundChain(state.chords.sound)}`;
    if (state.chords.sound !== 'piano') code += `\n  .release(0.5)`;
    if (state.chords.attack > 0) code += `\n  .attack(${state.chords.attack.toFixed(2)})`;
    if (state.chords.room > 0) code += `\n  .room(${state.chords.room.toFixed(2)})`;
    code = applyFx(code, state.chords.fx);
    code += `\n  .gain(${(state.chords.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function bassCode(): string | null {
    if (!state.bass.enabled || !isAudible(state.bass.gain)) return null;
    const slots = state.chords.slots;
    const roots = state.bass.follow && slots.length
      ? slots.map((s) => `${s.root}2`)
      : ['c2', 'c2', 'c2', 'c2'];
    let pattern = '';
    if (state.bass.rhythm === 'root') {
      pattern = roots.join(' ');
    } else if (state.bass.rhythm === 'steady') {
      pattern = roots.flatMap((r) => [r, r, r, r]).join(' ');
    } else if (state.bass.rhythm === 'syncopated') {
      pattern = roots.map((r) => `[${r} ~ ${r} [~ ${r}]]`).join(' ');
    } else if (state.bass.rhythm === 'octaves') {
      pattern = roots.map((r) => {
        const up = r.replace(/(\d)$/, (_m, d) => String(Number(d) + 1));
        return `[${r} ${up} ${r} ${up}]`;
      }).join(' ');
    } else if (state.bass.rhythm === 'walking') {
      pattern = roots.map((r, i) => {
        const next = roots[(i + 1) % roots.length];
        return `[${r} ${r} ${next} ${r}]`;
      }).join(' ');
    }
    let code = `note("${pattern}")\n  ${soundChain(state.bass.sound)}`;
    code = applyFx(code, state.bass.fx);
    code += `\n  .gain(${(state.bass.gain ** 1.7).toFixed(3)})`;
    return code;
  }

  function rollNotes(cells: boolean[][], steps: number, scale: string, key: string, octaveBase: number, slots: ChordSlot[], follow: boolean) {
    const tokens: string[] = [];
    const slotsPerStep = slots.length ? steps / slots.length : steps;
    for (let s = 0; s < steps; s++) {
      const onPitches: number[] = [];
      for (let p = 0; p < ROLL_PITCHES; p++) {
        if (cells[p][s]) onPitches.push(ROLL_PITCHES - 1 - p);
      }
      if (onPitches.length === 0) { tokens.push('~'); continue; }
      const slotIdx = Math.min(slots.length - 1, Math.floor(s / slotsPerStep));
      const localKey = follow && slots[slotIdx] ? slots[slotIdx].root : key;
      const names = onPitches.map((deg) => midiToName(scaleDegreeMidi(localKey, scale, deg, octaveBase)));
      tokens.push(names.length === 1 ? names[0] : `[${names.join(',')}]`);
    }
    return tokens.join(' ');
  }

  function arpCode(): string | null {
    if (!state.arp.enabled || !isAudible(state.arp.gain)) return null;
    const pattern = rollNotes(state.arp.cells, ARP_STEPS, state.scale, state.key, 4, state.chords.slots, state.arp.follow);
    let code = `note("${pattern}")`;
    code += `\n  ${soundChain(state.arp.sound)}`;
    if (state.arp.speed !== 1) code += `\n  .fast(${state.arp.speed})`;
    code = applyFx(code, state.arp.fx);
    code += `\n  .delay(0.25)\n  .gain(${(state.arp.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function midiNotesPattern(notes: MidiNote[], steps: number, scale: string, key: string, octaveBase: number, slots: ChordSlot[]) {
    type Step = { starts: string[]; sustain: boolean };
    const cells: Step[] = Array.from({ length: steps }, () => ({ starts: [], sustain: false }));
    const slotsPerStep = slots.length ? steps / slots.length : steps;
    notes.forEach((n) => {
      if (n.start >= steps) return;
      const slotIdx = Math.min(slots.length - 1, Math.floor(n.start / slotsPerStep));
      const localKey = slots[slotIdx] ? slots[slotIdx].root : key;
      const name = midiToName(scaleDegreeMidi(localKey, scale, n.pitch, octaveBase));
      cells[n.start].starts.push(name);
      for (let i = 1; i < n.length && n.start + i < steps; i++) {
        cells[n.start + i].sustain = true;
      }
    });
    return cells.map((c) => {
      if (c.starts.length === 0) return c.sustain ? '_' : '~';
      if (c.starts.length === 1) return c.starts[0];
      return `[${c.starts.join(',')}]`;
    }).join(' ');
  }
  function leadCode(): string | null {
    if (!state.lead.enabled || !isAudible(state.lead.gain)) return null;
    const pattern = midiNotesPattern(state.lead.notes ?? [], LEAD_STEPS, state.scale, state.key, 5, state.chords.slots);
    let code = `note("${pattern}")`;
    code += `\n  ${soundChain(state.lead.sound)}`;
    if (state.lead.attack > 0) code += `\n  .attack(${state.lead.attack.toFixed(2)})`;
    if (state.lead.effects.delay) code += `\n  .delay(0.4)`;
    if (state.lead.effects.room) code += `\n  .room(0.6)`;
    if (state.lead.effects.jux) code += `\n  .jux(rev)`;
    if (state.lead.effects.ghost) code += `\n  .off(1/8, x => x.fast(2).gain(0.5))`;
    if (state.lead.effects.shape) code += `\n  .shape(0.4)`;
    code = applyFx(code, state.lead.fx);
    code += `\n  .gain(${(state.lead.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function sampleCode(): string | null {
    if (!state.sample.enabled || !state.sample.url || !state.sample.name || !isAudible(state.sample.gain)) return null;
    return `s("${state.sample.name}").loopAt(4).gain(${(state.sample.gain ** 1.7).toFixed(3)})`;
  }

  function buildCode(): string {
    const generators: Array<[string, () => string | null]> = [
      ['drums', drumCode],
      ['chords', chordCode],
      ['bass', bassCode],
      ['arp', arpCode],
      ['lead', leadCode],
      ['sample', sampleCode],
    ];
    const parts = generators
      .map(([name, gen]) => ({ name, code: gen() }))
      .filter((p): p is { name: string; code: string } => !!p.code);

    const cps = (state.bpm / 60 / 4).toFixed(3);
    let header = `// ${state.key.toUpperCase()} ${state.scale}  •  ${state.bpm} bpm\nsetcps(${cps})`;
    if (state.sample.enabled && state.sample.url && state.sample.name) {
      header = `// dropped sample\nsamples({ ${state.sample.name}: '${state.sample.url}' })\n\n${header}`;
    }
    const tail: string[] = [];
    if (state.swing > 0) tail.push(`.swingBy(${state.swing.toFixed(2)}, 4)`);
    tail.push(`.gain(${curveGain(state.master).toFixed(3)})`);
    const tailStr = tail.map((t) => `  ${t}`).join('\n');
    if (parts.length === 0) {
      return `${header}\nsilence`;
    }
    if (parts.length === 1) {
      return `${header}\n// ${parts[0].name}\n${parts[0].code}\n${tailStr}`;
    }
    const blocks = parts.map((p) => indent(`// ${p.name}\n${p.code}`));
    return `${header}\nstack(\n${blocks.join(',\n\n')}\n)\n${tailStr}`;
  }

  // ===== Editor wiring =====
  let editorRef: any = null;
  let editorReady: Promise<any> | null = null;
  let isRunning = false;
  let liveTimer: number | null = null;

  const hostEl = document.getElementById('strudel-host');
  const statusEl = document.getElementById('strudel-status');
  const runBtn = document.getElementById('strudel-run') as HTMLButtonElement | null;
  const stopBtn = document.getElementById('strudel-stop') as HTMLButtonElement | null;

  function setStatus(text: string) { if (statusEl) statusEl.textContent = text; }

  function ensureEditor(): Promise<any> {
    if (editorReady) return editorReady;
    setStatus('loading…');
    editorReady = new Promise<any>((resolve, reject) => {
      const existing = document.querySelector<HTMLScriptElement>('script[data-strudel-repl]');
      const onLoaded = () => {
        const el = document.createElement('strudel-editor');
        el.setAttribute('code', buildCode());
        hostEl?.appendChild(el);
        // wait for connectedCallback to set up editor
        const tryAttach = (tries = 0) => {
          if ((el as any).editor) {
            editorRef = (el as any).editor;
            (el as any).addEventListener('update', (evt: CustomEvent) => {
              const started = !!evt.detail?.started;
              if (started !== isRunning) {
                isRunning = started;
                runBtn?.setAttribute('data-state', started ? 'running' : 'idle');
                hostEl?.classList.toggle('is-running', started);
              }
            });
            setStatus('ready');
            resolve(editorRef);
          } else if (tries < 50) {
            setTimeout(() => tryAttach(tries + 1), 80);
          } else {
            reject(new Error('editor did not initialize'));
          }
        };
        tryAttach();
      };
      if (existing) {
        if ((existing as any).dataset.loaded === 'true') onLoaded();
        else {
          existing.addEventListener('load', onLoaded, { once: true });
          existing.addEventListener('error', () => reject(new Error('repl load error')), { once: true });
        }
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/@strudel/repl@1.3.0/dist/index.js';
      script.async = true;
      script.dataset.strudelRepl = 'true';
      script.onload = () => { (script as any).dataset.loaded = 'true'; onLoaded(); };
      script.onerror = () => reject(new Error('repl load error'));
      document.head.appendChild(script);
    });
    return editorReady;
  }

  async function pushCode() {
    const code = buildCode();
    try { window.localStorage.setItem('strudel-state-v4', JSON.stringify(state)); } catch (e) {}
    try { await ensureEditor(); } catch (e) { setStatus('editor unavailable'); return; }
    if (!editorRef) return;
    editorRef.setCode(code);
    if (isRunning) {
      try { await editorRef.evaluate(); } catch (e) { setStatus('eval error'); }
    }
  }
  function scheduleLiveApply() {
    if (liveTimer !== null) window.clearTimeout(liveTimer);
    liveTimer = window.setTimeout(pushCode, 100);
  }

  async function run() {
    await ensureEditor();
    if (!editorRef) return;
    editorRef.setCode(buildCode());
    try {
      await editorRef.evaluate();
      isRunning = true;
      runBtn?.setAttribute('data-state', 'running');
      hostEl?.classList.add('is-running');
      setStatus('running');
    } catch (e) {
      setStatus(e instanceof Error ? e.message : 'eval error');
    }
  }
  async function stop() {
    if (!editorRef) return;
    try {
      await editorRef.stop();
      isRunning = false;
      runBtn?.setAttribute('data-state', 'idle');
      hostEl?.classList.remove('is-running');
      setStatus('stopped');
    } catch (e) {}
  }

  runBtn?.addEventListener('click', run);
  stopBtn?.addEventListener('click', stop);

  // ===== UI rendering =====
  function el<K extends keyof HTMLElementTagNameMap>(tag: K, attrs: Record<string, any> = {}, ...children: (Node | string)[]) {
    const node = document.createElement(tag);
    for (const [k, v] of Object.entries(attrs)) {
      if (k === 'class') node.className = v;
      else if (k === 'dataset') Object.assign(node.dataset, v);
      else if (k.startsWith('on') && typeof v === 'function') node.addEventListener(k.slice(2), v);
      else if (k === 'checked' || k === 'disabled' || k === 'selected') (node as any)[k] = v;
      else node.setAttribute(k, String(v));
    }
    for (const c of children) node.append(c);
    return node;
  }

  // --- Drums grid
  const drumGrid = document.getElementById('strudel-drum-grid');
  let painting: { value: boolean } | null = null;
  // Compact glyphs for the drum row labels — visually distinct and
  // readable at small sizes (clearer than 'bd'/'sd'/'hh'/'cp').
  const DRUM_ICONS: Record<DrumRow, string> = { bd: '●', sd: '◐', hh: '✕', cp: '✦' };
  const DRUM_TITLES: Record<DrumRow, string> = { bd: 'kick', sd: 'snare', hh: 'hi-hat', cp: 'clap' };
  function renderDrumGrid() {
    if (!drumGrid) return;
    drumGrid.replaceChildren();
    DRUMS.forEach((row) => {
      const label = el('span', { class: 'strudel-step-label strudel-drum-icon', title: DRUM_TITLES[row] }, DRUM_ICONS[row]);
      drumGrid.appendChild(label);
      for (let s = 0; s < STEPS; s++) {
        const on = state.drums.steps[row][s];
        const btn = el('button', {
          type: 'button',
          'aria-pressed': String(on),
          'aria-label': `${row} step ${s + 1}`,
          class: on ? 'is-on' : '',
          dataset: { row, step: String(s) },
        });
        btn.addEventListener('pointerdown', (event) => {
          event.preventDefault();
          const next = !state.drums.steps[row][s];
          painting = { value: next };
          state.drums.steps[row][s] = next;
          btn.classList.toggle('is-on', next);
          btn.setAttribute('aria-pressed', String(next));
          scheduleLiveApply();
        });
        btn.addEventListener('pointerenter', () => {
          if (!painting) return;
          state.drums.steps[row][s] = painting.value;
          btn.classList.toggle('is-on', painting.value);
          btn.setAttribute('aria-pressed', String(painting.value));
          scheduleLiveApply();
        });
        drumGrid.appendChild(btn);
      }
    });
  }
  window.addEventListener('pointerup', () => { painting = null; });

  // Compact label for a scale degree, e.g. degree 0 in C minor → "C",
  // degree 7 in C minor → "C" (octave up). Used to label rolls.
  function degreeLabel(degree: number, key: string, scale: string): string {
    const intervals = SCALES[scale] ?? SCALES.minor;
    const interval = intervals[((degree % intervals.length) + intervals.length) % intervals.length];
    const idx = (rootIndex(key) + interval) % 12;
    return NOTE_NAMES[idx].replace('b', '♭').toUpperCase();
  }

  // --- Piano roll (cells)
  function renderRoll(
    container: HTMLElement | null,
    cells: boolean[][],
    steps: number,
    onChange: () => void,
    labelFor: (degree: number) => string = (d) => `${d + 1}`,
  ) {
    if (!container) return;
    container.replaceChildren();
    container.style.gridTemplateColumns = '2.6rem 1fr';
    for (let p = 0; p < ROLL_PITCHES; p++) {
      const degree = ROLL_PITCHES - 1 - p; // top row = highest
      container.appendChild(el('span', { class: 'strudel-roll-label' }, labelFor(degree)));
      const rowEl = el('div', { class: 'strudel-piano-roll-row' });
      rowEl.style.gridTemplateColumns = `repeat(${steps}, 1fr)`;
      for (let s = 0; s < steps; s++) {
        const isBeat = s % 4 === 0;
        const on = cells[p][s];
        const cell = el('button', {
          type: 'button',
          'aria-pressed': String(on),
          class: `strudel-roll-cell${on ? ' is-on' : ''}${isBeat ? ' is-beat' : ''}`,
          dataset: { p: String(p), s: String(s) },
        });
        cell.addEventListener('click', () => {
          cells[p][s] = !cells[p][s];
          cell.classList.toggle('is-on', cells[p][s]);
          cell.setAttribute('aria-pressed', String(cells[p][s]));
          onChange();
        });
        rowEl.appendChild(cell);
      }
      container.appendChild(rowEl);
    }
  }

  // --- MIDI piano roll (notes with length)
  // Click empty cell + drag right to draw a note of variable length.
  // Click on existing note (the orange bar) to remove it.
  function renderMidiRoll(
    container: HTMLElement | null,
    notes: MidiNote[],
    steps: number,
    onChange: () => void,
    labelFor: (degree: number) => string = (d) => `${d + 1}`,
  ) {
    if (!container) return;
    let drawing: MidiNote | null = null;
    const refresh = () => {
      container.replaceChildren();
      container.style.gridTemplateColumns = '2.6rem 1fr';
      for (let p = 0; p < ROLL_PITCHES; p++) {
        const degree = ROLL_PITCHES - 1 - p;
        container.appendChild(el('span', { class: 'strudel-roll-label' }, labelFor(degree)));
        const rowEl = el('div', { class: 'strudel-midi-row' });
        rowEl.style.gridTemplateColumns = `repeat(${steps}, 1fr)`;
        for (let s = 0; s < steps; s++) {
          const isBeat = s % 4 === 0;
          const cell = el('button', {
            type: 'button',
            class: `strudel-roll-cell strudel-midi-cell${isBeat ? ' is-beat' : ''}`,
            dataset: { p: String(degree), s: String(s) },
          });
          cell.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            const note: MidiNote = { pitch: degree, start: s, length: 1 };
            notes.push(note);
            drawing = note;
            refresh();
            onChange();
          });
          cell.addEventListener('pointerenter', () => {
            if (!drawing) return;
            if (drawing.pitch !== degree) return;
            const newLen = Math.max(1, s - drawing.start + 1);
            if (newLen === drawing.length) return;
            drawing.length = newLen;
            refresh();
            onChange();
          });
          rowEl.appendChild(cell);
        }
        // Note overlays for this pitch row.
        notes.filter((n) => n.pitch === degree).forEach((n) => {
          const note = el('div', { class: 'strudel-midi-note' });
          note.style.left = `${(n.start / steps) * 100}%`;
          note.style.width = `${(Math.min(n.length, steps - n.start) / steps) * 100}%`;
          note.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            event.stopPropagation();
            const i = notes.indexOf(n);
            if (i >= 0) notes.splice(i, 1);
            refresh();
            onChange();
          });
          rowEl.appendChild(note);
        });
        container.appendChild(rowEl);
      }
    };
    const stopDraw = () => { drawing = null; };
    window.addEventListener('pointerup', stopDraw);
    window.addEventListener('pointercancel', stopDraw);
    refresh();
  }

  // --- Chord cards
  const chordGrid = document.getElementById('strudel-chord-grid');
  const ROOT_OPTIONS = NOTE_NAMES;
  const QUALITIES: Quality[] = ['min', 'maj', '7', 'maj7', 'min7', 'sus', 'dim'];
  function romanize(slot: ChordSlot, key: string, scale: string) {
    const intervals = SCALES[scale] ?? SCALES.minor;
    const interval = ((rootIndex(slot.root) - rootIndex(key)) % 12 + 12) % 12;
    const degree = intervals.indexOf(interval);
    const numerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII'];
    if (degree < 0) return '–';
    const isMin = slot.quality === 'min' || slot.quality === 'min7' || slot.quality === 'dim';
    return isMin ? numerals[degree].toLowerCase() : numerals[degree];
  }
  function renderChords() {
    if (!chordGrid) return;
    chordGrid.replaceChildren();
    state.chords.slots.forEach((slot, idx) => {
      const card = el('div', { class: 'strudel-chord-card' });
      const name = el('div', { class: 'chord-name' }, chordLabel(slot));
      const rootSel = el('select', {}) as HTMLSelectElement;
      ROOT_OPTIONS.forEach((r) => {
        const opt = el('option', { value: r, selected: r === slot.root }, r.toUpperCase());
        rootSel.appendChild(opt);
      });
      rootSel.addEventListener('change', () => { state.chords.slots[idx].root = rootSel.value; renderChords(); scheduleLiveApply(); });
      const qualSel = el('select', {}) as HTMLSelectElement;
      QUALITIES.forEach((q) => {
        const opt = el('option', { value: q, selected: q === slot.quality }, q);
        qualSel.appendChild(opt);
      });
      qualSel.addEventListener('change', () => { state.chords.slots[idx].quality = qualSel.value as Quality; renderChords(); scheduleLiveApply(); });
      const degree = el('div', { class: 'chord-degree' }, romanize(slot, state.key, state.scale));
      const oct = el('div', { class: 'chord-octave' });
      const minus = el('button', { type: 'button' }, '−');
      const plus = el('button', { type: 'button' }, '+');
      const octLabel = el('span', { class: 'chord-degree' }, `oct ${slot.octave}`);
      minus.addEventListener('click', () => { state.chords.slots[idx].octave = Math.max(1, slot.octave - 1); renderChords(); scheduleLiveApply(); });
      plus.addEventListener('click', () => { state.chords.slots[idx].octave = Math.min(6, slot.octave + 1); renderChords(); scheduleLiveApply(); });
      oct.append(minus, octLabel, plus);
      card.append(name, rootSel, qualSel, degree, oct);
      chordGrid.appendChild(card);
    });
  }

  // --- Generic part header binding
  function bindPart(partName: keyof State) {
    const section = document.querySelector<HTMLElement>(`.strudel-part[data-part="${partName}"]`);
    if (!section) return;
    const muteEl = section.querySelector<HTMLInputElement>('input[data-mute]');
    const gainEl = section.querySelector<HTMLInputElement>('input[data-gain]');
    if (muteEl) {
      muteEl.addEventListener('change', () => {
        (state[partName] as any).enabled = muteEl.checked;
        section.classList.toggle('is-muted', !muteEl.checked);
        scheduleLiveApply();
      });
    }
    if (gainEl) {
      gainEl.addEventListener('input', () => {
        (state[partName] as any).gain = Number(gainEl.value);
        scheduleLiveApply();
      });
    }
  }

  // --- Drums extras (bank)
  function bindDrums() {
    const bankSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="drums"] select[data-bank]');
    if (bankSel) {
      bankSel.value = state.drums.bank;
      bankSel.addEventListener('change', () => { state.drums.bank = bankSel.value; scheduleLiveApply(); });
    }
  }
  function bindChordsExtras() {
    const soundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="chords"] select[data-sound]');
    if (soundSel) {
      soundSel.value = state.chords.sound;
      soundSel.addEventListener('change', () => { state.chords.sound = soundSel.value; scheduleLiveApply(); });
    }
  }
  function bindBass() {
    const soundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="bass"] select[data-sound]');
    const rhythmSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="bass"] select[data-rhythm]');
    const followEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="bass"] input[data-follow]');
    if (soundSel) { soundSel.value = state.bass.sound; soundSel.addEventListener('change', () => { state.bass.sound = soundSel.value; scheduleLiveApply(); }); }
    if (rhythmSel) { rhythmSel.value = state.bass.rhythm; rhythmSel.addEventListener('change', () => { state.bass.rhythm = rhythmSel.value; scheduleLiveApply(); }); }
    if (followEl) { followEl.checked = state.bass.follow; followEl.addEventListener('change', () => { state.bass.follow = followEl.checked; scheduleLiveApply(); }); }
  }
  function bindArpExtras() {
    const soundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="arp"] select[data-sound]');
    const speedSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="arp"] select[data-speed]');
    const followEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="arp"] input[data-follow]');
    if (soundSel) { soundSel.value = state.arp.sound; soundSel.addEventListener('change', () => { state.arp.sound = soundSel.value; scheduleLiveApply(); }); }
    if (speedSel) { speedSel.value = String(state.arp.speed); speedSel.addEventListener('change', () => { state.arp.speed = Number(speedSel.value); scheduleLiveApply(); }); }
    if (followEl) { followEl.checked = state.arp.follow; followEl.addEventListener('change', () => { state.arp.follow = followEl.checked; scheduleLiveApply(); }); }
  }
  function bindLeadExtras() {
    const soundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="lead"] select[data-sound]');
    if (soundSel) { soundSel.value = state.lead.sound; soundSel.addEventListener('change', () => { state.lead.sound = soundSel.value; scheduleLiveApply(); }); }
    document.querySelectorAll<HTMLInputElement>('.strudel-part[data-part="lead"] input[data-effect]').forEach((input) => {
      input.addEventListener('change', () => {
        const key = input.dataset.effect as keyof State['lead']['effects'];
        state.lead.effects[key] = input.checked;
        scheduleLiveApply();
      });
    });
    const attackEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="lead"] input[data-attack]');
    if (attackEl) {
      attackEl.addEventListener('input', () => {
        state.lead.attack = Number(attackEl.value);
        const out = attackEl.parentElement?.querySelector('output');
        if (out) out.textContent = state.lead.attack === 0 ? 'off' : state.lead.attack.toFixed(2);
        scheduleLiveApply();
      });
    }
  }
  function bindChordsAttack() {
    const attackEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-attack]');
    if (!attackEl) return;
    attackEl.addEventListener('input', () => {
      state.chords.attack = Number(attackEl.value);
      const out = attackEl.parentElement?.querySelector('output');
      if (out) out.textContent = state.chords.attack === 0 ? 'off' : state.chords.attack.toFixed(2);
      scheduleLiveApply();
    });
  }
  function bindChordsRoom() {
    const roomEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-fx-room]');
    if (!roomEl) return;
    const out = roomEl.parentElement?.querySelector('output');
    roomEl.value = String(state.chords.room);
    if (out) out.textContent = state.chords.room.toFixed(2);
    roomEl.addEventListener('input', () => {
      state.chords.room = Number(roomEl.value);
      if (out) out.textContent = state.chords.room.toFixed(2);
      scheduleLiveApply();
    });
  }
  const FX_PARTS: (keyof State)[] = ['drums', 'chords', 'bass', 'arp', 'lead'];
  function bindFx() {
    FX_PARTS.forEach((part) => {
      const section = document.querySelector<HTMLElement>(`.strudel-part[data-part="${part}"]`);
      if (!section) return;
      const lpfEl = section.querySelector<HTMLInputElement>('input[data-fx-lpf]');
      const dropEl = section.querySelector<HTMLInputElement>('input[data-fx-drop]');
      const varyEl = section.querySelector<HTMLInputElement>('input[data-fx-vary]');
      const everySel = section.querySelector<HTMLSelectElement>('select[data-fx-every]');
      const panEl = section.querySelector<HTMLInputElement>('input[data-fx-pan]');
      const crushEl = section.querySelector<HTMLInputElement>('input[data-fx-crush]');
      const getFx = () => ((state[part] as any).fx as PartFx | undefined);
      if (lpfEl) {
        lpfEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.lpf = Number(lpfEl.value);
          const out = lpfEl.parentElement?.querySelector('output');
          if (out) out.textContent = fx.lpf >= 8000 ? 'off' : `${fx.lpf}`;
          scheduleLiveApply();
        });
      }
      if (dropEl) {
        dropEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.drop = Number(dropEl.value);
          const out = dropEl.parentElement?.querySelector('output');
          if (out) out.textContent = fx.drop === 0 ? 'off' : fx.drop.toFixed(2);
          scheduleLiveApply();
        });
      }
      if (varyEl) {
        varyEl.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.vary = varyEl.checked; scheduleLiveApply();
        });
      }
      if (everySel) {
        everySel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.every = everySel.value; scheduleLiveApply();
        });
      }
      if (panEl) {
        panEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.pan = Number(panEl.value);
          const out = panEl.parentElement?.querySelector('output');
          if (out) {
            const d = fx.pan - 0.5;
            out.textContent = Math.abs(d) < 0.01 ? 'C' : (d < 0 ? `L${Math.round(-d * 200)}` : `R${Math.round(d * 200)}`);
          }
          scheduleLiveApply();
        });
      }
      if (crushEl) {
        crushEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.crush = Number(crushEl.value);
          const out = crushEl.parentElement?.querySelector('output');
          if (out) out.textContent = fx.crush === 0 ? 'off' : `${fx.crush}`;
          scheduleLiveApply();
        });
      }
    });
  }

  // --- Sample drop
  const sampleFileInput = document.getElementById('strudel-sample-file') as HTMLInputElement | null;
  const sampleDrop = document.getElementById('strudel-drop') as HTMLElement | null;
  const sampleDropLabel = document.getElementById('strudel-drop-label');
  function loadDroppedSample(file: File) {
    if (!file.type.startsWith('audio/')) { setStatus('audio file required'); return; }
    if (state.sample.url) URL.revokeObjectURL(state.sample.url);
    state.sample.url = URL.createObjectURL(file);
    state.sample.name = (file.name.replace(/\.[^.]+$/, '').toLowerCase().replace(/[^a-z0-9]+/g, '').slice(0, 18)) || 'drop';
    state.sample.enabled = true;
    if (sampleDropLabel) sampleDropLabel.textContent = file.name;
    const muteEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="sample"] input[data-mute]');
    if (muteEl) muteEl.checked = true;
    document.querySelector<HTMLElement>('.strudel-part[data-part="sample"]')?.classList.remove('is-muted');
    scheduleLiveApply();
  }
  sampleFileInput?.addEventListener('change', () => { const f = sampleFileInput.files?.[0]; if (f) loadDroppedSample(f); });
  sampleDrop?.addEventListener('dragenter', (e) => { e.preventDefault(); sampleDrop.classList.add('is-dragging'); });
  sampleDrop?.addEventListener('dragover', (e) => e.preventDefault());
  sampleDrop?.addEventListener('dragleave', (e) => { if (!sampleDrop.contains(e.relatedTarget as Node | null)) sampleDrop.classList.remove('is-dragging'); });
  sampleDrop?.addEventListener('drop', (e) => {
    e.preventDefault(); sampleDrop.classList.remove('is-dragging');
    const f = e.dataTransfer?.files?.[0]; if (f) loadDroppedSample(f);
  });

  // --- Transport bindings
  const bpmEl = document.getElementById('strudel-bpm') as HTMLInputElement | null;
  const bpmOut = document.getElementById('strudel-bpm-out');
  const masterEl = document.getElementById('strudel-master') as HTMLInputElement | null;
  const masterOut = document.getElementById('strudel-master-out');
  const keySel = document.getElementById('strudel-key') as HTMLSelectElement | null;
  const scaleSel = document.getElementById('strudel-scale') as HTMLSelectElement | null;
  const swingEl = document.getElementById('strudel-swing') as HTMLInputElement | null;
  const swingOut = document.getElementById('strudel-swing-out');
  const shareBtn = document.getElementById('strudel-share') as HTMLButtonElement | null;

  if (bpmEl && bpmOut) {
    bpmEl.value = String(state.bpm); bpmOut.textContent = String(state.bpm);
    bpmEl.addEventListener('input', () => { state.bpm = Number(bpmEl.value); bpmOut.textContent = bpmEl.value; scheduleLiveApply(); });
  }
  if (masterEl && masterOut) {
    masterEl.value = String(state.master); masterOut.textContent = state.master.toFixed(2);
    masterEl.addEventListener('input', () => { state.master = Number(masterEl.value); masterOut.textContent = state.master.toFixed(2); scheduleLiveApply(); });
  }
  if (swingEl && swingOut) {
    swingEl.value = String(state.swing); swingOut.textContent = state.swing.toFixed(2);
    swingEl.addEventListener('input', () => { state.swing = Number(swingEl.value); swingOut.textContent = state.swing.toFixed(2); scheduleLiveApply(); });
  }
  function rerenderRolls() {
    renderRoll(document.getElementById('strudel-arp-roll'), state.arp.cells, ARP_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
    renderMidiRoll(document.getElementById('strudel-lead-roll'), state.lead.notes, LEAD_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
  }
  if (keySel) {
    keySel.value = state.key;
    keySel.addEventListener('change', () => { state.key = keySel.value; renderChords(); rerenderRolls(); scheduleLiveApply(); });
  }
  if (scaleSel) {
    scaleSel.value = state.scale;
    scaleSel.addEventListener('change', () => { state.scale = scaleSel.value; renderChords(); rerenderRolls(); scheduleLiveApply(); });
  }
  shareBtn?.addEventListener('click', async () => {
    const shareable: any = clone(state);
    if (shareable.sample) shareable.sample = { ...shareable.sample, url: null, name: '', enabled: false };
    const hash = btoa(JSON.stringify(shareable));
    const url = `${window.location.origin}${window.location.pathname}#${hash}`;
    try {
      await navigator.clipboard.writeText(url);
      setStatus('link copied');
    } catch (e) {
      window.prompt('share link', url);
    }
  });

  // --- Keyboard shortcuts
  window.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    const inField = target && (target.tagName === 'INPUT' || target.tagName === 'SELECT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
    if (e.key === ' ' && !inField) {
      e.preventDefault();
      isRunning ? stop() : run();
    } else if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      e.preventDefault();
      run();
    } else if (e.key === 'Escape') {
      stop();
    }
  });

  // --- Presets
  document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.preset as keyof typeof presets;
      const preset = presets[key];
      if (!preset) return;
      state = { ...clone(initialState), ...clone(preset) } as State;
      renderAll();
      scheduleLiveApply();
    });
  });

  // --- Reset
  const resetBtn = document.getElementById('strudel-reset') as HTMLButtonElement | null;
  resetBtn?.addEventListener('click', () => {
    if (state.sample.url) URL.revokeObjectURL(state.sample.url);
    state = clone(initialState);
    try { window.localStorage.removeItem('strudel-state-v4'); } catch (e) {}
    renderAll();
    scheduleLiveApply();
  });
  const aboutDialog = document.getElementById('strudel-about') as HTMLDialogElement | null;
  document.getElementById('strudel-info')?.addEventListener('click', () => aboutDialog?.showModal());
  aboutDialog?.addEventListener('click', (e) => { if (e.target === aboutDialog) aboutDialog.close(); });

  function syncAllInputs() {
    if (bpmEl && bpmOut) { bpmEl.value = String(state.bpm); bpmOut.textContent = String(state.bpm); }
    if (masterEl && masterOut) { masterEl.value = String(state.master); masterOut.textContent = state.master.toFixed(2); }
    if (swingEl && swingOut) { swingEl.value = String(state.swing); swingOut.textContent = state.swing.toFixed(2); }
    if (keySel) keySel.value = state.key;
    if (scaleSel) scaleSel.value = state.scale;
    (['drums', 'chords', 'bass', 'arp', 'lead', 'sample'] as const).forEach((p) => {
      const section = document.querySelector<HTMLElement>(`.strudel-part[data-part="${p}"]`);
      const muteEl = section?.querySelector<HTMLInputElement>('input[data-mute]');
      const gainEl = section?.querySelector<HTMLInputElement>('input[data-gain]');
      const ps: any = state[p];
      if (muteEl) muteEl.checked = !!ps.enabled;
      if (gainEl) gainEl.value = String(ps.gain ?? 0.5);
      section?.classList.toggle('is-muted', !ps.enabled);
      if (ps.fx) {
        const setSlider = (el: HTMLInputElement | null | undefined, value: number, formatOff: () => string, format: () => string) => {
          if (!el) return;
          el.value = String(value);
          const out = el.parentElement?.querySelector('output');
          if (out) out.textContent = format() === '' ? formatOff() : format();
        };
        setSlider(
          section?.querySelector<HTMLInputElement>('input[data-fx-lpf]'),
          ps.fx.lpf,
          () => 'off',
          () => ps.fx.lpf >= 8000 ? '' : `${ps.fx.lpf}`,
        );
        setSlider(
          section?.querySelector<HTMLInputElement>('input[data-fx-drop]'),
          ps.fx.drop,
          () => 'off',
          () => ps.fx.drop === 0 ? '' : ps.fx.drop.toFixed(2),
        );
        setSlider(
          section?.querySelector<HTMLInputElement>('input[data-fx-pan]'),
          ps.fx.pan,
          () => 'C',
          () => {
            const d = ps.fx.pan - 0.5;
            return Math.abs(d) < 0.01 ? '' : (d < 0 ? `L${Math.round(-d * 200)}` : `R${Math.round(d * 200)}`);
          },
        );
        setSlider(
          section?.querySelector<HTMLInputElement>('input[data-fx-crush]'),
          ps.fx.crush,
          () => 'off',
          () => ps.fx.crush === 0 ? '' : `${ps.fx.crush}`,
        );
        const varyEl = section?.querySelector<HTMLInputElement>('input[data-fx-vary]');
        const everySel = section?.querySelector<HTMLSelectElement>('select[data-fx-every]');
        if (varyEl) varyEl.checked = !!ps.fx.vary;
        if (everySel) everySel.value = ps.fx.every || '';
      }
    });
    const roomEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-fx-room]');
    if (roomEl) {
      roomEl.value = String(state.chords.room);
      const out = roomEl.parentElement?.querySelector('output');
      if (out) out.textContent = state.chords.room.toFixed(2);
    }
    const chordAttackEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-attack]');
    if (chordAttackEl) {
      chordAttackEl.value = String(state.chords.attack);
      const out = chordAttackEl.parentElement?.querySelector('output');
      if (out) out.textContent = state.chords.attack === 0 ? 'off' : state.chords.attack.toFixed(2);
    }
    const leadAttackEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="lead"] input[data-attack]');
    if (leadAttackEl) {
      leadAttackEl.value = String(state.lead.attack);
      const out = leadAttackEl.parentElement?.querySelector('output');
      if (out) out.textContent = state.lead.attack === 0 ? 'off' : state.lead.attack.toFixed(2);
    }
    document.querySelectorAll<HTMLInputElement>('.strudel-part[data-part="lead"] input[data-effect]').forEach((input) => {
      const key = input.dataset.effect as keyof State['lead']['effects'];
      input.checked = !!state.lead.effects[key];
    });
    const bankSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="drums"] select[data-bank]');
    if (bankSel) bankSel.value = state.drums.bank;
    const chordSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="chords"] select[data-sound]');
    if (chordSoundSel) chordSoundSel.value = state.chords.sound;
    const bassSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="bass"] select[data-sound]');
    if (bassSoundSel) bassSoundSel.value = state.bass.sound;
    const bassRhythmSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="bass"] select[data-rhythm]');
    if (bassRhythmSel) bassRhythmSel.value = state.bass.rhythm;
    const bassFollowEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="bass"] input[data-follow]');
    if (bassFollowEl) bassFollowEl.checked = state.bass.follow;
    const arpSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="arp"] select[data-sound]');
    if (arpSoundSel) arpSoundSel.value = state.arp.sound;
    const arpSpeedSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="arp"] select[data-speed]');
    if (arpSpeedSel) arpSpeedSel.value = String(state.arp.speed);
    const arpFollowEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="arp"] input[data-follow]');
    if (arpFollowEl) arpFollowEl.checked = state.arp.follow;
    const leadSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="lead"] select[data-sound]');
    if (leadSoundSel) leadSoundSel.value = state.lead.sound;
  }

  function renderAll() {
    renderDrumGrid();
    renderChords();
    renderRoll(document.getElementById('strudel-arp-roll'), state.arp.cells, ARP_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
    renderMidiRoll(document.getElementById('strudel-lead-roll'), state.lead.notes, LEAD_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
    syncAllInputs();
  }

  // initial bindings — attach listeners once; preset/reset only update values via syncAllInputs
  (['drums', 'chords', 'bass', 'arp', 'lead', 'sample'] as const).forEach(bindPart);
  bindDrums();
  bindChordsExtras();
  bindChordsRoom();
  bindChordsAttack();
  bindBass();
  bindArpExtras();
  bindLeadExtras();
  bindFx();
  renderDrumGrid();
  renderChords();
  renderRoll(document.getElementById('strudel-arp-roll'), state.arp.cells, ARP_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
  renderMidiRoll(document.getElementById('strudel-lead-roll'), state.lead.notes, LEAD_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
  syncAllInputs();

  // Eagerly load the editor so the code panel reflects state immediately,
  // not only after the user clicks Run.
  ensureEditor().catch(() => setStatus('editor unavailable'));
</script>
