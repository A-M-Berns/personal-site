        const plySel = section?.querySelector<HTMLSelectElement>('select[data-fx-ply]');
        if (plySel) plySel.value = String(ps.fx.ply || 1);
        // Refresh the visual struct grid from current fx.struct.
        const structGridEl = section?.querySelector<HTMLElement>('[data-fx-struct-grid]');
        if (structGridEl) {
