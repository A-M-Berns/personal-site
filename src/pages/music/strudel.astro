    if (chordVowelSel) chordVowelSel.value = state.chords.vowel || '';
    const chordAttackEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-attack]');
    if (chordAttackEl) {
      chordAttackEl.value = String(state.chords.attack);
      const out = chordAttackEl.parentElement?.querySelector('output');
      if (out) out.textContent = state.chords.attack === 0 ? 'off' : state.chords.attack.toFixed(2);
    }
    const leadAttackEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="lead"] input[data-attack]');
    if (leadAttackEl) {
      leadAttackEl.value = String(state.lead.attack);
      const out = leadAttackEl.parentElement?.querySelector('output');
