  // --- Keyboard shortcuts
  window.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    const inField = target && (target.tagName === 'INPUT' || target.tagName === 'SELECT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
    if (e.key === ' ' && !inField) {
      e.preventDefault();
      isRunning ? stop() : run();
    } else if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      e.preventDefault();
      run();
    } else if (e.key === 'Escape') {
      stop();
    }
  });

  // --- Click-to-enter for slider outputs.
  // Anywhere we render <label><input type=range><output></output></label>,
  // clicking the output swaps it for a text input so the user can type
  // an exact value. Commit on Enter or blur, cancel on Escape.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target || target.tagName !== 'OUTPUT') return;
    if (target.dataset.editing === 'true') return;
    const label = target.closest('label');
    const slider = label?.querySelector<HTMLInputElement>('input[type="range"]');
    if (!slider) return;

    target.dataset.editing = 'true';
    const original = target.textContent ?? '';
    const input = document.createElement('input');
    input.type = 'text';
    input.inputMode = 'decimal';
    input.value = String(slider.value);
    input.className = 'strudel-output-input';
    const min = parseFloat(slider.min || '0');
    const max = parseFloat(slider.max || '1');
    const cleanup = () => {
      target.dataset.editing = 'false';
    };
    const commit = () => {
      const v = parseFloat(input.value);
      if (!Number.isNaN(v)) {
        const clamped = Math.max(min, Math.min(max, v));
        slider.value = String(clamped);
        slider.dispatchEvent(new Event('input', { bubbles: true }));
      } else {
        target.textContent = original;
      }
      cleanup();
    };
    const cancel = () => {
      target.textContent = original;
      cleanup();
    };
    input.addEventListener('blur', commit);
    input.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter') { ev.preventDefault(); input.blur(); }
      else if (ev.key === 'Escape') { ev.preventDefault(); input.removeEventListener('blur', commit); cancel(); input.blur(); }
    });
    target.replaceChildren(input);
    input.focus();
    input.select();
  });

