  const FX_PARTS: (keyof State)[] = ['drums', 'chords', 'bass', 'arp', 'lead'];
  function bindFx() {
    FX_PARTS.forEach((part) => {
      const section = document.querySelector<HTMLElement>(`.strudel-part[data-part="${part}"]`);
      if (!section) return;
      const lpfEl = section.querySelector<HTMLInputElement>('input[data-fx-lpf]');
      const dropEl = section.querySelector<HTMLInputElement>('input[data-fx-drop]');
      const everyNSel = section.querySelector<HTMLSelectElement>('select[data-fx-every-n]');
      const everyFnSel = section.querySelector<HTMLSelectElement>('select[data-fx-every-fn]');
      const panEl = section.querySelector<HTMLInputElement>('input[data-fx-pan]');
      const crushEl = section.querySelector<HTMLInputElement>('input[data-fx-crush]');
      const modSel = section.querySelector<HTMLSelectElement>('select[data-fx-mod]');
      const modTargetSel = section.querySelector<HTMLSelectElement>('select[data-fx-mod-target]');
      const plySel = section.querySelector<HTMLSelectElement>('select[data-fx-ply]');
      const structGridEl = section.querySelector<HTMLElement>('[data-fx-struct-grid]');
      const structClearEl = section.querySelector<HTMLButtonElement>('[data-fx-struct-clear]');
      const superSel = section.querySelector<HTMLSelectElement>('select[data-fx-superimpose]');
      const getFx = () => ((state[part] as any).fx as PartFx | undefined);
      if (lpfEl) {
        lpfEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.lpf = Number(lpfEl.value);
          const out = lpfEl.parentElement?.querySelector('output');
          if (out) out.textContent = fx.lpf >= 8000 ? 'off' : `${fx.lpf}`;
          scheduleLiveApply();
        });
      }
      if (dropEl) {
        dropEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.drop = Number(dropEl.value);
          const out = dropEl.parentElement?.querySelector('output');
          if (out) out.textContent = fx.drop === 0 ? 'off' : fx.drop.toFixed(2);
          scheduleLiveApply();
        });
      }
      if (modSel) {
        modSel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.mod = modSel.value as FilterMod; scheduleLiveApply();
        });
      }
      if (plySel) {
        plySel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.ply = Number(plySel.value); scheduleLiveApply();
        });
      }
      if (everyNSel) {
        everyNSel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.everyN = everyNSel.value as EveryN; scheduleLiveApply();
        });
      }
      if (everyFnSel) {
        everyFnSel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.everyFn = everyFnSel.value as EveryFn; scheduleLiveApply();
        });
      }
      if (panEl) {
        panEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.pan = Number(panEl.value);
          const out = panEl.parentElement?.querySelector('output');
          if (out) {
            const d = fx.pan - 0.5;
            out.textContent = Math.abs(d) < 0.01 ? 'C' : (d < 0 ? `L${Math.round(-d * 200)}` : `R${Math.round(d * 200)}`);
          }
          scheduleLiveApply();
        });
      }
      if (crushEl) {
        crushEl.addEventListener('input', () => {
          const fx = getFx(); if (!fx) return;
          fx.crush = Number(crushEl.value);
          const out = crushEl.parentElement?.querySelector('output');
          if (out) out.textContent = fx.crush === 0 ? 'off' : `${fx.crush}`;
          scheduleLiveApply();
        });
      }
      if (modTargetSel) {
        modTargetSel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.modTarget = modTargetSel.value as ModTarget; scheduleLiveApply();
        });
      }
      if (structGridEl) {
        // 16-cell rhythm strip. Cells are 'x' (active) or '~' (rest).
        // The fx.struct string is built from the cells; empty string
        // when all rests so applyFx emits nothing.
        const cells: boolean[] = new Array(16).fill(false);
        const seed = (getFx()?.struct ?? '').split(/\s+/).filter(Boolean);
        seed.slice(0, 16).forEach((t, i) => { cells[i] = t !== '~'; });
        for (let i = 0; i < 16; i++) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'fx-struct-cell' + (cells[i] ? ' is-on' : '');
          btn.dataset.cell = String(i);
          btn.addEventListener('click', () => {
            const fx = getFx(); if (!fx) return;
            cells[i] = !cells[i];
            btn.classList.toggle('is-on', cells[i]);
            const anyOn = cells.some(Boolean);
            fx.struct = anyOn ? cells.map((c) => (c ? 'x' : '~')).join(' ') : '';
            scheduleLiveApply();
          });
          structGridEl.appendChild(btn);
        }
        if (structClearEl) {
          structClearEl.addEventListener('click', () => {
            const fx = getFx(); if (!fx) return;
            cells.fill(false);
            structGridEl.querySelectorAll<HTMLElement>('.fx-struct-cell').forEach((el) => el.classList.remove('is-on'));
            fx.struct = '';
            scheduleLiveApply();
          });
        }
      }
      if (superSel) {
        superSel.addEventListener('change', () => {
          const fx = getFx(); if (!fx) return;
          fx.superimpose = superSel.value as Superimpose; scheduleLiveApply();
        });
      }
    });
  }

  // --- Sample drop
