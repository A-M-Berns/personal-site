---
import Base from '../../layouts/Base.astro';

// Sound palettes — strudel passes these through `.s("...")` (synths,
// drum machines, soundfonts) or `.piano()` for the special-cased
// piano. Soundfonts and drum-machine banks are loaded by
// @strudel/repl's prebake, so the gm_* names work out of the box.
const melodyPalette: { label: string; items: [string, string][] }[] = [
  { label: 'synths', items: [
    ['sine', 'sine'], ['triangle', 'triangle'], ['square', 'square'],
    ['sawtooth', 'saw'], ['supersaw', 'supersaw'], ['pulse', 'pulse'],
    ['z_sine', 'zzfx sine'], ['z_sawtooth', 'zzfx saw'],
    ['white', 'noise'],
  ] },
  { label: 'piano + keys', items: [
    ['piano', 'piano'],
    ['gm_acoustic_grand_piano', 'grand piano'],
    ['gm_electric_piano_1', 'rhodes'],
    ['gm_electric_piano_2', 'wurli'],
    ['gm_harpsichord', 'harpsichord'],
    ['gm_celesta', 'celesta'],
    ['gm_drawbar_organ', 'organ'],
  ] },
  { label: 'mallets', items: [
    ['gm_vibraphone', 'vibraphone'],
    ['gm_marimba', 'marimba'],
    ['gm_xylophone', 'xylophone'],
    ['gm_glockenspiel', 'glockenspiel'],
    ['gm_music_box', 'music box'],
    ['gm_kalimba', 'kalimba'],
  ] },
  { label: 'strings', items: [
    ['gm_violin', 'violin'],
    ['gm_cello', 'cello'],
    ['gm_string_ensemble_1', 'string ensemble'],
    ['gm_synth_strings_1', 'synth strings'],
    ['gm_pizzicato_strings', 'pizzicato'],
  ] },
  { label: 'pads', items: [
    ['gm_pad_1_new_age', 'pad: new age'],
    ['gm_pad_2_warm', 'pad: warm'],
    ['gm_pad_3_polysynth', 'pad: polysynth'],
    ['gm_pad_4_choir', 'pad: choir'],
    ['gm_pad_5_bowed', 'pad: bowed'],
    ['gm_pad_8_sweep', 'pad: sweep'],
  ] },
  { label: 'leads', items: [
    ['gm_lead_1_square', 'lead: square'],
    ['gm_lead_2_sawtooth', 'lead: saw'],
    ['gm_lead_3_calliope', 'lead: calliope'],
    ['gm_lead_5_charang', 'lead: charang'],
    ['gm_lead_8_bass_lead', 'lead: bass'],
  ] },
  { label: 'wind / brass', items: [
    ['gm_flute', 'flute'],
    ['gm_clarinet', 'clarinet'],
    ['gm_oboe', 'oboe'],
    ['gm_synth_brass_1', 'synth brass'],
    ['gm_trumpet', 'trumpet'],
  ] },
  { label: 'guitar', items: [
    ['gm_acoustic_guitar_nylon', 'guitar: nylon'],
    ['gm_electric_guitar_clean', 'guitar: clean'],
    ['gm_overdriven_guitar', 'guitar: overdrive'],
    ['gm_distortion_guitar', 'guitar: dist'],
  ] },
  { label: 'fx', items: [
    ['gm_fx_2_soundtrack', 'fx: soundtrack'],
    ['gm_fx_3_crystal', 'fx: crystal'],
    ['gm_fx_4_atmosphere', 'fx: atmosphere'],
    ['gm_fx_5_brightness', 'fx: brightness'],
    ['gm_fx_8_scifi', 'fx: sci-fi'],
  ] },
];

const bassPalette: { label: string; items: [string, string][] }[] = [
  { label: 'synth', items: [
    ['sawtooth', 'saw'], ['square', 'square'], ['sine', 'sine'],
    ['triangle', 'triangle'], ['pulse', 'pulse'], ['supersaw', 'supersaw'],
  ] },
  { label: 'soundfont', items: [
    ['gm_acoustic_bass', 'acoustic bass'],
    ['gm_electric_bass_finger', 'electric bass'],
    ['gm_electric_bass_pick', 'pick bass'],
    ['gm_fretless_bass', 'fretless'],
    ['gm_slap_bass_1', 'slap'],
    ['gm_synth_bass_1', 'synth bass'],
    ['gm_synth_bass_2', 'rezzy bass'],
    ['gm_lead_8_bass_lead', 'bass lead'],
  ] },
];
---
<Base title="Strudel — A. M. Berns" description="A small Strudel live-coding workspace.">
  <div class="strudel-shell">
    <header class="strudel-transport" aria-label="Transport">
      <div class="strudel-transport-actions">
        <button id="strudel-run" type="button" data-state="idle">Run</button>
        <button id="strudel-stop" type="button">Stop</button>
      </div>
      <label class="strudel-knob">
        <span>bpm</span>
        <input id="strudel-bpm" type="range" min="60" max="180" step="1" value="110" />
        <output id="strudel-bpm-out">110</output>
      </label>
      <label class="strudel-knob">
        <span>master</span>
        <input id="strudel-master" type="range" min="0" max="1" step="0.01" value="0.85" />
        <output id="strudel-master-out">0.85</output>
      </label>
      <label class="strudel-knob strudel-knob--key">
        <span>key</span>
        <select id="strudel-key">
          <option value="c">C</option>
          <option value="db">C♯ / D♭</option>
          <option value="d">D</option>
          <option value="eb">D♯ / E♭</option>
          <option value="e">E</option>
          <option value="f">F</option>
          <option value="gb">F♯ / G♭</option>
          <option value="g">G</option>
          <option value="ab">G♯ / A♭</option>
          <option value="a">A</option>
          <option value="bb">A♯ / B♭</option>
          <option value="b">B</option>
        </select>
      </label>
      <label class="strudel-knob strudel-knob--key">
        <span>scale</span>
        <select id="strudel-scale">
          <option value="minor">minor</option>
          <option value="major">major</option>
          <option value="dorian">dorian</option>
          <option value="mixolydian">mixolydian</option>
          <option value="harmonic minor">harmonic minor</option>
        </select>
      </label>
      <label class="strudel-knob">
        <span>swing</span>
        <input id="strudel-swing" type="range" min="0" max="0.5" step="0.01" value="0" />
        <output id="strudel-swing-out">0</output>
      </label>
      <div class="strudel-presets">
        <button type="button" data-preset="lofi">lo-fi</button>
        <button type="button" data-preset="techno">techno</button>
        <button type="button" data-preset="ambient">ambient</button>
        <button type="button" data-preset="empty">clear</button>
        <button id="strudel-share" type="button" title="Copy a link with this patch">share</button>
      </div>
    </header>

    <main class="strudel-workspace" aria-label="Strudel workspace">
      <section class="strudel-editor-pane">
        <div class="strudel-pane-head">
          <h2>Pattern</h2>
          <span id="strudel-status" class="strudel-status" aria-live="polite"></span>
        </div>
        <div id="strudel-host" class="strudel-host"></div>
      </section>

      <aside class="strudel-side-pane">
        <section class="strudel-part" data-part="drums">
          <header class="strudel-part-head">
            <label class="strudel-mute"><input type="checkbox" data-mute /><span>drums</span></label>
            <div class="strudel-part-controls">
              <input type="range" min="0" max="1" step="0.01" data-gain />
              <select data-bank>
                <option value="RolandTR909">909</option>
                <option value="RolandTR808">808</option>
                <option value="RolandTR707">707</option>
                <option value="RolandTR606">606</option>
                <option value="AlesisHR16">HR16</option>
                <option value="AkaiLinn">linn</option>
                <option value="ViscoSpaceDrum">visco</option>
                <option value="bossanova">bossa</option>
                <option value="casio">casio</option>
                <option value="">default</option>
              </select>
            </div>
          </header>
          <div id="strudel-drum-grid" class="strudel-step-grid" aria-label="Drum step grid"></div>
          <div class="strudel-fx-row">
            <label class="fx-knob"><span>filter</span><input type="range" min="200" max="8000" step="50" data-fx-lpf /><output></output></label>
            <label class="fx-knob"><span>drop</span><input type="range" min="0" max="0.5" step="0.05" data-fx-drop /><output></output></label><label class="fx-knob"><span>pan</span><input type="range" min="0" max="1" step="0.05" data-fx-pan /><output></output></label><label class="fx-knob"><span>crush</span><input type="range" min="0" max="16" step="1" data-fx-crush /><output></output></label>
            <label class="fx-toggle"><input type="checkbox" data-fx-vary /><span>vary</span></label><select data-fx-every><option value="">—</option><option value="4fast">×2 every 4</option><option value="8jux">jux every 8</option><option value="4rev">rev every 4</option><option value="8slow">½× every 8</option></select>
          </div>
        </section>

        <section class="strudel-part" data-part="chords">
          <header class="strudel-part-head">
            <label class="strudel-mute"><input type="checkbox" data-mute /><span>chords</span></label>
            <div class="strudel-part-controls">
              <input type="range" min="0" max="1" step="0.01" data-gain />
              <select data-sound>
                {melodyPalette.map((group) => (
                  <optgroup label={group.label}>
                    {group.items.map(([value, label]) => (<option value={value}>{label}</option>))}
                  </optgroup>
                ))}
              </select>
            </div>
          </header>
          <div id="strudel-chord-grid" class="strudel-chord-grid" aria-label="Chord progression"></div>
          <div class="strudel-fx-row">
            <label class="fx-knob"><span>filter</span><input type="range" min="200" max="8000" step="50" data-fx-lpf /><output></output></label>
            <label class="fx-knob"><span>room</span><input type="range" min="0" max="1" step="0.05" data-fx-room /><output></output></label>
            <label class="fx-knob"><span>attack</span><input type="range" min="0" max="2" step="0.05" data-attack /><output></output></label>
            <label class="fx-knob"><span>drop</span><input type="range" min="0" max="0.5" step="0.05" data-fx-drop /><output></output></label><label class="fx-knob"><span>pan</span><input type="range" min="0" max="1" step="0.05" data-fx-pan /><output></output></label><label class="fx-knob"><span>crush</span><input type="range" min="0" max="16" step="1" data-fx-crush /><output></output></label>
            <label class="fx-toggle"><input type="checkbox" data-fx-vary /><span>vary</span></label><select data-fx-every><option value="">—</option><option value="4fast">×2 every 4</option><option value="8jux">jux every 8</option><option value="4rev">rev every 4</option><option value="8slow">½× every 8</option></select>
          </div>
        </section>

        <section class="strudel-part" data-part="bass">
          <header class="strudel-part-head">
            <label class="strudel-mute"><input type="checkbox" data-mute /><span>bass</span></label>
            <div class="strudel-part-controls">
              <input type="range" min="0" max="1" step="0.01" data-gain />
              <select data-sound>
                {bassPalette.map((group) => (
                  <optgroup label={group.label}>
                    {group.items.map(([value, label]) => (<option value={value}>{label}</option>))}
                  </optgroup>
                ))}
              </select>
            </div>
          </header>
          <div class="strudel-bass-row">
            <select data-rhythm>
              <option value="root">root only</option>
              <option value="steady">steady</option>
              <option value="syncopated" selected>syncopated</option>
              <option value="octaves">octaves</option>
              <option value="walking">walking</option>
            </select>
            <label><input type="checkbox" data-follow checked /><span>follow chords</span></label>
          </div>
          <div class="strudel-fx-row">
            <label class="fx-knob"><span>filter</span><input type="range" min="200" max="8000" step="50" data-fx-lpf /><output></output></label>
            <label class="fx-knob"><span>drop</span><input type="range" min="0" max="0.5" step="0.05" data-fx-drop /><output></output></label><label class="fx-knob"><span>pan</span><input type="range" min="0" max="1" step="0.05" data-fx-pan /><output></output></label><label class="fx-knob"><span>crush</span><input type="range" min="0" max="16" step="1" data-fx-crush /><output></output></label>
            <label class="fx-toggle"><input type="checkbox" data-fx-vary /><span>vary</span></label><select data-fx-every><option value="">—</option><option value="4fast">×2 every 4</option><option value="8jux">jux every 8</option><option value="4rev">rev every 4</option><option value="8slow">½× every 8</option></select>
          </div>
        </section>

        <section class="strudel-part" data-part="arp">
          <header class="strudel-part-head">
            <label class="strudel-mute"><input type="checkbox" data-mute /><span>arp</span></label>
            <div class="strudel-part-controls">
              <input type="range" min="0" max="1" step="0.01" data-gain />
              <select data-sound>
                {melodyPalette.map((group) => (
                  <optgroup label={group.label}>
                    {group.items.map(([value, label]) => (<option value={value}>{label}</option>))}
                  </optgroup>
                ))}
              </select>
            </div>
          </header>
          <div class="strudel-roll-row">
            <label><input type="checkbox" data-follow checked /><span>follow chords</span></label>
            <select data-speed>
              <option value="1">×1</option>
              <option value="2" selected>×2</option>
              <option value="4">×4</option>
            </select>
          </div>
          <div id="strudel-arp-roll" class="strudel-piano-roll" aria-label="Arp piano roll"></div>
          <div class="strudel-fx-row">
            <label class="fx-knob"><span>filter</span><input type="range" min="200" max="8000" step="50" data-fx-lpf /><output></output></label>
            <label class="fx-knob"><span>drop</span><input type="range" min="0" max="0.5" step="0.05" data-fx-drop /><output></output></label><label class="fx-knob"><span>pan</span><input type="range" min="0" max="1" step="0.05" data-fx-pan /><output></output></label><label class="fx-knob"><span>crush</span><input type="range" min="0" max="16" step="1" data-fx-crush /><output></output></label>
            <label class="fx-toggle"><input type="checkbox" data-fx-vary /><span>vary</span></label><select data-fx-every><option value="">—</option><option value="4fast">×2 every 4</option><option value="8jux">jux every 8</option><option value="4rev">rev every 4</option><option value="8slow">½× every 8</option></select>
          </div>
        </section>

        <section class="strudel-part" data-part="lead">
          <header class="strudel-part-head">
            <label class="strudel-mute"><input type="checkbox" data-mute /><span>lead</span></label>
            <div class="strudel-part-controls">
              <input type="range" min="0" max="1" step="0.01" data-gain />
              <select data-sound>
                {melodyPalette.map((group) => (
                  <optgroup label={group.label}>
                    {group.items.map(([value, label]) => (<option value={value}>{label}</option>))}
                  </optgroup>
                ))}
              </select>
            </div>
          </header>
          <div class="strudel-roll-row strudel-roll-row--effects">
            <label><input type="checkbox" data-effect="delay" /><span>delay</span></label>
            <label><input type="checkbox" data-effect="room" /><span>room</span></label>
            <label><input type="checkbox" data-effect="jux" /><span>jux</span></label>
            <label><input type="checkbox" data-effect="ghost" /><span>ghost</span></label>
            <label><input type="checkbox" data-effect="shape" /><span>shape</span></label>
            <label class="fx-knob fx-knob--inline"><span>attack</span><input type="range" min="0" max="2" step="0.05" data-attack /><output></output></label>
          </div>
          <div id="strudel-lead-roll" class="strudel-piano-roll" aria-label="Lead piano roll"></div>
          <div class="strudel-fx-row">
            <label class="fx-knob"><span>filter</span><input type="range" min="200" max="8000" step="50" data-fx-lpf /><output></output></label>
            <label class="fx-knob"><span>drop</span><input type="range" min="0" max="0.5" step="0.05" data-fx-drop /><output></output></label><label class="fx-knob"><span>pan</span><input type="range" min="0" max="1" step="0.05" data-fx-pan /><output></output></label><label class="fx-knob"><span>crush</span><input type="range" min="0" max="16" step="1" data-fx-crush /><output></output></label>
            <label class="fx-toggle"><input type="checkbox" data-fx-vary /><span>vary</span></label><select data-fx-every><option value="">—</option><option value="4fast">×2 every 4</option><option value="8jux">jux every 8</option><option value="4rev">rev every 4</option><option value="8slow">½× every 8</option></select>
          </div>
        </section>

        <section class="strudel-part" data-part="sample">
          <header class="strudel-part-head">
            <label class="strudel-mute"><input type="checkbox" data-mute /><span>drop sample</span></label>
            <div class="strudel-part-controls">
              <input type="range" min="0" max="1" step="0.01" data-gain />
            </div>
          </header>
          <label id="strudel-drop" class="strudel-drop" for="strudel-sample-file">
            <input id="strudel-sample-file" type="file" accept="audio/*" />
            <span id="strudel-drop-label">drop audio or choose file</span>
          </label>
        </section>
      </aside>
    </main>

    <div class="anim-controls">
      <button id="strudel-info" type="button" aria-label="About this Strudel page">About</button>
      <button id="strudel-reset" type="button" aria-label="Reset workspace">Reset</button>
    </div>

    <dialog id="strudel-about" class="anim-about" aria-labelledby="strudel-about-title">
      <h2 id="strudel-about-title">About</h2>
      <p>
        This page embeds <a href="https://www.npmjs.com/package/@strudel/repl">@strudel/repl</a>,
        part of <a href="https://codeberg.org/uzu/strudel">Strudel</a>, licensed under
        <a href="https://codeberg.org/uzu/strudel/src/branch/main/LICENSE">AGPL-3.0-or-later</a>.
        The GUI on the right writes the code on the left — edit either, but GUI changes overwrite manual edits.
        Site source at <a href="https://github.com/A-M-Berns/personal-site">GitHub</a>.
      </p>
    </dialog>
  </div>
</Base>

<style is:global>
  /* Editor host: scope down strudel-editor's defaults to fit the page. */
  .strudel-host {
    position: relative;
    flex: 1;
    min-height: 0;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.035);
    overflow: hidden;
    transition: border-color 140ms ease, box-shadow 180ms ease;
  }
  .strudel-host.is-running {
    border-color: var(--accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .strudel-host strudel-editor { display: none; }
  .strudel-host > div:not(.cm-host) {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: transparent;
  }
  .strudel-host .cm-editor {
    height: 100%;
    background: transparent !important;
    color: var(--ink);
    font: 0.92rem/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
  }
  .strudel-host .cm-scroller {
    background: transparent !important;
    font-family: inherit !important;
  }
  .strudel-host .cm-gutters {
    background: rgba(255, 255, 255, 0.02) !important;
    border-right: 1px solid var(--rule) !important;
    color: var(--muted) !important;
  }
  .strudel-host .cm-activeLine,
  .strudel-host .cm-activeLineGutter {
    background: rgba(255, 255, 255, 0.04) !important;
  }
  .strudel-host .cm-content {
    caret-color: var(--accent) !important;
  }
  .strudel-host .cm-cursor {
    border-left-color: var(--accent) !important;
  }
  .strudel-host .cm-selectionBackground,
  .strudel-host .cm-content ::selection {
    background: color-mix(in srgb, var(--accent) 30%, transparent) !important;
  }
</style>

<style>
  .strudel-shell {
    position: relative;
    height: calc(100vh - 11.25rem);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .strudel-transport {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    padding: 0.55rem 0.85rem;
    background: #000;
    border: 1px solid var(--rule);
    border-radius: 3px;
  }
  .strudel-transport-actions { display: flex; gap: 0.4rem; }
  .strudel-knob {
    display: grid;
    grid-template-columns: auto 7rem auto;
    align-items: center;
    gap: 0.45rem;
    color: var(--muted);
    font: 0.7rem/1 var(--font-lexend), var(--sans);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .strudel-knob--key { grid-template-columns: auto 1fr; }
  .strudel-knob output {
    font-variant-numeric: tabular-nums;
    color: var(--ink);
    text-align: right;
    min-width: 2.4rem;
  }
  .strudel-knob input[type="range"] { accent-color: var(--accent); width: 100%; }
  .strudel-presets { margin-left: auto; display: flex; gap: 0.4rem; }
  .strudel-presets button,
  .strudel-transport-actions button {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.35rem 0.65rem;
    cursor: pointer;
  }
  .strudel-transport-actions button[data-state="running"] {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-presets button:hover,
  .strudel-transport-actions button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-status {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .strudel-workspace {
    display: grid;
    grid-template-columns: minmax(34rem, 1.7fr) minmax(20rem, 24rem);
    gap: 1rem;
    align-items: stretch;
    flex: 1;
    min-height: 0;
  }
  .strudel-editor-pane,
  .strudel-side-pane {
    background: #000;
    padding: 0.85rem;
    border: 1px solid var(--rule);
    border-radius: 3px;
  }
  .strudel-editor-pane { display: flex; flex-direction: column; min-height: 0; }
  .strudel-pane-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.55rem;
  }
  .strudel-pane-head h2,
  .strudel-part-head .strudel-mute span {
    font-family: var(--display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
