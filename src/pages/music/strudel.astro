      input.checked = !!state.lead.effects[key];
    });
    const bankSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="drums"] select[data-bank]');
    if (bankSel) bankSel.value = state.drums.bank;
    const chordSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="chords"] select[data-sound]');
    if (chordSoundSel) chordSoundSel.value = state.chords.sound;
    const bassSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="bass"] select[data-sound]');
    if (bassSoundSel) bassSoundSel.value = state.bass.sound;
    const bassRhythmSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="bass"] select[data-rhythm]');
    if (bassRhythmSel) bassRhythmSel.value = state.bass.rhythm;
    const bassFollowEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="bass"] input[data-follow]');
    if (bassFollowEl) bassFollowEl.checked = state.bass.follow;
    const arpSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="arp"] select[data-sound]');
    if (arpSoundSel) arpSoundSel.value = state.arp.sound;
    const arpSpeedSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="arp"] select[data-speed]');
    if (arpSpeedSel) arpSpeedSel.value = String(state.arp.speed);
    const arpFollowEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="arp"] input[data-follow]');
    if (arpFollowEl) arpFollowEl.checked = state.arp.follow;
    const leadSoundSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="lead"] select[data-sound]');
    if (leadSoundSel) leadSoundSel.value = state.lead.sound;
  }

  function renderAll() {
    renderDrumGrid();
    renderChords();
    renderRoll(document.getElementById('strudel-arp-roll'), state.arp.cells, ARP_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
    renderMidiRoll(document.getElementById('strudel-lead-roll'), state.lead.notes, LEAD_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
    syncAllInputs();
  }

  // initial bindings — attach listeners once; preset/reset only update values via syncAllInputs
  (['drums', 'chords', 'bass', 'arp', 'lead', 'sample'] as const).forEach(bindPart);
  bindDrums();
  bindChordsExtras();
  bindChordsRoom();
  bindChordsVowel();
  bindChordsAttack();
  bindBass();
  bindArpExtras();
  bindLeadExtras();
  bindFx();
  renderDrumGrid();
  renderChords();
  renderRoll(document.getElementById('strudel-arp-roll'), state.arp.cells, ARP_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
  renderMidiRoll(document.getElementById('strudel-lead-roll'), state.lead.notes, LEAD_STEPS, scheduleLiveApply, (d) => degreeLabel(d, state.key, state.scale));
  syncAllInputs();

  // Eagerly load the editor so the code panel reflects state immediately,
  // not only after the user clicks Run.
  ensureEditor().catch(() => setStatus('editor unavailable'));
</script>
