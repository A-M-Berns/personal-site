    { label: 'piano + keys', items: [['piano', 'piano'], ['gm_acoustic_grand_piano', 'grand piano'], ['gm_electric_piano_1', 'rhodes'], ['gm_electric_piano_2', 'wurli'], ['gm_harpsichord', 'harpsichord'], ['gm_celesta', 'celesta'], ['gm_drawbar_organ', 'organ']] },
    { label: 'mallets', items: [['gm_vibraphone', 'vibraphone'], ['gm_marimba', 'marimba'], ['gm_xylophone', 'xylophone'], ['gm_glockenspiel', 'glockenspiel'], ['gm_music_box', 'music box'], ['gm_kalimba', 'kalimba']] },
    { label: 'strings', items: [['gm_violin', 'violin'], ['gm_cello', 'cello'], ['gm_string_ensemble_1', 'string ensemble'], ['gm_synth_strings_1', 'synth strings'], ['gm_pizzicato_strings', 'pizzicato']] },
    { label: 'pads', items: [['gm_pad_1_new_age', 'pad: new age'], ['gm_pad_2_warm', 'pad: warm'], ['gm_pad_3_polysynth', 'pad: polysynth'], ['gm_pad_4_choir', 'pad: choir'], ['gm_pad_5_bowed', 'pad: bowed'], ['gm_pad_8_sweep', 'pad: sweep']] },
    { label: 'leads', items: [['gm_lead_1_square', 'lead: square'], ['gm_lead_2_sawtooth', 'lead: saw'], ['gm_lead_3_calliope', 'lead: calliope'], ['gm_lead_5_charang', 'lead: charang'], ['gm_lead_8_bass_lead', 'lead: bass']] },
    { label: 'wind / brass', items: [['gm_flute', 'flute'], ['gm_clarinet', 'clarinet'], ['gm_oboe', 'oboe'], ['gm_synth_brass_1', 'synth brass'], ['gm_trumpet', 'trumpet']] },
    { label: 'guitar', items: [['gm_acoustic_guitar_nylon', 'guitar: nylon'], ['gm_electric_guitar_clean', 'guitar: clean'], ['gm_overdriven_guitar', 'guitar: overdrive'], ['gm_distortion_guitar', 'guitar: dist']] },
    { label: 'fx', items: [['gm_fx_2_soundtrack', 'fx: soundtrack'], ['gm_fx_3_crystal', 'fx: crystal'], ['gm_fx_4_atmosphere', 'fx: atmosphere'], ['gm_fx_5_brightness', 'fx: brightness'], ['gm_fx_8_scifi', 'fx: sci-fi']] },
  ];
  const BASS_PALETTE: { label: string; items: [string, string][] }[] = [
    { label: 'synth', items: [['sawtooth', 'saw'], ['square', 'square'], ['sine', 'sine'], ['triangle', 'triangle'], ['pulse', 'pulse'], ['supersaw', 'supersaw']] },
    { label: 'soundfont', items: [['gm_acoustic_bass', 'acoustic bass'], ['gm_electric_bass_finger', 'electric bass'], ['gm_electric_bass_pick', 'pick bass'], ['gm_fretless_bass', 'fretless'], ['gm_slap_bass_1', 'slap'], ['gm_synth_bass_1', 'synth bass'], ['gm_synth_bass_2', 'rezzy bass'], ['gm_lead_8_bass_lead', 'bass lead']] },
  ];
  function makeSoundSelect(palette: typeof MELODY_PALETTE, value: string): HTMLSelectElement {
    const sel = document.createElement('select');
    palette.forEach((group) => {
      const og = document.createElement('optgroup');
      og.label = group.label;
      group.items.forEach(([v, label]) => {
        const opt = document.createElement('option');
        opt.value = v;
        opt.textContent = label;
        if (v === value) opt.selected = true;
        og.appendChild(opt);
      });
      sel.appendChild(og);
    });
    sel.value = value;
    return sel;
  }
  const DRUM_BANKS: [string, string][] = [
    ['RolandTR909', '909'], ['RolandTR808', '808'], ['RolandTR707', '707'], ['RolandTR606', '606'],
    ['AlesisHR16', 'HR16'], ['AkaiLinn', 'linn'], ['ViscoSpaceDrum', 'visco'],
    ['bossanova', 'bossa'], ['casio', 'casio'], ['', 'default'],
  ];

  function makePartHead(p: Part, sec: HTMLElement, onChange: () => void): HTMLElement {
    const head = el('header', { class: 'strudel-part-head' });
    // Mute / Solo
    const ms = el('div', { class: 'strudel-ms' });
    const mBtn = el('button', {
      type: 'button',
      'aria-label': 'mute',
      dataset: { kind: 'm' },
      class: p.enabled ? '' : 'is-active',
    }, 'M') as HTMLButtonElement;
    mBtn.addEventListener('click', () => {
      p.enabled = !p.enabled;
      mBtn.classList.toggle('is-active', !p.enabled);
      sec.classList.toggle('is-muted', !p.enabled);
      onChange();
    });
    const sBtn = el('button', {
      type: 'button',
      'aria-label': 'solo',
      dataset: { kind: 's' },
      class: p.soloed ? 'is-active' : '',
    }, 'S') as HTMLButtonElement;
    sBtn.addEventListener('click', () => {
      p.soloed = !p.soloed;
      sBtn.classList.toggle('is-active', p.soloed);
      onChange();
    });
    ms.append(mBtn, sBtn);

    // Title
    const title = el('span', { class: 'strudel-part-title' }, p.type);

    // Gain
    const controls = el('div', { class: 'strudel-part-controls' });
    const gainEl = el('input', {
      type: 'range', min: '0', max: '1', step: '0.01', value: String(p.gain),
    }) as HTMLInputElement;
    gainEl.addEventListener('input', () => {
      p.gain = Number(gainEl.value);
      onChange();
    });
    controls.append(gainEl);

    // Sound select for parts that use one
    if (p.type === 'chords' || p.type === 'arp' || p.type === 'lead') {
      const sel = makeSoundSelect(MELODY_PALETTE, (p as any).sound);
      sel.addEventListener('change', () => { (p as any).sound = sel.value; onChange(); });
      controls.append(sel);
    } else if (p.type === 'bass') {
      const sel = makeSoundSelect(BASS_PALETTE, (p as BassPart).sound);
      sel.addEventListener('change', () => { (p as BassPart).sound = sel.value; onChange(); });
      controls.append(sel);
    } else if (p.type === 'drums') {
      const sel = document.createElement('select');
      DRUM_BANKS.forEach(([v, l]) => {
        const opt = document.createElement('option');
        opt.value = v; opt.textContent = l;
        if (v === (p as DrumsPart).bank) opt.selected = true;
        sel.appendChild(opt);
      });
      sel.addEventListener('change', () => { (p as DrumsPart).bank = sel.value; onChange(); });
      controls.append(sel);
    }

    // Delete
    const del = el('button', { type: 'button', class: 'strudel-part-delete', 'aria-label': 'remove part', title: 'remove part' }, '×');
    del.addEventListener('click', () => {
      const idx = state.parts.indexOf(p);
      if (idx >= 0) {
        state.parts.splice(idx, 1);
        sec.remove();
        onChange();
      }
    });

    head.append(ms, title, controls, del);
    return head;
  }

  // Generic fx-row builder shared by all part types.
  function makeFxRow(p: Part, onChange: () => void): HTMLElement {
    const row = el('div', { class: 'strudel-fx-row' });

    const sliderKnob = (label: string, min: string, max: string, step: string, get: () => number, set: (v: number) => void, fmt: (v: number) => string) => {
      const lbl = el('label', { class: 'fx-knob' });
      const span = el('span', {}, label);
      const input = el('input', { type: 'range', min, max, step, value: String(get()) }) as HTMLInputElement;
      const out = el('output', {}, fmt(get()));
      input.addEventListener('input', () => {
        const v = Number(input.value); set(v); out.textContent = fmt(v); onChange();
      });
      lbl.append(span, input, out);
      return lbl;
    };
    const smallSelectKnob = (label: string, options: [string, string][], get: () => string, set: (v: string) => void) => {
      const lbl = el('label', { class: 'fx-knob fx-knob--small' });
      lbl.appendChild(el('span', {}, label));
      const sel = document.createElement('select');
      options.forEach(([v, l]) => {
        const opt = document.createElement('option');
        opt.value = v; opt.textContent = l;
        if (v === get()) opt.selected = true;
        sel.appendChild(opt);
      });
      sel.addEventListener('change', () => { set(sel.value); onChange(); });
      lbl.appendChild(sel);
      return lbl;
    };

    row.append(
      sliderKnob('filter', '200', '8000', '50', () => p.fx.lpf, (v) => { p.fx.lpf = v; }, (v) => v >= 8000 ? 'off' : `${Math.round(v)}`),
      sliderKnob('drop', '0', '0.5', '0.05', () => p.fx.drop, (v) => { p.fx.drop = v; }, (v) => v === 0 ? 'off' : v.toFixed(2)),
      sliderKnob('pan', '0', '1', '0.05', () => p.fx.pan, (v) => { p.fx.pan = v; }, (v) => {
        const d = v - 0.5;
        return Math.abs(d) < 0.01 ? 'C' : (d < 0 ? `L${Math.round(-d * 200)}` : `R${Math.round(d * 200)}`);
      }),
      sliderKnob('crush', '0', '16', '1', () => p.fx.crush, (v) => { p.fx.crush = v; }, (v) => v === 0 ? 'off' : `${v}`),
      smallSelectKnob('mod', [
        ['', 'none'], ['sine-slow', '∿ sine slow'], ['sine-fast', '∿ sine fast'],
        ['tri', '△ tri'], ['saw', '⩘ saw'], ['square', '▢ square'],
        ['rand', '? rand'], ['perlin', '~ perlin'],
      ], () => p.fx.mod, (v) => { p.fx.mod = v as FilterMod; }),
      smallSelectKnob('→', [['lpf', 'filter'], ['pan', 'pan'], ['gain', 'gain']], () => p.fx.modTarget, (v) => { p.fx.modTarget = v as ModTarget; }),
      smallSelectKnob('ply', [['1', '×1'], ['2', '×2'], ['3', '×3'], ['4', '×4']], () => String(p.fx.ply), (v) => { p.fx.ply = Number(v); }),
    );

    // every group [fn] every [N]
    const everyGroup = el('div', { class: 'fx-every-group' });
    const fnSel = document.createElement('select');
    [['', '—'], ['fast2', 'fast ×2'], ['slow2', 'slow ×½'], ['rev', 'rev'], ['jux', 'jux rev'], ['chop', 'chop']].forEach(([v, l]) => {
      const opt = document.createElement('option'); opt.value = v; opt.textContent = l;
      if (v === p.fx.everyFn) opt.selected = true; fnSel.appendChild(opt);
    });
    fnSel.addEventListener('change', () => { p.fx.everyFn = fnSel.value as EveryFn; onChange(); });
    everyGroup.appendChild(fnSel);
    everyGroup.appendChild(el('span', { class: 'fx-every-label' }, 'every'));
    const nSel = document.createElement('select');
    [['', '—'], ['2', '2'], ['4', '4'], ['8', '8']].forEach(([v, l]) => {
      const opt = document.createElement('option'); opt.value = v; opt.textContent = l;
      if (v === p.fx.everyN) opt.selected = true; nSel.appendChild(opt);
    });
    nSel.addEventListener('change', () => { p.fx.everyN = nSel.value as EveryN; onChange(); });
    everyGroup.appendChild(nSel);
    row.appendChild(everyGroup);

    row.appendChild(smallSelectKnob('double', [
      ['', '—'], ['+5', '+5th'], ['+12', '+oct'], ['-12', '-oct'],
    ], () => p.fx.superimpose, (v) => { p.fx.superimpose = v as Superimpose; }));

    // Struct grid (16 cells)
    const structBox = el('div', { class: 'fx-struct' });
    structBox.appendChild(el('span', { class: 'fx-struct-label' }, 'struct'));
    const structGrid = el('div', { class: 'fx-struct-grid' });
    const cells: boolean[] = new Array(16).fill(false);
    (p.fx.struct || '').split(/\s+/).filter(Boolean).slice(0, 16).forEach((t, i) => { cells[i] = t === 'x'; });
    for (let i = 0; i < 16; i++) {
      const c = el('button', {
        type: 'button',
        class: `fx-struct-cell${cells[i] ? ' is-on' : ''}`,
      }) as HTMLButtonElement;
      c.addEventListener('click', () => {
        cells[i] = !cells[i];
        c.classList.toggle('is-on', cells[i]);
        p.fx.struct = cells.some(Boolean) ? cells.map((on) => (on ? 'x' : '~')).join(' ') : '';
        onChange();
      });
      structGrid.appendChild(c);
    }
    structBox.appendChild(structGrid);
    const clearBtn = el('button', { type: 'button', class: 'fx-struct-clear', title: 'Clear struct' }, '×');
    clearBtn.addEventListener('click', () => {
      cells.fill(false);
      structGrid.querySelectorAll('.fx-struct-cell').forEach((c) => c.classList.remove('is-on'));
      p.fx.struct = '';
      onChange();
    });
    structBox.appendChild(clearBtn);
    row.appendChild(structBox);

    return row;
  }

  // ===== Part body renderers =====

  function renderDrums(p: DrumsPart, sec: HTMLElement, onChange: () => void) {
    const grid = el('div', { class: 'strudel-step-grid' });
    function refreshGrid() {
      grid.replaceChildren();
      grid.style.gridTemplateColumns = `2.4rem repeat(16, minmax(0, 1fr)) 1.4rem`;
      p.rows.forEach((row) => {
        const info = drumRowInfo(row);
        const label = el('span', { class: 'strudel-step-label', title: info.label });
        label.appendChild(el('span', {}, info.icon));
        const remove = el('button', { type: 'button', title: `remove ${info.label}` }, '×');
        remove.addEventListener('click', () => {
          p.rows = p.rows.filter((r) => r !== row);
          delete p.steps[row];
          refreshGrid();
          onChange();
        });
        label.appendChild(remove);
        grid.appendChild(label);
        if (!p.steps[row]) p.steps[row] = new Array(STEPS).fill(false);
        for (let s = 0; s < STEPS; s++) {
          const isBeat = s % 4 === 0;
          const on = !!p.steps[row][s];
          const btn = el('button', {
            type: 'button',
            class: `drum-cell${on ? ' is-on' : ''}${isBeat ? ' is-beat' : ''}`,
            'aria-pressed': String(on),
          }) as HTMLButtonElement;
          let painting = false;
          let paintValue = false;
          btn.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            const next = !p.steps[row][s];
            p.steps[row][s] = next;
            btn.classList.toggle('is-on', next);
            paintingPattern.value = next;
            paintingActive = true;
            onChange();
          });
          btn.addEventListener('pointerenter', () => {
            if (!paintingActive) return;
            p.steps[row][s] = paintingPattern.value;
            btn.classList.toggle('is-on', paintingPattern.value);
            onChange();
          });
          grid.appendChild(btn);
        }
        // empty slot at end of row (column for remove button)
        const spacer = el('span', {});
        grid.appendChild(spacer);
      });
      // Add-row picker as a final full-width strip
      const addStrip = el('div', { class: 'drum-row-add' });
      addStrip.appendChild(el('span', {}, 'add:'));
      DRUM_ROW_PALETTE
        .filter((r) => !p.rows.includes(r.code))
        .forEach((r) => {
          const b = el('button', { type: 'button', title: r.label }, `${r.icon} ${r.label}`);
          b.addEventListener('click', () => {
            p.rows.push(r.code);
            p.steps[r.code] = new Array(STEPS).fill(false);
            refreshGrid();
            onChange();
          });
          addStrip.appendChild(b);
        });
      if (DRUM_ROW_PALETTE.every((r) => p.rows.includes(r.code))) {
        addStrip.appendChild(el('span', {}, '(all drums added)'));
      }
      grid.appendChild(addStrip);
    }
    refreshGrid();
    sec.appendChild(grid);
    sec.appendChild(makeFxRow(p, onChange));
  }

  function renderChords(p: ChordsPart, sec: HTMLElement, onChange: () => void) {
    const grid = el('div', { class: 'strudel-chord-grid' });
    function refreshGrid() {
      grid.replaceChildren();
      if (p.slots.length === 0) {
        grid.appendChild(el('div', { class: 'chord-empty-hint' }, 'no chords yet — click + to add one'));
      }
      const ROOT_OPTIONS = NOTE_NAMES;
      const QUALITIES: Quality[] = ['min', 'maj', '7', 'maj7', 'min7', 'sus', 'dim'];
      p.slots.forEach((slot, idx) => {
        const row = el('div', { class: 'strudel-chord-row' });
        const idxLabel = el('span', { class: 'chord-idx' }, String(idx + 1));
        const name = el('span', { class: 'chord-name' }, chordLabel(slot));
        const rootSel = document.createElement('select');
        ROOT_OPTIONS.forEach((r) => {
          const opt = document.createElement('option');
          opt.value = r;
          opt.textContent = r.replace('b', '♭').toUpperCase();
          if (r === slot.root) opt.selected = true;
          rootSel.appendChild(opt);
        });
        rootSel.addEventListener('change', () => { p.slots[idx].root = rootSel.value; refreshGrid(); onChange(); });
        const qualSel = document.createElement('select');
        QUALITIES.forEach((q) => {
          const opt = document.createElement('option');
          opt.value = q; opt.textContent = q;
          if (q === slot.quality) opt.selected = true;
          qualSel.appendChild(opt);
        });
        qualSel.addEventListener('change', () => { p.slots[idx].quality = qualSel.value as Quality; refreshGrid(); onChange(); });
        const oct = el('div', { class: 'chord-oct' });
        const minus = el('button', { type: 'button', title: 'lower octave' }, '−');
        const octLabel = el('span', { class: 'chord-oct-label' }, String(slot.octave));
        const plus = el('button', { type: 'button', title: 'raise octave' }, '+');
        minus.addEventListener('click', () => { p.slots[idx].octave = Math.max(1, slot.octave - 1); refreshGrid(); onChange(); });
        plus.addEventListener('click', () => { p.slots[idx].octave = Math.min(6, slot.octave + 1); refreshGrid(); onChange(); });
        oct.append(minus, octLabel, plus);
        const intervals = SCALES[state.scale] ?? SCALES.minor;
        const numerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII'];
        const interval = ((rootIndex(slot.root) - rootIndex(state.key)) % 12 + 12) % 12;
        const deg = intervals.indexOf(interval);
        const isMin = slot.quality === 'min' || slot.quality === 'min7' || slot.quality === 'dim';
        const romanText = deg < 0 ? '–' : (isMin ? numerals[deg]?.toLowerCase() : numerals[deg]);
        const degEl = el('span', { class: 'chord-degree' }, romanText ?? '–');
        const remove = el('button', { type: 'button', class: 'chord-remove', title: 'remove chord' }, '×');
        remove.addEventListener('click', () => { p.slots.splice(idx, 1); refreshGrid(); onChange(); });
        row.append(idxLabel, name, rootSel, qualSel, oct, degEl, remove);
        grid.appendChild(row);
      });
      const add = el('button', { type: 'button', class: 'chord-add' }, '+ add chord');
      add.addEventListener('click', () => {
        const last = p.slots[p.slots.length - 1];
        p.slots.push({
          root: last?.root ?? state.key,
          quality: last?.quality ?? 'min',
          octave: last?.octave ?? 3,
        });
        refreshGrid();
        onChange();
      });
      grid.appendChild(add);
    }
    refreshGrid();
    sec.appendChild(grid);

    // Room slider + vowel + attack
    const extras = el('div', { class: 'strudel-fx-row' });
    const roomLbl = el('label', { class: 'fx-knob' });
    roomLbl.append(el('span', {}, 'room'));
    const roomEl = el('input', { type: 'range', min: '0', max: '1', step: '0.05', value: String(p.room) }) as HTMLInputElement;
    const roomOut = el('output', {}, p.room.toFixed(2));
    roomEl.addEventListener('input', () => { p.room = Number(roomEl.value); roomOut.textContent = p.room.toFixed(2); onChange(); });
    roomLbl.append(roomEl, roomOut);
    extras.appendChild(roomLbl);

    const attackLbl = el('label', { class: 'fx-knob' });
    attackLbl.append(el('span', {}, 'attack'));
    const attackEl = el('input', { type: 'range', min: '0', max: '2', step: '0.05', value: String(p.attack) }) as HTMLInputElement;
    const attackOut = el('output', {}, p.attack === 0 ? 'off' : p.attack.toFixed(2));
    attackEl.addEventListener('input', () => {
      p.attack = Number(attackEl.value);
      attackOut.textContent = p.attack === 0 ? 'off' : p.attack.toFixed(2);
      onChange();
    });
    attackLbl.append(attackEl, attackOut);
    extras.appendChild(attackLbl);

    const vowelLbl = el('label', { class: 'fx-knob fx-knob--small' });
    vowelLbl.append(el('span', {}, 'vowel'));
    const vowelSel = document.createElement('select');
    [['', 'none'], ['a', 'a'], ['e', 'e'], ['i', 'i'], ['o', 'o'], ['u', 'u'], ['<a e i o>', 'a→e→i→o'], ['<a o>', 'a↔o'], ['<i u>', 'i↔u']].forEach(([v, l]) => {
      const opt = document.createElement('option'); opt.value = v; opt.textContent = l;
      if (v === p.vowel) opt.selected = true; vowelSel.appendChild(opt);
    });
    vowelSel.addEventListener('change', () => { p.vowel = vowelSel.value; onChange(); });
    vowelLbl.appendChild(vowelSel);
    extras.appendChild(vowelLbl);

    sec.appendChild(extras);
    sec.appendChild(makeFxRow(p, onChange));
  }

  function renderBass(p: BassPart, sec: HTMLElement, onChange: () => void) {
    const row = el('div', { class: 'strudel-bass-row' });
    const rhythmSel = document.createElement('select');
    [['root', 'root only'], ['steady', 'steady'], ['syncopated', 'syncopated'], ['octaves', 'octaves'], ['walking', 'walking']].forEach(([v, l]) => {
      const opt = document.createElement('option'); opt.value = v; opt.textContent = l;
      if (v === p.rhythm) opt.selected = true; rhythmSel.appendChild(opt);
    });
    rhythmSel.addEventListener('change', () => { p.rhythm = rhythmSel.value; onChange(); });
    const followLbl = el('label', {});
    const followEl = el('input', { type: 'checkbox' }) as HTMLInputElement;
    followEl.checked = p.follow;
    followEl.addEventListener('change', () => { p.follow = followEl.checked; onChange(); });
    followLbl.append(followEl, el('span', {}, 'follow chords'));
    row.append(rhythmSel, followLbl);
    sec.appendChild(row);
    sec.appendChild(makeFxRow(p, onChange));
  }

  function renderRoll(container: HTMLElement, cells: boolean[][], steps: number, labelFor: (d: number) => string, onChange: () => void) {
    container.replaceChildren();
    container.style.gridTemplateColumns = '2.6rem 1fr';
    for (let pp = 0; pp < ROLL_PITCHES; pp++) {
      const degree = ROLL_PITCHES - 1 - pp;
      container.appendChild(el('span', { class: 'strudel-roll-label' }, labelFor(degree)));
      const rowEl = el('div', { class: 'strudel-piano-roll-row' });
      rowEl.style.gridTemplateColumns = `repeat(${steps}, 1fr)`;
      for (let s = 0; s < steps; s++) {
        const isBeat = s % 4 === 0;
        const on = !!cells[pp][s];
        const cell = el('button', {
          type: 'button',
          class: `strudel-roll-cell${on ? ' is-on' : ''}${isBeat ? ' is-beat' : ''}`,
        }) as HTMLButtonElement;
        cell.addEventListener('click', () => {
          cells[pp][s] = !cells[pp][s];
          cell.classList.toggle('is-on', cells[pp][s]);
          onChange();
        });
        rowEl.appendChild(cell);
      }
      container.appendChild(rowEl);
    }
  }
  function renderArp(p: ArpPart, sec: HTMLElement, onChange: () => void) {
    const row = el('div', { class: 'strudel-roll-row' });
    const followLbl = el('label', {});
    const followEl = el('input', { type: 'checkbox' }) as HTMLInputElement;
    followEl.checked = p.follow;
    followEl.addEventListener('change', () => { p.follow = followEl.checked; onChange(); });
    followLbl.append(followEl, el('span', {}, 'follow chords'));
    const speedSel = document.createElement('select');
    [['1', '×1'], ['2', '×2'], ['4', '×4']].forEach(([v, l]) => {
      const opt = document.createElement('option'); opt.value = v; opt.textContent = l;
      if (Number(v) === p.speed) opt.selected = true; speedSel.appendChild(opt);
    });
    speedSel.addEventListener('change', () => { p.speed = Number(speedSel.value); onChange(); });
    row.append(followLbl, speedSel);
    sec.appendChild(row);
    const roll = el('div', { class: 'strudel-piano-roll' });
    renderRoll(roll, p.cells, ARP_STEPS, (d) => degreeLabel(d, state.key, state.scale), onChange);
    sec.appendChild(roll);
    sec.appendChild(makeFxRow(p, onChange));
  }

  function renderMidiRoll(container: HTMLElement, notes: MidiNote[], steps: number, labelFor: (d: number) => string, onChange: () => void) {
    let drawing: MidiNote | null = null;
    function refresh() {
      container.replaceChildren();
      container.style.gridTemplateColumns = '2.6rem 1fr';
      for (let pp = 0; pp < ROLL_PITCHES; pp++) {
        const degree = ROLL_PITCHES - 1 - pp;
        container.appendChild(el('span', { class: 'strudel-roll-label' }, labelFor(degree)));
        const rowEl = el('div', { class: 'strudel-midi-row' });
        rowEl.style.gridTemplateColumns = `repeat(${steps}, 1fr)`;
        for (let s = 0; s < steps; s++) {
          const isBeat = s % 4 === 0;
          const cell = el('button', {
            type: 'button',
            class: `strudel-roll-cell strudel-midi-cell${isBeat ? ' is-beat' : ''}`,
          }) as HTMLButtonElement;
          cell.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            const note: MidiNote = { pitch: degree, start: s, length: 1 };
            notes.push(note);
            drawing = note;
            refresh();
            onChange();
          });
          cell.addEventListener('pointerenter', () => {
            if (!drawing) return;
            if (drawing.pitch !== degree) return;
            const newLen = Math.max(1, s - drawing.start + 1);
            if (newLen === drawing.length) return;
            drawing.length = newLen;
            refresh();
            onChange();
          });
          rowEl.appendChild(cell);
        }
        notes.filter((n) => n.pitch === degree).forEach((n) => {
          const note = el('div', { class: 'strudel-midi-note' });
          note.style.left = `${(n.start / steps) * 100}%`;
          note.style.width = `${(Math.min(n.length, steps - n.start) / steps) * 100}%`;
          note.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            event.stopPropagation();
            const i = notes.indexOf(n);
            if (i >= 0) notes.splice(i, 1);
            refresh();
            onChange();
          });
          rowEl.appendChild(note);
        });
        container.appendChild(rowEl);
      }
    }
    const stopDraw = () => { drawing = null; };
    window.addEventListener('pointerup', stopDraw);
    window.addEventListener('pointercancel', stopDraw);
    refresh();
  }
  function renderLead(p: LeadPart, sec: HTMLElement, onChange: () => void) {
    const fx = el('div', { class: 'strudel-roll-row' });
    (['delay', 'room', 'jux', 'ghost', 'shape'] as const).forEach((key) => {
      const lbl = el('label', {});
      const cb = el('input', { type: 'checkbox' }) as HTMLInputElement;
      cb.checked = !!p.effects[key];
      cb.addEventListener('change', () => { (p.effects as any)[key] = cb.checked; onChange(); });
      lbl.append(cb, el('span', {}, key));
      fx.appendChild(lbl);
    });
    const echoLbl = el('label', { class: 'fx-knob fx-knob--small' });
    echoLbl.append(el('span', {}, 'echo'));
    const echoSel = document.createElement('select');
    [['', '—'], ['short', 'short ×3'], ['long', 'long ×5'], ['tape', 'tape']].forEach(([v, l]) => {
      const opt = document.createElement('option'); opt.value = v; opt.textContent = l;
      if (v === p.effects.echo) opt.selected = true; echoSel.appendChild(opt);
    });
    echoSel.addEventListener('change', () => { p.effects.echo = echoSel.value as EchoPreset; onChange(); });
    echoLbl.appendChild(echoSel);
    fx.appendChild(echoLbl);

    const attackLbl = el('label', { class: 'fx-knob' });
    attackLbl.append(el('span', {}, 'attack'));
    const attackEl = el('input', { type: 'range', min: '0', max: '2', step: '0.05', value: String(p.attack) }) as HTMLInputElement;
    const attackOut = el('output', {}, p.attack === 0 ? 'off' : p.attack.toFixed(2));
    attackEl.addEventListener('input', () => {
      p.attack = Number(attackEl.value);
      attackOut.textContent = p.attack === 0 ? 'off' : p.attack.toFixed(2);
      onChange();
    });
    attackLbl.append(attackEl, attackOut);
    fx.appendChild(attackLbl);

    sec.appendChild(fx);
    const roll = el('div', { class: 'strudel-piano-roll' });
    renderMidiRoll(roll, p.notes, LEAD_STEPS, (d) => degreeLabel(d, state.key, state.scale), onChange);
    sec.appendChild(roll);
    sec.appendChild(makeFxRow(p, onChange));
  }

  function renderSample(p: SamplePart, sec: HTMLElement, onChange: () => void) {
    const drop = el('label', { class: 'strudel-drop' });
    const input = el('input', { type: 'file', accept: 'audio/*' }) as HTMLInputElement;
    const dropLabel = el('span', {}, p.name ? p.name : 'drop audio or choose file');
    drop.append(input, dropLabel);
    function handleFile(file: File) {
      if (!file.type.startsWith('audio/')) { setStatus('audio file required'); return; }
      if (p.url) URL.revokeObjectURL(p.url);
      p.url = URL.createObjectURL(file);
      p.name = (file.name.replace(/\.[^.]+$/, '').toLowerCase().replace(/[^a-z0-9]+/g, '').slice(0, 18)) || 'drop';
      dropLabel.textContent = file.name;
      onChange();
    }
    input.addEventListener('change', () => {
      const f = input.files?.[0]; if (f) handleFile(f);
    });
    drop.addEventListener('dragenter', (e) => { e.preventDefault(); drop.classList.add('is-dragging'); });
    drop.addEventListener('dragover', (e) => e.preventDefault());
    drop.addEventListener('dragleave', (e) => {
      if (!drop.contains(e.relatedTarget as Node | null)) drop.classList.remove('is-dragging');
    });
    drop.addEventListener('drop', (e) => {
      e.preventDefault();
      drop.classList.remove('is-dragging');
      const f = (e as DragEvent).dataTransfer?.files?.[0];
      if (f) handleFile(f);
    });
    sec.appendChild(drop);
    sec.appendChild(makeFxRow(p, onChange));
  }

  // Module-level paint state for drum grid drag-painting.
  const paintingPattern = { value: false };
  let paintingActive = false;
  window.addEventListener('pointerup', () => { paintingActive = false; });

  function renderPart(p: Part): HTMLElement {
    const sec = el('section', { class: `strudel-part${p.enabled ? '' : ' is-muted'}`, dataset: { partId: p.id, partType: p.type } });
    sec.appendChild(makePartHead(p, sec, scheduleLiveApply));
    switch (p.type) {
      case 'drums':  renderDrums(p, sec, scheduleLiveApply); break;
      case 'chords': renderChords(p, sec, scheduleLiveApply); break;
      case 'bass':   renderBass(p, sec, scheduleLiveApply); break;
      case 'arp':    renderArp(p, sec, scheduleLiveApply); break;
      case 'lead':   renderLead(p, sec, scheduleLiveApply); break;
      case 'sample': renderSample(p, sec, scheduleLiveApply); break;
    }
    return sec;
  }

  function renderAllParts() {
    const container = document.getElementById('strudel-parts');
    if (!container) return;
    container.replaceChildren();
    state.parts.forEach((p) => container.appendChild(renderPart(p)));
  }

  // =========================================================================
  // Transport bindings.
  // =========================================================================
  const bpmEl = document.getElementById('strudel-bpm') as HTMLInputElement | null;
  const masterEl = document.getElementById('strudel-master') as HTMLInputElement | null;
  const masterOut = document.getElementById('strudel-master-out');
  const keySel = document.getElementById('strudel-key') as HTMLSelectElement | null;
  const scaleSel = document.getElementById('strudel-scale') as HTMLSelectElement | null;
  const swingEl = document.getElementById('strudel-swing') as HTMLInputElement | null;
  const swingOut = document.getElementById('strudel-swing-out');

  if (bpmEl) {
    bpmEl.value = String(state.bpm);
    bpmEl.addEventListener('input', () => {
      const v = Number(bpmEl.value);
      if (!Number.isNaN(v) && v > 0) { state.bpm = v; scheduleLiveApply(); }
    });
  }
  if (masterEl && masterOut) {
    masterEl.value = String(state.master);
    masterOut.textContent = state.master.toFixed(2);
    masterEl.addEventListener('input', () => {
      state.master = Number(masterEl.value);
      masterOut.textContent = state.master.toFixed(2);
      scheduleLiveApply();
    });
  }
  if (swingEl && swingOut) {
    swingEl.value = String(state.swing);
    swingOut.textContent = state.swing.toFixed(2);
    swingEl.addEventListener('input', () => {
      state.swing = Number(swingEl.value);
      swingOut.textContent = state.swing.toFixed(2);
      scheduleLiveApply();
    });
  }
  if (keySel) {
    keySel.value = state.key;
    keySel.addEventListener('change', () => {
      state.key = keySel.value;
      // Re-render any arp/lead rolls since labels depend on key.
      state.parts.forEach((p) => {
        if (p.type === 'arp' || p.type === 'lead') {
          // Re-render the part to refresh labels.
          const oldSec = document.querySelector<HTMLElement>(`.strudel-part[data-part-id="${p.id}"]`);
          if (oldSec) oldSec.replaceWith(renderPart(p));
        }
      });
      scheduleLiveApply();
    });
  }
  if (scaleSel) {
    scaleSel.value = state.scale;
    scaleSel.addEventListener('change', () => {
      state.scale = scaleSel.value;
      state.parts.forEach((p) => {
        if (p.type === 'arp' || p.type === 'lead' || p.type === 'chords') {
          const oldSec = document.querySelector<HTMLElement>(`.strudel-part[data-part-id="${p.id}"]`);
          if (oldSec) oldSec.replaceWith(renderPart(p));
        }
      });
      scheduleLiveApply();
    });
  }

  // =========================================================================
  // Add-part menu + reset + about
  // =========================================================================
  document.querySelectorAll<HTMLButtonElement>('[data-add-part]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const t = btn.dataset.addPart as PartType;
      const newPart = makePart(t);
      state.parts.push(newPart);
      const container = document.getElementById('strudel-parts');
      container?.appendChild(renderPart(newPart));
      scheduleLiveApply();
    });
  });

  const resetBtn = document.getElementById('strudel-reset') as HTMLButtonElement | null;
  resetBtn?.addEventListener('click', () => {
    state.parts.forEach((p) => {
      if (p.type === 'sample' && p.url) URL.revokeObjectURL(p.url);
    });
    state = clone(initialState);
    nextPartIdNum = 1;
    try { window.localStorage.removeItem('strudel-state-v6'); } catch (e) {}
    userTouchedEditor = false;
    setManual(false);
    if (bpmEl) bpmEl.value = String(state.bpm);
    if (masterEl && masterOut) { masterEl.value = String(state.master); masterOut.textContent = state.master.toFixed(2); }
    if (swingEl && swingOut) { swingEl.value = String(state.swing); swingOut.textContent = state.swing.toFixed(2); }
    if (keySel) keySel.value = state.key;
    if (scaleSel) scaleSel.value = state.scale;
    renderAllParts();
    scheduleLiveApply();
  });
  const aboutDialog = document.getElementById('strudel-about') as HTMLDialogElement | null;
  document.getElementById('strudel-info')?.addEventListener('click', () => aboutDialog?.showModal());
  aboutDialog?.addEventListener('click', (e) => { if (e.target === aboutDialog) aboutDialog.close(); });

  // =========================================================================
  // Initial render + editor mount.
  // =========================================================================
  renderAllParts();
  ensureEditor().catch(() => setStatus('editor unavailable'));
</script>
