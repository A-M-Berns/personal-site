    .strudel-workspace { grid-template-columns: 1fr; }
    .strudel-side-pane { overflow: visible; }
  }
</style>

<script>
  // ===== Types =====
  type Quality = 'maj' | 'min' | '7' | 'maj7' | 'min7' | 'sus' | 'dim';
  type DrumRow = 'bd' | 'sd' | 'hh' | 'cp';

  interface ChordSlot { root: string; quality: Quality; octave: number; }

  // Continuous-signal modulation. The waveform code maps to a strudel
  // signal (sine/saw/tri/square/rand/perlin) wrapped in .range().slow().
  // The target controls *which* parameter the signal modulates: filter
  // cutoff (auto-wah), pan (auto-pan), or gain (tremolo).
  type FilterMod = '' | 'sine-slow' | 'sine-fast' | 'saw' | 'tri' | 'square' | 'rand' | 'perlin';
  type ModTarget = 'lpf' | 'pan' | 'gain';

  // .every(n, fn) — apply transform every n cycles. Split into two
  // selects so they read more like the strudel function.
  type EveryN = '' | '2' | '4' | '8';
  type EveryFn = '' | 'fast2' | 'slow2' | 'rev' | 'jux' | 'chop';

  // .superimpose(x => x.add(N)) — layer a transposed copy of the part
  // on top of itself. Empty string means no superimpose.
  type Superimpose = '' | '+5' | '+12' | '-12';

  interface PartFx {
    lpf: number;
    hpf: number;
    drop: number;
    everyN: EveryN;
    everyFn: EveryFn;
    pan: number;
    crush: number;
    mod: FilterMod;
    modTarget: ModTarget;
    ply: number;
    struct: string;     // strudel struct() pattern, e.g. "x ~ x x"
    superimpose: Superimpose;
  }
  const defaultFx = (): PartFx => ({
    lpf: 8000, hpf: 0, drop: 0, everyN: '', everyFn: '', pan: 0.5, crush: 0,
    mod: '', modTarget: 'lpf', ply: 1, struct: '', superimpose: '',
  });

  interface MidiNote { pitch: number; start: number; length: number; }

  interface State {
    bpm: number;
    master: number;
    swing: number;
    key: string;
    scale: string;
    drums: { enabled: boolean; gain: number; bank: string; steps: Record<DrumRow, boolean[]>; fx: PartFx };
    chords: { enabled: boolean; gain: number; sound: string; slots: ChordSlot[]; room: number; attack: number; vowel: string; fx: PartFx };
    bass: { enabled: boolean; gain: number; sound: string; rhythm: string; follow: boolean; fx: PartFx };
    arp: { enabled: boolean; gain: number; sound: string; speed: number; follow: boolean; cells: boolean[][]; fx: PartFx };
    lead: {
      enabled: boolean; gain: number; sound: string;
      notes: MidiNote[];
      attack: number;
      effects: { delay: boolean; room: boolean; jux: boolean; ghost: boolean; shape: boolean; echo: '' | 'short' | 'long' | 'tape' };
      fx: PartFx;
    };
    sample: { enabled: boolean; gain: number; name: string; url: string | null };
  }

  // ===== Music helpers =====
  const NOTE_NAMES = ['c', 'db', 'd', 'eb', 'e', 'f', 'gb', 'g', 'ab', 'a', 'bb', 'b'];
  // Intervals (semitones from root) for each scale. Heptatonic modes
  // first, then pentatonic/blues, then exotic. Used for arp/lead
  // pitch-row labelling and degree-to-MIDI conversion.
  const SCALES: Record<string, number[]> = {
    major:              [0, 2, 4, 5, 7, 9, 11],
    dorian:             [0, 2, 3, 5, 7, 9, 10],
    phrygian:           [0, 1, 3, 5, 7, 8, 10],
    lydian:             [0, 2, 4, 6, 7, 9, 11],
    mixolydian:         [0, 2, 4, 5, 7, 9, 10],
    minor:              [0, 2, 3, 5, 7, 8, 10],
    locrian:            [0, 1, 3, 5, 6, 8, 10],
    'harmonic minor':   [0, 2, 3, 5, 7, 8, 11],
    'melodic minor':    [0, 2, 3, 5, 7, 9, 11],
    'major pentatonic': [0, 2, 4, 7, 9],
    'minor pentatonic': [0, 3, 5, 7, 10],
    blues:              [0, 3, 5, 6, 7, 10],
    'phrygian dominant':[0, 1, 4, 5, 7, 8, 10],
    'hungarian minor':  [0, 2, 3, 6, 7, 8, 11],
    'whole tone':       [0, 2, 4, 6, 8, 10],
  };
  const QUALITY_INTERVALS: Record<Quality, number[]> = {
    maj: [0, 4, 7],
    min: [0, 3, 7],
    '7': [0, 4, 7, 10],
    maj7: [0, 4, 7, 11],
    min7: [0, 3, 7, 10],
    sus: [0, 5, 7],
    dim: [0, 3, 6],
  };

  function rootIndex(root: string) {
    const idx = NOTE_NAMES.indexOf(root);
    return idx < 0 ? 0 : idx;
  }
  function midiToName(midi: number) {
    const n = ((midi % 12) + 12) % 12;
    const oct = Math.floor(midi / 12);
    return `${NOTE_NAMES[n]}${oct}`;
  }
  function chordNotes(slot: ChordSlot) {
    const intervals = QUALITY_INTERVALS[slot.quality] ?? QUALITY_INTERVALS.min;
    const baseMidi = (slot.octave + 1) * 12 + rootIndex(slot.root);
    return intervals.map((i) => midiToName(baseMidi + i));
  }
  function chordLabel(slot: ChordSlot) {
    const root = slot.root.replace('b', '♭').toUpperCase();
    const q = slot.quality === 'maj' ? '' : slot.quality === 'min' ? 'm' : slot.quality;
    return `${root}${q}`;
  }
  function scaleDegreeMidi(keyRoot: string, scaleName: string, degree: number, octave = 4) {
    const intervals = SCALES[scaleName] ?? SCALES.minor;
    const len = intervals.length;
    const wrap = ((degree % len) + len) % len;
    const oct = octave + Math.floor(degree / len);
    return oct * 12 + rootIndex(keyRoot) + intervals[wrap];
  }

  // ===== State =====
  const DRUMS: DrumRow[] = ['bd', 'sd', 'hh', 'cp'];
  const STEPS = 16;
  const ROLL_PITCHES = 12;
  const ARP_STEPS = 16;
  const LEAD_STEPS = 16;

  function emptySteps(): Record<DrumRow, boolean[]> {
    return Object.fromEntries(DRUMS.map((d) => [d, new Array(STEPS).fill(false)])) as Record<DrumRow, boolean[]>;
  }
  function emptyCells(steps: number): boolean[][] {
    return Array.from({ length: ROLL_PITCHES }, () => new Array(steps).fill(false));
  }
  // Defaults are intentionally empty — page loads silent. Each part
  // starts disabled with empty pattern data; presets fill them in.
  const initialState: State = {
    bpm: 110,
    master: 0.85,
    swing: 0,
    key: 'c',
    scale: 'minor',
    drums: { enabled: false, gain: 0.65, bank: 'RolandTR909', steps: emptySteps(), fx: defaultFx() },
    chords: {
      enabled: false,
      gain: 0.4,
      sound: 'piano',
      room: 0.5,
      attack: 0,
      vowel: '',
      slots: [],
      fx: defaultFx(),
    },
    bass: { enabled: false, gain: 0.55, sound: 'sawtooth', rhythm: 'syncopated', follow: true, fx: { ...defaultFx(), lpf: 800 } },
    arp: { enabled: false, gain: 0.42, sound: 'sine', speed: 2, follow: true, cells: emptyCells(ARP_STEPS), fx: defaultFx() },
    lead: { enabled: false, gain: 0.42, sound: 'square', notes: [], attack: 0, effects: { delay: false, room: false, jux: false, ghost: false, shape: false, echo: '' }, fx: defaultFx() },
    sample: { enabled: false, gain: 0.55, name: '', url: null },
  };

  const presets: Record<string, Partial<State>> = {
    empty: {
      drums: { ...initialState.drums, enabled: false, steps: emptySteps() },
      chords: { ...initialState.chords, enabled: false },
      bass: { ...initialState.bass, enabled: false },
      arp: { ...initialState.arp, enabled: false },
      lead: { ...initialState.lead, enabled: false },
    },
    lofi: {
      bpm: 82,
      swing: 0.18,
      key: 'eb',
      scale: 'minor',
      drums: { ...initialState.drums, gain: 0.55, bank: 'RolandTR808', steps: (() => { const s = emptySteps(); [0, 8].forEach((i) => (s.bd[i] = true)); [4, 12].forEach((i) => (s.sd[i] = true)); [0, 2, 4, 6, 8, 10, 12, 14].forEach((i) => (s.hh[i] = true)); return s; })(), fx: { ...defaultFx(), lpf: 3000, drop: 0.1, vary: false } },
      chords: { ...initialState.chords, gain: 0.42, sound: 'piano', room: 0.7, slots: [
        { root: 'eb', quality: 'min7', octave: 3 },
        { root: 'ab', quality: 'maj7', octave: 3 },
        { root: 'gb', quality: 'maj7', octave: 3 },
        { root: 'bb', quality: 'min7', octave: 3 },
      ], fx: { ...defaultFx(), lpf: 4000, drop: 0, vary: false } },
      bass: { ...initialState.bass, gain: 0.5, sound: 'sine', rhythm: 'root', follow: true, fx: { ...defaultFx(), lpf: 600, drop: 0, vary: false } },
    },
    techno: {
      bpm: 128,
      swing: 0,
      key: 'a',
      scale: 'minor',
      drums: { ...initialState.drums, gain: 0.7, bank: 'RolandTR909', steps: (() => { const s = emptySteps(); [0, 4, 8, 12].forEach((i) => (s.bd[i] = true)); [4, 12].forEach((i) => (s.sd[i] = true)); for (let i = 0; i < 16; i += 2) s.hh[i] = true; [3, 11].forEach((i) => (s.cp[i] = true)); return s; })(), fx: defaultFx() },
      chords: { ...initialState.chords, enabled: false },
      bass: { ...initialState.bass, gain: 0.6, sound: 'sawtooth', rhythm: 'octaves', follow: false, fx: { ...defaultFx(), lpf: 1200, drop: 0, vary: false } },
      arp: { ...initialState.arp, enabled: true, gain: 0.4, sound: 'square', speed: 4, follow: false, cells: (() => { const c = emptyCells(ARP_STEPS); [0, 4, 8, 12].forEach((s, i) => (c[ROLL_PITCHES - 1 - [7, 5, 7, 4][i]][s] = true)); return c; })(), fx: { ...defaultFx(), lpf: 2000, drop: 0.15, vary: true } },
    },
    ambient: {
      bpm: 70,
      swing: 0,
      key: 'd',
      scale: 'dorian',
      drums: { ...initialState.drums, enabled: false },
      chords: { ...initialState.chords, gain: 0.32, sound: 'triangle', room: 0.85, slots: [
        { root: 'd', quality: 'min7', octave: 3 },
        { root: 'g', quality: 'maj7', octave: 3 },
        { root: 'a', quality: 'min7', octave: 3 },
        { root: 'f', quality: 'maj7', octave: 3 },
      ], fx: { ...defaultFx(), lpf: 5000, drop: 0, vary: false } },
      bass: { ...initialState.bass, gain: 0.42, sound: 'sine', rhythm: 'root', follow: true, fx: { ...defaultFx(), lpf: 500, drop: 0, vary: false } },
      arp: { ...initialState.arp, enabled: true, gain: 0.32, sound: 'sine', speed: 1, follow: true, cells: (() => { const c = emptyCells(ARP_STEPS); [0, 3, 6, 9, 12, 15].forEach((s, i) => (c[ROLL_PITCHES - 1 - [0, 2, 4, 7, 4, 2][i]][s] = true)); return c; })(), fx: { ...defaultFx(), lpf: 4000, drop: 0.2, vary: true } },
    },
  };

  function clone<T>(value: T): T { return JSON.parse(JSON.stringify(value)); }
  function migrateLead(saved: any) {
    if (!saved || saved.notes) return saved;
    if (Array.isArray(saved.cells)) {
      const notes: MidiNote[] = [];
      for (let p = 0; p < saved.cells.length; p++) {
        const row = saved.cells[p];
        if (!Array.isArray(row)) continue;
        for (let s = 0; s < row.length; s++) {
          if (row[s]) notes.push({ pitch: ROLL_PITCHES - 1 - p, start: s, length: 1 });
        }
      }
      return { ...saved, notes, cells: undefined };
    }
    return saved;
  }
  // Convert the old single 'every' code (e.g. '4fast', '8jux') into
  // the new pair (everyN, everyFn). Drops the old key.
  function migrateFx(fx: any): any {
    if (!fx || typeof fx !== 'object') return fx;
    const out = { ...fx };
    if (typeof out.every === 'string' && out.every) {
      const m = out.every.match(/^(\d+)(\w+)$/);
      if (m) {
        const n = m[1] as EveryN;
        const fnKey = m[2];
        const map: Record<string, EveryFn> = { fast: 'fast2', slow: 'slow2', rev: 'rev', jux: 'jux', chop: 'chop' };
        if (['2','4','8'].includes(n)) out.everyN = n;
        if (map[fnKey]) out.everyFn = map[fnKey];
      }
      delete out.every;
    }
    delete out.vary;
    return out;
  }
  function mergeState(saved: any): State {
    const base = clone(initialState) as any;
    if (!saved || typeof saved !== 'object') return base;
    if (saved.lead) saved = { ...saved, lead: migrateLead(saved.lead) };
    for (const k of Object.keys(base)) {
      if (saved[k] === undefined) continue;
      if (typeof base[k] === 'object' && base[k] !== null && !Array.isArray(base[k])) {
        base[k] = { ...base[k], ...saved[k] };
        if (base[k].fx) base[k].fx = { ...defaultFx(), ...migrateFx(saved[k].fx ?? {}) };
        if (k === 'lead' && !Array.isArray(base[k].notes)) base[k].notes = clone(initialState.lead.notes);
      } else {
        base[k] = saved[k];
      }
    }
    return base as State;
  }
  let state: State = clone(initialState);
  function loadFromHash(): State | null {
    if (!window.location.hash || window.location.hash.length < 2) return null;
    try {
      const raw = decodeURIComponent(window.location.hash.slice(1));
      const decoded = atob(raw);
      return mergeState(JSON.parse(decoded));
    } catch (e) { return null; }
  }
  const fromHash = loadFromHash();
  if (fromHash) {
    state = fromHash;
  } else {
    try {
      const saved = window.localStorage.getItem('strudel-state-v5');
      if (saved) state = mergeState(JSON.parse(saved));
    } catch (e) {}
  }

  // ===== Code generation =====
  function indent(code: string, n = 2) {
    const pad = ' '.repeat(n);
    return code.split('\n').map((l) => pad + l).join('\n');
  }
  // Build a strudel signal expression: <wave>.range(min, max).slow(n).
  // Used by all mod targets (lpf, pan, gain).
  function modSignal(mod: FilterMod, min: number, max: number): string {
    if (!mod) return '';
    const slowMap: Record<FilterMod, number> = {
      '': 0, 'sine-slow': 4, 'sine-fast': 1, saw: 2, tri: 2, square: 2, rand: 1, perlin: 2,
    };
    const wave = mod === 'sine-slow' || mod === 'sine-fast' ? 'sine' : mod;
    return `${wave}.range(${min}, ${max}).slow(${slowMap[mod]})`;
  }
  // Sensible ranges for each mod target.
  function modRangeFor(target: ModTarget, fx: PartFx): [number, number] {
    if (target === 'lpf')  return [200, fx.lpf];
    if (target === 'pan')  return [0, 1];
    return [0.2, 1]; // gain — dip down, never silent
  }
  function applyFx(code: string, fx: PartFx): string {
    let out = code;
    const modOn = !!fx.mod;

    // lpf — modulated, static, or off.
    if (modOn && fx.modTarget === 'lpf') {
      const [lo, hi] = modRangeFor('lpf', fx);
      out += `\n  .lpf(${modSignal(fx.mod, lo, hi)})`;
    } else if (fx.lpf < 8000) {
      out += `\n  .lpf(${fx.lpf})`;
    }

    if (fx.hpf > 0) out += `\n  .hpf(${fx.hpf})`;
    if (fx.ply > 1) out += `\n  .ply(${fx.ply})`;
    if (fx.drop > 0) out += `\n  .degradeBy(${fx.drop.toFixed(2)})`;
    if (fx.crush > 0) out += `\n  .crush(${fx.crush})`;

    // pan — modulated, static, or off.
    if (modOn && fx.modTarget === 'pan') {
      const [lo, hi] = modRangeFor('pan', fx);
      out += `\n  .pan(${modSignal(fx.mod, lo, hi)})`;
    } else if (Math.abs(fx.pan - 0.5) > 0.001) {
      out += `\n  .pan(${fx.pan.toFixed(2)})`;
    }

    // gain modulation — multiplies with the part's static gain at the
    // end of the chain. Acts as a tremolo.
    if (modOn && fx.modTarget === 'gain') {
      const [lo, hi] = modRangeFor('gain', fx);
      out += `\n  .gain(${modSignal(fx.mod, lo, hi)})`;
    }

    // struct — overlay a rhythmic mask. Useful for chord pulses, lead
    // syncopation, etc. We strip embedded quotes defensively, and use
    // optional chaining so an undefined struct (older state) doesn't
    // throw and kill the whole code generation.
    if (fx.struct?.trim()) out += `\n  .struct("${fx.struct.replace(/"/g, '')}")`;

    if (fx.everyN && fx.everyFn) {
      const n = fx.everyN;
      const fn: Record<EveryFn, string> = {
        '':       '',
        fast2:    `x => x.fast(2)`,
        slow2:    `x => x.slow(2)`,
        rev:      `rev`,
        jux:      `x => x.jux(rev)`,
        chop:     `x => x.chop(2)`,
      };
      const expr = fn[fx.everyFn];
      if (expr) out += `\n  .every(${n}, ${expr})`;
    }

    // superimpose — layer the part with itself transposed.
    const semis: Record<Superimpose, number> = { '': 0, '+5': 7, '+12': 12, '-12': -12 };
    if (fx.superimpose && semis[fx.superimpose]) {
      out += `\n  .superimpose(x => x.add(${semis[fx.superimpose]}))`;
    }
    return out;
  }
  // Slider value 0..1 → audible gain via a perceptual curve. Below the
  // floor the part is dropped from the stack entirely so slider=0 is
  // truly silent (strudel's per-part .gain(0) doesn't always silence
  // soundfonts cleanly — masking via omission is more reliable).
  const GAIN_FLOOR = 0.01;
  function curveGain(v: number): number {
    return Math.pow(Math.max(0, Math.min(1, v)), 1.7);
  }
  function isAudible(v: number): boolean {
    return v >= GAIN_FLOOR;
  }
  function gainTail(v: number): string {
    return `.gain(${curveGain(v).toFixed(3)})`;
  }
  function drumCode(): string | null {
    if (!state.drums.enabled || !isAudible(state.drums.gain)) return null;
    const tokens: string[] = [];
    let any = false;
    for (let s = 0; s < STEPS; s++) {
      const hits = DRUMS.filter((d) => state.drums.steps[d][s]);
      if (hits.length > 0) any = true;
      tokens.push(hits.length === 0 ? '~' : hits.length === 1 ? hits[0] : `[${hits.join(',')}]`);
    }
    if (!any) return null;
    let code = `s("${tokens.join(' ')}")`;
    if (state.drums.bank) code += `\n  .bank("${state.drums.bank}")`;
    code = applyFx(code, state.drums.fx);
    code += `\n  .gain(${(state.drums.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function soundChain(sound: string): string {
    if (sound === 'piano') return '.piano()';
    return `.s("${sound}")`;
  }
  function chordCode(): string | null {
    if (!state.chords.enabled || !isAudible(state.chords.gain)) return null;
    if (state.chords.slots.length === 0) return null;
    const slotStrs = state.chords.slots.map((s) => `<${chordNotes(s).join(',')}>`);
    let code = `note("${slotStrs.join(' ')}")`;
    code += `\n  ${soundChain(state.chords.sound)}`;
    if (state.chords.sound !== 'piano') code += `\n  .release(0.5)`;
    if (state.chords.attack > 0) code += `\n  .attack(${state.chords.attack.toFixed(2)})`;
    if (state.chords.vowel) code += `\n  .vowel("${state.chords.vowel}")`;
    if (state.chords.room > 0) code += `\n  .room(${state.chords.room.toFixed(2)})`;
    code = applyFx(code, state.chords.fx);
    code += `\n  .gain(${(state.chords.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function bassCode(): string | null {
    if (!state.bass.enabled || !isAudible(state.bass.gain)) return null;
    const slots = state.chords.slots;
    // When follow is on, ride the chord roots; otherwise vamp on the
    // current key root (used to be hard-coded to c2 — bug).
    const fallback = `${state.key}2`;
    const roots = state.bass.follow && slots.length
      ? slots.map((s) => `${s.root}2`)
      : [fallback, fallback, fallback, fallback];
    let pattern = '';
    if (state.bass.rhythm === 'root') {
      pattern = roots.join(' ');
    } else if (state.bass.rhythm === 'steady') {
      pattern = roots.flatMap((r) => [r, r, r, r]).join(' ');
    } else if (state.bass.rhythm === 'syncopated') {
      pattern = roots.map((r) => `[${r} ~ ${r} [~ ${r}]]`).join(' ');
    } else if (state.bass.rhythm === 'octaves') {
      pattern = roots.map((r) => {
        const up = r.replace(/(\d)$/, (_m, d) => String(Number(d) + 1));
        return `[${r} ${up} ${r} ${up}]`;
      }).join(' ');
    } else if (state.bass.rhythm === 'walking') {
      pattern = roots.map((r, i) => {
        const next = roots[(i + 1) % roots.length];
        return `[${r} ${r} ${next} ${r}]`;
      }).join(' ');
    }
    let code = `note("${pattern}")\n  ${soundChain(state.bass.sound)}`;
    code = applyFx(code, state.bass.fx);
    code += `\n  .gain(${(state.bass.gain ** 1.7).toFixed(3)})`;
    return code;
  }

  function rollNotes(cells: boolean[][], steps: number, scale: string, key: string, octaveBase: number, slots: ChordSlot[], follow: boolean) {
    const tokens: string[] = [];
    const slotsPerStep = slots.length ? steps / slots.length : steps;
    for (let s = 0; s < steps; s++) {
      const onPitches: number[] = [];
      for (let p = 0; p < ROLL_PITCHES; p++) {
        if (cells[p][s]) onPitches.push(ROLL_PITCHES - 1 - p);
      }
      if (onPitches.length === 0) { tokens.push('~'); continue; }
      const slotIdx = Math.min(slots.length - 1, Math.floor(s / slotsPerStep));
      const localKey = follow && slots[slotIdx] ? slots[slotIdx].root : key;
      const names = onPitches.map((deg) => midiToName(scaleDegreeMidi(localKey, scale, deg, octaveBase)));
      tokens.push(names.length === 1 ? names[0] : `[${names.join(',')}]`);
    }
    return tokens.join(' ');
  }

  function arpCode(): string | null {
    if (!state.arp.enabled || !isAudible(state.arp.gain)) return null;
    const hasAny = state.arp.cells.some((row) => row.some(Boolean));
    if (!hasAny) return null;
    const pattern = rollNotes(state.arp.cells, ARP_STEPS, state.scale, state.key, 4, state.chords.slots, state.arp.follow);
    let code = `note("${pattern}")`;
    code += `\n  ${soundChain(state.arp.sound)}`;
    if (state.arp.speed !== 1) code += `\n  .fast(${state.arp.speed})`;
    code = applyFx(code, state.arp.fx);
    code += `\n  .delay(0.25)\n  .gain(${(state.arp.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function midiNotesPattern(notes: MidiNote[], steps: number, scale: string, key: string, octaveBase: number, slots: ChordSlot[]) {
    type Step = { starts: string[]; sustain: boolean };
    const cells: Step[] = Array.from({ length: steps }, () => ({ starts: [], sustain: false }));
    const slotsPerStep = slots.length ? steps / slots.length : steps;
    notes.forEach((n) => {
      if (n.start >= steps) return;
      const slotIdx = Math.min(slots.length - 1, Math.floor(n.start / slotsPerStep));
      const localKey = slots[slotIdx] ? slots[slotIdx].root : key;
      const name = midiToName(scaleDegreeMidi(localKey, scale, n.pitch, octaveBase));
      cells[n.start].starts.push(name);
      for (let i = 1; i < n.length && n.start + i < steps; i++) {
        cells[n.start + i].sustain = true;
      }
    });
    return cells.map((c) => {
      if (c.starts.length === 0) return c.sustain ? '_' : '~';
      if (c.starts.length === 1) return c.starts[0];
      return `[${c.starts.join(',')}]`;
    }).join(' ');
  }
  function leadCode(): string | null {
    if (!state.lead.enabled || !isAudible(state.lead.gain)) return null;
    if (!state.lead.notes || state.lead.notes.length === 0) return null;
    const pattern = midiNotesPattern(state.lead.notes, LEAD_STEPS, state.scale, state.key, 5, state.chords.slots);
    let code = `note("${pattern}")`;
    code += `\n  ${soundChain(state.lead.sound)}`;
    if (state.lead.attack > 0) code += `\n  .attack(${state.lead.attack.toFixed(2)})`;
    if (state.lead.effects.delay) code += `\n  .delay(0.4)`;
    // Tempo-synced echo: N repeats with decay. More musical than .delay
    // for rhythmic figures.
    const echoMap: Record<string, string> = {
      short: '.echo(3, 1/8, 0.7)',
      long:  '.echo(5, 1/4, 0.6)',
      tape:  '.echo(4, 3/16, 0.75)',
    };
    if (state.lead.effects.echo && echoMap[state.lead.effects.echo]) {
      code += `\n  ${echoMap[state.lead.effects.echo]}`;
    }
    if (state.lead.effects.room) code += `\n  .room(0.6)`;
    if (state.lead.effects.jux) code += `\n  .jux(rev)`;
    if (state.lead.effects.ghost) code += `\n  .off(1/8, x => x.fast(2).gain(0.5))`;
    if (state.lead.effects.shape) code += `\n  .shape(0.4)`;
    code = applyFx(code, state.lead.fx);
    code += `\n  .gain(${(state.lead.gain ** 1.7).toFixed(3)})`;
    return code;
  }
  function sampleCode(): string | null {
    if (!state.sample.enabled || !state.sample.url || !state.sample.name || !isAudible(state.sample.gain)) return null;
    return `s("${state.sample.name}").loopAt(4).gain(${(state.sample.gain ** 1.7).toFixed(3)})`;
  }

  function buildCode(): string {
    const generators: Array<[string, () => string | null]> = [
      ['drums', drumCode],
      ['chords', chordCode],
      ['bass', bassCode],
      ['arp', arpCode],
      ['lead', leadCode],
      ['sample', sampleCode],
    ];
    const parts = generators
      .map(([name, gen]) => ({ name, code: gen() }))
      .filter((p): p is { name: string; code: string } => !!p.code);

    const cps = (state.bpm / 60 / 4).toFixed(3);
    let header = `// ${state.key.toUpperCase()} ${state.scale}  •  ${state.bpm} bpm\nsetcps(${cps})`;
    if (state.sample.enabled && state.sample.url && state.sample.name) {
      header = `// dropped sample\nsamples({ ${state.sample.name}: '${state.sample.url}' })\n\n${header}`;
    }
    const tail: string[] = [];
    if (state.swing > 0) tail.push(`.swingBy(${state.swing.toFixed(2)}, 4)`);
    tail.push(`.gain(${curveGain(state.master).toFixed(3)})`);
    const tailStr = tail.map((t) => `  ${t}`).join('\n');
    if (parts.length === 0) {
      return `${header}\nsilence`;
    }
    if (parts.length === 1) {
      return `${header}\n// ${parts[0].name}\n${parts[0].code}\n${tailStr}`;
    }
    const blocks = parts.map((p) => indent(`// ${p.name}\n${p.code}`));
    return `${header}\nstack(\n${blocks.join(',\n\n')}\n)\n${tailStr}`;
  }

  // ===== Editor wiring =====
  let editorRef: any = null;
  let editorReady: Promise<any> | null = null;
  let isRunning = false;
  let liveTimer: number | null = null;
  // Manual mode is driven by a real input event on the editor host:
  // until the user actually types a key in the editor, GUI changes
  // flow into the code freely. Once they type, userTouchedEditor
  // latches true and we stop pushing — the regen button is the way
  // back. No more whitespace/string-comparison guessing.
  let userTouchedEditor = false;
  let manualMode = false;

  const hostEl = document.getElementById('strudel-host');
  // Status text was removed from the pane head; setStatus is a no-op
  // sink so existing call sites don't have to be touched.
  const statusEl: HTMLElement | null = null;
  const runBtn = document.getElementById('strudel-run') as HTMLButtonElement | null;
  const regenBtn = document.getElementById('strudel-regen') as HTMLButtonElement | null;

  function setStatus(text: string) { if (statusEl) statusEl.textContent = text; }

  function ensureEditor(): Promise<any> {
    if (editorReady) return editorReady;
    setStatus('loading…');
    editorReady = new Promise<any>((resolve, reject) => {
      const existing = document.querySelector<HTMLScriptElement>('script[data-strudel-repl]');
      const onLoaded = () => {
        const el = document.createElement('strudel-editor');
        el.setAttribute('code', buildCode());
        hostEl?.appendChild(el);
        // wait for connectedCallback to set up editor
        const tryAttach = (tries = 0) => {
          if ((el as any).editor) {
            editorRef = (el as any).editor;
            (el as any).addEventListener('update', (evt: CustomEvent) => {
              const started = !!evt.detail?.started;
              if (started !== isRunning) {
                isRunning = started;
                runBtn?.setAttribute('data-state', started ? 'running' : 'idle');
                hostEl?.classList.toggle('is-running', started);
              }
            });
            // Real signal that the user has hand-edited the code:
            // any input event from inside the editor's contenteditable
            // bubbles up to hostEl. Once that fires, we latch into
            // manual mode and stop pushing GUI changes.
            hostEl?.addEventListener('input', () => {
              if (!userTouchedEditor) {
                userTouchedEditor = true;
                setManual(true);
              }
            });
            setStatus('ready');
            resolve(editorRef);
          } else if (tries < 50) {
            setTimeout(() => tryAttach(tries + 1), 80);
          } else {
            reject(new Error('editor did not initialize'));
          }
        };
        tryAttach();
      };
      if (existing) {
        if ((existing as any).dataset.loaded === 'true') onLoaded();
        else {
          existing.addEventListener('load', onLoaded, { once: true });
          existing.addEventListener('error', () => reject(new Error('repl load error')), { once: true });
        }
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/@strudel/repl@1.3.0/dist/index.js';
      script.async = true;
      script.dataset.strudelRepl = 'true';
      script.onload = () => { (script as any).dataset.loaded = 'true'; onLoaded(); };
      script.onerror = () => reject(new Error('repl load error'));
      document.head.appendChild(script);
    });
    return editorReady;
  }

  function setManual(v: boolean) {
    if (manualMode === v) return;
    manualMode = v;
    hostEl?.classList.toggle('is-manual', v);
    if (regenBtn) regenBtn.hidden = !v;
    if (v) setStatus('manual edits — gui paused');
  }

  async function pushCode() {
    try { window.localStorage.setItem('strudel-state-v5', JSON.stringify(state)); } catch (e) {}
    try { await ensureEditor(); } catch (e) { setStatus('editor unavailable'); return; }
    if (!editorRef) return;
    if (userTouchedEditor) {
      // Latched into manual after a real keystroke. Don't overwrite.
      setManual(true);
      return;
    }
    editorRef.setCode(buildCode());
    if (isRunning) {
      try { await editorRef.evaluate(); } catch (e) { setStatus('eval error'); }
    }
  }
  function scheduleLiveApply() {
    if (liveTimer !== null) window.clearTimeout(liveTimer);
    liveTimer = window.setTimeout(pushCode, 100);
  }

  async function run() {
    await ensureEditor();
    if (!editorRef) return;
    // If the user has hand-edited, evaluate THEIR code as-is. Don't
    // silently revert their work to the GUI's version on play.
    if (!userTouchedEditor) {
      editorRef.setCode(buildCode());
    }
    try {
      await editorRef.evaluate();
      isRunning = true;
      runBtn?.setAttribute('data-state', 'running');
      hostEl?.classList.add('is-running');
      setStatus(manualMode ? 'running (manual)' : 'running');
    } catch (e) {
      setStatus(e instanceof Error ? e.message : 'eval error');
    }
  }
  function regenFromGui() {
    if (!editorRef) return;
    userTouchedEditor = false;
    setManual(false);
    editorRef.setCode(buildCode());
    setStatus('regenerated');
    if (isRunning) editorRef.evaluate().catch(() => setStatus('eval error'));
  }
  async function stop() {
    if (!editorRef) return;
    try {
      await editorRef.stop();
      isRunning = false;
      runBtn?.setAttribute('data-state', 'idle');
      hostEl?.classList.remove('is-running');
      setStatus('stopped');
    } catch (e) {}
  }

  // Run button is a play/pause toggle (icon swaps via CSS based on
  // data-state). Stop button always halts.
  runBtn?.addEventListener('click', () => (isRunning ? stop() : run()));
  regenBtn?.addEventListener('click', regenFromGui);

  // ===== UI rendering =====
  function el<K extends keyof HTMLElementTagNameMap>(tag: K, attrs: Record<string, any> = {}, ...children: (Node | string)[]) {
    const node = document.createElement(tag);
    for (const [k, v] of Object.entries(attrs)) {
      if (k === 'class') node.className = v;
      else if (k === 'dataset') Object.assign(node.dataset, v);
      else if (k.startsWith('on') && typeof v === 'function') node.addEventListener(k.slice(2), v);
      else if (k === 'checked' || k === 'disabled' || k === 'selected') (node as any)[k] = v;
      else node.setAttribute(k, String(v));
    }
    for (const c of children) node.append(c);
    return node;
  }

  // --- Drums grid
  const drumGrid = document.getElementById('strudel-drum-grid');
  let painting: { value: boolean } | null = null;
  // Compact glyphs for the drum row labels — visually distinct and
  // readable at small sizes (clearer than 'bd'/'sd'/'hh'/'cp').
  const DRUM_ICONS: Record<DrumRow, string> = { bd: '●', sd: '◐', hh: '✕', cp: '✦' };
  const DRUM_TITLES: Record<DrumRow, string> = { bd: 'kick', sd: 'snare', hh: 'hi-hat', cp: 'clap' };
  function renderDrumGrid() {
    if (!drumGrid) return;
    drumGrid.replaceChildren();
    DRUMS.forEach((row) => {
      const label = el('span', { class: 'strudel-step-label strudel-drum-icon', title: DRUM_TITLES[row] }, DRUM_ICONS[row]);
      drumGrid.appendChild(label);
      for (let s = 0; s < STEPS; s++) {
        const on = state.drums.steps[row][s];
        const btn = el('button', {
          type: 'button',
          'aria-pressed': String(on),
          'aria-label': `${row} step ${s + 1}`,
          class: on ? 'is-on' : '',
          dataset: { row, step: String(s) },
        });
        btn.addEventListener('pointerdown', (event) => {
          event.preventDefault();
          const next = !state.drums.steps[row][s];
          painting = { value: next };
          state.drums.steps[row][s] = next;
          btn.classList.toggle('is-on', next);
          btn.setAttribute('aria-pressed', String(next));
          scheduleLiveApply();
        });
        btn.addEventListener('pointerenter', () => {
          if (!painting) return;
          state.drums.steps[row][s] = painting.value;
          btn.classList.toggle('is-on', painting.value);
          btn.setAttribute('aria-pressed', String(painting.value));
          scheduleLiveApply();
        });
        drumGrid.appendChild(btn);
      }
    });
  }
  window.addEventListener('pointerup', () => { painting = null; });

  // Compact label for a scale degree, e.g. degree 0 in C minor → "C",
  // degree 7 in C minor → "C" (octave up). Used to label rolls.
  function degreeLabel(degree: number, key: string, scale: string): string {
    const intervals = SCALES[scale] ?? SCALES.minor;
    const interval = intervals[((degree % intervals.length) + intervals.length) % intervals.length];
    const idx = (rootIndex(key) + interval) % 12;
    return NOTE_NAMES[idx].replace('b', '♭').toUpperCase();
  }

  // --- Piano roll (cells)
  function renderRoll(
    container: HTMLElement | null,
    cells: boolean[][],
    steps: number,
    onChange: () => void,
    labelFor: (degree: number) => string = (d) => `${d + 1}`,
  ) {
    if (!container) return;
    container.replaceChildren();
    container.style.gridTemplateColumns = '2.6rem 1fr';
    for (let p = 0; p < ROLL_PITCHES; p++) {
      const degree = ROLL_PITCHES - 1 - p; // top row = highest
      container.appendChild(el('span', { class: 'strudel-roll-label' }, labelFor(degree)));
      const rowEl = el('div', { class: 'strudel-piano-roll-row' });
      rowEl.style.gridTemplateColumns = `repeat(${steps}, 1fr)`;
      for (let s = 0; s < steps; s++) {
        const isBeat = s % 4 === 0;
        const on = cells[p][s];
        const cell = el('button', {
          type: 'button',
          'aria-pressed': String(on),
          class: `strudel-roll-cell${on ? ' is-on' : ''}${isBeat ? ' is-beat' : ''}`,
          dataset: { p: String(p), s: String(s) },
        });
        cell.addEventListener('click', () => {
          cells[p][s] = !cells[p][s];
          cell.classList.toggle('is-on', cells[p][s]);
          cell.setAttribute('aria-pressed', String(cells[p][s]));
          onChange();
        });
        rowEl.appendChild(cell);
      }
      container.appendChild(rowEl);
    }
  }

  // --- MIDI piano roll (notes with length)
  // Click empty cell + drag right to draw a note of variable length.
  // Click on existing note (the orange bar) to remove it.
  function renderMidiRoll(
    container: HTMLElement | null,
    notes: MidiNote[],
    steps: number,
    onChange: () => void,
    labelFor: (degree: number) => string = (d) => `${d + 1}`,
  ) {
    if (!container) return;
    let drawing: MidiNote | null = null;
    const refresh = () => {
      container.replaceChildren();
      container.style.gridTemplateColumns = '2.6rem 1fr';
      for (let p = 0; p < ROLL_PITCHES; p++) {
        const degree = ROLL_PITCHES - 1 - p;
        container.appendChild(el('span', { class: 'strudel-roll-label' }, labelFor(degree)));
        const rowEl = el('div', { class: 'strudel-midi-row' });
        rowEl.style.gridTemplateColumns = `repeat(${steps}, 1fr)`;
        for (let s = 0; s < steps; s++) {
          const isBeat = s % 4 === 0;
          const cell = el('button', {
            type: 'button',
            class: `strudel-roll-cell strudel-midi-cell${isBeat ? ' is-beat' : ''}`,
            dataset: { p: String(degree), s: String(s) },
          });
          cell.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            const note: MidiNote = { pitch: degree, start: s, length: 1 };
            notes.push(note);
            drawing = note;
            refresh();
            onChange();
          });
          cell.addEventListener('pointerenter', () => {
            if (!drawing) return;
            if (drawing.pitch !== degree) return;
            const newLen = Math.max(1, s - drawing.start + 1);
            if (newLen === drawing.length) return;
            drawing.length = newLen;
            refresh();
            onChange();
          });
          rowEl.appendChild(cell);
        }
        // Note overlays for this pitch row.
        notes.filter((n) => n.pitch === degree).forEach((n) => {
          const note = el('div', { class: 'strudel-midi-note' });
          note.style.left = `${(n.start / steps) * 100}%`;
          note.style.width = `${(Math.min(n.length, steps - n.start) / steps) * 100}%`;
          note.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            event.stopPropagation();
            const i = notes.indexOf(n);
            if (i >= 0) notes.splice(i, 1);
            refresh();
            onChange();
          });
          rowEl.appendChild(note);
        });
        container.appendChild(rowEl);
      }
    };
    const stopDraw = () => { drawing = null; };
    window.addEventListener('pointerup', stopDraw);
    window.addEventListener('pointercancel', stopDraw);
    refresh();
  }

  // --- Chord cards
  const chordGrid = document.getElementById('strudel-chord-grid');
  const ROOT_OPTIONS = NOTE_NAMES;
  const QUALITIES: Quality[] = ['min', 'maj', '7', 'maj7', 'min7', 'sus', 'dim'];
  function romanize(slot: ChordSlot, key: string, scale: string) {
    const intervals = SCALES[scale] ?? SCALES.minor;
    const interval = ((rootIndex(slot.root) - rootIndex(key)) % 12 + 12) % 12;
    const degree = intervals.indexOf(interval);
    const numerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII'];
    if (degree < 0) return '–';
    const isMin = slot.quality === 'min' || slot.quality === 'min7' || slot.quality === 'dim';
    return isMin ? numerals[degree].toLowerCase() : numerals[degree];
  }
  // Render chord progression as a vertical list of compact rows. Slot
  // count is dynamic — "+ add chord" appends; "×" on a row removes.
  function renderChords() {
    if (!chordGrid) return;
    chordGrid.replaceChildren();
    if (state.chords.slots.length === 0) {
      chordGrid.appendChild(el('div', { class: 'chord-empty-hint' }, 'no chords yet — click + to add one'));
    }
    state.chords.slots.forEach((slot, idx) => {
      const row = el('div', { class: 'strudel-chord-row' });
      const idxLabel = el('span', { class: 'chord-idx' }, String(idx + 1));
      const name = el('span', { class: 'chord-name' }, chordLabel(slot));
      const rootSel = el('select', {}) as HTMLSelectElement;
      ROOT_OPTIONS.forEach((r) => {
        const opt = el('option', { value: r, selected: r === slot.root }, r.replace('b', '♭').toUpperCase());
        rootSel.appendChild(opt);
      });
      rootSel.addEventListener('change', () => { state.chords.slots[idx].root = rootSel.value; renderChords(); scheduleLiveApply(); });
      const qualSel = el('select', {}) as HTMLSelectElement;
      QUALITIES.forEach((q) => {
        const opt = el('option', { value: q, selected: q === slot.quality }, q);
        qualSel.appendChild(opt);
      });
      qualSel.addEventListener('change', () => { state.chords.slots[idx].quality = qualSel.value as Quality; renderChords(); scheduleLiveApply(); });
      const oct = el('div', { class: 'chord-oct' });
      const minus = el('button', { type: 'button', title: 'lower octave' }, '−');
      const octLabel = el('span', { class: 'chord-oct-label' }, String(slot.octave));
      const plus = el('button', { type: 'button', title: 'raise octave' }, '+');
      minus.addEventListener('click', () => { state.chords.slots[idx].octave = Math.max(1, slot.octave - 1); renderChords(); scheduleLiveApply(); });
      plus.addEventListener('click', () => { state.chords.slots[idx].octave = Math.min(6, slot.octave + 1); renderChords(); scheduleLiveApply(); });
      oct.append(minus, octLabel, plus);
      const degree = el('span', { class: 'chord-degree' }, romanize(slot, state.key, state.scale));
      const remove = el('button', { type: 'button', class: 'chord-remove', title: 'remove chord' }, '×');
      remove.addEventListener('click', () => { state.chords.slots.splice(idx, 1); renderChords(); scheduleLiveApply(); });
      row.append(idxLabel, name, rootSel, qualSel, oct, degree, remove);
      chordGrid.appendChild(row);
    });
    const add = el('button', { type: 'button', class: 'chord-add' }, '+ add chord');
    add.addEventListener('click', () => {
      const last = state.chords.slots[state.chords.slots.length - 1];
      state.chords.slots.push({
        root: last?.root ?? state.key,
        quality: last?.quality ?? 'min',
        octave: last?.octave ?? 3,
      });
      // Auto-enable the chord part on first add — saves a click for new users.
      if (state.chords.slots.length === 1) state.chords.enabled = true;
      renderChords();
      scheduleLiveApply();
      const muteEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-mute]');
      if (muteEl) muteEl.checked = state.chords.enabled;
      const section = document.querySelector<HTMLElement>('.strudel-part[data-part="chords"]');
      section?.classList.toggle('is-muted', !state.chords.enabled);
    });
    chordGrid.appendChild(add);
  }

