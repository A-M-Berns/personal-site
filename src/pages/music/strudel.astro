---
import Base from '../../layouts/Base.astro';

const defaultPattern = `note("c2 [eb3 g3] <bb2 f3> [ab2 c4]")
  .sound("sawtooth")
  .slow(2)
  .lpf(sine.range(500, 2200).slow(8))
  .gain(0.55)`;
---
<Base title="Strudel — A. M. Berns" description="A small Strudel live-coding workspace.">
  <div class="strudel-shell">
    <main class="strudel-workspace" aria-label="Strudel workspace">
      <section class="strudel-editor-pane">
        <div class="strudel-pane-head">
          <h2>Pattern</h2>
          <div class="strudel-actions">
            <button id="strudel-run" type="button">Run</button>
            <button id="strudel-stop" type="button">Stop</button>
          </div>
        </div>
        <div id="strudel-editor" class="strudel-code-wrap">
          <pre id="strudel-highlight" aria-hidden="true"></pre>
          <textarea id="strudel-code" spellcheck="false" autocomplete="off">{defaultPattern}</textarea>
        </div>
        <p id="strudel-status" class="strudel-status" aria-live="polite"></p>
      </section>

      <aside class="strudel-side-pane">
        <section>
          <h2>Presets</h2>
          <div class="strudel-preset-list">
            <button type="button" data-preset="melodic">Melodic</button>
            <button type="button" data-preset="pulse">Pulse</button>
            <button type="button" data-preset="drums">Drums</button>
            <button type="button" data-preset="texture">Texture</button>
            <button type="button" data-preset="bass">Bass</button>
            <button type="button" data-preset="bell">Bell</button>
            <button type="button" data-preset="breaks">Breaks</button>
            <button type="button" data-preset="ambient">Ambient</button>
            <button type="button" data-preset="sampleKit">Sample Kit</button>
            <button type="button" data-preset="breakbeat">Breakbeat</button>
          </div>
        </section>

        <section>
          <h2>Layers</h2>
          <div class="strudel-preset-list">
            <button type="button" data-layer="drums">Drums</button>
            <button type="button" data-layer="bass">Bass</button>
            <button type="button" data-layer="lead">Lead</button>
            <button type="button" data-layer="chords">Chords</button>
            <button type="button" data-layer="pad">Pad</button>
          </div>
        </section>

        <section>
          <h2>Drum Grid</h2>
          <div id="strudel-drum-grid" class="strudel-step-grid" aria-label="Drum step grid"></div>
          <div class="strudel-preset-list">
            <button id="strudel-drum-apply" type="button">Append Drums</button>
            <button id="strudel-drum-clear" type="button">Clear</button>
          </div>
        </section>

        <section>
          <h2>Arp Grid</h2>
          <div id="strudel-arp-grid" class="strudel-arp-grid" aria-label="Arpeggio step grid"></div>
          <div class="strudel-preset-list">
            <button id="strudel-arp-apply" type="button">Append Arp</button>
            <button id="strudel-arp-clear" type="button">Clear</button>
          </div>
        </section>

        <section>
          <h2>Builder</h2>
          <label class="strudel-field" for="strudel-builder-mode">
            <span>mode</span>
            <select id="strudel-builder-mode">
              <option value="note">note</option>
              <option value="sample">sample</option>
              <option value="stack">stack</option>
            </select>
            <output></output>
          </label>
          <label class="strudel-field strudel-field--wide" for="strudel-builder-pattern">
            <span>pattern</span>
            <input id="strudel-builder-pattern" type="text" value='c2 [eb3 g3] <bb2 f3> [ab2 c4]' />
          </label>
          <label class="strudel-field strudel-field--wide" for="strudel-builder-struct">
            <span>struct</span>
            <input id="strudel-builder-struct" type="text" value='x [~ x] x [x ~]' />
          </label>
          <label class="strudel-field" for="strudel-builder-bank">
            <span>bank</span>
            <select id="strudel-builder-bank">
              <option value="">none</option>
              <option value="RolandTR909">909</option>
              <option value="RolandTR808">808</option>
              <option value="CasioRZ1">RZ1</option>
            </select>
            <output></output>
          </label>
          <div class="strudel-preset-list">
            <button id="strudel-build-replace" type="button">Replace</button>
            <button id="strudel-build-append" type="button">Append Layer</button>
          </div>
        </section>

        <section>
          <h2>Controls</h2>
          <label class="strudel-field" for="strudel-sound">
            <span>sound</span>
            <select id="strudel-sound">
              <option value="sawtooth">saw</option>
              <option value="square">square</option>
              <option value="triangle">triangle</option>
              <option value="sine">sine</option>
            </select>
            <output></output>
          </label>
          <label class="strudel-field" for="strudel-gain">
            <span>gain</span>
            <input id="strudel-gain" type="range" min="0.15" max="0.9" step="0.05" value="0.55" />
            <output id="strudel-gain-value" for="strudel-gain">0.55</output>
          </label>
          <label class="strudel-field" for="strudel-slow">
            <span>slow</span>
            <input id="strudel-slow" type="range" min="0.5" max="6" step="0.5" value="2" />
            <output id="strudel-slow-value" for="strudel-slow">2</output>
          </label>
          <label class="strudel-field" for="strudel-room">
            <span>room</span>
            <input id="strudel-room" type="range" min="0" max="0.9" step="0.05" value="0.3" />
            <output id="strudel-room-value" for="strudel-room">0.30</output>
          </label>
          <label class="strudel-field" for="strudel-delay">
            <span>delay</span>
            <input id="strudel-delay" type="range" min="0" max="0.8" step="0.05" value="0.15" />
            <output id="strudel-delay-value" for="strudel-delay">0.15</output>
          </label>
          <label class="strudel-field" for="strudel-cutoff">
            <span>lpf</span>
            <input id="strudel-cutoff" type="range" min="300" max="4000" step="100" value="1800" />
            <output id="strudel-cutoff-value" for="strudel-cutoff">1800</output>
          </label>
          <button id="strudel-apply-controls" type="button">Apply to editor</button>
        </section>

        <section>
          <h2>Transforms</h2>
          <div class="strudel-preset-list">
            <button type="button" data-insert=".rev()">rev</button>
            <button type="button" data-insert=".jux(rev)">jux</button>
            <button type="button" data-insert=".sometimes(x => x.fast(2))">sometimes</button>
            <button type="button" data-insert=".every(4, rev)">every 4</button>
            <button type="button" data-insert=".off(0.25, x => x.gain(0.35))">echo</button>
          </div>
        </section>

        <section>
          <h2>Samples</h2>
          <label id="strudel-drop" class="strudel-drop" for="strudel-sample-file">
            <input id="strudel-sample-file" type="file" accept="audio/*" />
            <span id="strudel-drop-label">Drop audio or choose file</span>
          </label>
          <div class="strudel-preset-list">
            <button type="button" data-sample="bd sd hh*4">kit</button>
            <button type="button" data-sample="[bd ~] [~ sd] hh*8">backbeat</button>
            <button type="button" data-sample="bd*4">four</button>
            <button type="button" data-sample="[cp ~] hh [~ sd] hh">clap</button>
            <button type="button" data-sample="bd [~ sd] <hh*4 hh*8> [cp ~]">break</button>
          </div>
        </section>
      </aside>
    </main>

    <div class="anim-controls">
      <button id="strudel-info" type="button" aria-label="About this Strudel page">About</button>
      <button id="strudel-reset" type="button" aria-label="Reset Strudel editor">Reset</button>
    </div>

    <dialog id="strudel-about" class="anim-about" aria-labelledby="strudel-about-title">
      <h2 id="strudel-about-title">About</h2>
      <p>
        This page loads the unmodified <a href="https://www.npmjs.com/package/@strudel/web">@strudel/web</a>
        browser package, part of <a href="https://codeberg.org/uzu/strudel">Strudel</a>,
        licensed under <a href="https://codeberg.org/uzu/strudel/src/branch/main/LICENSE">AGPL-3.0-or-later</a>.
        Strudel is provided without warranty. Site source is available at
        <a href="https://github.com/A-M-Berns/personal-site">GitHub</a>.
      </p>
    </dialog>
  </div>
</Base>

<style>
  .strudel-shell {
    position: relative;
    min-height: calc(100vh - 11.25rem);
    --strudel-panel-height: min(78vh, 54rem);
  }
  .strudel-workspace {
    display: grid;
    grid-template-columns: minmax(38rem, 1.9fr) minmax(17rem, 22rem);
    gap: 1.25rem;
    align-items: stretch;
    max-width: 112rem;
  }
  .strudel-editor-pane,
  .strudel-side-pane {
    background: #000;
    padding: 0.95rem;
  }
  .strudel-editor-pane {
    display: flex;
    flex-direction: column;
    min-height: var(--strudel-panel-height);
  }
  .strudel-pane-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .strudel-pane-head h2,
  .strudel-side-pane h2 {
    font-family: var(--display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .strudel-actions,
  .strudel-preset-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .strudel-actions button,
  .strudel-preset-list button,
  .strudel-step-grid button,
  .strudel-arp-grid button,
  #strudel-build-replace,
  #strudel-build-append,
  #strudel-apply-controls {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.35rem 0.6rem;
  }
  .strudel-actions button:hover,
  .strudel-actions button:focus-visible,
  .strudel-preset-list button:hover,
  .strudel-preset-list button:focus-visible,
  .strudel-step-grid button:hover,
  .strudel-step-grid button:focus-visible,
  .strudel-arp-grid button:hover,
  .strudel-arp-grid button:focus-visible,
  #strudel-build-replace:hover,
  #strudel-build-replace:focus-visible,
  #strudel-build-append:hover,
  #strudel-build-append:focus-visible,
  #strudel-apply-controls:hover,
  #strudel-apply-controls:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    outline: none;
  }
  .strudel-step-grid {
    display: grid;
    grid-template-columns: 2.25rem repeat(16, minmax(0, 1fr));
    gap: 0.22rem;
    margin: 0.85rem 0;
  }
  .strudel-step-label,
  .strudel-arp-label {
    display: grid;
    place-items: center;
    min-height: 1.35rem;
    color: var(--muted);
    font: 0.62rem/1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
  }
  .strudel-step-grid button {
    min-width: 0;
    min-height: 1.35rem;
    padding: 0;
    border-color: color-mix(in srgb, var(--rule) 72%, transparent);
  }
  .strudel-step-grid button.is-on,
  .strudel-arp-grid button.is-on {
    color: #000;
    background: var(--accent);
    border-color: var(--accent);
  }
  .strudel-step-grid button:nth-child(17n + 2),
  .strudel-step-grid button:nth-child(17n + 6),
  .strudel-step-grid button:nth-child(17n + 10),
  .strudel-step-grid button:nth-child(17n + 14) {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--rule));
  }
  .strudel-arp-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 0.3rem;
    margin: 0.85rem 0;
  }
  .strudel-arp-cell {
    display: grid;
    gap: 0.2rem;
  }
  .strudel-arp-grid button {
    min-width: 0;
    min-height: 1.55rem;
    padding: 0.2rem 0;
    font-size: 0.62rem;
  }
  .strudel-code-wrap {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.035);
    overflow: hidden;
    transition: border-color 140ms ease, box-shadow 180ms ease, background 180ms ease;
  }
  .strudel-code-wrap.is-running {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 48%, transparent), 0 0 22px color-mix(in srgb, var(--accent) 18%, transparent);
    background:
      linear-gradient(90deg, transparent 0 46%, color-mix(in srgb, var(--accent) 14%, transparent) 49% 51%, transparent 54% 100%),
      rgba(255, 255, 255, 0.035);
    background-size: 240% 100%, auto;
    animation: strudel-play-scan 1.8s linear infinite;
  }
  .strudel-code-wrap.is-running #strudel-highlight .tok-fn,
  .strudel-code-wrap.is-running #strudel-highlight .tok-method {
    text-shadow: 0 0 0.75rem color-mix(in srgb, var(--accent) 48%, transparent);
  }
  @keyframes strudel-play-scan {
    from { background-position: 120% 0, 0 0; }
    to { background-position: -120% 0, 0 0; }
  }
  #strudel-code,
  #strudel-highlight {
    box-sizing: border-box;
    min-height: 100%;
    height: 100%;
    margin: 0;
    padding: 0.85rem;
    font: 0.94rem/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    tab-size: 2;
  }
  #strudel-highlight {
    position: absolute;
    inset: 0;
    z-index: 2;
    overflow: auto;
    pointer-events: none;
    color: var(--ink);
  }
  #strudel-highlight .tok-fn { color: var(--accent); }
  #strudel-highlight .tok-string { color: color-mix(in srgb, var(--accent) 72%, #fff); }
  #strudel-highlight .tok-number { color: #d6ff5a; }
  #strudel-highlight .tok-method { color: #4ad6ff; }
  #strudel-highlight .tok-symbol { color: var(--muted); }
  #strudel-highlight .code-line {
    display: block;
    min-height: 1.55em;
    margin-inline: -0.25rem;
    padding-inline: 0.25rem;
    border-radius: 2px;
  }
  .strudel-code-wrap.is-running #strudel-highlight .code-line.is-active {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
  }
  #strudel-code {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    resize: none;
    border: 0;
    background: transparent;
    color: transparent;
    caret-color: var(--ink);
    -webkit-text-fill-color: transparent;
  }
  #strudel-code:focus {
    outline: none;
  }
  .strudel-status {
    margin: 0.75rem 0 0;
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .strudel-status:empty {
    display: none;
  }
  .strudel-side-pane {
    display: grid;
    gap: 1.25rem;
    height: var(--strudel-panel-height);
    overflow-y: auto;
    padding-right: 0.25rem;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }
  .strudel-side-pane section {
    padding: 0;
  }
  .strudel-field {
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr) 3.2rem;
    gap: 0.55rem;
    align-items: center;
    margin: 0.8rem 0;
    color: var(--muted);
    font-size: 0.78rem;
  }
  .strudel-field input {
    width: 100%;
    margin: 0;
    accent-color: var(--accent);
  }
  .strudel-field input[type="text"] {
    min-width: 0;
    box-sizing: border-box;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.28rem 0.35rem;
    font: 0.76rem/1.35 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  .strudel-field input[type="text"]:focus {
    border-color: var(--accent);
    outline: none;
  }
  .strudel-field--wide {
    grid-template-columns: 3.25rem minmax(0, 1fr);
  }
  .strudel-field select {
    width: 100%;
    min-width: 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.25rem 0.35rem;
  }
  .strudel-field output {
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .strudel-drop {
    display: grid;
    place-items: center;
    min-height: 4.25rem;
    margin: 0.75rem 0;
    border: 1px dashed var(--rule);
    border-radius: 3px;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.78rem;
    text-align: center;
  }
  .strudel-drop.is-dragging,
  .strudel-drop:hover,
  .strudel-drop:focus-within {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-drop input {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .strudel-legal a {
    text-decoration: underline;
    text-decoration-color: var(--muted);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  @media (max-width: 880px) {
    .strudel-workspace {
      grid-template-columns: 1fr;
    }
    .strudel-side-pane {
      height: auto;
      overflow: visible;
      padding-right: 0;
    }
  }
</style>

<script>
  const codeEl = document.getElementById('strudel-code') as HTMLTextAreaElement | null;
  const editorEl = document.getElementById('strudel-editor') as HTMLElement | null;
  const highlightEl = document.getElementById('strudel-highlight');
  const runButton = document.getElementById('strudel-run') as HTMLButtonElement | null;
  const stopButton = document.getElementById('strudel-stop') as HTMLButtonElement | null;
  const statusEl = document.getElementById('strudel-status');
  const infoButton = document.getElementById('strudel-info') as HTMLButtonElement | null;
  const resetButton = document.getElementById('strudel-reset') as HTMLButtonElement | null;
  const aboutDialog = document.getElementById('strudel-about') as HTMLDialogElement | null;
  const soundInput = document.getElementById('strudel-sound') as HTMLSelectElement | null;
  const builderMode = document.getElementById('strudel-builder-mode') as HTMLSelectElement | null;
  const builderPattern = document.getElementById('strudel-builder-pattern') as HTMLInputElement | null;
  const builderStruct = document.getElementById('strudel-builder-struct') as HTMLInputElement | null;
  const builderBank = document.getElementById('strudel-builder-bank') as HTMLSelectElement | null;
  const buildReplace = document.getElementById('strudel-build-replace') as HTMLButtonElement | null;
  const buildAppend = document.getElementById('strudel-build-append') as HTMLButtonElement | null;
  const sampleFileInput = document.getElementById('strudel-sample-file') as HTMLInputElement | null;
  const sampleDrop = document.getElementById('strudel-drop') as HTMLElement | null;
  const sampleDropLabel = document.getElementById('strudel-drop-label');
  const gainInput = document.getElementById('strudel-gain') as HTMLInputElement | null;
  const gainValue = document.getElementById('strudel-gain-value');
  const slowInput = document.getElementById('strudel-slow') as HTMLInputElement | null;
  const slowValue = document.getElementById('strudel-slow-value');
  const roomInput = document.getElementById('strudel-room') as HTMLInputElement | null;
  const roomValue = document.getElementById('strudel-room-value');
  const delayInput = document.getElementById('strudel-delay') as HTMLInputElement | null;
  const delayValue = document.getElementById('strudel-delay-value');
  const cutoffInput = document.getElementById('strudel-cutoff') as HTMLInputElement | null;
  const cutoffValue = document.getElementById('strudel-cutoff-value');
  const applyControls = document.getElementById('strudel-apply-controls') as HTMLButtonElement | null;
  const drumGrid = document.getElementById('strudel-drum-grid');
  const arpGrid = document.getElementById('strudel-arp-grid');
  const drumApply = document.getElementById('strudel-drum-apply') as HTMLButtonElement | null;
  const drumClear = document.getElementById('strudel-drum-clear') as HTMLButtonElement | null;
  const arpApply = document.getElementById('strudel-arp-apply') as HTMLButtonElement | null;
  const arpClear = document.getElementById('strudel-arp-clear') as HTMLButtonElement | null;
  const defaultCode = codeEl?.defaultValue ?? '';

  const presets: Record<string, string> = {
    melodic: `note("c2 [eb3 g3] <bb2 f3> [ab2 c4]")
  .sound("sawtooth")
  .slow(2)
  .lpf(sine.range(500, 2200).slow(8))
  .gain(0.55)`,
    pulse: `note("<c2 c3> [g2 bb2] <f2 ab2> [eb2 g3]")
  .sound("square")
  .slow(3)
  .room(0.35)
  .gain(0.45)`,
    drums: `s("bd*2 [~ sd] <hh*4 hh*8> [cp ~]")
  .bank("RolandTR909")
  .slow(1.5)
  .gain(0.65)`,
    texture: `note("c3 eb3 g3 bb3")
  .sound("triangle")
  .fast("<1 1.5 2>")
  .delay(0.45)
  .room(0.75)
  .gain(0.35)`,
    bass: `note("<c1 c2> [~ eb1] <bb0 bb1> [f1 ab1]")
  .sound("sawtooth")
  .struct("x [~ x] x [x ~]")
  .lpf(900)
  .gain(0.62)`,
    bell: `note("c5 <eb5 g5> bb4 [ab5 c6]")
  .sound("sine")
  .slow(4)
  .delay(0.35)
  .room(0.8)
  .gain(0.42)`,
    breaks: `s("[bd ~] [~ sd] hh*8 [bd sd]")
  .slow(1)
  .sometimes(x => x.fast(2))
  .room(0.25)
  .gain(0.68)`,
    ambient: `note("c2 eb2 g2 bb2")
  .sound("triangle")
  .slow(8)
  .lpf(sine.range(400, 2600).slow(12))
  .delay(0.55)
  .room(0.9)
  .gain(0.38)`,
    sampleKit: `s("bd sd hh*4 [cp ~]")
  .bank("RolandTR909")
  .slow(1)
  .gain(0.62)`,
    breakbeat: `s("[bd ~] [~ sd] <hh*8 hh*4> [bd cp]")
  .bank("RolandTR909")
  .sometimes(x => x.fast(2))
  .room(0.25)
  .gain(0.66)`,
  };

  const layerSnippets: Record<string, string> = {
    drums: `s("bd [~ sd] hh*8 [cp ~]")
  .bank("RolandTR909")
  .gain(0.65)`,
    bass: `note("c1 [~ eb1] <bb0 bb1> [f1 ab1]")
  .sound("sawtooth")
  .struct("x [~ x] x [x ~]")
  .lpf(800)
  .gain(0.56)`,
    lead: `note("c4 eb4 g4 <bb4 c5>")
  .sound("square")
  .fast(2)
  .delay(0.25)
  .gain(0.42)`,
    chords: `note("<c3 eb3 g3> <bb2 d3 f3> <ab2 c3 eb3> <g2 bb2 d3>")
  .sound("triangle")
  .slow(2)
  .room(0.55)
  .gain(0.38)`,
    pad: `note("<c2 eb2 g2 bb2> <ab2 c3 eb3 g3>")
  .sound("sine")
  .slow(4)
  .lpf(sine.range(500, 2500).slow(8))
  .room(0.85)
  .gain(0.34)`,
  };

  const drumRows = [
    { label: 'bd', hits: [0, 4, 8, 12] },
    { label: 'sd', hits: [4, 12] },
    { label: 'hh', hits: [2, 6, 10, 14] },
    { label: 'cp', hits: [7, 15] },
  ];
  const arpNotes = ['~', 'c3', 'eb3', 'g3', 'bb3', 'c4'];
  const arpDefault = ['c3', '~', 'eb3', 'g3', 'bb3', 'g3', 'c4', 'eb3'];

  let strudelReady: Promise<void> | null = null;
  let droppedSampleUrl: string | null = null;
  let activeLineIndex = -1;
  let playIndicatorTimer: number | null = null;
  let isRunning = false;
  let liveApplyTimer: number | null = null;
  let isPaintingSteps = false;

  function setStatus(message: string) {
    if (statusEl) statusEl.textContent = message;
  }

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function highlightStrudel(code: string) {
    const escaped = escapeHtml(code);
    return escaped.replace(
      /("(?:\\.|[^"\\])*")|(\.[a-zA-Z_]\w*)|(\b(?:note|s|n|sound|samples|stack|cat|seq|slow|fast|gain|room|delay|lpf|hpf|rev|jux|sometimes|every|off|struct|bank|sine|saw|square|tri|rand|range)\b)|(\b\d+(?:\.\d+)?\b)|([()[\]{}<>*,])/g,
      (_match, stringToken, methodToken, functionToken, numberToken, symbolToken) => {
        if (stringToken) return `<span class="tok-string">${stringToken}</span>`;
        if (methodToken) return `<span class="tok-method">${methodToken}</span>`;
        if (functionToken) return `<span class="tok-fn">${functionToken}</span>`;
        if (numberToken) return `<span class="tok-number">${numberToken}</span>`;
        if (symbolToken) return `<span class="tok-symbol">${symbolToken}</span>`;
        return _match;
      },
    );
  }

  function syncHighlight() {
    if (!codeEl || !highlightEl) return;
    const lines = codeEl.value.split('\n');
    highlightEl.innerHTML = lines
      .map((line, index) => {
        const activeClass = index === activeLineIndex ? ' is-active' : '';
        return `<span class="code-line${activeClass}">${highlightStrudel(line) || ' '}</span>`;
      })
      .join('');
    highlightEl.scrollTop = codeEl.scrollTop;
    highlightEl.scrollLeft = codeEl.scrollLeft;
  }

  function stopPlayIndicator() {
    if (playIndicatorTimer !== null) window.clearInterval(playIndicatorTimer);
    playIndicatorTimer = null;
    activeLineIndex = -1;
    editorEl?.classList.remove('is-running');
    syncHighlight();
  }

  function startPlayIndicator() {
    if (!codeEl) return;
    if (playIndicatorTimer !== null) window.clearInterval(playIndicatorTimer);
    editorEl?.classList.add('is-running');
    const step = () => {
      const lineCount = Math.max(1, codeEl.value.split('\n').length);
      activeLineIndex = (activeLineIndex + 1) % lineCount;
      syncHighlight();
    };
    activeLineIndex = -1;
    step();
    playIndicatorTimer = window.setInterval(step, 650);
  }

  function evaluateCurrentPattern(status = 'Updated.') {
    if (!codeEl) return;
    const evaluate = (window as any).evaluate;
    if (typeof evaluate !== 'function') return;
    evaluate(codeEl.value);
    setStatus(status);
    try {
      window.localStorage.setItem('strudel-code', codeEl.value);
    } catch (e) {}
  }

  function scheduleLiveApply() {
    if (!isRunning) return;
    if (liveApplyTimer !== null) window.clearTimeout(liveApplyTimer);
    liveApplyTimer = window.setTimeout(() => evaluateCurrentPattern(), 120);
  }

  function loadStrudel() {
    if (strudelReady) return strudelReady;
    setStatus('Loading Strudel...');
    strudelReady = new Promise((resolve, reject) => {
      const existing = document.querySelector<HTMLScriptElement>('script[data-strudel-web]');
      if (existing) {
        existing.addEventListener('load', () => resolve(), { once: true });
        existing.addEventListener('error', () => reject(new Error('Could not load Strudel.')), { once: true });
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/@strudel/web@1.3.0';
      script.async = true;
      script.dataset.strudelWeb = 'true';
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('Could not load Strudel.'));
      document.head.append(script);
    }).then(async () => {
      const initStrudel = (window as any).initStrudel;
      if (typeof initStrudel !== 'function') throw new Error('Strudel did not initialize.');
      await initStrudel();
      setStatus('Ready.');
    });
    return strudelReady;
  }

  function updateControlLabels() {
    if (gainInput && gainValue) gainValue.textContent = Number(gainInput.value).toFixed(2);
    if (slowInput && slowValue) slowValue.textContent = Number(slowInput.value).toString();
    if (roomInput && roomValue) roomValue.textContent = Number(roomInput.value).toFixed(2);
    if (delayInput && delayValue) delayValue.textContent = Number(delayInput.value).toFixed(2);
    if (cutoffInput && cutoffValue) cutoffValue.textContent = Number(cutoffInput.value).toString();
  }

  async function runPattern() {
    if (!codeEl) return;
    try {
      await loadStrudel();
      const evaluate = (window as any).evaluate;
      if (typeof evaluate !== 'function') throw new Error('Strudel evaluator is unavailable.');
      isRunning = true;
      evaluateCurrentPattern('Running.');
      startPlayIndicator();
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Could not run pattern.');
    }
  }

  async function stopPattern() {
    try {
      await loadStrudel();
      const hush = (window as any).hush;
      if (typeof hush !== 'function') throw new Error('Strudel stop function is unavailable.');
      hush();
      isRunning = false;
      stopPlayIndicator();
      setStatus('Stopped.');
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Could not stop pattern.');
    }
  }

  function applyEditorControls() {
    if (!codeEl || !gainInput || !slowInput || !soundInput || !roomInput || !delayInput || !cutoffInput) return;
    const gain = Number(gainInput.value).toFixed(2);
    const slow = Number(slowInput.value).toString();
    const room = Number(roomInput.value).toFixed(2);
    const delay = Number(delayInput.value).toFixed(2);
    const cutoff = Number(cutoffInput.value).toString();
    const sound = soundInput.value;
    const base = codeEl.value
      .replace(/\n\s*\.gain\([^)]*\)/g, '')
      .replace(/\n\s*\.slow\([^)]*\)/g, '')
      .replace(/\n\s*\.sound\([^)]*\)/g, '')
      .replace(/\n\s*\.room\([^)]*\)/g, '')
      .replace(/\n\s*\.delay\([^)]*\)/g, '')
      .replace(/\n\s*\.lpf\([^)]*\)/g, '');
    codeEl.value = `${base}\n  .sound("${sound}")\n  .slow(${slow})\n  .lpf(${cutoff})\n  .delay(${delay})\n  .room(${room})\n  .gain(${gain})`;
    syncHighlight();
    scheduleLiveApply();
  }

  function appendCodeLayer(layerCode: string, status = 'Appended layer.') {
    if (!codeEl) return;
    const current = codeEl.value.trim();
    const next = layerCode.trim()
      .split('\n')
      .map((line) => `  ${line}`)
      .join('\n');
    codeEl.value = current.startsWith('stack(')
      ? current.replace(/\)\s*$/, `,\n${next}\n)`)
      : `stack(\n  ${current.replace(/\n/g, '\n  ')},\n${next}\n)`;
    syncHighlight();
    setStatus(status);
    scheduleLiveApply();
  }

  function activeStepTokens(rowLabels: string[], stepCount: number, getIsOn: (row: string, step: number) => boolean) {
    return Array.from({ length: stepCount }, (_unused, step) => {
      const hits = rowLabels.filter((row) => getIsOn(row, step));
      if (hits.length === 0) return '~';
      return hits.length === 1 ? hits[0] : `[${hits.join(' ')}]`;
    });
  }

  function drumCodeFromGrid() {
    const tokens = activeStepTokens(
      drumRows.map((row) => row.label),
      16,
      (row, step) => drumGrid?.querySelector<HTMLButtonElement>(`button[data-row="${row}"][data-step="${step}"]`)?.classList.contains('is-on') ?? false,
    );
    return `s("${tokens.join(' ')}")
  .bank("RolandTR909")
  .gain(0.65)`;
  }

  function arpCodeFromGrid() {
    const notes = Array.from({ length: 8 }, (_unused, step) => (
      arpGrid?.querySelector<HTMLButtonElement>(`button.is-on[data-step="${step}"]`)?.dataset.note || '~'
    ));
    const pattern = notes.join(' ');
    return `note("${pattern}")
  .sound("${soundInput?.value ?? 'sine'}")
  .fast(2)
  .delay(0.2)
  .gain(0.42)`;
  }

  function setStepState(button: HTMLButtonElement, force?: boolean) {
    const next = force ?? !button.classList.contains('is-on');
    button.classList.toggle('is-on', next);
    button.setAttribute('aria-pressed', String(next));
  }

  function renderDrumGrid() {
    if (!drumGrid) return;
    drumGrid.innerHTML = '';
    drumRows.forEach((row) => {
      const label = document.createElement('span');
      label.className = 'strudel-step-label';
      label.textContent = row.label;
      drumGrid.append(label);
      Array.from({ length: 16 }, (_unused, step) => {
        const button = document.createElement('button');
        const isOn = row.hits.includes(step);
        button.type = 'button';
        button.dataset.row = row.label;
        button.dataset.step = String(step);
        button.classList.toggle('is-on', isOn);
        button.setAttribute('aria-label', `${row.label} step ${step + 1}`);
        button.setAttribute('aria-pressed', String(isOn));
        button.addEventListener('pointerdown', (event) => {
          event.preventDefault();
          isPaintingSteps = true;
          setStepState(button);
        });
        button.addEventListener('pointerenter', () => {
          if (isPaintingSteps) setStepState(button, true);
        });
        drumGrid.append(button);
      });
    });
  }

  function renderArpGrid() {
    if (!arpGrid) return;
    arpGrid.innerHTML = '';
    arpDefault.forEach((activeNote, step) => {
      const cell = document.createElement('div');
      cell.className = 'strudel-arp-cell';
      const label = document.createElement('span');
      label.className = 'strudel-arp-label';
      label.textContent = String(step + 1);
      cell.append(label);
      arpNotes.forEach((note) => {
        const button = document.createElement('button');
        const isOn = note === activeNote;
        button.type = 'button';
        button.textContent = note;
        button.dataset.note = note;
        button.dataset.step = String(step);
        button.classList.toggle('is-on', isOn);
        button.setAttribute('aria-pressed', String(isOn));
        button.addEventListener('click', () => {
          cell.querySelectorAll<HTMLButtonElement>('button').forEach((other) => setStepState(other, false));
          setStepState(button, true);
        });
        cell.append(button);
      });
      arpGrid.append(cell);
    });
  }

  function builderExpression() {
    const mode = builderMode?.value ?? 'note';
    const pattern = builderPattern?.value.trim() || 'c2 eb2 g2 bb2';
    const struct = builderStruct?.value.trim();
    const bank = builderBank?.value;
    if (mode === 'sample') {
      const base = [`s("${pattern}")`];
      if (bank) base.push(`  .bank("${bank}")`);
      if (struct) base.push(`  .struct("${struct}")`);
      return base.join('\n');
    }
    if (mode === 'stack') {
      return `stack(
  note("${pattern}").sound("${soundInput?.value ?? 'sawtooth'}"),
  s("${struct || 'bd [~ sd] hh*4'}")
)`;
    }
    const base = `note("${pattern}")\n  .sound("${soundInput?.value ?? 'sawtooth'}")`;
    return struct ? `${base}\n  .struct("${struct}")` : base;
  }

  function replaceFromBuilder() {
    if (!codeEl) return;
    codeEl.value = `${builderExpression()}\n  .gain(${gainInput?.value ?? '0.55'})`;
    syncHighlight();
    setStatus('Built pattern.');
  }

  function appendFromBuilder() {
    appendCodeLayer(builderExpression());
  }

  function resetEditor() {
    if (codeEl) codeEl.value = defaultCode;
    if (soundInput) soundInput.value = 'sawtooth';
    if (gainInput) gainInput.value = '0.55';
    if (slowInput) slowInput.value = '2';
    if (roomInput) roomInput.value = '0.3';
    if (delayInput) delayInput.value = '0.15';
    if (cutoffInput) cutoffInput.value = '1800';
    if (sampleFileInput) sampleFileInput.value = '';
    if (sampleDropLabel) sampleDropLabel.textContent = 'Drop audio or choose file';
    if (droppedSampleUrl) URL.revokeObjectURL(droppedSampleUrl);
    droppedSampleUrl = null;
    isRunning = false;
    stopPlayIndicator();
    renderDrumGrid();
    renderArpGrid();
    updateControlLabels();
    syncHighlight();
    try {
      window.localStorage.removeItem('strudel-code');
    } catch (e) {}
    setStatus('Reset.');
  }

  function sampleNameFromFile(file: File) {
    const base = file.name.replace(/\.[^.]+$/, '').toLowerCase().replace(/[^a-z0-9]+/g, '').slice(0, 18);
    return base || 'drop';
  }

  function loadDroppedSample(file: File) {
    if (!codeEl || !file.type.startsWith('audio/')) {
      setStatus('Choose an audio file.');
      return;
    }
    if (droppedSampleUrl) URL.revokeObjectURL(droppedSampleUrl);
    droppedSampleUrl = URL.createObjectURL(file);
    const sampleName = sampleNameFromFile(file);
    codeEl.value = `samples({
  ${sampleName}: '${droppedSampleUrl}',
})

s("${sampleName}")
  .loopAt(4)
  .slice(8, "0 1 2 3 4 5 6 7")
  .gain(${gainInput?.value ?? '0.55'})`;
    if (builderMode) builderMode.value = 'sample';
    if (builderPattern) builderPattern.value = sampleName;
    if (builderStruct) builderStruct.value = 'x*8';
    if (sampleDropLabel) sampleDropLabel.textContent = file.name;
    syncHighlight();
    setStatus(`Loaded local sample: ${file.name}`);
  }

  try {
    const saved = window.localStorage.getItem('strudel-code');
    if (saved && codeEl) codeEl.value = saved;
  } catch (e) {}

  updateControlLabels();
  renderDrumGrid();
  renderArpGrid();
  syncHighlight();
  codeEl?.addEventListener('input', syncHighlight);
  codeEl?.addEventListener('scroll', syncHighlight);
  window.addEventListener('pointerup', () => {
    isPaintingSteps = false;
  });
  [gainInput, slowInput, roomInput, delayInput, cutoffInput, soundInput].forEach((input) => {
    input?.addEventListener('input', () => {
      updateControlLabels();
      applyEditorControls();
    });
  });
  applyControls?.addEventListener('click', applyEditorControls);
  buildReplace?.addEventListener('click', replaceFromBuilder);
  buildAppend?.addEventListener('click', appendFromBuilder);
  drumApply?.addEventListener('click', () => appendCodeLayer(drumCodeFromGrid(), 'Appended drum grid.'));
  drumClear?.addEventListener('click', () => {
    drumGrid?.querySelectorAll<HTMLButtonElement>('button').forEach((button) => setStepState(button, false));
    setStatus('Cleared drum grid.');
  });
  arpApply?.addEventListener('click', () => appendCodeLayer(arpCodeFromGrid(), 'Appended arp grid.'));
  arpClear?.addEventListener('click', () => {
    arpGrid?.querySelectorAll<HTMLButtonElement>('button').forEach((button) => setStepState(button, false));
    setStatus('Cleared arp grid.');
  });
  resetButton?.addEventListener('click', resetEditor);
  infoButton?.addEventListener('click', () => aboutDialog?.showModal());
  aboutDialog?.addEventListener('click', (event) => {
    if (event.target === aboutDialog) aboutDialog.close();
  });
  runButton?.addEventListener('click', runPattern);
  stopButton?.addEventListener('click', stopPattern);
  document.querySelectorAll<HTMLButtonElement>('[data-layer]').forEach((button) => {
    button.addEventListener('click', () => {
      const layer = button.dataset.layer;
      if (layer && layerSnippets[layer]) appendCodeLayer(layerSnippets[layer], `Appended ${button.textContent?.trim() ?? 'layer'}.`);
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-insert]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!codeEl || !button.dataset.insert) return;
      codeEl.value = `${codeEl.value.trimEnd()}\n  ${button.dataset.insert}`;
      syncHighlight();
      setStatus(`Inserted ${button.textContent?.trim() ?? 'transform'}.`);
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-sample]').forEach((button) => {
    button.addEventListener('click', () => {
      if (builderMode) builderMode.value = 'sample';
      if (builderPattern && button.dataset.sample) builderPattern.value = button.dataset.sample;
      if (builderBank && !builderBank.value) builderBank.value = 'RolandTR909';
      replaceFromBuilder();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((button) => {
    button.addEventListener('click', () => {
      const preset = button.dataset.preset;
      if (preset && presets[preset] && codeEl) {
        codeEl.value = presets[preset];
        syncHighlight();
        setStatus(`Loaded ${button.textContent?.trim() ?? 'preset'}.`);
      }
    });
  });
  sampleFileInput?.addEventListener('change', () => {
    const file = sampleFileInput.files?.[0];
    if (file) loadDroppedSample(file);
  });
  sampleDrop?.addEventListener('dragenter', (event) => {
    event.preventDefault();
    sampleDrop.classList.add('is-dragging');
  });
  sampleDrop?.addEventListener('dragover', (event) => {
    event.preventDefault();
  });
  sampleDrop?.addEventListener('dragleave', (event) => {
    if (!sampleDrop.contains(event.relatedTarget as Node | null)) sampleDrop.classList.remove('is-dragging');
  });
  sampleDrop?.addEventListener('drop', (event) => {
    event.preventDefault();
    sampleDrop.classList.remove('is-dragging');
    const file = event.dataTransfer?.files?.[0];
    if (file) loadDroppedSample(file);
  });
</script>
