    const leadEchoSel = document.querySelector<HTMLSelectElement>('.strudel-part[data-part="lead"] select[data-effect-echo]');
    if (leadEchoSel) leadEchoSel.value = state.lead.effects.echo || '';
    const roomEl = document.querySelector<HTMLInputElement>('.strudel-part[data-part="chords"] input[data-fx-room]');
    if (roomEl) {
      roomEl.value = String(state.chords.room);
