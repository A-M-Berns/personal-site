---
import Base from '../../layouts/Base.astro';

// Sound palettes — strudel passes these through `.s("...")` (synths,
// drum machines, soundfonts) or `.piano()` for the special-cased
// piano. Soundfonts and drum-machine banks are loaded by
// @strudel/repl's prebake, so the gm_* names work out of the box.
const melodyPalette: { label: string; items: [string, string][] }[] = [
  { label: 'synths', items: [
    ['sine', 'sine'], ['triangle', 'triangle'], ['square', 'square'],
    ['sawtooth', 'saw'], ['supersaw', 'supersaw'], ['pulse', 'pulse'],
    ['z_sine', 'zzfx sine'], ['z_sawtooth', 'zzfx saw'],
    ['white', 'noise'],
  ] },
  { label: 'piano + keys', items: [
    ['piano', 'piano'],
    ['gm_acoustic_grand_piano', 'grand piano'],
    ['gm_electric_piano_1', 'rhodes'],
    ['gm_electric_piano_2', 'wurli'],
    ['gm_harpsichord', 'harpsichord'],
    ['gm_celesta', 'celesta'],
    ['gm_drawbar_organ', 'organ'],
  ] },
  { label: 'mallets', items: [
    ['gm_vibraphone', 'vibraphone'],
    ['gm_marimba', 'marimba'],
    ['gm_xylophone', 'xylophone'],
    ['gm_glockenspiel', 'glockenspiel'],
    ['gm_music_box', 'music box'],
    ['gm_kalimba', 'kalimba'],
  ] },
  { label: 'strings', items: [
    ['gm_violin', 'violin'],
    ['gm_cello', 'cello'],
    ['gm_string_ensemble_1', 'string ensemble'],
    ['gm_synth_strings_1', 'synth strings'],
    ['gm_pizzicato_strings', 'pizzicato'],
  ] },
  { label: 'pads', items: [
    ['gm_pad_1_new_age', 'pad: new age'],
    ['gm_pad_2_warm', 'pad: warm'],
    ['gm_pad_3_polysynth', 'pad: polysynth'],
    ['gm_pad_4_choir', 'pad: choir'],
    ['gm_pad_5_bowed', 'pad: bowed'],
    ['gm_pad_8_sweep', 'pad: sweep'],
  ] },
  { label: 'leads', items: [
    ['gm_lead_1_square', 'lead: square'],
    ['gm_lead_2_sawtooth', 'lead: saw'],
    ['gm_lead_3_calliope', 'lead: calliope'],
    ['gm_lead_5_charang', 'lead: charang'],
    ['gm_lead_8_bass_lead', 'lead: bass'],
  ] },
  { label: 'wind / brass', items: [
    ['gm_flute', 'flute'],
    ['gm_clarinet', 'clarinet'],
    ['gm_oboe', 'oboe'],
    ['gm_synth_brass_1', 'synth brass'],
    ['gm_trumpet', 'trumpet'],
  ] },
  { label: 'guitar', items: [
    ['gm_acoustic_guitar_nylon', 'guitar: nylon'],
    ['gm_electric_guitar_clean', 'guitar: clean'],
    ['gm_overdriven_guitar', 'guitar: overdrive'],
    ['gm_distortion_guitar', 'guitar: dist'],
  ] },
  { label: 'fx', items: [
    ['gm_fx_2_soundtrack', 'fx: soundtrack'],
    ['gm_fx_3_crystal', 'fx: crystal'],
    ['gm_fx_4_atmosphere', 'fx: atmosphere'],
    ['gm_fx_5_brightness', 'fx: brightness'],
    ['gm_fx_8_scifi', 'fx: sci-fi'],
  ] },
];

const bassPalette: { label: string; items: [string, string][] }[] = [
  { label: 'synth', items: [
    ['sawtooth', 'saw'], ['square', 'square'], ['sine', 'sine'],
    ['triangle', 'triangle'], ['pulse', 'pulse'], ['supersaw', 'supersaw'],
  ] },
  { label: 'soundfont', items: [
    ['gm_acoustic_bass', 'acoustic bass'],
    ['gm_electric_bass_finger', 'electric bass'],
    ['gm_electric_bass_pick', 'pick bass'],
    ['gm_fretless_bass', 'fretless'],
    ['gm_slap_bass_1', 'slap'],
    ['gm_synth_bass_1', 'synth bass'],
    ['gm_synth_bass_2', 'rezzy bass'],
    ['gm_lead_8_bass_lead', 'bass lead'],
  ] },
];

const drumBankOptions: [string, string][] = [
  ['RolandTR909', '909'],
  ['RolandTR808', '808'],
  ['RolandTR707', '707'],
  ['RolandTR606', '606'],
  ['AlesisHR16', 'HR16'],
  ['AkaiLinn', 'linn'],
  ['ViscoSpaceDrum', 'visco'],
  ['bossanova', 'bossa'],
  ['casio', 'casio'],
  ['', 'default'],
];

// Drum row palette — the full set of drum-machine sample names a user
// might want in a row. Sample codes match strudel's tidal-drum-machines
// naming. A drum part is rendered with a subset of these as rows; user
// can add/remove rows from this palette.
const drumRowPalette: { code: string; label: string; icon: string }[] = [
  { code: 'bd',   label: 'kick',     icon: '●' },
  { code: 'sd',   label: 'snare',    icon: '◐' },
  { code: 'hh',   label: 'closed hat', icon: '✕' },
  { code: 'oh',   label: 'open hat', icon: '○' },
  { code: 'cp',   label: 'clap',     icon: '✦' },
  { code: 'rim',  label: 'rim',      icon: '◇' },
  { code: 'cy',   label: 'cymbal',   icon: '✻' },
  { code: 'cr',   label: 'crash',    icon: '✺' },
  { code: 'rd',   label: 'ride',     icon: '◑' },
  { code: 'lt',   label: 'low tom',  icon: '◆' },
  { code: 'mt',   label: 'mid tom',  icon: '◈' },
  { code: 'ht',   label: 'high tom', icon: '◊' },
  { code: 'sh',   label: 'shaker',   icon: '⋮' },
  { code: 'perc', label: 'perc',     icon: '⌑' },
  { code: 'cb',   label: 'cowbell',  icon: '▮' },
];
---
<Base title="Strudel — A. M. Berns" description="A small Strudel live-coding workspace.">
  <div class="strudel-shell">
    <main class="strudel-workspace" aria-label="Strudel workspace">
      <section class="strudel-editor-pane">
        <div class="strudel-pane-head">
          <h2>Pattern</h2>
          <div class="strudel-pane-head-right">
            <button id="strudel-regen" type="button" hidden title="Replace your edits with GUI-generated code">↻ regen from gui</button>
            <span id="strudel-status" class="strudel-status" aria-live="polite"></span>
          </div>
        </div>
        <div id="strudel-host" class="strudel-host"></div>
      </section>

      <aside class="strudel-side-pane">
        <aside class="strudel-transport" aria-label="Transport">
          <div class="strudel-transport-actions">
            <button id="strudel-run" type="button" data-state="idle" aria-label="Play / pause">
              <svg class="icon-play" viewBox="0 0 24 24" aria-hidden="true"><polygon points="6,4 6,20 20,12"/></svg>
              <svg class="icon-pause" viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
            </button>
            <button id="strudel-stop" type="button" aria-label="Stop">
              <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="5" width="14" height="14"/></svg>
            </button>
          </div>
          <div class="strudel-transport-grid">
            <div class="strudel-transport-row strudel-transport-row--meta">
              <label class="strudel-knob strudel-knob--num">
                <span>bpm</span>
                <input id="strudel-bpm" type="number" min="40" max="220" step="1" value="110" />
              </label>
              <label class="strudel-knob strudel-knob--key">
                <span>key</span>
                <select id="strudel-key">
                  <option value="c">C</option>
                  <option value="db">C♯ / D♭</option>
                  <option value="d">D</option>
                  <option value="eb">D♯ / E♭</option>
                  <option value="e">E</option>
                  <option value="f">F</option>
                  <option value="gb">F♯ / G♭</option>
                  <option value="g">G</option>
                  <option value="ab">G♯ / A♭</option>
                  <option value="a">A</option>
                  <option value="bb">A♯ / B♭</option>
                  <option value="b">B</option>
                </select>
              </label>
              <label class="strudel-knob strudel-knob--key">
                <span>scale</span>
                <select id="strudel-scale">
                  <optgroup label="modes">
                    <option value="major">major (ionian)</option>
                    <option value="dorian">dorian</option>
                    <option value="phrygian">phrygian</option>
                    <option value="lydian">lydian</option>
                    <option value="mixolydian">mixolydian</option>
                    <option value="minor">minor (aeolian)</option>
                    <option value="locrian">locrian</option>
                  </optgroup>
                  <optgroup label="minor variants">
                    <option value="harmonic minor">harmonic minor</option>
                    <option value="melodic minor">melodic minor</option>
                  </optgroup>
                  <optgroup label="pentatonic / blues">
                    <option value="major pentatonic">major pentatonic</option>
                    <option value="minor pentatonic">minor pentatonic</option>
                    <option value="blues">blues</option>
                  </optgroup>
                  <optgroup label="exotic">
                    <option value="phrygian dominant">phrygian dominant</option>
                    <option value="hungarian minor">hungarian minor</option>
                    <option value="whole tone">whole tone</option>
                  </optgroup>
                </select>
              </label>
            </div>
            <div class="strudel-transport-row strudel-transport-row--sliders">
              <label class="strudel-knob">
                <span>vol</span>
                <input id="strudel-master" type="range" min="0" max="1" step="0.01" value="0.85" />
                <output id="strudel-master-out">0.85</output>
              </label>
              <label class="strudel-knob">
                <span>swing</span>
                <input id="strudel-swing" type="range" min="0" max="0.5" step="0.01" value="0" />
                <output id="strudel-swing-out">0</output>
              </label>
            </div>
          </div>
        </aside>

        <!-- Parts container — rendered dynamically from state.parts -->
        <div id="strudel-parts" class="strudel-parts"></div>

        <!-- Add-part menu — click a button to spawn a new part of that
             type. Multiple parts of the same type are allowed (e.g.
             two drum tracks). -->
        <div class="strudel-add-part" aria-label="Add part">
          <span class="strudel-add-label">add</span>
          <button type="button" data-add-part="drums">drums</button>
          <button type="button" data-add-part="chords">chords</button>
          <button type="button" data-add-part="bass">bass</button>
          <button type="button" data-add-part="arp">arp</button>
          <button type="button" data-add-part="lead">lead</button>
          <button type="button" data-add-part="sample">sample</button>
        </div>
      </aside>
    </main>

    <div class="anim-controls">
      <button id="strudel-info" type="button" aria-label="About this Strudel page">About</button>
      <button id="strudel-reset" type="button" aria-label="Reset workspace">Reset</button>
    </div>

    <dialog id="strudel-about" class="anim-about" aria-labelledby="strudel-about-title">
      <h2 id="strudel-about-title">About</h2>
      <p>
        This page embeds <a href="https://www.npmjs.com/package/@strudel/repl">@strudel/repl</a>,
        part of <a href="https://codeberg.org/uzu/strudel">Strudel</a>, licensed under
        <a href="https://codeberg.org/uzu/strudel/src/branch/main/LICENSE">AGPL-3.0-or-later</a>.
        Build your patch on the right; the code on the left auto-updates. Hand-edit the code if you want — the GUI stops overwriting once you type, and the regen button puts the GUI back in charge.
        Site source at <a href="https://github.com/A-M-Berns/personal-site">GitHub</a>.
      </p>
    </dialog>
  </div>
</Base>

<style is:global>
  /* Editor host: scope down strudel-editor's defaults to fit the page. */
  .strudel-host {
    position: relative;
    flex: 1;
    min-height: 0;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.035);
    overflow: hidden;
    transition: border-color 140ms ease, box-shadow 180ms ease;
  }
  .strudel-host.is-running {
    border-color: var(--accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .strudel-host strudel-editor { display: none; }
  .strudel-host > div:not(.cm-host) {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: transparent;
  }
  .strudel-host .cm-editor {
    height: 100%;
    background: transparent !important;
    color: var(--ink);
    font: 0.92rem/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
  }
  .strudel-host .cm-scroller {
    background: transparent !important;
    font-family: inherit !important;
  }
  .strudel-host .cm-gutters {
    background: rgba(255, 255, 255, 0.02) !important;
    border-right: 1px solid var(--rule) !important;
    color: var(--muted) !important;
  }
  .strudel-host .cm-activeLine,
  .strudel-host .cm-activeLineGutter {
    background: rgba(255, 255, 255, 0.04) !important;
  }
  .strudel-host .cm-content {
    caret-color: var(--accent) !important;
  }
  .strudel-host .cm-cursor {
    border-left-color: var(--accent) !important;
  }
  .strudel-host .cm-selectionBackground,
  .strudel-host .cm-content ::selection {
    background: color-mix(in srgb, var(--accent) 30%, transparent) !important;
  }
</style>

<style>
  .strudel-shell {
    position: relative;
    height: calc(100vh - 11.25rem);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .strudel-transport {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.55rem 0.7rem;
    background: rgba(0, 0, 0, 0.92);
    border: 1px solid var(--rule);
    border-radius: 3px;
  }
  .strudel-transport-actions { display: flex; gap: 0.4rem; }
  .strudel-transport-grid {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .strudel-transport-row {
    display: grid;
    align-items: center;
    gap: 0.45rem;
  }
  .strudel-transport-row--meta {
    grid-template-columns: auto auto minmax(0, 1fr);
  }
  .strudel-transport-row--meta .strudel-knob--num input[type="number"] {
    max-width: 3.4rem;
  }
  .strudel-transport-row--meta .strudel-knob--key:first-of-type select {
    max-width: 5rem;
  }
  .strudel-transport-row--meta .strudel-knob select { min-width: 0; }
  .strudel-transport-row--sliders {
    grid-template-columns: 1fr 1fr;
  }
  .strudel-knob--num {
    grid-template-columns: auto 1fr;
  }
  .strudel-knob--num input[type="number"] {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.2rem 0.3rem;
    font: 0.78rem/1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-variant-numeric: tabular-nums;
  }
  .strudel-knob--num input[type="number"]:focus {
    outline: none;
    border-color: var(--accent);
  }
  .strudel-knob {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.35rem;
    color: var(--muted);
    font: 0.65rem/1 var(--font-lexend), var(--sans);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .strudel-knob--key { grid-template-columns: auto 1fr; }
  .strudel-knob output {
    font-variant-numeric: tabular-nums;
    color: var(--ink);
    text-align: right;
    min-width: 2rem;
    cursor: text;
  }
  .strudel-knob input[type="range"] { accent-color: var(--accent); width: 100%; }
  .strudel-knob output:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  :global(input.strudel-output-input) {
    width: 3rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--accent);
    border-radius: 2px;
    color: var(--ink);
    padding: 0 0.25rem;
    font: inherit;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  :global(input.strudel-output-input:focus) { outline: none; }
  .strudel-transport-actions button {
    width: 2.1rem;
    height: 2.1rem;
    display: grid;
    place-items: center;
    padding: 0;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    cursor: pointer;
  }
  .strudel-transport-actions button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-transport-actions button svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: currentColor;
  }
  .strudel-transport-actions #strudel-run .icon-pause { display: none; }
  .strudel-transport-actions #strudel-run[data-state="running"] {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-transport-actions #strudel-run[data-state="running"] .icon-play { display: none; }
  .strudel-transport-actions #strudel-run[data-state="running"] .icon-pause { display: block; }
  .strudel-status {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .strudel-pane-head-right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  #strudel-regen {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.65rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--accent);
    border-radius: 3px;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
  }
  #strudel-regen:hover { background: color-mix(in srgb, var(--accent) 15%, transparent); }
  .strudel-host.is-manual {
    border-color: color-mix(in srgb, var(--accent) 70%, var(--rule));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .strudel-workspace {
    display: grid;
    grid-template-columns: minmax(34rem, 1.7fr) minmax(20rem, 24rem);
    gap: 1rem;
    align-items: stretch;
    flex: 1;
    min-height: 0;
  }
  .strudel-editor-pane,
  .strudel-side-pane {
    background: #000;
    padding: 0.85rem;
    border: 1px solid var(--rule);
    border-radius: 3px;
  }
  .strudel-editor-pane { display: flex; flex-direction: column; min-height: 0; }
  .strudel-pane-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.55rem;
  }
  .strudel-pane-head h2 {
    font-family: var(--display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .strudel-side-pane {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }
  .strudel-parts {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .strudel-part {
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.55rem 0.7rem;
    background: rgba(255, 255, 255, 0.015);
  }
  .strudel-part-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .strudel-part-head .strudel-part-title {
    font-family: var(--display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
    flex: 1;
    min-width: 0;
  }
  .strudel-part.is-muted .strudel-part-title {
    color: var(--muted);
    opacity: 0.7;
  }
  /* Mute / Solo / Delete cluster */
  .strudel-ms {
    display: inline-flex;
    gap: 2px;
  }
  .strudel-ms button {
    width: 1.5rem;
    height: 1.4rem;
    padding: 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    color: var(--muted);
    font: 700 0.66rem/1 var(--font-lexend), var(--sans);
    border-radius: 2px;
    cursor: pointer;
  }
  .strudel-ms button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-ms button.is-active[data-kind="m"] {
    background: color-mix(in srgb, #ff6b6b 22%, transparent);
    border-color: #ff6b6b;
    color: #ff8c8c;
  }
  .strudel-ms button.is-active[data-kind="s"] {
    background: color-mix(in srgb, #ffd24a 22%, transparent);
    border-color: #ffd24a;
    color: #ffe07a;
  }
  .strudel-part-delete {
    width: 1.5rem;
    height: 1.4rem;
    padding: 0;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--rule) 70%, transparent);
    color: var(--muted);
    border-radius: 2px;
    cursor: pointer;
    font: 0.95rem/1 ui-monospace, monospace;
  }
  .strudel-part-delete:hover { color: var(--accent); border-color: var(--accent); }
  .strudel-part-controls {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .strudel-part-controls input[type="range"] { width: 4.5rem; accent-color: var(--accent); }
  .strudel-part-controls select,
  .strudel-fx-row select,
  .strudel-knob select {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.2rem 0.3rem;
    font-size: 0.72rem;
  }
  .strudel-part.is-muted > :not(.strudel-part-head) { display: none; }
  .strudel-part.is-muted .strudel-part-controls { display: none; }
  .strudel-part.is-muted { padding: 0.4rem 0.7rem; background: transparent; }

  /* Add-part menu */
  .strudel-add-part {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.6rem;
