<script>
  // =========================================================================
  // Strudel workspace — parts list architecture.
  //
  // The side pane holds an ordered list of "parts" — each an instance of
  // one type (drums, chords, bass, arp, lead, sample). Multiple instances
  // of the same type are allowed (e.g. two drum tracks). Each part has
  // its own mute and solo toggles, like a DAW track. Solo overrides mute:
  // if any part is soloed, only soloed parts play; otherwise all enabled
  // parts play.
  // =========================================================================

  // ===== Types =====
  type Quality = 'maj' | 'min' | '7' | 'maj7' | 'min7' | 'sus' | 'dim';
  type PartType = 'drums' | 'chords' | 'bass' | 'arp' | 'lead' | 'sample';
  type FilterMod = '' | 'sine-slow' | 'sine-fast' | 'saw' | 'tri' | 'square' | 'rand' | 'perlin';
  type ModTarget = 'lpf' | 'pan' | 'gain';
  type EveryN = '' | '2' | '4' | '8';
  type EveryFn = '' | 'fast2' | 'slow2' | 'rev' | 'jux' | 'chop';
  type Superimpose = '' | '+5' | '+12' | '-12';
  type EchoPreset = '' | 'short' | 'long' | 'tape';

  interface ChordSlot { root: string; quality: Quality; octave: number; }
  interface MidiNote { pitch: number; start: number; length: number; }

  interface PartFx {
    lpf: number; hpf: number; drop: number;
    everyN: EveryN; everyFn: EveryFn;
    pan: number; crush: number;
    mod: FilterMod; modTarget: ModTarget;
    ply: number; struct: string;
    superimpose: Superimpose;
  }
  const defaultFx = (): PartFx => ({
    lpf: 8000, hpf: 0, drop: 0, everyN: '', everyFn: '', pan: 0.5, crush: 0,
    mod: '', modTarget: 'lpf', ply: 1, struct: '', superimpose: '',
  });

  interface PartBase {
    id: string;
    type: PartType;
    enabled: boolean;
    soloed: boolean;
    gain: number;
    fx: PartFx;
  }
  interface DrumsPart extends PartBase {
    type: 'drums';
    bank: string;
    rows: string[];                                // ordered list of drum codes (bd, sd, hh, ...)
    steps: Record<string, boolean[]>;              // step grid per row code
  }
  interface ChordsPart extends PartBase {
    type: 'chords';
    sound: string;
    slots: ChordSlot[];
    room: number;
    attack: number;
    vowel: string;
  }
  interface BassPart extends PartBase {
    type: 'bass';
    sound: string;
    rhythm: string;
    follow: boolean;
  }
  interface ArpPart extends PartBase {
    type: 'arp';
    sound: string;
    speed: number;
    follow: boolean;
    cells: boolean[][];
  }
  interface LeadPart extends PartBase {
    type: 'lead';
    sound: string;
    notes: MidiNote[];
    attack: number;
    effects: { delay: boolean; room: boolean; jux: boolean; ghost: boolean; shape: boolean; echo: EchoPreset };
  }
  interface SamplePart extends PartBase {
    type: 'sample';
    name: string;
    url: string | null;
  }
  type Part = DrumsPart | ChordsPart | BassPart | ArpPart | LeadPart | SamplePart;

  interface State {
    bpm: number;
    master: number;
    swing: number;
    key: string;
    scale: string;
    parts: Part[];
  }

  // ===== Music helpers =====
  const NOTE_NAMES = ['c', 'db', 'd', 'eb', 'e', 'f', 'gb', 'g', 'ab', 'a', 'bb', 'b'];
  const SCALES: Record<string, number[]> = {
    major:              [0, 2, 4, 5, 7, 9, 11],
    dorian:             [0, 2, 3, 5, 7, 9, 10],
    phrygian:           [0, 1, 3, 5, 7, 8, 10],
    lydian:             [0, 2, 4, 6, 7, 9, 11],
    mixolydian:         [0, 2, 4, 5, 7, 9, 10],
    minor:              [0, 2, 3, 5, 7, 8, 10],
    locrian:            [0, 1, 3, 5, 6, 8, 10],
    'harmonic minor':   [0, 2, 3, 5, 7, 8, 11],
    'melodic minor':    [0, 2, 3, 5, 7, 9, 11],
    'major pentatonic': [0, 2, 4, 7, 9],
    'minor pentatonic': [0, 3, 5, 7, 10],
    blues:              [0, 3, 5, 6, 7, 10],
    'phrygian dominant':[0, 1, 4, 5, 7, 8, 10],
    'hungarian minor':  [0, 2, 3, 6, 7, 8, 11],
    'whole tone':       [0, 2, 4, 6, 8, 10],
  };
  const QUALITY_INTERVALS: Record<Quality, number[]> = {
    maj: [0, 4, 7],
    min: [0, 3, 7],
    '7': [0, 4, 7, 10],
    maj7: [0, 4, 7, 11],
    min7: [0, 3, 7, 10],
    sus: [0, 5, 7],
    dim: [0, 3, 6],
  };
  function rootIndex(root: string) {
    const idx = NOTE_NAMES.indexOf(root);
    return idx < 0 ? 0 : idx;
  }
  function midiToName(midi: number) {
    const n = ((midi % 12) + 12) % 12;
    const oct = Math.floor(midi / 12);
    return `${NOTE_NAMES[n]}${oct}`;
  }
  function chordNotesOf(slot: ChordSlot) {
    const intervals = QUALITY_INTERVALS[slot.quality] ?? QUALITY_INTERVALS.min;
    const baseMidi = (slot.octave + 1) * 12 + rootIndex(slot.root);
    return intervals.map((i) => midiToName(baseMidi + i));
  }
  function chordLabel(slot: ChordSlot) {
    const root = slot.root.replace('b', '♭').toUpperCase();
    const q = slot.quality === 'maj' ? '' : slot.quality === 'min' ? 'm' : slot.quality;
    return `${root}${q}`;
  }
  function scaleDegreeMidi(keyRoot: string, scaleName: string, degree: number, octave = 4) {
    const intervals = SCALES[scaleName] ?? SCALES.minor;
    const len = intervals.length;
    const wrap = ((degree % len) + len) % len;
    const oct = octave + Math.floor(degree / len);
    return oct * 12 + rootIndex(keyRoot) + intervals[wrap];
  }
  function degreeLabel(degree: number, key: string, scale: string): string {
    const intervals = SCALES[scale] ?? SCALES.minor;
    const interval = intervals[((degree % intervals.length) + intervals.length) % intervals.length];
    const idx = (rootIndex(key) + interval) % 12;
    return NOTE_NAMES[idx].replace('b', '♭').toUpperCase();
  }

  // ===== Constants =====
  const STEPS = 16;
  const ROLL_PITCHES = 12;
  const ARP_STEPS = 16;
  const LEAD_STEPS = 16;
  const DEFAULT_DRUM_ROWS = ['bd', 'sd', 'hh', 'cp'];
  const GAIN_FLOOR = 0.01;

  // Drum palette from frontmatter — exposed to script via DOM data:
  // we just inline it here to avoid a script island round-trip.
  const DRUM_ROW_PALETTE: { code: string; label: string; icon: string }[] = [
    { code: 'bd',   label: 'kick',     icon: '●' },
    { code: 'sd',   label: 'snare',    icon: '◐' },
    { code: 'hh',   label: 'closed hat', icon: '✕' },
    { code: 'oh',   label: 'open hat', icon: '○' },
    { code: 'cp',   label: 'clap',     icon: '✦' },
    { code: 'rim',  label: 'rim',      icon: '◇' },
    { code: 'cy',   label: 'cymbal',   icon: '✻' },
    { code: 'cr',   label: 'crash',    icon: '✺' },
    { code: 'rd',   label: 'ride',     icon: '◑' },
    { code: 'lt',   label: 'low tom',  icon: '◆' },
    { code: 'mt',   label: 'mid tom',  icon: '◈' },
    { code: 'ht',   label: 'high tom', icon: '◊' },
    { code: 'sh',   label: 'shaker',   icon: '⋮' },
    { code: 'perc', label: 'perc',     icon: '⌑' },
    { code: 'cb',   label: 'cowbell',  icon: '▮' },
  ];
  function drumRowInfo(code: string) {
    return DRUM_ROW_PALETTE.find((r) => r.code === code) ?? { code, label: code, icon: code };
  }

  // ===== Defaults =====
  function emptyDrumSteps(rows: string[]): Record<string, boolean[]> {
    const obj: Record<string, boolean[]> = {};
    rows.forEach((r) => { obj[r] = new Array(STEPS).fill(false); });
    return obj;
  }
  function emptyCells(steps: number): boolean[][] {
    return Array.from({ length: ROLL_PITCHES }, () => new Array(steps).fill(false));
  }
  let nextPartIdNum = 1;
  function makePartId(type: PartType) { return `${type}-${nextPartIdNum++}`; }

  function makePart(type: PartType): Part {
    const base = { id: makePartId(type), type, enabled: true, soloed: false } as const;
    switch (type) {
      case 'drums': {
        const rows = [...DEFAULT_DRUM_ROWS];
        return { ...base, type, gain: 0.65, fx: defaultFx(), bank: 'RolandTR909', rows, steps: emptyDrumSteps(rows) };
      }
      case 'chords':
        return { ...base, type, gain: 0.4, fx: defaultFx(), sound: 'piano', slots: [], room: 0.5, attack: 0, vowel: '' };
      case 'bass':
        return { ...base, type, gain: 0.55, fx: { ...defaultFx(), lpf: 800 }, sound: 'sawtooth', rhythm: 'syncopated', follow: true };
      case 'arp':
        return { ...base, type, gain: 0.42, fx: defaultFx(), sound: 'sine', speed: 2, follow: true, cells: emptyCells(ARP_STEPS) };
      case 'lead':
        return { ...base, type, gain: 0.42, fx: defaultFx(), sound: 'square', notes: [], attack: 0, effects: { delay: false, room: false, jux: false, ghost: false, shape: false, echo: '' } };
      case 'sample':
        return { ...base, type, gain: 0.55, fx: defaultFx(), name: '', url: null };
    }
  }

  const initialState: State = {
    bpm: 110, master: 0.85, swing: 0, key: 'c', scale: 'minor', parts: [],
  };

  // ===== Migration: old fixed-shape state -> new parts list =====
  function migrateOldStateToParts(saved: any): Part[] {
    const parts: Part[] = [];
    const types: PartType[] = ['drums', 'chords', 'bass', 'arp', 'lead', 'sample'];
    for (const t of types) {
      const old = saved?.[t];
      if (!old || !old.enabled) continue;          // only carry enabled parts forward
      const part = makePart(t);
      part.gain = old.gain ?? part.gain;
      part.fx = { ...part.fx, ...(old.fx ?? {}) };
      delete (part.fx as any).vary;
      if (t === 'drums') {
        const p = part as DrumsPart;
        p.bank = old.bank ?? p.bank;
        if (old.steps && typeof old.steps === 'object') {
          p.rows = Object.keys(old.steps);
          p.steps = old.steps;
        }
      } else if (t === 'chords') {
        const p = part as ChordsPart;
        p.sound = old.sound ?? p.sound;
        p.slots = Array.isArray(old.slots) ? old.slots : [];
        p.room = old.room ?? p.room;
        p.attack = old.attack ?? 0;
        p.vowel = old.vowel ?? '';
      } else if (t === 'bass') {
        const p = part as BassPart;
        p.sound = old.sound ?? p.sound;
        p.rhythm = old.rhythm ?? p.rhythm;
        p.follow = old.follow ?? true;
      } else if (t === 'arp') {
        const p = part as ArpPart;
        p.sound = old.sound ?? p.sound;
        p.speed = old.speed ?? p.speed;
        p.follow = old.follow ?? true;
        if (Array.isArray(old.cells)) p.cells = old.cells;
      } else if (t === 'lead') {
        const p = part as LeadPart;
        p.sound = old.sound ?? p.sound;
        p.notes = Array.isArray(old.notes) ? old.notes : [];
        p.attack = old.attack ?? 0;
        p.effects = { ...p.effects, ...(old.effects ?? {}) };
      } else if (t === 'sample') {
        const p = part as SamplePart;
        p.name = old.name ?? '';
        p.url = null;                                // can't carry blob URLs across reloads
      }
      parts.push(part);
    }
    return parts;
  }

  function clone<T>(value: T): T { return JSON.parse(JSON.stringify(value)); }
  function loadState(): State {
    try {
      const raw = window.localStorage.getItem('strudel-state-v6');
      if (raw) {
        const saved = JSON.parse(raw);
        if (Array.isArray(saved.parts)) {
          // Already in new shape.
          // Reset volatile blob URLs on sample parts.
          (saved.parts as Part[]).forEach((p) => {
            if (p.type === 'sample') (p as SamplePart).url = null;
          });
          // Ensure each part has all required fields (fx defaults etc.)
          (saved.parts as Part[]).forEach((p) => {
            p.fx = { ...defaultFx(), ...(p.fx ?? {}) };
            delete (p.fx as any).vary;
          });
          // Track max id seen to seed nextPartIdNum
          const maxN = saved.parts.reduce((m: number, p: Part) => {
            const match = p.id?.match(/-(\d+)$/);
            return match ? Math.max(m, parseInt(match[1], 10)) : m;
          }, 0);
          nextPartIdNum = maxN + 1;
          return { ...initialState, ...saved };
        }
      }
      // Try v5 state and migrate.
      const oldRaw = window.localStorage.getItem('strudel-state-v5');
      if (oldRaw) {
        const saved = JSON.parse(oldRaw);
        const parts = migrateOldStateToParts(saved);
        return {
          bpm: saved.bpm ?? 110,
          master: saved.master ?? 0.85,
          swing: saved.swing ?? 0,
          key: saved.key ?? 'c',
          scale: saved.scale ?? 'minor',
          parts,
        };
      }
    } catch (e) {}
    return clone(initialState);
  }

  let state: State = loadState();

  function saveState() {
    try {
      const dehydrated = clone(state);
      // strip blob URLs
      dehydrated.parts.forEach((p) => {
        if (p.type === 'sample') (p as SamplePart).url = null;
      });
      window.localStorage.setItem('strudel-state-v6', JSON.stringify(dehydrated));
    } catch (e) {}
  }

  // ===== Code generation =====
  function indent(code: string, n = 2) {
    const pad = ' '.repeat(n);
    return code.split('\n').map((l) => pad + l).join('\n');
  }
  function soundChain(sound: string): string {
    if (sound === 'piano') return '.piano()';
    return `.s("${sound}")`;
  }
  function modSignal(mod: FilterMod, min: number, max: number): string {
    if (!mod) return '';
    const slowMap: Record<FilterMod, number> = {
      '': 0, 'sine-slow': 4, 'sine-fast': 1, saw: 2, tri: 2, square: 2, rand: 1, perlin: 2,
    };
    const wave = mod === 'sine-slow' || mod === 'sine-fast' ? 'sine' : mod;
    return `${wave}.range(${min}, ${max}).slow(${slowMap[mod]})`;
  }
  function modRangeFor(target: ModTarget, fx: PartFx): [number, number] {
    if (target === 'lpf')  return [200, fx.lpf];
    if (target === 'pan')  return [0, 1];
    return [0.2, 1];
  }
  function applyFx(code: string, fx: PartFx): string {
    let out = code;
    const modOn = !!fx.mod;
    if (modOn && fx.modTarget === 'lpf') {
      const [lo, hi] = modRangeFor('lpf', fx);
      out += `\n  .lpf(${modSignal(fx.mod, lo, hi)})`;
    } else if (fx.lpf < 8000) {
      out += `\n  .lpf(${fx.lpf})`;
    }
    if (fx.hpf > 0) out += `\n  .hpf(${fx.hpf})`;
    if (fx.ply > 1) out += `\n  .ply(${fx.ply})`;
    if (fx.drop > 0) out += `\n  .degradeBy(${fx.drop.toFixed(2)})`;
    if (fx.crush > 0) out += `\n  .crush(${fx.crush})`;
    if (modOn && fx.modTarget === 'pan') {
      const [lo, hi] = modRangeFor('pan', fx);
      out += `\n  .pan(${modSignal(fx.mod, lo, hi)})`;
    } else if (Math.abs(fx.pan - 0.5) > 0.001) {
      out += `\n  .pan(${fx.pan.toFixed(2)})`;
    }
    if (modOn && fx.modTarget === 'gain') {
      const [lo, hi] = modRangeFor('gain', fx);
      out += `\n  .gain(${modSignal(fx.mod, lo, hi)})`;
    }
    if (fx.struct?.trim()) out += `\n  .struct("${fx.struct.replace(/"/g, '')}")`;
    if (fx.everyN && fx.everyFn) {
      const fnMap: Record<EveryFn, string> = {
        '': '', fast2: 'x => x.fast(2)', slow2: 'x => x.slow(2)',
        rev: 'rev', jux: 'x => x.jux(rev)', chop: 'x => x.chop(2)',
      };
      const expr = fnMap[fx.everyFn];
      if (expr) out += `\n  .every(${fx.everyN}, ${expr})`;
    }
    const semis: Record<Superimpose, number> = { '': 0, '+5': 7, '+12': 12, '-12': -12 };
    if (fx.superimpose && semis[fx.superimpose]) {
      out += `\n  .superimpose(x => x.add(${semis[fx.superimpose]}))`;
    }
    return out;
  }
  const isAudible = (v: number) => v >= GAIN_FLOOR;
  const curvedGain = (v: number) => `${(v ** 1.7).toFixed(3)}`;

  // Helpers shared by arp/lead/bass — find the first enabled chords
  // part to follow harmonically. Returns its slots or an empty list.
  function chordSlotsForFollow(): ChordSlot[] {
    const c = state.parts.find((p): p is ChordsPart => p.type === 'chords' && p.enabled);
    return c?.slots ?? [];
  }

  function drumCode(p: DrumsPart): string | null {
    if (!isAudible(p.gain)) return null;
    const tokens: string[] = [];
    let any = false;
    for (let s = 0; s < STEPS; s++) {
      const hits = p.rows.filter((r) => p.steps[r]?.[s]);
      if (hits.length > 0) any = true;
      tokens.push(hits.length === 0 ? '~' : hits.length === 1 ? hits[0] : `[${hits.join(',')}]`);
    }
    if (!any) return null;
    let code = `s("${tokens.join(' ')}")`;
    if (p.bank) code += `\n  .bank("${p.bank}")`;
    code = applyFx(code, p.fx);
    code += `\n  .gain(${curvedGain(p.gain)})`;
    return code;
  }
  function chordCode(p: ChordsPart): string | null {
    if (!isAudible(p.gain) || p.slots.length === 0) return null;
    const slotStrs = p.slots.map((s) => `<${chordNotesOf(s).join(',')}>`);
    let code = `note("${slotStrs.join(' ')}")`;
    code += `\n  ${soundChain(p.sound)}`;
    if (p.sound !== 'piano') code += `\n  .release(0.5)`;
    if (p.attack > 0) code += `\n  .attack(${p.attack.toFixed(2)})`;
    if (p.vowel) code += `\n  .vowel("${p.vowel}")`;
    if (p.room > 0) code += `\n  .room(${p.room.toFixed(2)})`;
    code = applyFx(code, p.fx);
    code += `\n  .gain(${curvedGain(p.gain)})`;
    return code;
  }
  function bassCode(p: BassPart): string | null {
    if (!isAudible(p.gain)) return null;
    const slots = chordSlotsForFollow();
    const fallback = `${state.key}2`;
    const roots = p.follow && slots.length
      ? slots.map((s) => `${s.root}2`)
      : [fallback, fallback, fallback, fallback];
    let pattern = '';
    if (p.rhythm === 'root')       pattern = roots.join(' ');
    else if (p.rhythm === 'steady') pattern = roots.flatMap((r) => [r, r, r, r]).join(' ');
    else if (p.rhythm === 'syncopated') pattern = roots.map((r) => `[${r} ~ ${r} [~ ${r}]]`).join(' ');
    else if (p.rhythm === 'octaves')   pattern = roots.map((r) => {
      const up = r.replace(/(\d)$/, (_m, d) => String(Number(d) + 1));
      return `[${r} ${up} ${r} ${up}]`;
    }).join(' ');
    else if (p.rhythm === 'walking')   pattern = roots.map((r, i) => {
      const next = roots[(i + 1) % roots.length];
      return `[${r} ${r} ${next} ${r}]`;
    }).join(' ');
    let code = `note("${pattern}")\n  ${soundChain(p.sound)}`;
    code = applyFx(code, p.fx);
    code += `\n  .gain(${curvedGain(p.gain)})`;
    return code;
  }
  function rollPattern(cells: boolean[][], steps: number, follow: boolean, octaveBase: number): string {
    const slots = follow ? chordSlotsForFollow() : [];
    const slotsPerStep = slots.length ? steps / slots.length : steps;
    const tokens: string[] = [];
    for (let s = 0; s < steps; s++) {
      const onPitches: number[] = [];
      for (let pp = 0; pp < ROLL_PITCHES; pp++) {
        if (cells[pp]?.[s]) onPitches.push(ROLL_PITCHES - 1 - pp);
      }
      if (onPitches.length === 0) { tokens.push('~'); continue; }
      const slotIdx = Math.min(slots.length - 1, Math.floor(s / slotsPerStep));
      const localKey = follow && slots[slotIdx] ? slots[slotIdx].root : state.key;
      const names = onPitches.map((deg) => midiToName(scaleDegreeMidi(localKey, state.scale, deg, octaveBase)));
      tokens.push(names.length === 1 ? names[0] : `[${names.join(',')}]`);
    }
    return tokens.join(' ');
  }
  function arpCode(p: ArpPart): string | null {
    if (!isAudible(p.gain)) return null;
    const hasAny = p.cells.some((row) => row.some(Boolean));
    if (!hasAny) return null;
    let code = `note("${rollPattern(p.cells, ARP_STEPS, p.follow, 4)}")`;
    code += `\n  ${soundChain(p.sound)}`;
    if (p.speed !== 1) code += `\n  .fast(${p.speed})`;
    code = applyFx(code, p.fx);
    code += `\n  .delay(0.25)\n  .gain(${curvedGain(p.gain)})`;
    return code;
  }
  function midiNotesPattern(notes: MidiNote[], steps: number, octaveBase: number): string {
    type Step = { starts: string[]; sustain: boolean };
    const cells: Step[] = Array.from({ length: steps }, () => ({ starts: [], sustain: false }));
    const slots = chordSlotsForFollow();
    const slotsPerStep = slots.length ? steps / slots.length : steps;
    notes.forEach((n) => {
      if (n.start >= steps) return;
      const slotIdx = Math.min(slots.length - 1, Math.floor(n.start / slotsPerStep));
      const localKey = slots[slotIdx] ? slots[slotIdx].root : state.key;
      const name = midiToName(scaleDegreeMidi(localKey, state.scale, n.pitch, octaveBase));
      cells[n.start].starts.push(name);
      for (let i = 1; i < n.length && n.start + i < steps; i++) cells[n.start + i].sustain = true;
    });
    return cells.map((c) => {
      if (c.starts.length === 0) return c.sustain ? '_' : '~';
      if (c.starts.length === 1) return c.starts[0];
      return `[${c.starts.join(',')}]`;
    }).join(' ');
  }
  function leadCode(p: LeadPart): string | null {
    if (!isAudible(p.gain) || !p.notes || p.notes.length === 0) return null;
    let code = `note("${midiNotesPattern(p.notes, LEAD_STEPS, 5)}")`;
    code += `\n  ${soundChain(p.sound)}`;
    if (p.attack > 0) code += `\n  .attack(${p.attack.toFixed(2)})`;
    if (p.effects.delay) code += `\n  .delay(0.4)`;
    const echoMap: Record<EchoPreset, string> = {
      '': '', short: '.echo(3, 1/8, 0.7)', long: '.echo(5, 1/4, 0.6)', tape: '.echo(4, 3/16, 0.75)',
    };
    if (p.effects.echo && echoMap[p.effects.echo]) code += `\n  ${echoMap[p.effects.echo]}`;
    if (p.effects.room) code += `\n  .room(0.6)`;
    if (p.effects.jux) code += `\n  .jux(rev)`;
    if (p.effects.ghost) code += `\n  .off(1/8, x => x.fast(2).gain(0.5))`;
    if (p.effects.shape) code += `\n  .shape(0.4)`;
    code = applyFx(code, p.fx);
    code += `\n  .gain(${curvedGain(p.gain)})`;
    return code;
  }
  function sampleCode(p: SamplePart): string | null {
    if (!isAudible(p.gain) || !p.url || !p.name) return null;
    return `s("${p.name}").loopAt(4).gain(${curvedGain(p.gain)})`;
  }

  function genForPart(p: Part): string | null {
    switch (p.type) {
      case 'drums':  return drumCode(p);
      case 'chords': return chordCode(p);
      case 'bass':   return bassCode(p);
      case 'arp':    return arpCode(p);
      case 'lead':   return leadCode(p);
      case 'sample': return sampleCode(p);
    }
  }

  function buildCode(): string {
    const anySolo = state.parts.some((p) => p.soloed);
    const active = state.parts.filter((p) => anySolo ? p.soloed : p.enabled);

    const cps = (state.bpm / 60 / 4).toFixed(3);
    let header = `// ${state.key.toUpperCase()} ${state.scale}  •  ${state.bpm} bpm\nsetcps(${cps})`;
    // samples({}) prelude for any sample parts with loaded blob URLs
    const sampleDefs = active
      .filter((p): p is SamplePart => p.type === 'sample' && !!p.url && !!p.name)
      .map((p) => `  ${p.name}: '${p.url}'`);
    if (sampleDefs.length > 0) {
      header = `// dropped samples\nsamples({\n${sampleDefs.join(',\n')},\n})\n\n${header}`;
    }
    const tail: string[] = [];
    if (state.swing > 0) tail.push(`.swingBy(${state.swing.toFixed(2)}, 4)`);
    tail.push(`.gain(${curvedGain(state.master)})`);
    const tailStr = tail.map((t) => `  ${t}`).join('\n');

    const blocks = active.map((p) => {
      const c = genForPart(p);
      return c ? { code: c, name: `${p.type} (${p.id})` } : null;
    }).filter((x): x is { code: string; name: string } => !!x);
    if (blocks.length === 0) return `${header}\nsilence`;
    if (blocks.length === 1) return `${header}\n// ${blocks[0].name}\n${blocks[0].code}\n${tailStr}`;
    const indented = blocks.map((b) => indent(`// ${b.name}\n${b.code}`));
    return `${header}\nstack(\n${indented.join(',\n\n')}\n)\n${tailStr}`;
  }

  // =========================================================================
  // Editor wiring + manual-mode tracking via real input events.
  // =========================================================================
  let editorRef: any = null;
  let editorReady: Promise<any> | null = null;
  let isRunning = false;
  let liveTimer: number | null = null;
  let userTouchedEditor = false;
  let manualMode = false;

  const hostEl = document.getElementById('strudel-host');
  const statusEl = document.getElementById('strudel-status');
  const runBtn = document.getElementById('strudel-run') as HTMLButtonElement | null;
  const stopBtn = document.getElementById('strudel-stop') as HTMLButtonElement | null;
  const regenBtn = document.getElementById('strudel-regen') as HTMLButtonElement | null;

  function setStatus(text: string) { if (statusEl) statusEl.textContent = text; }
  function setManual(v: boolean) {
    if (manualMode === v) return;
    manualMode = v;
    hostEl?.classList.toggle('is-manual', v);
    if (regenBtn) regenBtn.hidden = !v;
    if (v) setStatus('manual edits — gui paused');
  }

  function ensureEditor(): Promise<any> {
    if (editorReady) return editorReady;
    setStatus('loading…');
    editorReady = new Promise<any>((resolve, reject) => {
      const existing = document.querySelector<HTMLScriptElement>('script[data-strudel-repl]');
      const onLoaded = () => {
        const el = document.createElement('strudel-editor');
        el.setAttribute('code', buildCode());
        hostEl?.appendChild(el);
        const tryAttach = (tries = 0) => {
          if ((el as any).editor) {
            editorRef = (el as any).editor;
            // Subscribe to scheduler-state updates dispatched by the
            // strudel-editor component, to track play/pause.
            (el as any).addEventListener('update', (evt: CustomEvent) => {
              const started = !!evt.detail?.started;
              if (started !== isRunning) {
                isRunning = started;
                runBtn?.setAttribute('data-state', started ? 'running' : 'idle');
                hostEl?.classList.toggle('is-running', started);
              }
            });
            // Manual-mode detection — listen for actual input events on
            // CodeMirror's content. Bubbles up to hostEl.
            const onInput = () => {
              if (!userTouchedEditor) {
                userTouchedEditor = true;
                setManual(true);
              }
            };
            hostEl?.addEventListener('input', onInput);
            setStatus('ready');
            resolve(editorRef);
          } else if (tries < 50) {
            setTimeout(() => tryAttach(tries + 1), 80);
          } else {
            reject(new Error('editor did not initialize'));
          }
        };
        tryAttach();
      };
      if (existing) {
        if ((existing as any).dataset.loaded === 'true') onLoaded();
        else {
          existing.addEventListener('load', onLoaded, { once: true });
          existing.addEventListener('error', () => reject(new Error('repl load error')), { once: true });
        }
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/@strudel/repl@1.3.0/dist/index.js';
      script.async = true;
      script.dataset.strudelRepl = 'true';
      script.onload = () => { (script as any).dataset.loaded = 'true'; onLoaded(); };
      script.onerror = () => reject(new Error('repl load error'));
      document.head.appendChild(script);
    });
    return editorReady;
  }

  async function pushCode() {
    saveState();
    try { await ensureEditor(); } catch (e) { setStatus('editor unavailable'); return; }
    if (!editorRef) return;
    if (userTouchedEditor) {
      setManual(true);
      return;
    }
    const code = buildCode();
    editorRef.setCode(code);
    if (isRunning) {
      try { await editorRef.evaluate(); } catch (e) { setStatus('eval error'); }
    }
  }
  function scheduleLiveApply() {
    if (liveTimer !== null) window.clearTimeout(liveTimer);
    liveTimer = window.setTimeout(pushCode, 100);
  }
  async function run() {
    await ensureEditor();
    if (!editorRef) return;
    if (!userTouchedEditor) {
      editorRef.setCode(buildCode());
    }
    try {
      await editorRef.evaluate();
      isRunning = true;
      runBtn?.setAttribute('data-state', 'running');
      hostEl?.classList.add('is-running');
      setStatus(manualMode ? 'running (manual)' : 'running');
    } catch (e) {
      setStatus(e instanceof Error ? e.message : 'eval error');
    }
  }
  async function stop() {
    if (!editorRef) return;
    try {
      await editorRef.stop();
      isRunning = false;
      runBtn?.setAttribute('data-state', 'idle');
      hostEl?.classList.remove('is-running');
      setStatus('stopped');
    } catch (e) {}
  }
  function regenFromGui() {
    if (!editorRef) return;
    userTouchedEditor = false;
    setManual(false);
    const code = buildCode();
    editorRef.setCode(code);
    setStatus('regenerated');
    if (isRunning) editorRef.evaluate().catch(() => setStatus('eval error'));
  }

  runBtn?.addEventListener('click', () => (isRunning ? stop() : run()));
  stopBtn?.addEventListener('click', stop);
  regenBtn?.addEventListener('click', regenFromGui);

  // =========================================================================
  // Click-to-enter for slider outputs.
  // =========================================================================
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target || target.tagName !== 'OUTPUT') return;
    if (target.dataset.editing === 'true') return;
    const label = target.closest('label');
    const slider = label?.querySelector<HTMLInputElement>('input[type="range"]');
    if (!slider) return;
    target.dataset.editing = 'true';
    const original = target.textContent ?? '';
    const input = document.createElement('input');
    input.type = 'text';
    input.inputMode = 'decimal';
    input.value = String(slider.value);
    input.className = 'strudel-output-input';
    const min = parseFloat(slider.min || '0');
    const max = parseFloat(slider.max || '1');
    const cleanup = () => { target.dataset.editing = 'false'; };
    const commit = () => {
      const v = parseFloat(input.value);
      if (!Number.isNaN(v)) {
        const clamped = Math.max(min, Math.min(max, v));
        slider.value = String(clamped);
        slider.dispatchEvent(new Event('input', { bubbles: true }));
      } else {
        target.textContent = original;
      }
      cleanup();
    };
    const cancel = () => { target.textContent = original; cleanup(); };
    input.addEventListener('blur', commit);
    input.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter') { ev.preventDefault(); input.blur(); }
      else if (ev.key === 'Escape') {
        ev.preventDefault();
        input.removeEventListener('blur', commit);
        cancel();
        input.blur();
      }
    });
    target.replaceChildren(input);
    input.focus();
    input.select();
  });

  // =========================================================================
  // Keyboard shortcuts: space (play/pause), ⌘/Ctrl-Enter (re-eval), esc (stop).
  // =========================================================================
  window.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    const inField = target && (target.tagName === 'INPUT' || target.tagName === 'SELECT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
    if (e.key === ' ' && !inField) {
      e.preventDefault();
      isRunning ? stop() : run();
    } else if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      e.preventDefault();
      run();
    } else if (e.key === 'Escape') {
      stop();
    }
  });

  // =========================================================================
  // DOM helpers.
  // =========================================================================
  function el<K extends keyof HTMLElementTagNameMap>(tag: K, attrs: Record<string, any> = {}, ...children: (Node | string)[]) {
    const node = document.createElement(tag);
    for (const [k, v] of Object.entries(attrs)) {
      if (k === 'class') node.className = v;
      else if (k === 'dataset') Object.assign(node.dataset, v);
      else if (k.startsWith('on') && typeof v === 'function') node.addEventListener(k.slice(2), v);
      else if (k === 'checked' || k === 'disabled' || k === 'selected' || k === 'hidden') (node as any)[k] = v;
      else node.setAttribute(k, String(v));
    }
    for (const c of children) node.append(c);
    return node;
  }

  // Build the melody/bass select markup. Mirrors the Astro frontmatter.
  const MELODY_PALETTE: { label: string; items: [string, string][] }[] = [
