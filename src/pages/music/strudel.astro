---
import Base from '../../layouts/Base.astro';

const defaultPattern = '';
---
<Base title="Strudel — A. M. Berns" description="A small Strudel live-coding workspace.">
  <div class="strudel-shell">
    <main class="strudel-workspace" aria-label="Strudel workspace">
      <section class="strudel-editor-pane">
        <div class="strudel-pane-head">
          <h2>Pattern</h2>
          <div class="strudel-actions">
            <button id="strudel-run" type="button">Run</button>
            <button id="strudel-stop" type="button">Stop</button>
          </div>
        </div>
        <div id="strudel-editor" class="strudel-code-wrap">
          <pre id="strudel-highlight" aria-hidden="true"></pre>
          <textarea id="strudel-code" spellcheck="false" autocomplete="off">{defaultPattern}</textarea>
        </div>
      </section>

      <aside class="strudel-side-pane">
        <section>
          <h2>Drums</h2>
          <div id="strudel-drum-grid" class="strudel-step-grid" aria-label="Drum step grid"></div>
          <div class="strudel-preset-list">
            <button id="strudel-drum-apply" type="button">Add Drums</button>
            <button id="strudel-drum-clear" type="button">Clear</button>
          </div>
        </section>

        <section>
          <h2>Arp</h2>
          <div id="strudel-arp-grid" class="strudel-arp-grid" aria-label="Arpeggio step grid"></div>
          <div class="strudel-preset-list">
            <button id="strudel-arp-apply" type="button">Add Arp</button>
            <button id="strudel-arp-clear" type="button">Clear</button>
          </div>
        </section>

        <section>
          <h2>Chords</h2>
          <div id="strudel-chord-grid" class="strudel-chord-grid" aria-label="Chord progression builder"></div>
          <div class="strudel-preset-list">
            <button id="strudel-chord-apply" type="button">Add Chords</button>
          </div>
        </section>

        <section>
          <h2>Lead</h2>
          <label class="strudel-field" for="strudel-lead-sound">
            <span>sound</span>
            <select id="strudel-lead-sound">
              <option value="square">square</option>
              <option value="sawtooth">saw</option>
              <option value="triangle">triangle</option>
              <option value="sine">sine</option>
            </select>
            <output></output>
          </label>
          <label id="strudel-drop" class="strudel-drop" for="strudel-sample-file">
            <input id="strudel-sample-file" type="file" accept="audio/*" />
            <span id="strudel-drop-label">Drop audio or choose file</span>
          </label>
          <div class="strudel-preset-list">
            <button id="strudel-lead-apply" type="button">Add Lead</button>
            <button type="button" data-lead-effect=".delay(0.25)">delay</button>
            <button type="button" data-lead-effect=".jux(rev)">jux</button>
          </div>
        </section>

        <section>
          <h2>Bass</h2>
          <div class="strudel-preset-list">
            <button id="strudel-bass-apply" type="button">Add Bass</button>
            <button type="button" data-bass-pattern="steady">steady</button>
            <button type="button" data-bass-pattern="syncopated">sync</button>
            <button type="button" data-bass-pattern="octaves">octaves</button>
          </div>
        </section>
      </aside>
    </main>

    <div class="anim-controls">
      <button id="strudel-info" type="button" aria-label="About this Strudel page">About</button>
      <button id="strudel-reset" type="button" aria-label="Reset Strudel editor">Reset</button>
    </div>

    <dialog id="strudel-about" class="anim-about" aria-labelledby="strudel-about-title">
      <h2 id="strudel-about-title">About</h2>
      <p>
        This page loads the unmodified <a href="https://www.npmjs.com/package/@strudel/web">@strudel/web</a>
        browser package, part of <a href="https://codeberg.org/uzu/strudel">Strudel</a>,
        licensed under <a href="https://codeberg.org/uzu/strudel/src/branch/main/LICENSE">AGPL-3.0-or-later</a>.
        Strudel is provided without warranty. Site source is available at
        <a href="https://github.com/A-M-Berns/personal-site">GitHub</a>.
      </p>
    </dialog>
  </div>
</Base>

<style>
  .strudel-shell {
    position: relative;
    height: calc(100vh - 11.25rem);
    overflow: hidden;
    --strudel-panel-height: 100%;
  }
  .strudel-workspace {
    display: grid;
    grid-template-columns: minmax(38rem, 1.9fr) minmax(17rem, 22rem);
    gap: 1.25rem;
    align-items: stretch;
    max-width: 112rem;
    height: 100%;
  }
  .strudel-editor-pane,
  .strudel-side-pane {
    background: #000;
    padding: 0.95rem;
  }
  .strudel-editor-pane {
    display: flex;
    flex-direction: column;
    min-height: var(--strudel-panel-height);
  }
  .strudel-pane-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .strudel-pane-head h2,
  .strudel-side-pane h2 {
    font-family: var(--display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .strudel-actions,
  .strudel-preset-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .strudel-actions button,
  .strudel-preset-list button,
  .strudel-step-grid button,
  .strudel-arp-grid button,
  #strudel-chord-apply {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.35rem 0.6rem;
  }
  .strudel-actions button:hover,
  .strudel-actions button:focus-visible,
  .strudel-preset-list button:hover,
  .strudel-preset-list button:focus-visible,
  .strudel-step-grid button:hover,
  .strudel-step-grid button:focus-visible,
  .strudel-arp-grid button:hover,
  .strudel-arp-grid button:focus-visible,
  #strudel-chord-apply:hover,
  #strudel-chord-apply:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    outline: none;
  }
  .strudel-step-grid {
    display: grid;
    grid-template-columns: 2.25rem repeat(16, minmax(0, 1fr));
    gap: 0.22rem;
    margin: 0.85rem 0;
  }
  .strudel-step-label,
  .strudel-arp-label {
    display: grid;
    place-items: center;
    min-height: 1.35rem;
    color: var(--muted);
    font: 0.62rem/1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
  }
  .strudel-step-grid :global(button) {
    min-width: 0;
    min-height: 1.35rem;
    padding: 0;
    border-color: color-mix(in srgb, var(--rule) 72%, transparent);
    color: transparent;
    touch-action: none;
    user-select: none;
  }
  .strudel-step-grid :global(button.is-on),
  .strudel-arp-grid :global(button.is-on) {
    color: #000;
    background: var(--accent);
    border-color: var(--accent);
  }
  .strudel-step-grid :global(button:nth-child(17n + 2)),
  .strudel-step-grid :global(button:nth-child(17n + 6)),
  .strudel-step-grid :global(button:nth-child(17n + 10)),
  .strudel-step-grid :global(button:nth-child(17n + 14)) {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--rule));
  }
  .strudel-step-grid :global(button.is-on)::after {
    content: "";
    display: block;
    width: 0.45rem;
    height: 0.45rem;
    margin: auto;
    border-radius: 999px;
    background: #000;
  }
  .strudel-arp-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 0.3rem;
    margin: 0.85rem 0;
  }
  .strudel-arp-cell {
    display: grid;
    gap: 0.2rem;
  }
  .strudel-arp-grid :global(button) {
    min-width: 0;
    min-height: 1.55rem;
    padding: 0.2rem 0;
    font-size: 0.62rem;
  }
  .strudel-chord-grid {
    display: grid;
    gap: 0.35rem;
    margin: 0.85rem 0;
  }
  .strudel-chord-row {
    display: grid;
    grid-template-columns: 1.4rem minmax(0, 1fr) minmax(0, 1.25fr);
    gap: 0.35rem;
    align-items: center;
  }
  .strudel-chord-row span {
    color: var(--muted);
    font: 0.66rem/1 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-align: center;
  }
  .strudel-chord-row select {
    min-width: 0;
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.25rem 0.35rem;
    font-size: 0.7rem;
  }
  .strudel-code-wrap {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.035);
    overflow: hidden;
    transition: border-color 140ms ease, box-shadow 180ms ease;
  }
  .strudel-code-wrap.is-running {
    border-color: var(--accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .strudel-code-wrap.is-running::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    border-radius: 2px;
    border-left: 2px solid var(--accent);
    opacity: 0.7;
    animation: strudel-edge-pulse 1.8s ease-in-out infinite;
  }
  @keyframes strudel-edge-pulse {
    0%, 100% { opacity: 0.32; }
    50% { opacity: 0.82; }
  }
  #strudel-code,
  #strudel-highlight {
    box-sizing: border-box;
    min-height: 100%;
    height: 100%;
    margin: 0;
    padding: 0.85rem;
    font: 0.94rem/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    tab-size: 2;
  }
  #strudel-highlight {
    position: absolute;
    inset: 0;
    z-index: 2;
    overflow: auto;
    pointer-events: none;
    color: var(--ink);
  }
  #strudel-highlight :global(.tok-fn) { color: var(--accent); }
  #strudel-highlight :global(.tok-string) { color: color-mix(in srgb, var(--accent) 72%, #fff); }
  #strudel-highlight :global(.tok-number) { color: #d6ff5a; }
  #strudel-highlight :global(.tok-method) { color: #4ad6ff; }
  #strudel-highlight :global(.tok-symbol) { color: var(--muted); }
  #strudel-highlight :global(.tok-comment) { color: color-mix(in srgb, var(--muted) 78%, transparent); }
  #strudel-highlight :global(.code-line) {
    display: block;
    min-height: 1.55em;
    margin-inline: -0.25rem;
    padding-inline: 0.25rem;
    border-radius: 2px;
  }
  #strudel-highlight :global(.tok-play) {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 28%, transparent);
    border-radius: 2px;
  }
  #strudel-code {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    resize: none;
    border: 0;
    background: transparent;
    color: transparent;
    caret-color: var(--ink);
    -webkit-text-fill-color: transparent;
  }
  #strudel-code:focus {
    outline: none;
  }
  .strudel-side-pane {
    display: grid;
    gap: 1.25rem;
    height: var(--strudel-panel-height);
    overflow-y: auto;
    padding-right: 0.25rem;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }
  .strudel-side-pane section {
    padding: 0;
  }
  .strudel-field {
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr) 3.2rem;
    gap: 0.55rem;
    align-items: center;
    margin: 0.8rem 0;
    color: var(--muted);
    font-size: 0.78rem;
  }
  .strudel-field input {
    width: 100%;
    margin: 0;
    accent-color: var(--accent);
  }
  .strudel-field input[type="text"] {
    min-width: 0;
    box-sizing: border-box;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.28rem 0.35rem;
    font: 0.76rem/1.35 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  .strudel-field input[type="text"]:focus {
    border-color: var(--accent);
    outline: none;
  }
  .strudel-field--wide {
    grid-template-columns: 3.25rem minmax(0, 1fr);
  }
  .strudel-field select {
    width: 100%;
    min-width: 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink);
    padding: 0.25rem 0.35rem;
  }
  .strudel-field output {
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .strudel-drop {
    display: grid;
    place-items: center;
    min-height: 4.25rem;
    margin: 0.75rem 0;
    border: 1px dashed var(--rule);
    border-radius: 3px;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.78rem;
    text-align: center;
  }
  .strudel-drop.is-dragging,
  .strudel-drop:hover,
  .strudel-drop:focus-within {
    color: var(--accent);
    border-color: var(--accent);
  }
  .strudel-drop input {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .strudel-legal a {
    text-decoration: underline;
    text-decoration-color: var(--muted);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  @media (max-width: 880px) {
    .strudel-shell {
      height: auto;
      overflow: visible;
    }
    .strudel-workspace {
      grid-template-columns: 1fr;
      height: auto;
    }
    .strudel-side-pane {
      height: auto;
      overflow: visible;
      padding-right: 0;
    }
  }
</style>

<script>
  const codeEl = document.getElementById('strudel-code') as HTMLTextAreaElement | null;
  const editorEl = document.getElementById('strudel-editor') as HTMLElement | null;
  const highlightEl = document.getElementById('strudel-highlight');
  const runButton = document.getElementById('strudel-run') as HTMLButtonElement | null;
  const stopButton = document.getElementById('strudel-stop') as HTMLButtonElement | null;
  const infoButton = document.getElementById('strudel-info') as HTMLButtonElement | null;
  const resetButton = document.getElementById('strudel-reset') as HTMLButtonElement | null;
  const aboutDialog = document.getElementById('strudel-about') as HTMLDialogElement | null;
  const leadSound = document.getElementById('strudel-lead-sound') as HTMLSelectElement | null;
  const chordGrid = document.getElementById('strudel-chord-grid');
  const chordApply = document.getElementById('strudel-chord-apply') as HTMLButtonElement | null;
  const sampleFileInput = document.getElementById('strudel-sample-file') as HTMLInputElement | null;
  const sampleDrop = document.getElementById('strudel-drop') as HTMLElement | null;
  const sampleDropLabel = document.getElementById('strudel-drop-label');
  const drumGrid = document.getElementById('strudel-drum-grid');
  const arpGrid = document.getElementById('strudel-arp-grid');
  const drumApply = document.getElementById('strudel-drum-apply') as HTMLButtonElement | null;
  const drumClear = document.getElementById('strudel-drum-clear') as HTMLButtonElement | null;
  const arpApply = document.getElementById('strudel-arp-apply') as HTMLButtonElement | null;
  const arpClear = document.getElementById('strudel-arp-clear') as HTMLButtonElement | null;
  const leadApply = document.getElementById('strudel-lead-apply') as HTMLButtonElement | null;
  const bassApply = document.getElementById('strudel-bass-apply') as HTMLButtonElement | null;
  const defaultCode = codeEl?.defaultValue ?? '';

  const drumRows = [
    { label: 'bd', hits: [0, 4, 8, 12] },
    { label: 'sd', hits: [4, 12] },
    { label: 'hh', hits: [2, 6, 10, 14] },
    { label: 'cp', hits: [7, 15] },
  ];
  const arpNotes = ['~', 'c3', 'eb3', 'g3', 'bb3', 'c4'];
  const arpDefault = ['c3', '~', 'eb3', 'g3', 'bb3', 'g3', 'c4', 'eb3'];
  const chordRoots = ['c', 'd', 'eb', 'f', 'g', 'ab', 'bb'];
  const chordQualities = ['minor', 'major', 'sus', 'wide'];
  const chordDefault = [
    { root: 'c', quality: 'minor' },
    { root: 'bb', quality: 'major' },
    { root: 'ab', quality: 'major' },
    { root: 'g', quality: 'minor' },
  ];
  let bassPattern = 'syncopated';
  let leadEffect = '.delay(0.25)';

  let strudelReady: Promise<void> | null = null;
  let droppedSampleUrl: string | null = null;
  let activeLineIndex = -1;
  let playIndicatorTimer: number | null = null;
  let isRunning = false;
  let liveApplyTimer: number | null = null;
  let isPaintingSteps = false;

  function setStatus(_message: string) {}

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function highlightStrudel(code: string) {
    const escaped = escapeHtml(code);
    return escaped.replace(
      /(\/\/.*$)|("(?:\\.|[^"\\])*")|(\.[a-zA-Z_]\w*)|(\b(?:note|s|n|sound|samples|stack|cat|seq|slow|fast|gain|room|delay|lpf|hpf|rev|jux|sometimes|every|off|struct|bank|sine|saw|square|tri|rand|range)\b)|(\b\d+(?:\.\d+)?\b)|([()[\]{}<>*,])/gm,
      (_match, commentToken, stringToken, methodToken, functionToken, numberToken, symbolToken) => {
        if (commentToken) return `<span class="tok-comment">${commentToken}</span>`;
        if (stringToken) return `<span class="tok-string">${stringToken}</span>`;
        if (methodToken) return `<span class="tok-method">${methodToken}</span>`;
        if (functionToken) return `<span class="tok-fn">${functionToken}</span>`;
        if (numberToken) return `<span class="tok-number">${numberToken}</span>`;
        if (symbolToken) return `<span class="tok-symbol">${symbolToken}</span>`;
        return _match;
      },
    );
  }

  function syncHighlight() {
    if (!codeEl || !highlightEl) return;
    const lines = codeEl.value.split('\n');
    highlightEl.innerHTML = lines
      .map((line, index) => {
        const highlighted = highlightStrudel(line);
        const activeLine = index === activeLineIndex && line.trim().length > 0;
        return `<span class="code-line">${activeLine ? markActiveToken(highlighted) : highlighted || ' '}</span>`;
      })
      .join('');
    highlightEl.scrollTop = codeEl.scrollTop;
    highlightEl.scrollLeft = codeEl.scrollLeft;
  }

  function markActiveToken(html: string) {
    if (!html.trim()) return html;
    const tokenPattern = /(<span class="tok-(?:fn|method|string|number)">.*?<\/span>|[A-Za-z_][\w]*|"(?:\\.|[^"\\])*")/;
    return html.replace(tokenPattern, '<span class="tok-play">$1</span>');
  }

  function stopPlayIndicator() {
    if (playIndicatorTimer !== null) window.clearInterval(playIndicatorTimer);
    playIndicatorTimer = null;
    activeLineIndex = -1;
    editorEl?.classList.remove('is-running');
    syncHighlight();
  }

  function startPlayIndicator() {
    if (!codeEl) return;
    if (playIndicatorTimer !== null) window.clearInterval(playIndicatorTimer);
    editorEl?.classList.add('is-running');
    const step = () => {
      const lineCount = Math.max(1, codeEl.value.split('\n').length);
      activeLineIndex = (activeLineIndex + 1) % lineCount;
      syncHighlight();
    };
    activeLineIndex = -1;
    step();
    playIndicatorTimer = window.setInterval(step, 650);
  }

  function evaluateCurrentPattern(status = 'Updated.') {
    if (!codeEl) return;
    const evaluate = getStrudelFunction('evaluate');
    if (typeof evaluate !== 'function') return;
    const audioContext = getStrudelFunction('getAudioContext')?.();
    if (typeof audioContext?.resume === 'function') audioContext.resume();
    evaluate(codeEl.value);
    setStatus(status);
    try {
      window.localStorage.setItem('strudel-code', codeEl.value);
    } catch (e) {}
  }

  function scheduleLiveApply() {
    if (!isRunning) return;
    if (liveApplyTimer !== null) window.clearTimeout(liveApplyTimer);
    liveApplyTimer = window.setTimeout(async () => {
      await loadStrudel();
      evaluateCurrentPattern();
    }, 120);
  }

  function loadStrudel() {
    if (strudelReady) return strudelReady;
    setStatus('Loading Strudel...');
    strudelReady = new Promise((resolve, reject) => {
      const existing = document.querySelector<HTMLScriptElement>('script[data-strudel-web]');
      if (existing) {
        existing.addEventListener('load', () => resolve(), { once: true });
        existing.addEventListener('error', () => reject(new Error('Could not load Strudel.')), { once: true });
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/@strudel/web@1.3.0';
      script.async = true;
      script.dataset.strudelWeb = 'true';
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('Could not load Strudel.'));
      document.head.append(script);
    }).then(async () => {
      const initStrudel = getStrudelFunction('initStrudel');
      if (typeof initStrudel !== 'function') throw new Error('Strudel did not initialize.');
      await initStrudel();
      setStatus('Ready.');
    });
    return strudelReady;
  }

  function getStrudelFunction(name: string) {
    const win = window as any;
    return typeof win[name] === 'function'
      ? win[name]
      : typeof win.strudel?.[name] === 'function'
        ? win.strudel[name].bind(win.strudel)
        : null;
  }

  async function runPattern() {
    if (!codeEl) return;
    try {
      await loadStrudel();
      const evaluate = getStrudelFunction('evaluate');
      if (typeof evaluate !== 'function') throw new Error('Strudel evaluator is unavailable.');
      isRunning = true;
      evaluateCurrentPattern('Running.');
      startPlayIndicator();
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Could not run pattern.');
    }
  }

  async function stopPattern() {
    try {
      await loadStrudel();
      const hush = getStrudelFunction('hush');
      const evaluate = getStrudelFunction('evaluate');
      const audioContext = getStrudelFunction('getAudioContext')?.();
      if (typeof hush === 'function') hush();
      const silence = getStrudelFunction('silence');
      if (typeof silence === 'function') silence();
      if (typeof evaluate === 'function') {
        try { evaluate('silence'); } catch (e) {}
        try { evaluate('silence()'); } catch (e) {}
      }
      const scheduler = (window as any).strudelMirror?.repl?.scheduler;
      if (typeof scheduler?.stop === 'function') scheduler.stop();
      if (typeof audioContext?.suspend === 'function') audioContext.suspend();
      isRunning = false;
      stopPlayIndicator();
      setStatus('Stopped.');
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Could not stop pattern.');
    }
  }

  function appendCodeLayer(layerCode: string, sectionName = 'Part') {
    if (!codeEl) return;
    const current = codeEl.value.trimEnd();
    const next = `// ${sectionName}\n${layerCode.trim()}`
      .split('\n')
      .map((line) => `  ${line}`)
      .join('\n');
    if (!current.trim()) {
      codeEl.value = `stack(\n${next}\n)`;
    } else if (current.trimStart().startsWith('stack(')) {
      const closeIndex = current.lastIndexOf('\n)');
      codeEl.value = closeIndex >= 0
        ? `${current.slice(0, closeIndex).trimEnd()},\n\n${next}\n)`
        : `${current},\n\n${next}`;
    } else {
      codeEl.value = `stack(\n  // Starting pattern\n  ${current.trim().replace(/\n/g, '\n  ')},\n\n${next}\n)`;
    }
    syncHighlight();
    setStatus(`Appended ${sectionName.toLowerCase()}.`);
    scheduleLiveApply();
  }

  function activeStepTokens(rowLabels: string[], stepCount: number, getIsOn: (row: string, step: number) => boolean) {
    return Array.from({ length: stepCount }, (_unused, step) => {
      const hits = rowLabels.filter((row) => getIsOn(row, step));
      if (hits.length === 0) return '~';
      return hits.length === 1 ? hits[0] : `[${hits.join(' ')}]`;
    });
  }

  function drumCodeFromGrid() {
    const tokens = activeStepTokens(
      drumRows.map((row) => row.label),
      16,
      (row, step) => drumGrid?.querySelector<HTMLButtonElement>(`button[data-row="${row}"][data-step="${step}"]`)?.classList.contains('is-on') ?? false,
    );
    return `s("${tokens.join(' ')}")
  .bank("RolandTR909")
  .gain(0.65)`;
  }

  function arpCodeFromGrid() {
    const notes = Array.from({ length: 8 }, (_unused, step) => (
      arpGrid?.querySelector<HTMLButtonElement>(`button.is-on[data-step="${step}"]`)?.dataset.note || '~'
    ));
    const pattern = notes.join(' ');
    return `note("${pattern}")
  .sound("sine")
  .fast(2)
  .delay(0.2)
  .gain(0.42)`;
  }

  function chordCodeFromPanel() {
    const selected = Array.from({ length: 4 }, (_unused, index) => ({
      root: chordGrid?.querySelector<HTMLSelectElement>(`select[data-chord-root="${index}"]`)?.value ?? chordDefault[index].root,
      quality: chordGrid?.querySelector<HTMLSelectElement>(`select[data-chord-quality="${index}"]`)?.value ?? chordDefault[index].quality,
    }));
    const names = ['c', 'db', 'd', 'eb', 'e', 'f', 'gb', 'g', 'ab', 'a', 'bb', 'b'];
    const noteAt = (root: string, semitones: number, octave = 3) => {
      const rootIndex = Math.max(0, names.indexOf(root));
      const index = rootIndex + semitones;
      return `${names[((index % 12) + 12) % 12]}${octave + Math.floor(index / 12)}`;
    };
    const intervals: Record<string, number[]> = {
      minor: [0, 3, 7],
      major: [0, 4, 7],
      sus: [0, 5, 7],
      wide: [0, 7, 15],
    };
    const progression = selected.map(({ root, quality }) => {
      const octave = quality === 'wide' ? 2 : 3;
      return `<${(intervals[quality] ?? intervals.minor).map((interval) => noteAt(root, interval, octave)).join(' ')}>`;
    }).join(' ');
    return `note("${progression}")
  .sound("triangle")
  .slow(2)
  .room(0.55)
  .gain(0.38)`;
  }

  function leadCode() {
    const sound = leadSound?.value ?? 'square';
    return `note("c4 eb4 g4 <bb4 c5>")
  .sound("${sound}")
  .fast(2)
  ${leadEffect}
  .gain(0.42)`;
  }

  function bassCode() {
    const patterns: Record<string, string> = {
      steady: 'c1 c1 bb0 ab0',
      syncopated: 'c1 [~ eb1] <bb0 bb1> [f1 ab1]',
      octaves: '<c1 c2> [~ eb1] <bb0 bb1> [ab0 ab1]',
    };
    return `note("${patterns[bassPattern] ?? patterns.syncopated}")
  .sound("sawtooth")
  .struct("x [~ x] x [x ~]")
  .lpf(800)
  .gain(0.56)`;
  }

  function setStepState(button: HTMLButtonElement, force?: boolean) {
    const next = force ?? !button.classList.contains('is-on');
    button.classList.toggle('is-on', next);
    button.setAttribute('aria-pressed', String(next));
  }

  function renderDrumGrid() {
    if (!drumGrid) return;
    drumGrid.innerHTML = '';
    drumRows.forEach((row) => {
      const label = document.createElement('span');
      label.className = 'strudel-step-label';
      label.textContent = row.label;
      drumGrid.append(label);
      Array.from({ length: 16 }, (_unused, step) => {
        const button = document.createElement('button');
        const isOn = row.hits.includes(step);
        button.type = 'button';
        button.dataset.row = row.label;
        button.dataset.step = String(step);
        button.classList.toggle('is-on', isOn);
        button.setAttribute('aria-label', `${row.label} step ${step + 1}`);
        button.setAttribute('aria-pressed', String(isOn));
        button.addEventListener('pointerdown', (event) => {
          event.preventDefault();
          isPaintingSteps = true;
          setStepState(button);
        });
        button.addEventListener('click', (event) => {
          if (event.detail !== 0) return;
          setStepState(button);
        });
        button.addEventListener('pointerenter', () => {
          if (isPaintingSteps) setStepState(button, true);
        });
        drumGrid.append(button);
      });
    });
  }

  function renderArpGrid() {
    if (!arpGrid) return;
    arpGrid.innerHTML = '';
    arpDefault.forEach((activeNote, step) => {
      const cell = document.createElement('div');
      cell.className = 'strudel-arp-cell';
      const label = document.createElement('span');
      label.className = 'strudel-arp-label';
      label.textContent = String(step + 1);
      cell.append(label);
      arpNotes.forEach((note) => {
        const button = document.createElement('button');
        const isOn = note === activeNote;
        button.type = 'button';
        button.textContent = note;
        button.dataset.note = note;
        button.dataset.step = String(step);
        button.classList.toggle('is-on', isOn);
        button.setAttribute('aria-pressed', String(isOn));
        button.addEventListener('click', () => {
          cell.querySelectorAll<HTMLButtonElement>('button').forEach((other) => setStepState(other, false));
          setStepState(button, true);
        });
        cell.append(button);
      });
      arpGrid.append(cell);
    });
  }

  function renderChordGrid() {
    if (!chordGrid) return;
    chordGrid.innerHTML = '';
    chordDefault.forEach((chord, index) => {
      const row = document.createElement('div');
      row.className = 'strudel-chord-row';
      const label = document.createElement('span');
      label.textContent = String(index + 1);
      const rootSelect = document.createElement('select');
      rootSelect.dataset.chordRoot = String(index);
      chordRoots.forEach((root) => {
        const option = document.createElement('option');
        option.value = root;
        option.textContent = root.toUpperCase();
        option.selected = root === chord.root;
        rootSelect.append(option);
      });
      const qualitySelect = document.createElement('select');
      qualitySelect.dataset.chordQuality = String(index);
      chordQualities.forEach((quality) => {
        const option = document.createElement('option');
        option.value = quality;
        option.textContent = quality;
        option.selected = quality === chord.quality;
        qualitySelect.append(option);
      });
      row.append(label, rootSelect, qualitySelect);
      chordGrid.append(row);
    });
  }

  function resetEditor() {
    if (codeEl) codeEl.value = defaultCode;
    if (leadSound) leadSound.value = 'square';
    if (sampleFileInput) sampleFileInput.value = '';
    if (sampleDropLabel) sampleDropLabel.textContent = 'Drop audio or choose file';
    if (droppedSampleUrl) URL.revokeObjectURL(droppedSampleUrl);
    droppedSampleUrl = null;
    isRunning = false;
    stopPlayIndicator();
    renderDrumGrid();
    renderArpGrid();
    renderChordGrid();
    syncHighlight();
    try {
      window.localStorage.removeItem('strudel-code');
    } catch (e) {}
    setStatus('Reset.');
  }

  function sampleNameFromFile(file: File) {
    const base = file.name.replace(/\.[^.]+$/, '').toLowerCase().replace(/[^a-z0-9]+/g, '').slice(0, 18);
    return base || 'drop';
  }

  function loadDroppedSample(file: File) {
    if (!codeEl || !file.type.startsWith('audio/')) {
      setStatus('Choose an audio file.');
      return;
    }
    if (droppedSampleUrl) URL.revokeObjectURL(droppedSampleUrl);
    droppedSampleUrl = URL.createObjectURL(file);
    const sampleName = sampleNameFromFile(file);
    codeEl.value = `samples({
  ${sampleName}: '${droppedSampleUrl}',
})

// Dropped sample
s("${sampleName}")
  .loopAt(4)
  .slice(8, "0 1 2 3 4 5 6 7")
  .gain(0.55)`;
    if (sampleDropLabel) sampleDropLabel.textContent = file.name;
    syncHighlight();
    setStatus(`Loaded local sample: ${file.name}`);
  }

  try {
    const saved = window.localStorage.getItem('strudel-code');
    if (saved && codeEl) codeEl.value = saved;
  } catch (e) {}

  renderDrumGrid();
  renderArpGrid();
  renderChordGrid();
  syncHighlight();
  codeEl?.addEventListener('input', syncHighlight);
  codeEl?.addEventListener('scroll', syncHighlight);
  window.addEventListener('pointerup', () => {
    isPaintingSteps = false;
  });
  drumApply?.addEventListener('click', () => appendCodeLayer(drumCodeFromGrid(), 'Drums'));
  drumClear?.addEventListener('click', () => {
    drumGrid?.querySelectorAll<HTMLButtonElement>('button').forEach((button) => setStepState(button, false));
    setStatus('Cleared drum grid.');
  });
  arpApply?.addEventListener('click', () => appendCodeLayer(arpCodeFromGrid(), 'Arp'));
  arpClear?.addEventListener('click', () => {
    arpGrid?.querySelectorAll<HTMLButtonElement>('button').forEach((button) => setStepState(button, false));
    setStatus('Cleared arp grid.');
  });
  chordApply?.addEventListener('click', () => appendCodeLayer(chordCodeFromPanel(), 'Chords'));
  leadApply?.addEventListener('click', () => appendCodeLayer(leadCode(), 'Lead'));
  bassApply?.addEventListener('click', () => appendCodeLayer(bassCode(), 'Bass'));
  resetButton?.addEventListener('click', resetEditor);
  infoButton?.addEventListener('click', () => aboutDialog?.showModal());
  aboutDialog?.addEventListener('click', (event) => {
    if (event.target === aboutDialog) aboutDialog.close();
  });
  runButton?.addEventListener('click', runPattern);
  stopButton?.addEventListener('click', stopPattern);
  document.querySelectorAll<HTMLButtonElement>('[data-lead-effect]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!button.dataset.leadEffect) return;
      leadEffect = button.dataset.leadEffect;
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-bass-pattern]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!button.dataset.bassPattern) return;
      bassPattern = button.dataset.bassPattern;
    });
  });
  sampleFileInput?.addEventListener('change', () => {
    const file = sampleFileInput.files?.[0];
    if (file) loadDroppedSample(file);
  });
  sampleDrop?.addEventListener('dragenter', (event) => {
    event.preventDefault();
    sampleDrop.classList.add('is-dragging');
  });
  sampleDrop?.addEventListener('dragover', (event) => {
    event.preventDefault();
  });
  sampleDrop?.addEventListener('dragleave', (event) => {
    if (!sampleDrop.contains(event.relatedTarget as Node | null)) sampleDrop.classList.remove('is-dragging');
  });
  sampleDrop?.addEventListener('drop', (event) => {
    event.preventDefault();
    sampleDrop.classList.remove('is-dragging');
    const file = event.dataTransfer?.files?.[0];
    if (file) loadDroppedSample(file);
  });
</script>
