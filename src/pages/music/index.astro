---
import Base from '../../layouts/Base.astro';
---
<Base title="Music — A. M. Berns" description="Music by Anson Berns.">
  <div class="other-shell">
    <canvas id="lenia-sim" class="lenia-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Music</span></h1>
    </header>
    <p class="music-intro"><span class="hl">I make sample-based experimental music. More to come.</span></p>
    <div class="music-panes">
      <section class="writing-pane">
        <h2>Streaming</h2>
        <p><a href="https://open.spotify.com/artist/3dS0px84EtOAKKdgoaNd2c">Anson Berns on Spotify</a></p>
      </section>
      <section class="writing-pane">
        <h2>Other Projects</h2>
        <div class="audio-player" data-src="/music/gbr-project.wav">
          <button class="audio-play" type="button" aria-label="Play">
            <svg viewBox="0 0 12 12" aria-hidden="true" focusable="false">
              <polygon class="audio-icon-play" points="3,2 10,6 3,10"></polygon>
              <g class="audio-icon-pause">
                <rect x="3" y="2" width="2" height="8"></rect>
                <rect x="7" y="2" width="2" height="8"></rect>
              </g>
            </svg>
          </button>
          <div class="audio-track" tabindex="0" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
            <div class="audio-progress"></div>
          </div>
          <span class="audio-time">0:00 / —:—</span>
        </div>
      </section>
      <section class="writing-pane">
        <h2>Strudel</h2>
        <p><a href="/music/strudel">Open the Strudel workspace</a></p>
      </section>
    </div>

    <div class="anim-controls">
      <button id="lenia-info" type="button" aria-label="About">About</button>
      <button id="lenia-restart" type="button" aria-label="Reset Particle Lenia">Reset</button>
    </div>
    <dialog id="lenia-about" class="anim-about" aria-labelledby="lenia-about-title">
      <h2 id="lenia-about-title">About</h2>
      <p>
        This animation is an implementation of <a href="https://google-research.github.io/self-organising-systems/particle-lenia/">Particle Lenia</a>, a system of differential equations that gives rise to lifelike behavior. Each cycle randomly tunes a few parameters of the equations and initializes based on a random template and seed. A flow is also applied according to a randomly generated vector field. The resulting blobs often look like alien cells, brain tissue, or weather radar. Click to perturb the field and push the blobs around.
      </p>
    </dialog>
    <aside id="tune-panel" class="tune-panel" aria-label="Particle Lenia parameters">
      <h3>Tune</h3>
      <p class="tune-seeder">seeder: <span id="seeder-label">—</span></p>
      <div class="tune-row">
        <label for="s-t">t</label>
        <input type="range" id="s-t" min="0" max="1" step="0.005" />
        <span class="val" id="v-t"></span>
      </div>
      <div class="tune-row tune-row--readonly">
        <label for="s-muK">μK</label>
        <input type="range" id="s-muK" min="3.0" max="5.0" step="0.01" disabled />
        <span class="val" id="v-muK"></span>
      </div>
      <div class="tune-row tune-row--readonly">
        <label for="s-sigmaK">σK</label>
        <input type="range" id="s-sigmaK" min="0.5" max="1.3" step="0.01" disabled />
        <span class="val" id="v-sigmaK"></span>
      </div>
      <div class="tune-row">
        <label for="s-wK">wK</label>
        <input type="range" id="s-wK" min="0.035" max="0.060" step="0.0005" />
        <span class="val" id="v-wK"></span>
      </div>
      <div class="tune-row">
        <label for="s-muG">μG</label>
        <input type="range" id="s-muG" min="0.20" max="1.60" step="0.005" />
        <span class="val" id="v-muG"></span>
      </div>
      <div class="tune-row">
        <label for="s-cRep">cRep</label>
        <input type="range" id="s-cRep" min="0.2" max="3.0" step="0.02" />
        <span class="val" id="v-cRep"></span>
      </div>
      <div class="tune-row">
        <label for="s-noise">noise</label>
        <input type="range" id="s-noise" min="0" max="0.04" step="0.001" />
        <span class="val" id="v-noise"></span>
      </div>
      <div class="tune-row">
        <label for="s-flow">flow</label>
        <input type="range" id="s-flow" min="0" max="0.30" step="0.005" />
        <span class="val" id="v-flow"></span>
      </div>
      <button id="reset-btn" type="button">Reset</button>
      <p class="tune-hint">Click on the background to nudge particles.</p>
    </aside>
  </div>
</Base>

<style>
  .tune-panel {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    z-index: 3;
    width: 16.5rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .tune-panel h3 {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.4rem;
    color: var(--ink);
  }
  .tune-seeder {
    margin: 0 0 0.55rem;
    font-size: 0.7rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tune-seeder span {
    color: var(--ink);
  }
  .tune-row {
    display: grid;
    grid-template-columns: 3.5ch 1fr 4.5ch;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .tune-row label {
    font-size: 0.78rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tune-row input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    margin: 0;
  }
  .tune-row .val {
    font-size: 0.7rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .tune-row--readonly label,
  .tune-row--readonly .val {
    color: rgba(142, 142, 136, 0.6);
  }
  .tune-row--readonly input[type="range"] {
    opacity: 0.55;
    cursor: default;
  }
  .tune-panel button {
    margin-top: 0.6rem;
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.4rem 0.7rem;
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .tune-panel button:hover {
    color: var(--ink);
    border-color: var(--muted);
  }
  .tune-hint {
    margin: 0.6rem 0 0;
    font-size: 0.7rem;
    color: var(--muted);
    line-height: 1.35;
  }
  @media (max-width: 600px) {
    .tune-panel {
      bottom: 0.5rem;
      left: 0.5rem;
      right: 0.5rem;
      width: auto;
    }
  }
</style>

<script>
  // Particle Lenia (Mordvintsev, Niklasson, Randazzo, Chan).
  // Each particle is a point in 2D world space. The continuous field U(x) is
  // a sum of bell-ring kernels K(|x − p_j|) over all particles, and each
  // particle's energy is R(p_i) − G(U(p_i)) where R is short-range repulsion
  // and G is a Gaussian "growth" preference for the field strength near it.
  // Particles flow along the negative gradient of total energy, producing
  // self-propelled clusters that swim, divide, and dissolve.
  //
  // Rendered by splatting each particle's kernel onto a coarse pixel grid;
  // the chunky pixel look matches the rest of the site's animations.
  const canvas = document.getElementById('lenia-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N_LEVELS = 8;
    const CELL_PX = 3;          // display pixels per grid cell
    const CELLS_PER_UNIT = 6;   // grid cells per world unit
    const DT = 0.1;
    const N_PARTICLES = 320;
    const RESEED_AFTER = 2000;

    // Parameter ranges sampled per cycle. muK and sigmaK are correlated
    // inversely via a shared "type" parameter t ∈ [0, 1]: at t=0 the kernel
    // is large-radius / sharp-ring (big μK, small σK); at t=1 it's
    // small-radius / fat-ring (small μK, big σK), with a small jitter per
    // axis so the relation isn't perfectly tight.
    const PARAM_RANGES = {
      muK:    [3.0, 5.0],     // kernel peak (creature radius)
      sigmaK: [0.5, 1.3],     // kernel ring width
      wK:     [0.035, 0.060], // per-particle field weight
      muG:    [0.50, 1.10],   // growth target field strength
      cRep:   [0.6, 1.7],     // close-range repulsion strength
      noise:  [0.001, 0.014], // Brownian jitter strength
      flow:   [0.025, 0.16],  // ambient curl-flow strength
    } as const;
    const SIGMA_G_FIXED = 0.5;

    // muK ↔ sigmaK are now strictly coupled through a single "type" t ∈ [0,1].
    // The user-exposed `t` slider drives both inversely; the muK and sigmaK
    // sliders display the derived values but stay disabled (read-only).
    function deriveMuKFromT(t: number) {
      return mix(PARAM_RANGES.muK[1], PARAM_RANGES.muK[0], t);
    }
    function deriveSigmaKFromT(t: number) {
      return mix(PARAM_RANGES.sigmaK[0], PARAM_RANGES.sigmaK[1], t);
    }

    // Slider bounds. The displayed muK / sigmaK sliders can't be moved by
    // the user, so HASH_CELL_SIZE only needs to cover the t-curve extremes.
    const SLIDER_MAX_MU_K = PARAM_RANGES.muK[1];
    const SLIDER_MAX_SIGMA_K = PARAM_RANGES.sigmaK[1];
    const MAX_KERNEL_RANGE = SLIDER_MAX_MU_K + 3 * SLIDER_MAX_SIGMA_K;
    const HASH_CELL_SIZE = MAX_KERNEL_RANGE;

    type Params = {
      t: number;
      muK: number; sigmaK: number; wK: number;
      muG: number; sigmaG: number; cRep: number;
      noise: number; flow: number;
      kernelRange: number; kernelRangeSq: number;
      renderRangeCells: number;
      sigmaK2: number; sigmaG2: number;
    };

    function lerp(lo: number, hi: number) {
      return lo + Math.random() * (hi - lo);
    }

    function mix(a: number, b: number, t: number) {
      return a + (b - a) * t;
    }

    function clamp(v: number, lo: number, hi: number) {
      return v < lo ? lo : v > hi ? hi : v;
    }

    function recompute(p: Params) {
      p.kernelRange = p.muK + 3 * p.sigmaK;
      p.kernelRangeSq = p.kernelRange * p.kernelRange;
      p.renderRangeCells = Math.ceil(p.kernelRange * CELLS_PER_UNIT);
      p.sigmaK2 = p.sigmaK * p.sigmaK;
      p.sigmaG2 = p.sigmaG * p.sigmaG;
    }

    function pickParams(): Params {
      // t ∈ [0, 1] inversely couples muK and sigmaK:
      //   t=0 → big muK + small sigmaK (large radius, sharp ring)
      //   t=1 → small muK + big sigmaK (small radius, fat ring)
      const t = Math.random();
      const p: Params = {
        t,
        muK:    deriveMuKFromT(t),
        sigmaK: deriveSigmaKFromT(t),
        wK:     lerp(PARAM_RANGES.wK[0],     PARAM_RANGES.wK[1]),
        muG:    lerp(PARAM_RANGES.muG[0],    PARAM_RANGES.muG[1]),
        sigmaG: SIGMA_G_FIXED,
        cRep:   lerp(PARAM_RANGES.cRep[0],   PARAM_RANGES.cRep[1]),
        noise:  lerp(PARAM_RANGES.noise[0],  PARAM_RANGES.noise[1]),
        flow:   lerp(PARAM_RANGES.flow[0],   PARAM_RANGES.flow[1]),
        kernelRange: 0, kernelRangeSq: 0, renderRangeCells: 0,
        sigmaK2: 0, sigmaG2: 0,
      };
      recompute(p);
      return p;
    }

    let params: Params = pickParams();

    type FlowWave = {
      dx: number;
      dy: number;
      k: number;
      phase: number;
      speed: number;
      amp: number;
    };

    let flowWaves: FlowWave[] = [];

    function pickFlowWaves(): FlowWave[] {
      const count = 2 + ((Math.random() * 3) | 0);
      const span = Math.max(10, Math.min(W_world || 24, H_world || 24));
      const baseAngle = Math.random() * Math.PI * 2;
      const waves: FlowWave[] = [];
      for (let i = 0; i < count; i++) {
        const angle = baseAngle + (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 0.85;
        const wavelength = span * (0.45 + Math.random() * 0.75);
        waves.push({
          dx: Math.cos(angle),
          dy: Math.sin(angle),
          k: (Math.PI * 2) / wavelength,
          phase: Math.random() * Math.PI * 2,
          speed: (Math.random() < 0.5 ? -1 : 1) * (0.04 + Math.random() * 0.20),
          amp: 0.45 + Math.random() * 0.80,
        });
      }
      return waves;
    }

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]}, ${c[1]}, ${c[2]})`;
    }

    const paper = parseHex(paperHex);
    const canvasOpacity = parseFloat(getComputedStyle(canvas).opacity) || 1;

    function mixRGB(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function visibleCanvasColor(c: RGB): RGB {
      return mixRGB(paper, c, canvasOpacity);
    }

    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N_LEVELS; i++) {
        const lo = Math.floor((i * colorPool.length) / N_LEVELS);
        const hi = Math.floor(((i + 1) * colorPool.length) / N_LEVELS);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N_LEVELS; i++) {
        const t = i / (N_LEVELS - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    function wrap(d: number, size: number): number {
      if (d > size * 0.5) return d - size;
      if (d < -size * 0.5) return d + size;
      return d;
    }

    let W_grid = 0, H_grid = 0;
    let W_world = 0, H_world = 0;
    let hashW = 0, hashH = 0;

    let positions = new Float32Array(0);
    let U = new Float32Array(0);
    let Gp = new Float32Array(0);
    let F = new Float32Array(0);
    // Per-particle velocity. Adds light momentum so the integrator low-passes
    // both random noise and the gradient flow — visibly smooths the per-step
    // twitchiness without departing too far from overdamped Lenia dynamics.
    let velocities = new Float32Array(0);
    const DAMPING = 0.55;
    let field = new Float32Array(0);
    let prevField = new Float32Array(0);
    // Per-frame blend with previous frame's field. Higher value = more
    // temporal smoothing at the cost of motion blur.
    const FIELD_SMOOTH = 0.8;
    let kernelLUT = new Float32Array(0);
    let img: ImageData | null = null;
    let palette: RGB[] = buildPalette(pickStops());
    let stepCount = 0;

    // Cache the kernel splat as a 2D LUT keyed by integer cell offset. The
    // inner draw loop becomes a flat array lookup instead of an exp() call —
    // that's the dominant render cost. Rebuilt on every reseed and on
    // muK / sigmaK / wK slider changes via syncDerivedKernel().
    function buildKernelLUT() {
      const r = params.renderRangeCells;
      const sz = 2 * r + 1;
      kernelLUT = new Float32Array(sz * sz);
      const wK = params.wK;
      const muK = params.muK;
      const sigmaK2 = params.sigmaK2;
      const kernelRangeSq = params.kernelRangeSq;
      for (let dy = -r; dy <= r; dy++) {
        for (let dx = -r; dx <= r; dx++) {
          const ddx = dx / CELLS_PER_UNIT;
          const ddy = dy / CELLS_PER_UNIT;
          const d2 = ddx * ddx + ddy * ddy;
          if (d2 > kernelRangeSq) continue;
          const rd = Math.sqrt(d2);
          const dk = rd - muK;
          const w = wK * Math.exp(-(dk * dk) / sigmaK2);
          if (w < 1e-4) continue;
          kernelLUT[(dy + r) * sz + (dx + r)] = w;
        }
      }
    }

    // Spatial hash, linked-list per cell. hashHead[c] is the first particle
    // in cell c (or −1 if empty); hashNext[i] is the next particle after i.
    let hashHead = new Int32Array(0);
    let hashNext = new Int32Array(0);

    function rebuildHash() {
      hashHead.fill(-1);
      for (let i = 0; i < N_PARTICLES; i++) {
        const x = positions[i * 2];
        const y = positions[i * 2 + 1];
        const hx = Math.floor(x / HASH_CELL_SIZE);
        const hy = Math.floor(y / HASH_CELL_SIZE);
        const cx = ((hx % hashW) + hashW) % hashW;
        const cy = ((hy % hashH) + hashH) % hashH;
        const slot = cy * hashW + cx;
        hashNext[i] = hashHead[slot];
        hashHead[slot] = i;
      }
    }

    // Rejection sampler: place particles where a scalar field is high. The
    // power exponent biases toward peaks (higher = stronger concentration).
    // Falls back to uniform random for any unplaced slots.
    function sampleByField(sampler: (wx: number, wy: number) => number, power = 2) {
      let placed = 0;
      let attempts = 0;
      const maxAttempts = N_PARTICLES * 40;
      while (placed < N_PARTICLES && attempts < maxAttempts) {
        attempts++;
        const px = Math.random() * W_world;
        const py = Math.random() * H_world;
        let v = sampler(px, py);
        if (v < 0) v = 0;
        else if (v > 1) v = 1;
        if (Math.random() < Math.pow(v, power)) {
          positions[placed * 2] = px;
          positions[placed * 2 + 1] = py;
          placed++;
        }
      }
      while (placed < N_PARTICLES) {
        positions[placed * 2] = Math.random() * W_world;
        positions[placed * 2 + 1] = Math.random() * H_world;
        placed++;
      }
    }

    type Seeder = { name: string; fn: () => void };
    const seeders: Seeder[] = [
      {
        name: 'clusters',
        fn: () => {
          const k = 6 + ((Math.random() * 8) | 0);
          const cxs = new Float32Array(k);
          const cys = new Float32Array(k);
          for (let i = 0; i < k; i++) {
            cxs[i] = Math.random() * W_world;
            cys[i] = Math.random() * H_world;
          }
          const sigma = 2.5 + Math.random() * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            const c = (Math.random() * k) | 0;
            // Box–Muller for a 2D Gaussian offset.
            const u1 = Math.random() || 1e-9;
            const u2 = Math.random();
            const mag = Math.sqrt(-2 * Math.log(u1)) * sigma;
            const ang = 2 * Math.PI * u2;
            const px = cxs[c] + Math.cos(ang) * mag;
            const py = cys[c] + Math.sin(ang) * mag;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'rings',
        fn: () => {
          const k = 3 + ((Math.random() * 4) | 0);
          const perRing = Math.ceil(N_PARTICLES / k);
          let idx = 0;
          for (let ri = 0; ri < k && idx < N_PARTICLES; ri++) {
            const cx = Math.random() * W_world;
            const cy = Math.random() * H_world;
            const radius = 4 + Math.random() * 6;
            const count = Math.min(perRing, N_PARTICLES - idx);
            const phase = Math.random() * Math.PI * 2;
            for (let i = 0; i < count; i++) {
              const theta = phase + (i / count) * Math.PI * 2;
              const jitter = (Math.random() - 0.5) * 0.6;
              const px = cx + Math.cos(theta) * (radius + jitter);
              const py = cy + Math.sin(theta) * (radius + jitter);
              positions[idx * 2] = ((px % W_world) + W_world) % W_world;
              positions[idx * 2 + 1] = ((py % H_world) + H_world) % H_world;
              idx++;
            }
          }
          for (; idx < N_PARTICLES; idx++) {
            positions[idx * 2] = Math.random() * W_world;
            positions[idx * 2 + 1] = Math.random() * H_world;
          }
        },
      },
      {
        name: 'donut',
        fn: () => {
          // Single annular ring centered on the world, hollow inside.
          const cx = W_world / 2;
          const cy = H_world / 2;
          const span = Math.min(W_world, H_world);
          const inner = span * (0.14 + Math.random() * 0.08);
          const outer = span * (0.28 + Math.random() * 0.10);
          const phase = Math.random() * Math.PI * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
