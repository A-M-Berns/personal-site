          const fx1 = Math.cos(angle), fy1 = Math.sin(angle);
          const fx2 = -Math.sin(angle), fy2 = Math.cos(angle);
          sampleByField((wx, wy) => {
            const v1 = Math.sin((wx * fx1 + wy * fy1) / period * Math.PI * 2);
            const v2 = Math.sin((wx * fx2 + wy * fy2) / period * Math.PI * 2);
            return (Math.max(v1, v2) + 1) / 2;
          }, 4);
        },
      },
      {
        name: 'lissajous',
        fn: () => {
          // Particles arranged along a Lissajous curve sampled at evenly
          // spaced parameter values. Self-intersecting paths in 2D.
          const a = 1 + ((Math.random() * 4) | 0);
          let b = a;
          while (b === a) b = 1 + ((Math.random() * 4) | 0);
          const phase = Math.random() * Math.PI * 2;
          const cx = W_world / 2, cy = H_world / 2;
          const ax = W_world * 0.42, ay = H_world * 0.42;
          for (let i = 0; i < N_PARTICLES; i++) {
            const t = (i / N_PARTICLES) * Math.PI * 2;
            const px = cx + ax * Math.sin(a * t + phase) + (Math.random() - 0.5) * 1.5;
            const py = cy + ay * Math.sin(b * t) + (Math.random() - 0.5) * 1.5;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'honeycomb',
        fn: () => {
          // Triangular / hex lattice — different lattice symmetry than the
          // square lattice-tilt seeder. Each lattice point is a tight cluster.
          const spacing = 4 + Math.random() * 2;
          const dx = spacing;
          const dy = spacing * Math.sqrt(3) / 2;
          const points: Array<[number, number]> = [];
          for (let r = 0; r * dy < H_world; r++) {
            const offset = (r % 2) * dx * 0.5;
            for (let c = 0; c * dx + offset < W_world; c++) {
              points.push([c * dx + offset, r * dy]);
            }
          }
          const sigma = 0.6;
          for (let i = 0; i < N_PARTICLES; i++) {
            const p = points[(Math.random() * points.length) | 0];
            const u1 = Math.random() || 1e-9;
            const u2 = Math.random();
            const mag = Math.sqrt(-2 * Math.log(u1)) * sigma;
            const ang = 2 * Math.PI * u2;
            positions[i * 2] = ((p[0] + Math.cos(ang) * mag) % W_world + W_world) % W_world;
            positions[i * 2 + 1] = ((p[1] + Math.sin(ang) * mag) % H_world + H_world) % H_world;
          }
        },
      },
      {
        name: 'caustics',
        fn: () => {
          // Particles on Voronoi *edges* (not centers): for each candidate
          // point, accept if its distance-difference between the two closest
          // sites is small. Reads as a network of bright filaments.
          const k = 10 + ((Math.random() * 10) | 0);
          const sx = new Float32Array(k);
          const sy = new Float32Array(k);
          for (let i = 0; i < k; i++) {
            sx[i] = Math.random() * W_world;
            sy[i] = Math.random() * H_world;
          }
          const edgeWidth = 1.5;
          let placed = 0, attempts = 0;
          while (placed < N_PARTICLES && attempts < N_PARTICLES * 80) {
            attempts++;
            const px = Math.random() * W_world;
            const py = Math.random() * H_world;
            let best = Infinity, second = Infinity;
            for (let i = 0; i < k; i++) {
              const ddx = px - sx[i], ddy = py - sy[i];
              const d2 = ddx * ddx + ddy * ddy;
              if (d2 < best) { second = best; best = d2; }
              else if (d2 < second) { second = d2; }
            }
            const diff = Math.sqrt(second) - Math.sqrt(best);
            if (diff < edgeWidth) {
              positions[placed * 2] = px;
              positions[placed * 2 + 1] = py;
              placed++;
            }
          }
          while (placed < N_PARTICLES) {
            positions[placed * 2] = Math.random() * W_world;
            positions[placed * 2 + 1] = Math.random() * H_world;
            placed++;
          }
        },
      },
      {
        name: 'petals',
        fn: () => {
          // Rose curve: r(θ) = a · cos(k · θ) gives radial petals. Particles
          // distributed along the curve.
          const petals = 3 + ((Math.random() * 5) | 0);
          const cx = W_world / 2, cy = H_world / 2;
          const maxR = Math.min(W_world, H_world) * 0.40;
          const phase = Math.random() * Math.PI * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            const t = (i / N_PARTICLES) * Math.PI * 2;
            const rho = Math.abs(Math.cos(petals * t + phase)) * maxR;
            const px = cx + rho * Math.cos(t) + (Math.random() - 0.5) * 1.4;
            const py = cy + rho * Math.sin(t) + (Math.random() - 0.5) * 1.4;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'shockwave',
        fn: () => {
          // Dense central cluster with several radial filaments shooting
          // outward, like a frozen explosion.
          const cx = W_world / 2, cy = H_world / 2;
          const centerFrac = 0.3 + Math.random() * 0.15;
          const arms = 5 + ((Math.random() * 5) | 0);
          const armSpread = 0.18;
          const maxR = Math.min(W_world, H_world) * 0.45;
          const phase = Math.random() * Math.PI * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            if (i / N_PARTICLES < centerFrac) {
              const u1 = Math.random() || 1e-9;
              const u2 = Math.random();
              const mag = Math.sqrt(-2 * Math.log(u1)) * 1.8;
              const ang = 2 * Math.PI * u2;
              positions[i * 2] = ((cx + Math.cos(ang) * mag) % W_world + W_world) % W_world;
              positions[i * 2 + 1] = ((cy + Math.sin(ang) * mag) % H_world + H_world) % H_world;
            } else {
              const armIdx = i % arms;
              const u = Math.random();
              const r = Math.pow(u, 0.6) * maxR;
              const a = phase + (armIdx / arms) * Math.PI * 2 + (Math.random() - 0.5) * armSpread;
              positions[i * 2] = ((cx + r * Math.cos(a)) % W_world + W_world) % W_world;
              positions[i * 2 + 1] = ((cy + r * Math.sin(a)) % H_world + H_world) % H_world;
            }
          }
        },
      },
    ];

    // Deterministic round-robin cycle through seeders[0..N-1] (temporary —
    // makes it easy to verify each seeder by watching the label).
    let lastSeeder = -1;
    function nextSeeder(): number {
      lastSeeder = (lastSeeder + 1) % seeders.length;
      return lastSeeder;
    }

    function reseed() {
      params = pickParams();
      flowWaves = pickFlowWaves();
      lastSeeder = nextSeeder();
      seeders[lastSeeder].fn();
      const stops = pickStops();
      palette = buildPalette(stops);
      document.documentElement.style.setProperty('--accent', rgb(visibleCanvasColor(palette[4])));
      stepCount = 0;
      velocities.fill(0);
      prevField.fill(0);
      syncSliders();
      buildKernelLUT();
      const label = document.getElementById('seeder-label');
      if (label) label.textContent = seeders[lastSeeder].name;
    }

    function resize() {
      W_grid = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H_grid = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W_grid;
      canvas.height = H_grid;
      W_world = W_grid / CELLS_PER_UNIT;
      H_world = H_grid / CELLS_PER_UNIT;
      hashW = Math.max(1, Math.floor(W_world / HASH_CELL_SIZE));
      hashH = Math.max(1, Math.floor(H_world / HASH_CELL_SIZE));
      positions = new Float32Array(N_PARTICLES * 2);
      velocities = new Float32Array(N_PARTICLES * 2);
      U = new Float32Array(N_PARTICLES);
      Gp = new Float32Array(N_PARTICLES);
      F = new Float32Array(N_PARTICLES * 2);
      field = new Float32Array(W_grid * H_grid);
      prevField = new Float32Array(W_grid * H_grid);
      img = ctx.createImageData(W_grid, H_grid);
      hashHead = new Int32Array(hashW * hashH);
      hashNext = new Int32Array(N_PARTICLES);
      reseed();
    }

    function step() {
      rebuildHash();
      // Hoist params into locals — these inner loops run 10⁴⁺ times per step.
      const muK = params.muK;
      const sigmaK2 = params.sigmaK2;
      const muG = params.muG;
      const sigmaG2 = params.sigmaG2;
      const wK = params.wK;
      const cRep = params.cRep;
      const kernelRange = params.kernelRange;
      const kernelRangeSq = params.kernelRangeSq;

      // Pass 1: U(p_i) for every particle by summing kernel contributions
      // from all neighbors in the 3×3 hash-cell window.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2];
        const py = positions[i * 2 + 1];
        const hx = Math.floor(px / HASH_CELL_SIZE);
        const hy = Math.floor(py / HASH_CELL_SIZE);
        let u = 0;
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const cx = (((hx + dx) % hashW) + hashW) % hashW;
            const cy = (((hy + dy) % hashH) + hashH) % hashH;
            let j = hashHead[cy * hashW + cx];
            while (j !== -1) {
              const dxw = wrap(px - positions[j * 2], W_world);
              const dyw = wrap(py - positions[j * 2 + 1], H_world);
              const r2 = dxw * dxw + dyw * dyw;
              if (r2 < kernelRangeSq) {
                const r = Math.sqrt(r2);
                const dk = (r - muK);
                u += wK * Math.exp(-(dk * dk) / sigmaK2);
              }
              j = hashNext[j];
            }
          }
        }
        U[i] = u;
      }

      // Cache G'(U_i) for each particle so the force pass doesn't recompute.
      for (let i = 0; i < N_PARTICLES; i++) {
        const d = U[i] - muG;
        Gp[i] = -2 * d / sigmaG2 * Math.exp(-(d * d) / sigmaG2);
      }

      // Pass 2: pair-wise force on each particle. Growth-driven force on i
      // from j is (G'(U_i) + G'(U_j)) · K'(r) · (p_i − p_j)/r; repulsion
      // adds 2·c_rep·(1−r) along the same axis when r < 1.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2];
        const py = positions[i * 2 + 1];
        const hx = Math.floor(px / HASH_CELL_SIZE);
        const hy = Math.floor(py / HASH_CELL_SIZE);
        const Gpi = Gp[i];
        let fx = 0;
        let fy = 0;
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const cx = (((hx + dx) % hashW) + hashW) % hashW;
            const cy = (((hy + dy) % hashH) + hashH) % hashH;
            let j = hashHead[cy * hashW + cx];
            while (j !== -1) {
              if (j === i) { j = hashNext[j]; continue; }
              const dxw = wrap(px - positions[j * 2], W_world);
              const dyw = wrap(py - positions[j * 2 + 1], H_world);
              const r2 = dxw * dxw + dyw * dyw;
              if (r2 < 1e-10) { j = hashNext[j]; continue; }
              const r = Math.sqrt(r2);
              const ux = dxw / r;
              const uy = dyw / r;
              if (r < 1.0) {
                const rep = 2 * cRep * (1 - r);
                fx += rep * ux;
                fy += rep * uy;
              }
              if (r < kernelRange) {
                const dk = (r - muK);
                const Kr = Math.exp(-(dk * dk) / sigmaK2);
                const Kp = -2 * dk / sigmaK2 * Kr * wK;
                const ff = (Gpi + Gp[j]) * Kp;
                fx += ff * ux;
                fy += ff * uy;
              }
              j = hashNext[j];
            }
          }
        }
        F[i * 2] = fx;
        F[i * 2 + 1] = fy;
      }

      // Overdamped integration; wrap to torus.
      // Two ambient dynamics on top of the gradient flow:
      //  • noise — per-particle Brownian jitter (uncorrelated kicks).
      //  • flow  — a per-cycle random curl field, so creatures get advected
      //    by coherent currents without repeating the same geometry forever.
      // Front-load the ambient stirring so each cycle can relax into structure
      // instead of being shaken at the same strength until the reseed.
      const cycleRest = 1 - Math.min(1, stepCount / RESEED_AFTER);
      const ambient = 0.15 + 0.85 * cycleRest * cycleRest;
      const noise = params.noise * ambient;
      const flowAmp = params.flow * ambient;
      const flowT = stepCount * 0.0035;
      for (let i = 0; i < N_PARTICLES; i++) {
        // Accumulate forces (gradient + flow + noise) into velocity with
        // damping. The damping factor controls how much of last step's motion
        // carries over — higher = more momentum-y, smoother but less responsive.
        let vx = velocities[i * 2] * DAMPING + DT * F[i * 2];
        let vy = velocities[i * 2 + 1] * DAMPING + DT * F[i * 2 + 1];
        if (flowAmp > 0) {
          const px = positions[i * 2];
          const py = positions[i * 2 + 1];
          let fx = 0;
          let fy = 0;
          for (const wave of flowWaves) {
            const phase = (px * wave.dx + py * wave.dy) * wave.k +
              flowT * wave.speed + wave.phase;
            const curl = Math.cos(phase) * wave.amp * wave.k;
            fx += -wave.dy * curl;
            fy += wave.dx * curl;
          }
          vx += flowAmp * fx * 1.15;
          vy += flowAmp * fy * 1.15;
        }
        if (noise > 0) {
          vx += (Math.random() - 0.5) * 2 * noise;
          vy += (Math.random() - 0.5) * 2 * noise;
        }
        velocities[i * 2] = vx;
        velocities[i * 2 + 1] = vy;
        let nx = positions[i * 2] + vx;
        let ny = positions[i * 2 + 1] + vy;
        nx = ((nx % W_world) + W_world) % W_world;
        ny = ((ny % H_world) + H_world) % H_world;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
      }

      stepCount++;
      if (stepCount >= RESEED_AFTER) reseed();
    }

    function draw() {
      if (!img) return;
      field.fill(0);
      const muG = params.muG;
      const renderRangeCells = params.renderRangeCells;
      const lutSize = renderRangeCells * 2 + 1;

      // Splat each particle's kernel onto the field grid via the precomputed
      // 2D LUT — eliminates the per-cell exp() call which was the dominant
      // cost in the inner loop. LUT is rebuilt on every reseed and on muK /
      // sigmaK / wK slider changes.
      for (let p = 0; p < N_PARTICLES; p++) {
        const px = positions[p * 2] * CELLS_PER_UNIT;
        const py = positions[p * 2 + 1] * CELLS_PER_UNIT;
        const cx = Math.round(px);
        const cy = Math.round(py);
        for (let dy = -renderRangeCells; dy <= renderRangeCells; dy++) {
          const lutRow = (dy + renderRangeCells) * lutSize;
          const yIdx = (((cy + dy) % H_grid) + H_grid) % H_grid;
          const fieldRow = yIdx * W_grid;
          for (let dx = -renderRangeCells; dx <= renderRangeCells; dx++) {
            const w = kernelLUT[lutRow + (dx + renderRangeCells)];
            if (w === 0) continue;
            const xIdx = (((cx + dx) % W_grid) + W_grid) % W_grid;
            field[fieldRow + xIdx] += w;
          }
        }
      }

      // Blend with previous frame's field so the rendered pixels don't snap
      // when each particle's rounded splat center hops by one cell.
      const len = field.length;
      const ks = 1 - FIELD_SMOOTH;
      for (let i = 0; i < len; i++) {
        const blended = field[i] * ks + prevField[i] * FIELD_SMOOTH;
        field[i] = blended;
        prevField[i] = blended;
      }

      // Map field strength to a palette index, clipping at ~1.4·μ_G so dense
      // creature interiors saturate but the outer halo still resolves into
      // distinct bands.
      const scale = 1 / (muG * 1.4);
      const data = img.data;
      for (let i = 0; i < len; i++) {
        let v = field[i] * scale;
        if (v > 1) v = 1;
        let idx = (v * N_LEVELS) | 0;
        if (idx >= N_LEVELS) idx = N_LEVELS - 1;
        const c = palette[idx];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    // ── Sliders ─────────────────────────────────────────────────────────
    type SliderKey = 'muK' | 'sigmaK' | 'wK' | 'muG' | 'cRep' | 'noise' | 'flow';
    const SLIDER_KEYS: SliderKey[] = ['muK', 'sigmaK', 'wK', 'muG', 'cRep', 'noise', 'flow'];
    const FORMAT: Record<SliderKey, (n: number) => string> = {
      muK:    (n) => n.toFixed(2),
      sigmaK: (n) => n.toFixed(2),
      wK:     (n) => n.toFixed(4),
      muG:    (n) => n.toFixed(3),
      cRep:   (n) => n.toFixed(2),
      noise:  (n) => n.toFixed(3),
      flow:   (n) => n.toFixed(3),
    };
    const sliderEls: Partial<Record<SliderKey, HTMLInputElement>> = {};
    const valEls:    Partial<Record<SliderKey, HTMLElement>>    = {};
    for (const k of SLIDER_KEYS) {
      sliderEls[k] = document.getElementById('s-' + k) as HTMLInputElement;
      valEls[k]    = document.getElementById('v-' + k) as HTMLElement;
    }

    // The standalone `t` slider drives muK and sigmaK through the inverse
    // map. It's not in SLIDER_KEYS because it doesn't bind directly to a
    // single Params field — it computes two derived ones at once.
    const tSlider = document.getElementById('s-t') as HTMLInputElement | null;
    const tVal = document.getElementById('v-t') as HTMLElement | null;
    function syncSliders() {
      for (const k of SLIDER_KEYS) {
        const el = sliderEls[k];
        const v = valEls[k];
        if (!el || !v) continue;
        el.value = String(params[k]);
        v.textContent = FORMAT[k](params[k]);
      }
      if (tSlider && tVal) {
        tSlider.value = String(params.t);
        tVal.textContent = params.t.toFixed(2);
      }
    }

    for (const k of SLIDER_KEYS) {
      const el = sliderEls[k];
      const v = valEls[k];
      if (!el || !v) continue;
      el.addEventListener('input', () => {
        const num = parseFloat(el.value);
        params[k] = num;
        v.textContent = FORMAT[k](num);
        // Any kernel-shape change requires rebuilding the splat LUT.
        if (k === 'wK') buildKernelLUT();
      });
    }

    tSlider?.addEventListener('input', () => {
      const t = parseFloat(tSlider.value);
      params.t = t;
      params.muK = deriveMuKFromT(t);
      params.sigmaK = deriveSigmaKFromT(t);
      if (tVal) tVal.textContent = t.toFixed(2);
      // Mirror to the disabled muK / sigmaK sliders so the UI stays accurate.
      const muKEl = sliderEls.muK, muKValEl = valEls.muK;
      if (muKEl && muKValEl) {
        muKEl.value = String(params.muK);
        muKValEl.textContent = FORMAT.muK(params.muK);
      }
      const sgEl = sliderEls.sigmaK, sgValEl = valEls.sigmaK;
      if (sgEl && sgValEl) {
        sgEl.value = String(params.sigmaK);
        sgValEl.textContent = FORMAT.sigmaK(params.sigmaK);
      }
      recompute(params);
      buildKernelLUT();
    });

    const resetBtn = document.getElementById('reset-btn');
    resetBtn?.addEventListener('click', () => reseed());
    const restartBtn = document.getElementById('lenia-restart');
    restartBtn?.addEventListener('click', () => reseed());
    const aboutDlg = document.getElementById('lenia-about') as HTMLDialogElement | null;
    const infoBtn = document.getElementById('lenia-info');
    infoBtn?.addEventListener('click', () => aboutDlg?.showModal());
    aboutDlg?.addEventListener('click', (e) => {
      if (e.target === aboutDlg) aboutDlg.close();
    });

    // ── Click perturbation ──────────────────────────────────────────────
    // Click drops a strong outward kick on every particle within a generous
    // radius. Falloff is (1 − r/R)² so the center gets the brunt and the
    // edge tapers off smoothly.
    function perturb(gx: number, gy: number) {
      const wx = gx / CELLS_PER_UNIT;
      const wy = gy / CELLS_PER_UNIT;
      const kickRadius = Math.max(11, params.muK * 4.0);
      const kickRadius2 = kickRadius * kickRadius;
      const kickStrength = 16;
      for (let i = 0; i < N_PARTICLES; i++) {
        const dxw = wrap(positions[i * 2] - wx, W_world);
        const dyw = wrap(positions[i * 2 + 1] - wy, H_world);
        const r2 = dxw * dxw + dyw * dyw;
        if (r2 >= kickRadius2 || r2 < 1e-6) continue;
        const r = Math.sqrt(r2);
        const t = 1 - r / kickRadius;
        const kick = kickStrength * t * t;
        let nx = positions[i * 2] + (dxw / r) * kick;
        let ny = positions[i * 2 + 1] + (dyw / r) * kick;
        nx = ((nx % W_world) + W_world) % W_world;
        ny = ((ny % H_world) + H_world) % H_world;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
        // Impulse velocity in the same direction so the damped integrator
        // carries momentum through several frames after the click; without
        // this the gradient flow snaps particles back almost immediately.
        velocities[i * 2] += (dxw / r) * kick * 0.6;
        velocities[i * 2 + 1] += (dyw / r) * kick * 0.6;
      }
    }

    window.addEventListener('pointerdown', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      if (target.closest('a, button, input, label, .tune-panel, .anim-controls, .anim-about')) return;
      const gx = (e.clientX / window.innerWidth) * W_grid;
      const gy = (e.clientY / window.innerHeight) * H_grid;
      perturb(gx, gy);
    });

    resize();
    syncSliders();
    window.addEventListener('resize', resize);

    if (reduce) {
      for (let i = 0; i < 200; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 50;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>

<script>
  // Custom audio player to keep the controls in the site's visual language
  // (no native browser chrome). Exposes play/pause toggle, click-to-seek,
  // and a tabular-numeric time readout.
  for (const player of document.querySelectorAll<HTMLElement>('.audio-player')) {
    const src = player.dataset.src;
    if (!src) continue;
    const audio = new Audio(src);
    audio.preload = 'metadata';
    const playBtn = player.querySelector<HTMLButtonElement>('.audio-play');
    const track = player.querySelector<HTMLElement>('.audio-track');
    const progress = player.querySelector<HTMLElement>('.audio-progress');
    const timeEl = player.querySelector<HTMLElement>('.audio-time');

    function fmt(t: number): string {
      if (!isFinite(t) || t < 0) return '—:—';
      const m = Math.floor(t / 60);
      const s = Math.floor(t - m * 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    }
    function syncTime() {
      if (!timeEl) return;
      timeEl.textContent = `${fmt(audio.currentTime)} / ${fmt(audio.duration)}`;
    }
    function syncProgress() {
      if (!progress || !track) return;
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      progress.style.width = `${pct}%`;
      track.setAttribute('aria-valuenow', pct.toFixed(0));
    }
    function seekTo(clientX: number) {
      if (!track || !audio.duration) return;
      const rect = track.getBoundingClientRect();
      const t = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      audio.currentTime = t * audio.duration;
      syncProgress();
      syncTime();
    }

    playBtn?.addEventListener('click', () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });
    audio.addEventListener('play', () => {
      player.classList.add('is-playing');
      playBtn?.setAttribute('aria-label', 'Pause');
    });
    audio.addEventListener('pause', () => {
      player.classList.remove('is-playing');
      playBtn?.setAttribute('aria-label', 'Play');
    });
    audio.addEventListener('timeupdate', () => {
      syncProgress();
      syncTime();
    });
    audio.addEventListener('loadedmetadata', () => {
      syncProgress();
      syncTime();
    });
    audio.addEventListener('ended', () => {
      audio.currentTime = 0;
      syncProgress();
      syncTime();
    });
    track?.addEventListener('pointerdown', (e) => {
      seekTo(e.clientX);
      const onMove = (m: PointerEvent) => seekTo(m.clientX);
      const onUp = () => {
        window.removeEventListener('pointermove', onMove);
        window.removeEventListener('pointerup', onUp);
      };
      window.addEventListener('pointermove', onMove);
      window.addEventListener('pointerup', onUp);
    });
    track?.addEventListener('keydown', (e) => {
      if (!audio.duration) return;
      if (e.key === 'ArrowLeft') {
        audio.currentTime = Math.max(0, audio.currentTime - 5);
        e.preventDefault();
      } else if (e.key === 'ArrowRight') {
        audio.currentTime = Math.min(audio.duration, audio.currentTime + 5);
        e.preventDefault();
      } else if (e.key === ' ' || e.key === 'Enter') {
        if (audio.paused) audio.play();
        else audio.pause();
        e.preventDefault();
      }
    });
    syncTime();
  }
</script>
