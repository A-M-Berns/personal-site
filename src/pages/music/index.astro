---
import Base from '../../layouts/Base.astro';

const spotifyArtistUrl = 'https://open.spotify.com/artist/3dS0px84EtOAKKdgoaNd2c';
const spotifyEmbedUrl = 'https://open.spotify.com/embed/artist/3dS0px84EtOAKKdgoaNd2c?utm_source=generator&theme=0';
---
<Base title="Music — A. M. Berns" description="Music by Anson Berns.">
  <header class="section-head">
    <h1>Music</h1>
    <p>Released music and site-only recordings.</p>
  </header>

  <article class="note music-page">
    <section class="music-section">
      <h2>Streaming</h2>
      <p><a href={spotifyArtistUrl}>Anson Berns on Spotify</a></p>
      <div class="spotify-embed">
        <iframe
          title="Anson Berns on Spotify"
          src={spotifyEmbedUrl}
          width="100%"
          height="352"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>
    </section>

    <section class="music-section">
      <h2>Site-only</h2>
      <p>More to come.</p>
    </section>
  </article>
</Base>
