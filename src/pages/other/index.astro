---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Side projects and miscellaneous experiments.">
  <div class="other-shell">
    <canvas id="sandpile-sim" class="sandpile-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Side projects and miscellaneous experiments.</span></p>
    </header>
    <article class="note other-note">
      <ul>
        <li><span class="hl">Abelian sandpile experiments.</span></li>
        <li><span class="hl"><a href="/Animations/">Animation-only views</a></span></li>
      </ul>
    </article>
    <aside class="sandpile-panel" aria-label="Sandpile controls">
      <div class="sandpile-panel-head">
        <h2>Sandpile</h2>
        <div class="sandpile-panel-head-actions">
          <button id="sandpile-reset" type="button">Reset</button>
          <button id="sandpile-collapse" type="button" aria-label="Collapse panel" aria-expanded="true">−</button>
        </div>
      </div>
      <div class="sandpile-panel-body">
      <label class="sandpile-panel-field" for="sandpile-mode-select">
        <span>mode</span>
        <select id="sandpile-mode-select">
          <optgroup label="symmetric stationary">
            <option value="center" selected>center</option>
            <option value="quadrants">quadrants</option>
            <option value="axes">axes</option>
            <option value="cross-5">cross-5</option>
            <option value="ring-8">ring-8</option>
            <option value="grid-9">grid-9</option>
          </optgroup>
          <optgroup label="asymmetric stationary">
            <option value="golden-2">golden-2</option>
            <option value="scatter-7">scatter-7</option>
            <option value="comet">comet</option>
          </optgroup>
          <optgroup label="moving">
            <option value="orbit-1">orbit-1</option>
            <option value="binary">binary</option>
            <option value="lissajous-3">lissajous-3</option>
            <option value="drift">drift</option>
          </optgroup>
          <optgroup label="other">
            <option value="uniform">uniform</option>
          </optgroup>
        </select>
      </label>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-passes">passes</label>
        <input id="sandpile-passes" type="range" min="1" max="100" step="1" value="8" />
        <span id="sandpile-passes-value">8</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-base">base</label>
        <input id="sandpile-base" type="range" min="0" max="3" step="1" value="0" />
        <span id="sandpile-base-value">0</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-mass">mass</label>
        <input id="sandpile-mass" type="range" min="0.3" max="2.4" step="0.1" value="1" />
        <span id="sandpile-mass-value">1.0</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-cadence">cadence</label>
        <input id="sandpile-cadence" type="range" min="1" max="2700" step="1" value="90" />
        <span id="sandpile-cadence-value">90</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-motion">motion</label>
        <input id="sandpile-motion" type="range" min="0" max="3" step="0.1" value="1" />
        <span id="sandpile-motion-value">1.0</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-ease">ease</label>
        <input id="sandpile-ease" type="range" min="0.05" max="1" step="0.05" value="0.2" />
        <span id="sandpile-ease-value">0.20</span>
      </div>
      <dl class="sandpile-stats">
        <div><dt>seed</dt><dd id="sandpile-seed">-</dd></div>
        <div><dt>iterations</dt><dd id="sandpile-frame">-</dd></div>
      </dl>
      </div>
    </aside>
  </div>
</Base>

<script>
  const canvas = document.getElementById('sandpile-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const resetButton = document.getElementById('sandpile-reset') as HTMLButtonElement | null;
    const collapseButton = document.getElementById('sandpile-collapse') as HTMLButtonElement | null;
    const panelEl = document.querySelector('.sandpile-panel') as HTMLElement | null;
    const modeSelect = document.getElementById('sandpile-mode-select') as HTMLSelectElement | null;
    const passesInput = document.getElementById('sandpile-passes') as HTMLInputElement | null;
    const baseInput = document.getElementById('sandpile-base') as HTMLInputElement | null;
    const massInput = document.getElementById('sandpile-mass') as HTMLInputElement | null;
    const cadenceInput = document.getElementById('sandpile-cadence') as HTMLInputElement | null;
    const motionInput = document.getElementById('sandpile-motion') as HTMLInputElement | null;
    const easeInput = document.getElementById('sandpile-ease') as HTMLInputElement | null;
    const passesValue = document.getElementById('sandpile-passes-value');
    const baseValue = document.getElementById('sandpile-base-value');
    const massValue = document.getElementById('sandpile-mass-value');
    const cadenceValue = document.getElementById('sandpile-cadence-value');
    const motionValue = document.getElementById('sandpile-motion-value');
    const easeValue = document.getElementById('sandpile-ease-value');
    const seedLabel = document.getElementById('sandpile-seed');
    const frameLabel = document.getElementById('sandpile-frame');

    const CELL_PX = 3;
    const ACTIVE_DECAY = 18;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex(styles.getPropertyValue('--paper').trim() || '#0e0e10');
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let grains = new Uint32Array();
    let nextGrains = new Uint32Array();
    let active = new Uint8Array();
    let display = new Float32Array();
    let image = new ImageData(1, 1);
    let rng = mulberry32(1);
    let frame = 0;
    let seed = 0;
    let topplePassesPerFrame = Number(passesInput?.value ?? 8);
    const PULSE_CYCLE_FRAMES = 2700;
    let pulseCadence = Math.max(1, Number(cadenceInput?.value ?? 90));
    type InjectionMode =
      | 'center' | 'quadrants' | 'axes' | 'cross-5' | 'ring-8' | 'grid-9' | 'uniform'
      | 'orbit-1' | 'binary' | 'lissajous-3' | 'drift'
      | 'golden-2' | 'scatter-7' | 'comet';
    const VALID_MODES: ReadonlyArray<InjectionMode> = [
      'center', 'quadrants', 'axes', 'cross-5', 'ring-8', 'grid-9', 'uniform',
      'orbit-1', 'binary', 'lissajous-3', 'drift',
      'golden-2', 'scatter-7', 'comet',
    ];
    function parseMode(v: string | undefined): InjectionMode {
      return (VALID_MODES as readonly string[]).includes(v ?? '') ? (v as InjectionMode) : 'center';
    }
    let injectionMode: InjectionMode = parseMode(modeSelect?.value);
    let baseHeight = Number(baseInput?.value ?? 0);
    let massScale = Number(massInput?.value ?? 1);
    let motionSpeed = Number(motionInput?.value ?? 1);
    let easeAlpha = Number(easeInput?.value ?? 0.2);
    let palette: number[][] = [];

    function parseHex(h: string) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: number[]) {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: number[], b: number[], t: number) {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function hashString(s: string) {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(n: number) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function idx(x: number, y: number) {
      return y * W + x;
    }

    function choosePalette() {
      const Lp = luma(paper);
      const targets = [
        22 + Math.floor(rng() * 12),
        Math.floor(65 + rng() * 15),
        Math.floor(135 + rng() * 20),
        Math.floor(195 + rng() * 15),
        Math.floor(222 + rng() * 15),
      ];
      const midPart = [targets[1], targets[2], targets[3]];
      for (let i = midPart.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [midPart[i], midPart[j]] = [midPart[j], midPart[i]];
      }
      targets[1] = midPart[0];
      targets[2] = midPart[1];
      targets[3] = midPart[2];
      const used = new Set<number>();
      palette = targets.map((t) => {
        const candidates: number[] = [];
        for (let i = 0; i < colorPool.length; i++) {
          if (used.has(i)) continue;
          if (luma(colorPool[i]) >= t - 8) candidates.push(i);
        }
        let pickIdx: number;
        if (candidates.length > 0) {
          pickIdx = candidates[Math.floor(rng() * candidates.length)];
        } else {
          const all: number[] = [];
          for (let i = 0; i < colorPool.length; i++) if (!used.has(i)) all.push(i);
          pickIdx = all[Math.floor(rng() * all.length)];
        }
        used.add(pickIdx);
        const color = colorPool[pickIdx];
        const denom = luma(color) - Lp;
        const alpha = denom > 1 ? Math.max(0.04, Math.min(1, (t - Lp) / denom)) : 1;
        return mix(paper, color, alpha);
      });
    }

    function fillBase() {
      grains.fill(Math.max(0, baseHeight));
    }

    function seedCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      choosePalette();
      nextGrains.fill(0);
      active.fill(0);
      display.fill(0);
      frame = 0;
      pulseAccumulator = 0;
      sourceState = {};
      grains.fill(3);
      for (let i = 0; i < grains.length; i++) display[i] = Math.min(3, grains[i]);
      updatePanel();
    }

    function pulseUniformSymmetric() {
      for (let i = 0; i < grains.length; i++) grains[i] += 1;
    }

    type DriftAgent = { x: number; y: number; vx: number; vy: number };
    type SourceState = { positions?: number[][]; drift?: DriftAgent[] };
    let sourceState: SourceState = {};

    const SOURCE_POSITIONS: Record<string, () => number[][]> = {
      center: () => [[W >> 1, H >> 1]],
      quadrants: () => [
        [W >> 2, H >> 2],
        [(3 * W) >> 2, H >> 2],
        [W >> 2, (3 * H) >> 2],
        [(3 * W) >> 2, (3 * H) >> 2],
      ],
      axes: () => [
        [W >> 1, H >> 2],
        [W >> 1, (3 * H) >> 2],
        [W >> 2, H >> 1],
        [(3 * W) >> 2, H >> 1],
      ],
      'cross-5': () => [
        [W >> 1, H >> 1],
        [W >> 2, H >> 2],
        [(3 * W) >> 2, H >> 2],
        [W >> 2, (3 * H) >> 2],
        [(3 * W) >> 2, (3 * H) >> 2],
      ],
      'ring-8': () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const r = Math.min(W, H) / 3;
        const out: number[][] = [];
        for (let i = 0; i < 8; i++) {
          const a = (i / 8) * Math.PI * 2;
          out.push([Math.round(cx + r * Math.cos(a)), Math.round(cy + r * Math.sin(a))]);
        }
        return out;
      },
      'grid-9': () => {
        const out: number[][] = [];
        for (const fy of [0.25, 0.5, 0.75]) {
          for (const fx of [0.25, 0.5, 0.75]) {
            out.push([Math.round(W * fx), Math.round(H * fy)]);
          }
        }
        return out;
      },
      'orbit-1': () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const r = Math.min(W, H) * 0.33;
        const a = frame * 0.012 * motionSpeed;
        return [[Math.round(cx + r * Math.cos(a)), Math.round(cy + r * Math.sin(a))]];
      },
      binary: () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const r = Math.min(W, H) * 0.3;
        const a = frame * 0.01 * motionSpeed;
        return [
          [Math.round(cx + r * Math.cos(a)), Math.round(cy + r * Math.sin(a))],
          [Math.round(cx - r * Math.cos(a)), Math.round(cy - r * Math.sin(a))],
        ];
      },
      'lissajous-3': () => {
        const cx = W >> 1;
        const cy = H >> 1;
        const ax = W * 0.42;
        const ay = H * 0.42;
        const t = frame * 0.007 * motionSpeed;
        return [
          [Math.round(cx + ax * Math.sin(3 * t)),       Math.round(cy + ay * Math.sin(2 * t))],
          [Math.round(cx + ax * Math.sin(2 * t + 1.0)), Math.round(cy + ay * Math.sin(5 * t + 0.7))],
          [Math.round(cx + ax * Math.sin(5 * t + 2.1)), Math.round(cy + ay * Math.sin(3 * t + 1.5))],
        ];
      },
      drift: () => {
        if (!sourceState.drift) return [];
        return sourceState.drift.map((d) => [Math.round(d.x), Math.round(d.y)]);
      },
      'golden-2': () => {
        if (!sourceState.positions) {
          const phi = 0.6180339887;
          sourceState.positions = [
            [Math.round(W * phi), Math.round(H * phi), 1],
            [Math.round(W * (1 - phi * 0.7)), Math.round(H * (1 - phi * 0.4)), 1],
          ];
        }
        return sourceState.positions;
      },
      'scatter-7': () => {
        if (!sourceState.positions) {
          const out: number[][] = [];
          const pad = 4;
          for (let i = 0; i < 7; i++) {
            out.push([
              Math.round(rng() * (W - 2 * pad) + pad),
              Math.round(rng() * (H - 2 * pad) + pad),
            ]);
          }
          sourceState.positions = out;
        }
        return sourceState.positions;
      },
      comet: () => {
        if (!sourceState.positions) {
          const cx = W >> 1;
          const cy = H >> 1;
          sourceState.positions = [
            [Math.round(cx - W * 0.08), Math.round(cy + H * 0.05), 4],
            [Math.round(cx + W * 0.18), Math.round(cy - H * 0.12), 1],
          ];
        }
        return sourceState.positions;
      },
    };

    function tickDrift() {
      if (!sourceState.drift) {
        const N = 4;
        const arr: DriftAgent[] = [];
        for (let i = 0; i < N; i++) {
          arr.push({
            x: rng() * (W - 4) + 2,
            y: rng() * (H - 4) + 2,
            vx: (rng() - 0.5) * 0.8,
            vy: (rng() - 0.5) * 0.8,
          });
        }
        sourceState.drift = arr;
      }
      const max = 1.2;
      for (const d of sourceState.drift) {
        d.vx += (rng() - 0.5) * 0.06;
        d.vy += (rng() - 0.5) * 0.06;
        const v = Math.hypot(d.vx, d.vy);
        if (v > max) { d.vx *= max / v; d.vy *= max / v; }
        d.x += d.vx * motionSpeed;
        d.y += d.vy * motionSpeed;
        if (d.x < 1)     { d.x = 1;     d.vx = Math.abs(d.vx); }
        if (d.x > W - 2) { d.x = W - 2; d.vx = -Math.abs(d.vx); }
        if (d.y < 1)     { d.y = 1;     d.vy = Math.abs(d.vy); }
        if (d.y > H - 2) { d.y = H - 2; d.vy = -Math.abs(d.vy); }
      }
    }

    let pulseAccumulator = 0;

    function pulsePoints(positions: number[][]) {
      const n = positions.length;
      if (n === 0) return;
      const totalPerCycle = 32000 * massScale;
      const totalPerPulse = totalPerCycle * pulseCadence / PULSE_CYCLE_FRAMES;
      pulseAccumulator += totalPerPulse;
      let weightSum = 0;
      for (const p of positions) weightSum += (p[2] ?? 1);
      if (weightSum <= 0) return;
      const massThisPulse = Math.floor(pulseAccumulator);
      if (massThisPulse <= 0) return;
      pulseAccumulator -= massThisPulse;
      let allocated = 0;
      for (let i = 0; i < n; i++) {
        const x = positions[i][0];
        const y = positions[i][1];
        const w = positions[i][2] ?? 1;
        const isLast = i === n - 1;
        const share = isLast
          ? massThisPulse - allocated
          : Math.floor(massThisPulse * (w / weightSum));
        allocated += share;
        if (share > 0 && x >= 0 && x < W && y >= 0 && y < H) {
          grains[idx(x, y)] += share;
        }
      }
    }

    function topplePass() {
      let topples = 0;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const i = idx(x, y);
          const q = Math.floor(grains[i] / 4);
          let value = grains[i] - q * 4;
          if (x > 0) value += Math.floor(grains[i - 1] / 4);
          if (x < W - 1) value += Math.floor(grains[i + 1] / 4);
          if (y > 0) value += Math.floor(grains[i - W] / 4);
          if (y < H - 1) value += Math.floor(grains[i + W] / 4);
          nextGrains[i] = value;
          if (q > 0) {
            active[i] = 255;
            topples += q;
          }
        }
      }
      [grains, nextGrains] = [nextGrains, grains];
      return topples;
    }

    function step() {
      if (injectionMode === 'drift') tickDrift();
      if (frame % pulseCadence === 0) {
        if (injectionMode === 'uniform') pulseUniformSymmetric();
        else pulsePoints(SOURCE_POSITIONS[injectionMode]());
      }
      for (let i = 0; i < topplePassesPerFrame; i++) topplePass();
      for (let i = 0; i < active.length; i++) {
        if (active[i] > ACTIVE_DECAY) active[i] -= ACTIVE_DECAY;
        else active[i] = 0;
      }
      frame++;
      if (frame % 12 === 0) updatePanel();
    }

    function updatePanel() {
      if (!seedLabel) return;
      seedLabel.textContent = seed.toString(16).padStart(8, '0');
      if (frameLabel) frameLabel.textContent = frame.toLocaleString();
    }

    function draw() {
      const data = image.data;
      const a = easeAlpha;
      for (let i = 0; i < grains.length; i++) {
        const target = grains[i] < 3 ? grains[i] : 3;
        display[i] += (target - display[i]) * a;
        const v = display[i];
        const lo = v < 0 ? 0 : v > 3 ? 3 : Math.floor(v);
        const hi = lo < 3 ? lo + 1 : 3;
        const t = v - lo;
        const c0 = palette[lo];
        const c1 = palette[hi];
        const o = i * 4;
        data[o]     = c0[0] + (c1[0] - c0[0]) * t;
        data[o + 1] = c0[1] + (c1[1] - c0[1]) * t;
        data[o + 2] = c0[2] + (c1[2] - c0[2]) * t;
        data[o + 3] = v >= 1 ? 255 : 150 + 105 * v;
      }
      ctx.putImageData(image, 0, 0);
    }

    function resize() {
      W = Math.max(48, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(36, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      grains = new Uint32Array(W * H);
      nextGrains = new Uint32Array(W * H);
      active = new Uint8Array(W * H);
      display = new Float32Array(W * H);
      image = new ImageData(W, H);
      seedCycle();
      draw();
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 300; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    resetButton?.addEventListener('click', () => {
      seedCycle();
      draw();
    });
    const COLLAPSE_KEY = 'sandpile-panel-collapsed';
    function applyCollapsed(collapsed: boolean) {
      if (!panelEl || !collapseButton) return;
      panelEl.classList.toggle('collapsed', collapsed);
      collapseButton.textContent = collapsed ? '+' : '−';
      collapseButton.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      collapseButton.setAttribute('aria-label', collapsed ? 'Expand panel' : 'Collapse panel');
    }
    try {
      applyCollapsed(localStorage.getItem(COLLAPSE_KEY) === '1');
    } catch {}
    collapseButton?.addEventListener('click', () => {
      const next = !panelEl?.classList.contains('collapsed');
      applyCollapsed(next);
      try { localStorage.setItem(COLLAPSE_KEY, next ? '1' : '0'); } catch {}
    });
    modeSelect?.addEventListener('change', () => {
      injectionMode = parseMode(modeSelect.value);
      sourceState = {};
      pulseAccumulator = 0;
    });
    passesInput?.addEventListener('input', () => {
      topplePassesPerFrame = Number(passesInput.value);
      if (passesValue) passesValue.textContent = passesInput.value;
    });
    baseInput?.addEventListener('input', () => {
      baseHeight = Number(baseInput.value);
      if (baseValue) baseValue.textContent = baseInput.value;
    });
    massInput?.addEventListener('input', () => {
      massScale = Number(massInput.value);
      if (massValue) massValue.textContent = massScale.toFixed(1);
    });
    cadenceInput?.addEventListener('input', () => {
      pulseCadence = Math.max(1, Number(cadenceInput.value));
      if (cadenceValue) cadenceValue.textContent = String(pulseCadence);
    });
    motionInput?.addEventListener('input', () => {
      motionSpeed = Number(motionInput.value);
      if (motionValue) motionValue.textContent = motionSpeed.toFixed(1);
    });
    easeInput?.addEventListener('input', () => {
      easeAlpha = Number(easeInput.value);
      if (easeValue) easeValue.textContent = easeAlpha.toFixed(2);
    });
  }
</script>
