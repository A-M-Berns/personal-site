---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Music, side projects, and miscellany.">
  <div class="other-shell">
    <canvas id="lenia-sim" class="lenia-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Music, side projects, and miscellany.</span></p>
    </header>
    <article class="note">
      <ul>
        <li><span class="hl"><a href="/music/">Music</a></span></li>
      </ul>
    </article>

    <aside id="tune-panel" class="tune-panel" aria-label="Particle Lenia parameters">
      <h3>Tune</h3>
      <div class="tune-row">
        <label for="s-muK">μK</label>
        <input type="range" id="s-muK" min="2.5" max="6.0" step="0.05" />
        <span class="val" id="v-muK"></span>
      </div>
      <div class="tune-row">
        <label for="s-sigmaK">σK</label>
        <input type="range" id="s-sigmaK" min="0.5" max="1.5" step="0.02" />
        <span class="val" id="v-sigmaK"></span>
      </div>
      <div class="tune-row">
        <label for="s-wK">wK</label>
        <input type="range" id="s-wK" min="0.012" max="0.034" step="0.0005" />
        <span class="val" id="v-wK"></span>
      </div>
      <div class="tune-row">
        <label for="s-muG">μG</label>
        <input type="range" id="s-muG" min="0.35" max="0.80" step="0.005" />
        <span class="val" id="v-muG"></span>
      </div>
      <div class="tune-row">
        <label for="s-sigmaG">σG</label>
        <input type="range" id="s-sigmaG" min="0.07" max="0.25" step="0.005" />
        <span class="val" id="v-sigmaG"></span>
      </div>
      <div class="tune-row">
        <label for="s-cRep">cRep</label>
        <input type="range" id="s-cRep" min="0.4" max="2.0" step="0.02" />
        <span class="val" id="v-cRep"></span>
      </div>
      <div class="tune-row">
        <label for="s-noise">noise</label>
        <input type="range" id="s-noise" min="0" max="0.15" step="0.002" />
        <span class="val" id="v-noise"></span>
      </div>
      <button id="reset-btn" type="button">Reset</button>
      <p class="tune-hint">Click on the background to nudge particles.</p>
    </aside>
  </div>
</Base>

<style>
  .tune-panel {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 3;
    width: 16.5rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .tune-panel h3 {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.6rem;
    color: var(--ink);
  }
  .tune-row {
    display: grid;
    grid-template-columns: 3.5ch 1fr 4.5ch;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .tune-row label {
    font-size: 0.78rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tune-row input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    margin: 0;
  }
  .tune-row .val {
    font-size: 0.7rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .tune-panel button {
    margin-top: 0.6rem;
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.4rem 0.7rem;
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .tune-panel button:hover {
    color: var(--ink);
    border-color: var(--muted);
  }
  .tune-hint {
    margin: 0.6rem 0 0;
    font-size: 0.7rem;
    color: var(--muted);
    line-height: 1.35;
  }
  @media (max-width: 600px) {
    .tune-panel {
      bottom: 0.5rem;
      right: 0.5rem;
      left: 0.5rem;
      width: auto;
    }
  }
</style>

<script>
  // Particle Lenia (Mordvintsev, Niklasson, Randazzo, Chan).
  // Each particle is a point in 2D world space. The continuous field U(x) is
  // a sum of bell-ring kernels K(|x − p_j|) over all particles, and each
  // particle's energy is R(p_i) − G(U(p_i)) where R is short-range repulsion
  // and G is a Gaussian "growth" preference for the field strength near it.
  // Particles flow along the negative gradient of total energy, producing
  // self-propelled clusters that swim, divide, and dissolve.
  //
  // Rendered by splatting each particle's kernel onto a coarse pixel grid;
  // the chunky pixel look matches the rest of the site's animations.
  const canvas = document.getElementById('lenia-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N_LEVELS = 8;
    const CELL_PX = 6;          // display pixels per grid cell
    const CELLS_PER_UNIT = 4;   // grid cells per world unit
    const DT = 0.1;
    const N_PARTICLES = 320;
    const RESEED_AFTER = 2000;

    // Parameter ranges sampled per cycle. Each reseed picks a fresh point in
    // this box, the same way the homepage CA re-rolls its palette and seeder.
    // Tuneable starting bounds — fine-tune to taste.
    const PARAM_RANGES = {
      muK:    [3.5, 5.0],     // kernel peak (creature radius)
      sigmaK: [0.8, 1.2],     // kernel ring width
      wK:     [0.020, 0.026], // per-particle field weight
      muG:    [0.50, 0.65],   // growth target field strength
      sigmaG: [0.12, 0.17],   // growth tolerance
      cRep:   [0.8, 1.3],     // close-range repulsion strength
      noise:  [0.0, 0.05],    // per-step Brownian jitter
    } as const;

    // Slider bounds (wider than randomization range, for live exploration).
    // The hash-cell size must cover the largest possible kernel range over
    // these bounds, since the slider lets the user push muK/sigmaK higher
    // than the randomization box.
    const SLIDER_MAX_MU_K = 6.0;
    const SLIDER_MAX_SIGMA_K = 1.5;
    const MAX_KERNEL_RANGE = SLIDER_MAX_MU_K + 3 * SLIDER_MAX_SIGMA_K;
    const HASH_CELL_SIZE = MAX_KERNEL_RANGE;

    type Params = {
      muK: number; sigmaK: number; wK: number;
      muG: number; sigmaG: number; cRep: number;
      noise: number;
      kernelRange: number; kernelRangeSq: number;
      renderRangeCells: number;
      sigmaK2: number; sigmaG2: number;
    };

    function lerp(lo: number, hi: number) {
      return lo + Math.random() * (hi - lo);
    }

    function recompute(p: Params) {
      p.kernelRange = p.muK + 3 * p.sigmaK;
      p.kernelRangeSq = p.kernelRange * p.kernelRange;
      p.renderRangeCells = Math.ceil(p.kernelRange * CELLS_PER_UNIT);
      p.sigmaK2 = p.sigmaK * p.sigmaK;
      p.sigmaG2 = p.sigmaG * p.sigmaG;
    }

    function pickParams(): Params {
      const p: Params = {
        muK:    lerp(PARAM_RANGES.muK[0],    PARAM_RANGES.muK[1]),
        sigmaK: lerp(PARAM_RANGES.sigmaK[0], PARAM_RANGES.sigmaK[1]),
        wK:     lerp(PARAM_RANGES.wK[0],     PARAM_RANGES.wK[1]),
        muG:    lerp(PARAM_RANGES.muG[0],    PARAM_RANGES.muG[1]),
        sigmaG: lerp(PARAM_RANGES.sigmaG[0], PARAM_RANGES.sigmaG[1]),
        cRep:   lerp(PARAM_RANGES.cRep[0],   PARAM_RANGES.cRep[1]),
        noise:  lerp(PARAM_RANGES.noise[0],  PARAM_RANGES.noise[1]),
        kernelRange: 0, kernelRangeSq: 0, renderRangeCells: 0,
        sigmaK2: 0, sigmaG2: 0,
      };
      recompute(p);
      return p;
    }

    let params: Params = pickParams();

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N_LEVELS; i++) {
        const lo = Math.floor((i * colorPool.length) / N_LEVELS);
        const hi = Math.floor(((i + 1) * colorPool.length) / N_LEVELS);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N_LEVELS; i++) {
        const t = i / (N_LEVELS - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    function wrap(d: number, size: number): number {
      if (d > size * 0.5) return d - size;
      if (d < -size * 0.5) return d + size;
      return d;
    }

    let W_grid = 0, H_grid = 0;
    let W_world = 0, H_world = 0;
    let hashW = 0, hashH = 0;

    let positions = new Float32Array(0);
    let U = new Float32Array(0);
    let Gp = new Float32Array(0);
    let F = new Float32Array(0);
    let field = new Float32Array(0);
    let img: ImageData | null = null;
    let palette: RGB[] = buildPalette(pickStops());
    let stepCount = 0;

    // Spatial hash, linked-list per cell. hashHead[c] is the first particle
    // in cell c (or −1 if empty); hashNext[i] is the next particle after i.
    let hashHead = new Int32Array(0);
    let hashNext = new Int32Array(0);

    function rebuildHash() {
      hashHead.fill(-1);
      for (let i = 0; i < N_PARTICLES; i++) {
        const x = positions[i * 2];
        const y = positions[i * 2 + 1];
        const hx = Math.floor(x / HASH_CELL_SIZE);
        const hy = Math.floor(y / HASH_CELL_SIZE);
        const cx = ((hx % hashW) + hashW) % hashW;
        const cy = ((hy % hashH) + hashH) % hashH;
        const slot = cy * hashW + cx;
        hashNext[i] = hashHead[slot];
        hashHead[slot] = i;
      }
    }

    type Seeder = { name: string; fn: () => void };
    const seeders: Seeder[] = [
      {
        name: 'scatter',
        fn: () => {
          for (let i = 0; i < N_PARTICLES; i++) {
            positions[i * 2] = Math.random() * W_world;
            positions[i * 2 + 1] = Math.random() * H_world;
          }
        },
      },
      {
        name: 'clusters',
        fn: () => {
          const k = 6 + ((Math.random() * 8) | 0);
          const cxs = new Float32Array(k);
          const cys = new Float32Array(k);
          for (let i = 0; i < k; i++) {
            cxs[i] = Math.random() * W_world;
            cys[i] = Math.random() * H_world;
          }
          const sigma = 2.5 + Math.random() * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            const c = (Math.random() * k) | 0;
            // Box–Muller for a 2D Gaussian offset.
            const u1 = Math.random() || 1e-9;
            const u2 = Math.random();
            const mag = Math.sqrt(-2 * Math.log(u1)) * sigma;
            const ang = 2 * Math.PI * u2;
            const px = cxs[c] + Math.cos(ang) * mag;
            const py = cys[c] + Math.sin(ang) * mag;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'rings',
        fn: () => {
          const k = 3 + ((Math.random() * 4) | 0);
          const perRing = Math.ceil(N_PARTICLES / k);
          let idx = 0;
          for (let ri = 0; ri < k && idx < N_PARTICLES; ri++) {
            const cx = Math.random() * W_world;
            const cy = Math.random() * H_world;
            const radius = 4 + Math.random() * 6;
            const count = Math.min(perRing, N_PARTICLES - idx);
            const phase = Math.random() * Math.PI * 2;
            for (let i = 0; i < count; i++) {
              const theta = phase + (i / count) * Math.PI * 2;
              const jitter = (Math.random() - 0.5) * 0.6;
              const px = cx + Math.cos(theta) * (radius + jitter);
              const py = cy + Math.sin(theta) * (radius + jitter);
              positions[idx * 2] = ((px % W_world) + W_world) % W_world;
              positions[idx * 2 + 1] = ((py % H_world) + H_world) % H_world;
              idx++;
            }
          }
          for (; idx < N_PARTICLES; idx++) {
            positions[idx * 2] = Math.random() * W_world;
            positions[idx * 2 + 1] = Math.random() * H_world;
          }
        },
      },
      {
        name: 'jitter-grid',
        fn: () => {
          const cols = Math.max(1, Math.round(Math.sqrt(N_PARTICLES * W_world / H_world)));
          const rows = Math.max(1, Math.ceil(N_PARTICLES / cols));
          const dx = W_world / cols;
          const dy = H_world / rows;
          let idx = 0;
          for (let r = 0; r < rows && idx < N_PARTICLES; r++) {
            for (let c = 0; c < cols && idx < N_PARTICLES; c++) {
              positions[idx * 2] = (c + 0.5 + (Math.random() - 0.5) * 0.5) * dx;
              positions[idx * 2 + 1] = (r + 0.5 + (Math.random() - 0.5) * 0.5) * dy;
              idx++;
            }
          }
        },
      },
      {
        name: 'streak',
        fn: () => {
          // Particles laid out along a random line, biased to seed cluster
          // formation along a coherent direction.
          const angle = Math.random() * Math.PI * 2;
          const ax = Math.cos(angle);
          const ay = Math.sin(angle);
          const span = Math.min(W_world, H_world) * 0.45;
          const cx0 = W_world * 0.5;
          const cy0 = H_world * 0.5;
          for (let i = 0; i < N_PARTICLES; i++) {
            const t = (i / N_PARTICLES - 0.5) * span * 2;
            const j = (Math.random() - 0.5) * 4;
            const px = cx0 + ax * t - ay * j;
            const py = cy0 + ay * t + ax * j;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
    ];

    let deck: number[] = [];
    let lastSeeder = -1;
    function refillDeck(avoid: number) {
      const idxs: number[] = [];
      for (let i = 0; i < seeders.length; i++) idxs.push(i);
      for (let i = idxs.length - 1; i > 0; i--) {
        const j = (Math.random() * (i + 1)) | 0;
        const t = idxs[i]; idxs[i] = idxs[j]; idxs[j] = t;
      }
      if (avoid >= 0 && idxs.length > 1 && idxs[0] === avoid) {
        const t = idxs[0]; idxs[0] = idxs[1]; idxs[1] = t;
      }
      deck = idxs;
    }
    function nextSeeder(): number {
      if (deck.length === 0) refillDeck(lastSeeder);
      return deck.shift()!;
    }

    function reseed() {
      params = pickParams();
      lastSeeder = nextSeeder();
      seeders[lastSeeder].fn();
      palette = buildPalette(pickStops());
      stepCount = 0;
      syncSliders();
    }

    function resize() {
      W_grid = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H_grid = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W_grid;
      canvas.height = H_grid;
      W_world = W_grid / CELLS_PER_UNIT;
      H_world = H_grid / CELLS_PER_UNIT;
      hashW = Math.max(1, Math.floor(W_world / HASH_CELL_SIZE));
      hashH = Math.max(1, Math.floor(H_world / HASH_CELL_SIZE));
      positions = new Float32Array(N_PARTICLES * 2);
      U = new Float32Array(N_PARTICLES);
      Gp = new Float32Array(N_PARTICLES);
      F = new Float32Array(N_PARTICLES * 2);
      field = new Float32Array(W_grid * H_grid);
      img = ctx.createImageData(W_grid, H_grid);
      hashHead = new Int32Array(hashW * hashH);
      hashNext = new Int32Array(N_PARTICLES);
      reseed();
    }

    function step() {
      rebuildHash();
      // Hoist params into locals — these inner loops run 10⁴⁺ times per step.
      const muK = params.muK;
      const sigmaK2 = params.sigmaK2;
      const muG = params.muG;
      const sigmaG2 = params.sigmaG2;
      const wK = params.wK;
      const cRep = params.cRep;
      const kernelRange = params.kernelRange;
      const kernelRangeSq = params.kernelRangeSq;

      // Pass 1: U(p_i) for every particle by summing kernel contributions
      // from all neighbors in the 3×3 hash-cell window.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2];
        const py = positions[i * 2 + 1];
        const hx = Math.floor(px / HASH_CELL_SIZE);
        const hy = Math.floor(py / HASH_CELL_SIZE);
        let u = 0;
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const cx = (((hx + dx) % hashW) + hashW) % hashW;
            const cy = (((hy + dy) % hashH) + hashH) % hashH;
            let j = hashHead[cy * hashW + cx];
            while (j !== -1) {
              const dxw = wrap(px - positions[j * 2], W_world);
              const dyw = wrap(py - positions[j * 2 + 1], H_world);
              const r2 = dxw * dxw + dyw * dyw;
              if (r2 < kernelRangeSq) {
                const r = Math.sqrt(r2);
                const dk = (r - muK);
                u += wK * Math.exp(-(dk * dk) / sigmaK2);
              }
              j = hashNext[j];
            }
          }
        }
        U[i] = u;
      }

      // Cache G'(U_i) for each particle so the force pass doesn't recompute.
      for (let i = 0; i < N_PARTICLES; i++) {
        const d = U[i] - muG;
        Gp[i] = -2 * d / sigmaG2 * Math.exp(-(d * d) / sigmaG2);
      }

      // Pass 2: pair-wise force on each particle. Growth-driven force on i
      // from j is (G'(U_i) + G'(U_j)) · K'(r) · (p_i − p_j)/r; repulsion
      // adds 2·c_rep·(1−r) along the same axis when r < 1.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2];
        const py = positions[i * 2 + 1];
        const hx = Math.floor(px / HASH_CELL_SIZE);
        const hy = Math.floor(py / HASH_CELL_SIZE);
        const Gpi = Gp[i];
        let fx = 0;
        let fy = 0;
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const cx = (((hx + dx) % hashW) + hashW) % hashW;
            const cy = (((hy + dy) % hashH) + hashH) % hashH;
            let j = hashHead[cy * hashW + cx];
            while (j !== -1) {
              if (j === i) { j = hashNext[j]; continue; }
              const dxw = wrap(px - positions[j * 2], W_world);
              const dyw = wrap(py - positions[j * 2 + 1], H_world);
              const r2 = dxw * dxw + dyw * dyw;
              if (r2 < 1e-10) { j = hashNext[j]; continue; }
              const r = Math.sqrt(r2);
              const ux = dxw / r;
              const uy = dyw / r;
              if (r < 1.0) {
                const rep = 2 * cRep * (1 - r);
                fx += rep * ux;
                fy += rep * uy;
              }
              if (r < kernelRange) {
                const dk = (r - muK);
                const Kr = Math.exp(-(dk * dk) / sigmaK2);
                const Kp = -2 * dk / sigmaK2 * Kr * wK;
                const ff = (Gpi + Gp[j]) * Kp;
                fx += ff * ux;
                fy += ff * uy;
              }
              j = hashNext[j];
            }
          }
        }
        F[i * 2] = fx;
        F[i * 2 + 1] = fy;
      }

      // Overdamped integration; wrap to torus. A small per-step Brownian
      // jitter keeps the field from settling into perfectly static patterns.
      const noise = params.noise;
      for (let i = 0; i < N_PARTICLES; i++) {
        let nx = positions[i * 2] + DT * F[i * 2];
        let ny = positions[i * 2 + 1] + DT * F[i * 2 + 1];
        if (noise > 0) {
          nx += (Math.random() - 0.5) * 2 * noise;
          ny += (Math.random() - 0.5) * 2 * noise;
        }
        nx = ((nx % W_world) + W_world) % W_world;
        ny = ((ny % H_world) + H_world) % H_world;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
      }
      stepCount++;
      if (stepCount >= RESEED_AFTER) reseed();
    }

    function draw() {
      if (!img) return;
      field.fill(0);
      const muK = params.muK;
      const sigmaK2 = params.sigmaK2;
      const wK = params.wK;
      const muG = params.muG;
      const kernelRangeSq = params.kernelRangeSq;
      const renderRangeCells = params.renderRangeCells;

      // Splat each particle's kernel onto the field grid. Wraps on the torus.
      for (let p = 0; p < N_PARTICLES; p++) {
        const px = positions[p * 2] * CELLS_PER_UNIT;
        const py = positions[p * 2 + 1] * CELLS_PER_UNIT;
        const cx = Math.round(px);
        const cy = Math.round(py);
        for (let dy = -renderRangeCells; dy <= renderRangeCells; dy++) {
          for (let dx = -renderRangeCells; dx <= renderRangeCells; dx++) {
            const ddx = (cx + dx - px) / CELLS_PER_UNIT;
            const ddy = (cy + dy - py) / CELLS_PER_UNIT;
            const r2 = ddx * ddx + ddy * ddy;
            if (r2 > kernelRangeSq) continue;
            const r = Math.sqrt(r2);
            const dk = r - muK;
            const w = wK * Math.exp(-(dk * dk) / sigmaK2);
            if (w < 1e-5) continue;
            const x = (((cx + dx) % W_grid) + W_grid) % W_grid;
            const y = (((cy + dy) % H_grid) + H_grid) % H_grid;
            field[y * W_grid + x] += w;
          }
        }
      }

      // Map field strength to a palette index, clipping at ~1.4·μ_G so dense
      // creature interiors saturate but the outer halo still resolves into
      // distinct bands.
      const scale = 1 / (muG * 1.4);
      const data = img.data;
      const len = field.length;
      for (let i = 0; i < len; i++) {
        let v = field[i] * scale;
        if (v > 1) v = 1;
        let idx = (v * N_LEVELS) | 0;
        if (idx >= N_LEVELS) idx = N_LEVELS - 1;
        const c = palette[idx];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    // ── Sliders ─────────────────────────────────────────────────────────
    type SliderKey = 'muK' | 'sigmaK' | 'wK' | 'muG' | 'sigmaG' | 'cRep' | 'noise';
    const SLIDER_KEYS: SliderKey[] = ['muK', 'sigmaK', 'wK', 'muG', 'sigmaG', 'cRep', 'noise'];
    const FORMAT: Record<SliderKey, (n: number) => string> = {
      muK:    (n) => n.toFixed(2),
      sigmaK: (n) => n.toFixed(2),
      wK:     (n) => n.toFixed(4),
      muG:    (n) => n.toFixed(3),
      sigmaG: (n) => n.toFixed(3),
      cRep:   (n) => n.toFixed(2),
      noise:  (n) => n.toFixed(3),
    };
    const sliderEls: Partial<Record<SliderKey, HTMLInputElement>> = {};
    const valEls:    Partial<Record<SliderKey, HTMLElement>>    = {};
    for (const k of SLIDER_KEYS) {
      sliderEls[k] = document.getElementById('s-' + k) as HTMLInputElement;
      valEls[k]    = document.getElementById('v-' + k) as HTMLElement;
    }

    function syncSliders() {
      for (const k of SLIDER_KEYS) {
        const el = sliderEls[k];
        const v = valEls[k];
        if (!el || !v) continue;
        el.value = String(params[k]);
        v.textContent = FORMAT[k](params[k]);
      }
    }

    for (const k of SLIDER_KEYS) {
      const el = sliderEls[k];
      const v = valEls[k];
      if (!el || !v) continue;
      el.addEventListener('input', () => {
        const num = parseFloat(el.value);
        params[k] = num;
        v.textContent = FORMAT[k](num);
        // muK / sigmaK changes invalidate kernelRange and friends.
        if (k === 'muK' || k === 'sigmaK') recompute(params);
        else if (k === 'sigmaG') params.sigmaG2 = num * num;
      });
    }

    const resetBtn = document.getElementById('reset-btn');
    resetBtn?.addEventListener('click', () => reseed());

    // ── Click perturbation ──────────────────────────────────────────────
    // A click on bare background nudges nearby particles outward, like a
    // pebble dropped into the field. Skip clicks on the tune panel and on
    // links/buttons so the foreground UI still works normally.
    const tunePanel = document.getElementById('tune-panel');
    function perturb(wx: number, wy: number) {
      const radius = Math.max(4, params.muK * 1.5);
      const radius2 = radius * radius;
      const strength = 4;
      for (let i = 0; i < N_PARTICLES; i++) {
        const dxw = wrap(positions[i * 2] - wx, W_world);
        const dyw = wrap(positions[i * 2 + 1] - wy, H_world);
        const r2 = dxw * dxw + dyw * dyw;
        if (r2 >= radius2 || r2 < 1e-6) continue;
        const r = Math.sqrt(r2);
        const t = 1 - r / radius;
        const kick = strength * t * t;
        let nx = positions[i * 2] + (dxw / r) * kick;
        let ny = positions[i * 2 + 1] + (dyw / r) * kick;
        nx = ((nx % W_world) + W_world) % W_world;
        ny = ((ny % H_world) + H_world) % H_world;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
      }
    }

    window.addEventListener('pointerdown', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      if (target.closest('a, button, input, label, .tune-panel')) return;
      const wx = (e.clientX / window.innerWidth) * W_world;
      const wy = (e.clientY / window.innerHeight) * H_world;
      perturb(wx, wy);
    });

    resize();
    syncSliders();
    window.addEventListener('resize', resize);

    if (reduce) {
      for (let i = 0; i < 200; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 50;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>
