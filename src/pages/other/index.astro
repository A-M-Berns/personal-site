---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Music, side projects, and miscellany.">
  <div class="other-shell">
    <canvas id="lenia-sim" class="lenia-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Music, side projects, and miscellany.</span></p>
    </header>
    <article class="note">
      <ul>
        <li><span class="hl"><a href="/music/">Music</a></span></li>
      </ul>
    </article>
  </div>
</Base>

<script>
  // Lenia: continuous cellular automaton on a torus. Each cell holds a value
  // in [0, 1]. Per step, convolve the field with a bell-ring kernel, pass the
  // result through a Gaussian growth function, and integrate with small dt.
  // With Orbium-ish parameters (mu≈0.15, sigma≈0.022, R=10), random circular
  // patches usually evolve into pulsing blobs and gliders before dissolving.
  const canvas = document.getElementById('lenia-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N = 8;
    const CELL_PX = 6;
    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const lo = Math.floor((i * colorPool.length) / N);
        const hi = Math.floor(((i + 1) * colorPool.length) / N);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    // Lenia parameters.
    const R = 10;
    const T = 10;
    const dt = 1 / T;
    const mu = 0.14;
    const sigma = 0.022;

    // Bell-ring kernel core: peaks at r=0.5, vanishes at r=0 and r=1. Standard
    // Lenia "core" function K_C(r) = exp(α − α / (4r(1−r))) with α=4.
    function kernelCore(r: number): number {
      if (r <= 0 || r >= 1) return 0;
      const a = 4;
      return Math.exp(a - a / (4 * r * (1 - r)));
    }

    // Flatten the kernel into parallel arrays of nonzero entries — the inner
    // convolution loop indexes these directly, avoiding per-cell branches on
    // zero weights.
    let kdx = new Int16Array(0);
    let kdy = new Int16Array(0);
    let kw = new Float32Array(0);
    let klen = 0;
    {
      const dxs: number[] = [];
      const dys: number[] = [];
      const ws: number[] = [];
      let total = 0;
      for (let dy = -R; dy <= R; dy++) {
        for (let dx = -R; dx <= R; dx++) {
          if (dx === 0 && dy === 0) continue;
          const r = Math.sqrt(dx * dx + dy * dy) / R;
          const w = kernelCore(r);
          if (w <= 1e-4) continue;
          dxs.push(dx);
          dys.push(dy);
          ws.push(w);
          total += w;
        }
      }
      kdx = new Int16Array(dxs);
      kdy = new Int16Array(dys);
      kw = new Float32Array(ws.length);
      for (let i = 0; i < ws.length; i++) kw[i] = ws[i] / total;
      klen = kdx.length;
    }

    let W = 0;
    let H = 0;
    let A = new Float32Array(0);
    let next = new Float32Array(0);
    let img: ImageData | null = null;
    let palette: RGB[] = buildPalette(pickStops());
    let stepCount = 0;
    const RESEED_AFTER = 1500;

    type Seeder = { name: string; fn: () => void };
    const seeders: Seeder[] = [
      {
        name: 'patches',
        fn: () => {
          A.fill(0);
          const k = 6 + ((Math.random() * 8) | 0);
          for (let i = 0; i < k; i++) {
            const cx = (Math.random() * W) | 0;
            const cy = (Math.random() * H) | 0;
            const r = R + ((Math.random() * R) | 0);
            const r2 = r * r;
            for (let dy = -r; dy <= r; dy++) {
              for (let dx = -r; dx <= r; dx++) {
                if (dx * dx + dy * dy > r2) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                A[y * W + x] = 0.6 + Math.random() * 0.4;
              }
            }
          }
        },
      },
      {
        name: 'blobs',
        fn: () => {
          A.fill(0);
          const k = 4 + ((Math.random() * 5) | 0);
          for (let i = 0; i < k; i++) {
            const cx = (Math.random() * W) | 0;
            const cy = (Math.random() * H) | 0;
            const sx = R * (0.7 + Math.random() * 0.8);
            const sy = R * (0.7 + Math.random() * 0.8);
            const reach = Math.ceil(Math.max(sx, sy) * 2.5);
            for (let dy = -reach; dy <= reach; dy++) {
              for (let dx = -reach; dx <= reach; dx++) {
                const v = Math.exp(-(dx * dx) / (2 * sx * sx) - (dy * dy) / (2 * sy * sy));
                if (v < 0.05) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                A[y * W + x] = Math.min(1, A[y * W + x] + v);
              }
            }
          }
        },
      },
      {
        name: 'rings',
        fn: () => {
          A.fill(0);
          const k = 3 + ((Math.random() * 4) | 0);
          for (let i = 0; i < k; i++) {
            const cx = (Math.random() * W) | 0;
            const cy = (Math.random() * H) | 0;
            const inner = R * 0.45;
            const outer = R * 1.1;
            const reach = Math.ceil(outer);
            for (let dy = -reach; dy <= reach; dy++) {
              for (let dx = -reach; dx <= reach; dx++) {
                const r = Math.sqrt(dx * dx + dy * dy);
                if (r < inner || r > outer) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                A[y * W + x] = 0.65 + Math.random() * 0.35;
              }
            }
          }
        },
      },
      {
        name: 'speckle',
        fn: () => {
          A.fill(0);
          const target = Math.floor(W * H * 0.0015);
          for (let i = 0; i < target; i++) {
            const cx = (Math.random() * W) | 0;
            const cy = (Math.random() * H) | 0;
            const r = 2 + ((Math.random() * 4) | 0);
            const r2 = r * r;
            for (let dy = -r; dy <= r; dy++) {
              for (let dx = -r; dx <= r; dx++) {
                if (dx * dx + dy * dy > r2) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                A[y * W + x] = 1;
              }
            }
          }
        },
      },
      {
        name: 'drift',
        fn: () => {
          // Cluster of small dense circles biased along a random axis — gives
          // the field a coherent direction so emergent gliders tend to travel
          // together rather than scattering immediately.
          A.fill(0);
          const angle = Math.random() * Math.PI * 2;
          const dxA = Math.cos(angle);
          const dyA = Math.sin(angle);
          const k = 8 + ((Math.random() * 6) | 0);
          for (let i = 0; i < k; i++) {
            const t = (i / k - 0.5) * Math.min(W, H) * 0.9;
            const j = (Math.random() - 0.5) * Math.min(W, H) * 0.4;
            const cx = ((W / 2 + dxA * t - dyA * j) | 0);
            const cy = ((H / 2 + dyA * t + dxA * j) | 0);
            const r = Math.floor(R * (0.7 + Math.random() * 0.5));
            const r2 = r * r;
            for (let dy = -r; dy <= r; dy++) {
              for (let dx = -r; dx <= r; dx++) {
                if (dx * dx + dy * dy > r2) continue;
                const x = ((cx + dx) % W + W) % W;
                const y = ((cy + dy) % H + H) % H;
                A[y * W + x] = 0.65 + Math.random() * 0.35;
              }
            }
          }
        },
      },
    ];

    let deck: number[] = [];
    let lastSeeder = -1;
    function refillDeck(avoid: number) {
      const idxs: number[] = [];
      for (let i = 0; i < seeders.length; i++) idxs.push(i);
      for (let i = idxs.length - 1; i > 0; i--) {
        const j = (Math.random() * (i + 1)) | 0;
        const t = idxs[i]; idxs[i] = idxs[j]; idxs[j] = t;
      }
      if (avoid >= 0 && idxs.length > 1 && idxs[0] === avoid) {
        const t = idxs[0]; idxs[0] = idxs[1]; idxs[1] = t;
      }
      deck = idxs;
    }
    function nextSeeder(): number {
      if (deck.length === 0) refillDeck(lastSeeder);
      return deck.shift()!;
    }

    function reseed() {
      lastSeeder = nextSeeder();
      seeders[lastSeeder].fn();
      palette = buildPalette(pickStops());
      stepCount = 0;
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      A = new Float32Array(W * H);
      next = new Float32Array(W * H);
      img = ctx.createImageData(W, H);
      reseed();
    }

    function step() {
      let total = 0;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          let u = 0;
          for (let i = 0; i < klen; i++) {
            let nx = x + kdx[i];
            let ny = y + kdy[i];
            if (nx < 0) nx += W; else if (nx >= W) nx -= W;
            if (ny < 0) ny += H; else if (ny >= H) ny -= H;
            u += A[ny * W + nx] * kw[i];
          }
          const d = u - mu;
          const g = 2 * Math.exp(-(d * d) / (2 * sigma * sigma)) - 1;
          let v = A[y * W + x] + dt * g;
          if (v < 0) v = 0;
          else if (v > 1) v = 1;
          next[y * W + x] = v;
          total += v;
        }
      }
      const tmp = A; A = next; next = tmp;
      stepCount++;

      const avg = total / (W * H);
      // Reseed if the field has died out, runaway-saturated, or run long enough.
      if (avg < 0.003 || avg > 0.55 || stepCount >= RESEED_AFTER) reseed();
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let i = 0; i < A.length; i++) {
        let idx = (A[i] * N) | 0;
        if (idx >= N) idx = N - 1;
        const c = palette[idx];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    resize();
    window.addEventListener('resize', resize);

    if (reduce) {
      for (let i = 0; i < 200; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 100;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>
