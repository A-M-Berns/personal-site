---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Side projects and miscellaneous experiments.">
  <div class="other-shell">
    <canvas id="dla-sim" class="dla-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Side projects and miscellaneous experiments.</span></p>
    </header>
    <article class="note other-note">
      <p><span class="hl">Background: diffusion-limited aggregation.</span></p>
    </article>
    <div class="anim-controls">
      <button id="dla-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="dla-restart" type="button" aria-label="Reset DLA">Reset</button>
    </div>
    <dialog id="dla-about" class="anim-about" aria-labelledby="dla-about-title">
      <button class="anim-about-close" type="button" aria-label="Close">×</button>
      <h2 id="dla-about-title">About this animation</h2>
      <p>
        Diffusion-limited aggregation (Witten and Sander, 1981): seed cells
        anchor a growing cluster. Random walkers are released from a circle
        just outside the cluster and wander until they touch it; on contact
        they freeze in place, becoming part of the cluster. The resulting
        structure is a fractal of dimension ~1.71 in two dimensions.
      </p>
    </dialog>
    <aside class="dla-panel" aria-label="DLA controls">
      <div class="dla-panel-head">
        <h2>DLA</h2>
        <button id="dla-reset" type="button">Reset</button>
      </div>
      <div class="dla-panel-body">
        <label class="dla-panel-field">
          <span>preset</span>
          <select id="dla-preset">
            <option value="random" selected>random</option>
            <option value="classic">classic</option>
            <option value="lightning">lightning</option>
            <option value="frost">frost</option>
            <option value="coral">coral</option>
            <option value="speckle">speckle</option>
          </select>
        </label>
        <label class="dla-panel-field">
          <span>seed</span>
          <select id="dla-seed-mode">
            <option value="point-center" selected>point-center</option>
            <option value="point-random">point-random</option>
            <option value="top-edge">top-edge</option>
            <option value="bottom-edge">bottom-edge</option>
            <option value="vertical-stripe">vertical-stripe</option>
            <option value="circle-outline">circle-outline</option>
            <option value="multi-point">multi-point</option>
          </select>
        </label>
        <label class="dla-panel-field">
          <span>spawn</span>
          <select id="dla-spawn-mode">
            <option value="cluster-shell" selected>cluster-shell</option>
            <option value="top-edge">top-edge</option>
            <option value="bottom-edge">bottom-edge</option>
            <option value="boundary-uniform">boundary-uniform</option>
          </select>
        </label>
        <div class="dla-panel-row">
          <label for="dla-drift-x">drift x</label>
          <input id="dla-drift-x" type="range" min="-1" max="1" step="0.05" value="0" />
          <span id="dla-drift-x-value">0.00</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-drift-y">drift y</label>
          <input id="dla-drift-y" type="range" min="-1" max="1" step="0.05" value="0" />
          <span id="dla-drift-y-value">0.00</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-pstick">p stick</label>
          <input id="dla-pstick" type="range" min="0.05" max="1" step="0.05" value="1" />
          <span id="dla-pstick-value">1.00</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-speed">speed</label>
          <input id="dla-speed" type="range" min="50" max="3000" step="50" value="350" />
          <span id="dla-speed-value">350</span>
        </div>
        <label class="dla-panel-field">
          <span>stick</span>
          <select id="dla-stick-rule">
            <option value="4" selected>4-neighbor</option>
            <option value="8">8-neighbor</option>
          </select>
        </label>
        <label class="dla-panel-field">
          <span>walk</span>
          <select id="dla-walk-rule">
            <option value="4">4-direction</option>
            <option value="8" selected>8-direction</option>
          </select>
        </label>
        <label class="dla-panel-field">
          <span>render</span>
          <select id="dla-render-mode">
            <option value="pixel">pixel</option>
            <option value="lines" selected>lines</option>
            <option value="both">both</option>
          </select>
        </label>
        <label class="dla-panel-field">
          <span>color</span>
          <select id="dla-color-mode">
            <option value="age-cycle" selected>age-cycle</option>
            <option value="radial">radial</option>
            <option value="branch">branch</option>
            <option value="speckle">speckle</option>
          </select>
        </label>
        <dl class="dla-stats">
          <div><dt>seed</dt><dd id="dla-seed-readout">-</dd></div>
          <div><dt>cells</dt><dd id="dla-count">-</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</Base>

<style>
  .dla-sim {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    opacity: 0.85;
  }
  html.render-pixel .dla-sim {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  .dla-panel {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 3;
    width: 16.5rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .dla-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .dla-panel-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .dla-panel button {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
  }
  .dla-panel button:hover {
    color: var(--ink);
    border-color: var(--muted);
  }
  .dla-panel-field {
    display: grid;
    grid-template-columns: 4.3rem 1fr;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .dla-panel-field span {
    font-size: 0.7rem;
    color: var(--muted);
  }
  .dla-panel-field select {
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    color: var(--muted);
    background: rgba(14, 14, 16, 0.55);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.2rem 0.35rem;
  }
  .dla-panel-row {
    display: grid;
    grid-template-columns: 4.3rem 1fr 3.3rem;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .dla-panel-row label {
    font-size: 0.7rem;
    color: var(--muted);
  }
  .dla-panel-row input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    margin: 0;
  }
  .dla-panel-row span {
    font-size: 0.68rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .dla-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin: 0.6rem 0 0;
    font-size: 0.65rem;
  }
  .dla-stats div {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.3rem;
  }
  .dla-stats dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .dla-stats dd {
    margin: 0;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  const canvas = document.getElementById('dla-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const seedSelect = document.getElementById('dla-seed-mode') as HTMLSelectElement | null;
    const spawnSelect = document.getElementById('dla-spawn-mode') as HTMLSelectElement | null;
    const driftXInput = document.getElementById('dla-drift-x') as HTMLInputElement | null;
    const driftYInput = document.getElementById('dla-drift-y') as HTMLInputElement | null;
    const driftXValue = document.getElementById('dla-drift-x-value');
    const driftYValue = document.getElementById('dla-drift-y-value');
    const pStickInput = document.getElementById('dla-pstick') as HTMLInputElement | null;
    const pStickValue = document.getElementById('dla-pstick-value');
    const stickRuleSelect = document.getElementById('dla-stick-rule') as HTMLSelectElement | null;
    const walkRuleSelect = document.getElementById('dla-walk-rule') as HTMLSelectElement | null;
    const renderModeSelect = document.getElementById('dla-render-mode') as HTMLSelectElement | null;
    const speedInput = document.getElementById('dla-speed') as HTMLInputElement | null;
    const speedValue = document.getElementById('dla-speed-value');
    const presetSelect = document.getElementById('dla-preset') as HTMLSelectElement | null;
    const colorModeSelect = document.getElementById('dla-color-mode') as HTMLSelectElement | null;
    const seedReadout = document.getElementById('dla-seed-readout');
    const countReadout = document.getElementById('dla-count');

    const CELL_PX = 2;
    const MAX_WALK_STEPS = 4000;
    const SPAWN_MARGIN = 4;
    const KILL_MARGIN = 24;
    const SKIP_BUFFER = 2;
    const AUTO_RESET_MS = 90_000;

    type SeedMode =
      | 'point-center' | 'point-random' | 'top-edge' | 'bottom-edge'
      | 'vertical-stripe' | 'circle-outline' | 'multi-point';
    type SpawnMode = 'cluster-shell' | 'top-edge' | 'bottom-edge' | 'boundary-uniform';
    type RenderMode = 'pixel' | 'lines' | 'both';
    type ColorMode = 'speckle' | 'age-cycle' | 'radial' | 'branch';
    type PresetName = 'random' | 'classic' | 'lightning' | 'frost' | 'coral' | 'speckle';

    const COLOR_CYCLE = 800;
    const BRANCH_RECOLOR_PROB = 0.0025;

    const DX8 = [1, 1, 0, -1, -1, -1, 0, 1];
    const DY8 = [0, 1, 1, 1, 0, -1, -1, -1];

    let W = 0;
    let H = 0;
    let state = new Uint8Array(0);
    let parents = new Int32Array(0);
    let cellPaletteIdx = new Uint8Array(0);
    let palette: number[][] = [];
    let bxmin = 0, bxmax = 0, bymin = 0, bymax = 0;
    let cycleStart = 0;
    let rng = mulberry32(1);
    let stuckCount = 0;
    let seedHash = 0;
    let radialMaxDist = 16;

    let seedMode: SeedMode = (seedSelect?.value as SeedMode) ?? 'point-center';
    let spawnMode: SpawnMode = (spawnSelect?.value as SpawnMode) ?? 'cluster-shell';
    let driftX = Number(driftXInput?.value ?? 0);
    let driftY = Number(driftYInput?.value ?? 0);
    let pStick = Number(pStickInput?.value ?? 1);
    let stickRule: 4 | 8 = (Number(stickRuleSelect?.value ?? 4) === 8 ? 8 : 4);
    let walkRule: 4 | 8 = (Number(walkRuleSelect?.value ?? 8) === 4 ? 4 : 8);
    let renderMode: RenderMode = ((renderModeSelect?.value as RenderMode) ?? 'lines');
    let colorMode: ColorMode = ((colorModeSelect?.value as ColorMode) ?? 'age-cycle');
    let stepsPerFrame = Number(speedInput?.value ?? 350);
    let preset: PresetName = ((presetSelect?.value as PresetName) ?? 'random');
    applyRenderClass();

    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex);

    function parseHex(h: string) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function mulberry32(n: number) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function idx(x: number, y: number) { return y * W + x; }

    function pickPalette() {
      const indices = new Set<number>();
      while (indices.size < 4) indices.add(Math.floor(rng() * colorPool.length));
      palette = Array.from(indices).map((i) => colorPool[i]);
    }

    function applyRenderClass() {
      document.documentElement.classList.toggle('render-pixel', renderMode === 'pixel');
    }

    function setStuck(x: number, y: number, parent: number) {
      const i = idx(x, y);
      state[i] = 1;
      parents[i] = parent;
      stuckCount++;
      if (x < bxmin) bxmin = x;
      if (x > bxmax) bxmax = x;
      if (y < bymin) bymin = y;
      if (y > bymax) bymax = y;
      const cdx = x - ((bxmin + bxmax) >> 1);
      const cdy = y - ((bymin + bymax) >> 1);
      const r = Math.sqrt(cdx * cdx + cdy * cdy);
      if (r > radialMaxDist) radialMaxDist = r;
      if (colorMode === 'branch') {
        if (parent < 0 || rng() < BRANCH_RECOLOR_PROB) {
          cellPaletteIdx[i] = Math.floor(rng() * palette.length);
        } else {
          cellPaletteIdx[i] = cellPaletteIdx[parent];
        }
      }
      paintCell(x, y, parent);
    }

    function lerpRGB(a: number[], b: number[], t: number): number[] {
      return [
        a[0] + (b[0] - a[0]) * t,
        a[1] + (b[1] - a[1]) * t,
        a[2] + (b[2] - a[2]) * t,
      ];
    }

    function paletteCycle(t: number): number[] {
      const n = palette.length;
      const u = ((t % 1) + 1) % 1;
      const seg = u * n;
      const i = Math.floor(seg) % n;
      const j = (i + 1) % n;
      return lerpRGB(palette[i], palette[j], seg - Math.floor(seg));
    }

    function colorFor(x: number, y: number, parent: number, cellIdx: number): number[] {
      switch (colorMode) {
        case 'age-cycle':
          return paletteCycle(stuckCount / COLOR_CYCLE);
        case 'radial': {
          const cx = (bxmin + bxmax) >> 1;
          const cy = (bymin + bymax) >> 1;
          const dx = x - cx;
          const dy = y - cy;
          const r = Math.sqrt(dx * dx + dy * dy);
          return paletteCycle(r / Math.max(1, radialMaxDist) * (palette.length - 1) / palette.length);
        }
        case 'branch':
          return palette[cellPaletteIdx[cellIdx]] || palette[0];
        case 'speckle':
        default:
          return palette[(x * 73856093 ^ y * 19349663 ^ stuckCount * 83492791) & (palette.length - 1)] || palette[0];
      }
    }

    function paintCell(x: number, y: number, parent: number) {
      const c = colorFor(x, y, parent, idx(x, y));
      const r = Math.round(c[0]);
      const g = Math.round(c[1]);
      const b = Math.round(c[2]);
      const css = `rgb(${r},${g},${b})`;
      if (renderMode === 'pixel' || renderMode === 'both' || parent < 0) {
        ctx.fillStyle = css;
        ctx.fillRect(x, y, 1, 1);
      }
      if ((renderMode === 'lines' || renderMode === 'both') && parent >= 0) {
        const px = parent % W;
        const py = (parent / W) | 0;
        ctx.strokeStyle = css;
        ctx.beginPath();
        ctx.moveTo(px + 0.5, py + 0.5);
        ctx.lineTo(x + 0.5, y + 0.5);
        ctx.stroke();
      }
    }

    function placeSeed() {
      bxmin = W; bxmax = -1; bymin = H; bymax = -1;
      stuckCount = 0;
      const cx = W >> 1;
      const cy = H >> 1;
      switch (seedMode) {
        case 'point-center':
          setStuck(cx, cy, -1);
          break;
        case 'point-random': {
          const x = Math.floor(rng() * (W - 4)) + 2;
          const y = Math.floor(rng() * (H - 4)) + 2;
          setStuck(x, y, -1);
          break;
        }
        case 'top-edge': {
          const y = 1;
          for (let x = 0; x < W; x++) setStuck(x, y, -1);
          break;
        }
        case 'bottom-edge': {
          const y = H - 2;
          for (let x = 0; x < W; x++) setStuck(x, y, -1);
          break;
        }
        case 'vertical-stripe': {
          const x = cx;
          for (let y = 0; y < H; y++) setStuck(x, y, -1);
          break;
        }
        case 'circle-outline': {
          const r = Math.floor(Math.min(W, H) * 0.3);
          const steps = Math.floor(2 * Math.PI * r);
          for (let i = 0; i < steps; i++) {
            const a = (i / steps) * 2 * Math.PI;
            const x = Math.round(cx + r * Math.cos(a));
            const y = Math.round(cy + r * Math.sin(a));
            if (x >= 1 && x < W - 1 && y >= 1 && y < H - 1 && !state[idx(x, y)]) setStuck(x, y, -1);
          }
          break;
        }
        case 'multi-point': {
          const n = 4 + Math.floor(rng() * 5);
          for (let i = 0; i < n; i++) {
            const x = Math.floor(rng() * (W - 8)) + 4;
            const y = Math.floor(rng() * (H - 8)) + 4;
            if (!state[idx(x, y)]) setStuck(x, y, -1);
          }
          break;
        }
      }
    }

    function seedCycle() {
      if (preset === 'random') applyPreset(pickRandomPreset());
      seedHash = (Date.now() ^ Math.floor(Math.random() * 0xffffffff)) >>> 0;
      rng = mulberry32(seedHash);
      pickPalette();
      state.fill(0);
      cellPaletteIdx.fill(0);
      radialMaxDist = 16;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      placeSeed();
      cycleStart = performance.now();
      updateReadout();
    }

    type PresetSpec = {
      seedMode: SeedMode; spawnMode: SpawnMode;
      driftX: number; driftY: number;
      pStick: number; stickRule: 4 | 8; walkRule: 4 | 8;
      renderMode: RenderMode; colorMode: ColorMode;
    };
    const PRESETS: Record<Exclude<PresetName, 'random'>, PresetSpec> = {
      classic:   { seedMode: 'point-center',     spawnMode: 'cluster-shell', driftX: 0,  driftY: 0,    pStick: 1,   stickRule: 4, walkRule: 8, renderMode: 'lines', colorMode: 'age-cycle' },
      lightning: { seedMode: 'top-edge',         spawnMode: 'top-edge',      driftX: 0,  driftY: 0.55, pStick: 1,   stickRule: 4, walkRule: 8, renderMode: 'lines', colorMode: 'age-cycle' },
      frost:     { seedMode: 'multi-point',      spawnMode: 'cluster-shell', driftX: 0,  driftY: 0,    pStick: 0.4, stickRule: 4, walkRule: 8, renderMode: 'lines', colorMode: 'branch' },
      coral:     { seedMode: 'circle-outline',   spawnMode: 'cluster-shell', driftX: 0,  driftY: 0,    pStick: 0.7, stickRule: 8, walkRule: 8, renderMode: 'both',  colorMode: 'radial' },
      speckle:   { seedMode: 'point-center',     spawnMode: 'cluster-shell', driftX: 0,  driftY: 0,    pStick: 1,   stickRule: 4, walkRule: 4, renderMode: 'pixel', colorMode: 'speckle' },
    };
    const PRESET_KEYS = Object.keys(PRESETS) as Array<keyof typeof PRESETS>;
    function pickRandomPreset(): keyof typeof PRESETS {
      return PRESET_KEYS[Math.floor(Math.random() * PRESET_KEYS.length)];
    }
    function applyPreset(name: keyof typeof PRESETS) {
      const p = PRESETS[name];
      seedMode = p.seedMode;
      spawnMode = p.spawnMode;
      driftX = p.driftX;
      driftY = p.driftY;
      pStick = p.pStick;
      stickRule = p.stickRule;
      walkRule = p.walkRule;
      renderMode = p.renderMode;
      colorMode = p.colorMode;
      applyRenderClass();
      if (seedSelect) seedSelect.value = p.seedMode;
      if (spawnSelect) spawnSelect.value = p.spawnMode;
      if (driftXInput) driftXInput.value = String(p.driftX);
      if (driftYInput) driftYInput.value = String(p.driftY);
      if (pStickInput) pStickInput.value = String(p.pStick);
      if (stickRuleSelect) stickRuleSelect.value = String(p.stickRule);
      if (walkRuleSelect) walkRuleSelect.value = String(p.walkRule);
      if (renderModeSelect) renderModeSelect.value = p.renderMode;
      if (colorModeSelect) colorModeSelect.value = p.colorMode;
      if (driftXValue) driftXValue.textContent = p.driftX.toFixed(2);
      if (driftYValue) driftYValue.textContent = p.driftY.toFixed(2);
      if (pStickValue) pStickValue.textContent = p.pStick.toFixed(2);
    }

    function updateReadout() {
      if (seedReadout) seedReadout.textContent = seedHash.toString(16).padStart(8, '0');
      if (countReadout) countReadout.textContent = stuckCount.toLocaleString();
    }

    function spawnWalker(): [number, number] {
      switch (spawnMode) {
        case 'top-edge':
          return [Math.floor(rng() * (W - 2)) + 1, Math.floor(rng() * 3)];
        case 'bottom-edge':
          return [Math.floor(rng() * (W - 2)) + 1, H - 2 - Math.floor(rng() * 3)];
        case 'boundary-uniform': {
          const side = Math.floor(rng() * 4);
          if (side === 0) return [Math.floor(rng() * (W - 2)) + 1, 1];
          if (side === 1) return [Math.floor(rng() * (W - 2)) + 1, H - 2];
          if (side === 2) return [1, Math.floor(rng() * (H - 2)) + 1];
          return [W - 2, Math.floor(rng() * (H - 2)) + 1];
        }
        case 'cluster-shell':
        default: {
          const cx = (bxmin + bxmax) >> 1;
          const cy = (bymin + bymax) >> 1;
          const halfW = (bxmax - bxmin) >> 1;
          const halfH = (bymax - bymin) >> 1;
          const radius = Math.max(halfW, halfH, 4) + SPAWN_MARGIN;
          const a = rng() * Math.PI * 2;
          let x = Math.round(cx + radius * Math.cos(a));
          let y = Math.round(cy + radius * Math.sin(a));
          x = Math.max(1, Math.min(W - 2, x));
          y = Math.max(1, Math.min(H - 2, y));
          return [x, y];
        }
      }
    }

    function distanceToBbox(x: number, y: number) {
      const dx = x < bxmin ? bxmin - x : x > bxmax ? x - bxmax : 0;
      const dy = y < bymin ? bymin - y : y > bymax ? y - bymax : 0;
      return Math.max(dx, dy);
    }

    function biasedDir4(): number {
      const wRight = Math.max(0, 1 + driftX);
      const wLeft = Math.max(0, 1 - driftX);
      const wDown = Math.max(0, 1 + driftY);
      const wUp = Math.max(0, 1 - driftY);
      const total = wRight + wLeft + wDown + wUp;
      if (total <= 0) return Math.floor(rng() * 4);
      let r = rng() * total;
      if ((r -= wRight) < 0) return 0;
      if ((r -= wLeft) < 0) return 1;
      if ((r -= wDown) < 0) return 2;
      return 3;
    }

    function biasedDir8(): number {
      let total = 0;
      const w = [0, 0, 0, 0, 0, 0, 0, 0];
      for (let i = 0; i < 8; i++) {
        const v = 1 + driftX * DX8[i] + driftY * DY8[i];
        w[i] = v > 0 ? v : 0;
        total += w[i];
      }
      if (total <= 0) return Math.floor(rng() * 8);
      let r = rng() * total;
      for (let i = 0; i < 8; i++) {
        if ((r -= w[i]) < 0) return i;
      }
      return 7;
    }

    function findStuckNeighbor(x: number, y: number): number {
      const N = stickRule === 8 ? 8 : 4;
      let pick = -1;
      let count = 0;
      for (let i = 0; i < N; i++) {
        const nx = x + DX8[i];
        const ny = y + DY8[i];
        if (nx < 0 || nx >= W || ny < 0 || ny >= H) continue;
        const ni = idx(nx, ny);
        if (state[ni]) {
          count++;
          if (count === 1 || rng() * count < 1) pick = ni;
        }
      }
      return pick;
    }

    function walkOne() {
      let [x, y] = spawnWalker();
      if (state[idx(x, y)]) return;
      const cx = (bxmin + bxmax) >> 1;
      const cy = (bymin + bymax) >> 1;
      const halfW = (bxmax - bxmin) >> 1;
      const halfH = (bymax - bymin) >> 1;
      const killRadius = Math.max(halfW, halfH, 4) + KILL_MARGIN;
      const kill2 = killRadius * killRadius;
      for (let i = 0; i < MAX_WALK_STEPS; i++) {
        const d = distanceToBbox(x, y);
        if (d > SKIP_BUFFER) {
          const jump = d - SKIP_BUFFER;
          const dir8 = Math.floor(rng() * 8);
          const dx = dir8 === 0 || dir8 === 1 || dir8 === 7 ? 1 : dir8 === 3 || dir8 === 4 || dir8 === 5 ? -1 : 0;
          const dy = dir8 === 1 || dir8 === 2 || dir8 === 3 ? 1 : dir8 === 5 || dir8 === 6 || dir8 === 7 ? -1 : 0;
          x += dx * jump;
          y += dy * jump;
          if (x < 1 || x > W - 2 || y < 1 || y > H - 2) return;
          continue;
        }
        if (state[idx(x, y)] === 0) {
          const parent = findStuckNeighbor(x, y);
          if (parent >= 0 && rng() < pStick) {
            setStuck(x, y, parent);
            return;
          }
        }
        if (walkRule === 8) {
          const dir = biasedDir8();
          x += DX8[dir];
          y += DY8[dir];
        } else {
          const dir = biasedDir4();
          if (dir === 0) x++;
          else if (dir === 1) x--;
          else if (dir === 2) y++;
          else y--;
        }
        const cdx = x - cx;
        const cdy = y - cy;
        if (cdx * cdx + cdy * cdy > kill2) return;
        if (x < 1 || x > W - 2 || y < 1 || y > H - 2) return;
      }
    }

    function step() {
      if (performance.now() - cycleStart >= AUTO_RESET_MS) {
        seedCycle();
        return;
      }
      for (let i = 0; i < stepsPerFrame; i++) walkOne();
      updateReadout();
    }

    function resize() {
      W = Math.max(48, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(36, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      ctx.lineWidth = 1;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      state = new Uint8Array(W * H);
      parents = new Int32Array(W * H);
      cellPaletteIdx = new Uint8Array(W * H);
      seedCycle();
    }

    resize();
    if (!reduce) {
      const loop = () => {
        step();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    } else {
      for (let i = 0; i < 30; i++) step();
    }
    window.addEventListener('resize', resize);

    const aboutDlg = document.getElementById('dla-about') as HTMLDialogElement | null;
    const infoBtn = document.getElementById('dla-info');
    const restartBtn = document.getElementById('dla-restart');
    const panelResetBtn = document.getElementById('dla-reset');
    infoBtn?.addEventListener('click', () => aboutDlg?.showModal());
    restartBtn?.addEventListener('click', () => seedCycle());
    panelResetBtn?.addEventListener('click', () => seedCycle());
    aboutDlg?.querySelector('.anim-about-close')?.addEventListener('click', () => aboutDlg.close());
    aboutDlg?.addEventListener('click', (e) => {
      if (e.target === aboutDlg) aboutDlg.close();
    });

    seedSelect?.addEventListener('change', () => {
      seedMode = seedSelect.value as SeedMode;
      seedCycle();
    });
    spawnSelect?.addEventListener('change', () => {
      spawnMode = spawnSelect.value as SpawnMode;
    });
    driftXInput?.addEventListener('input', () => {
      driftX = Number(driftXInput.value);
      if (driftXValue) driftXValue.textContent = driftX.toFixed(2);
    });
    driftYInput?.addEventListener('input', () => {
      driftY = Number(driftYInput.value);
      if (driftYValue) driftYValue.textContent = driftY.toFixed(2);
    });
    pStickInput?.addEventListener('input', () => {
      pStick = Number(pStickInput.value);
      if (pStickValue) pStickValue.textContent = pStick.toFixed(2);
    });
    stickRuleSelect?.addEventListener('change', () => {
      stickRule = Number(stickRuleSelect.value) === 8 ? 8 : 4;
    });
    walkRuleSelect?.addEventListener('change', () => {
      walkRule = Number(walkRuleSelect.value) === 4 ? 4 : 8;
    });
    renderModeSelect?.addEventListener('change', () => {
      renderMode = renderModeSelect.value as RenderMode;
      applyRenderClass();
    });
    speedInput?.addEventListener('input', () => {
      stepsPerFrame = Number(speedInput.value);
      if (speedValue) speedValue.textContent = String(stepsPerFrame);
    });
    presetSelect?.addEventListener('change', () => {
      preset = presetSelect.value as PresetName;
      if (preset !== 'random') applyPreset(preset);
      seedCycle();
    });
    colorModeSelect?.addEventListener('change', () => {
      colorMode = colorModeSelect.value as ColorMode;
    });
  }
</script>
