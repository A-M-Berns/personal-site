---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Music, side projects, and miscellany.">
  <div class="other-shell">
    <canvas id="lenia-sim" class="lenia-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Music, side projects, and miscellany.</span></p>
    </header>
    <article class="note">
      <ul>
        <li><span class="hl"><a href="/music/">Music</a></span></li>
      </ul>
    </article>

    <aside id="tune-panel" class="tune-panel" aria-label="Particle Lenia parameters">
      <h3>Tune</h3>
      <p class="tune-seeder">seeder: <span id="seeder-label">—</span></p>
      <div class="tune-row">
        <label for="s-muK">μK</label>
        <input type="range" id="s-muK" min="1.5" max="7.0" step="0.05" />
        <span class="val" id="v-muK"></span>
      </div>
      <div class="tune-row">
        <label for="s-sigmaK">σK</label>
        <input type="range" id="s-sigmaK" min="0.3" max="2.0" step="0.02" />
        <span class="val" id="v-sigmaK"></span>
      </div>
      <div class="tune-row">
        <label for="s-wK">wK</label>
        <input type="range" id="s-wK" min="0.005" max="0.12" step="0.0005" />
        <span class="val" id="v-wK"></span>
      </div>
      <div class="tune-row">
        <label for="s-muG">μG</label>
        <input type="range" id="s-muG" min="0.20" max="1.00" step="0.005" />
        <span class="val" id="v-muG"></span>
      </div>
      <div class="tune-row">
        <label for="s-sigmaG">σG</label>
        <input type="range" id="s-sigmaG" min="0.4" max="0.6" step="0.005" />
        <span class="val" id="v-sigmaG"></span>
      </div>
      <div class="tune-row">
        <label for="s-cRep">cRep</label>
        <input type="range" id="s-cRep" min="0.2" max="3.0" step="0.02" />
        <span class="val" id="v-cRep"></span>
      </div>
      <div class="tune-row">
        <label for="s-noise">noise</label>
        <input type="range" id="s-noise" min="0" max="0.30" step="0.002" />
        <span class="val" id="v-noise"></span>
      </div>
      <div class="tune-row">
        <label for="s-flow">flow</label>
        <input type="range" id="s-flow" min="0" max="0.30" step="0.002" />
        <span class="val" id="v-flow"></span>
      </div>
      <button id="reset-btn" type="button">Reset</button>
      <p class="tune-hint">Click on the background to drop colored ink.</p>
    </aside>
  </div>
</Base>

<style>
  .tune-panel {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 3;
    width: 16.5rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .tune-panel h3 {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.4rem;
    color: var(--ink);
  }
  .tune-seeder {
    margin: 0 0 0.55rem;
    font-size: 0.7rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tune-seeder span {
    color: var(--ink);
  }
  .tune-row {
    display: grid;
    grid-template-columns: 3.5ch 1fr 4.5ch;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .tune-row label {
    font-size: 0.78rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tune-row input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    margin: 0;
  }
  .tune-row .val {
    font-size: 0.7rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .tune-panel button {
    margin-top: 0.6rem;
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.4rem 0.7rem;
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .tune-panel button:hover {
    color: var(--ink);
    border-color: var(--muted);
  }
  .tune-hint {
    margin: 0.6rem 0 0;
    font-size: 0.7rem;
    color: var(--muted);
    line-height: 1.35;
  }
  @media (max-width: 600px) {
    .tune-panel {
      bottom: 0.5rem;
      right: 0.5rem;
      left: 0.5rem;
      width: auto;
    }
  }
</style>

<script>
  // Particle Lenia (Mordvintsev, Niklasson, Randazzo, Chan).
  // Each particle is a point in 2D world space. The continuous field U(x) is
  // a sum of bell-ring kernels K(|x − p_j|) over all particles, and each
  // particle's energy is R(p_i) − G(U(p_i)) where R is short-range repulsion
  // and G is a Gaussian "growth" preference for the field strength near it.
  // Particles flow along the negative gradient of total energy, producing
  // self-propelled clusters that swim, divide, and dissolve.
  //
  // Rendered by splatting each particle's kernel onto a coarse pixel grid;
  // the chunky pixel look matches the rest of the site's animations.
  const canvas = document.getElementById('lenia-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const N_LEVELS = 8;
    const CELL_PX = 6;          // display pixels per grid cell
    const CELLS_PER_UNIT = 4;   // grid cells per world unit
    const DT = 0.1;
    const N_PARTICLES = 320;
    const RESEED_AFTER = 2000;

    // Parameter ranges sampled per cycle. muK and sigmaK are correlated
    // inversely via a shared "type" parameter t ∈ [0, 1]: at t=0 the kernel
    // is large-radius / sharp-ring (big μK, small σK); at t=1 it's
    // small-radius / fat-ring (small μK, big σK), with a small jitter per
    // axis so the relation isn't perfectly tight.
    const PARAM_RANGES = {
      muK:    [3.0, 5.5],     // kernel peak (creature radius)
      sigmaK: [0.5, 1.5],     // kernel ring width
      wK:     [0.035, 0.060], // per-particle field weight
      muG:    [0.40, 0.78],   // growth target field strength
      sigmaG: [0.40, 0.60],   // growth tolerance (broad, permissive)
      cRep:   [0.6, 1.7],     // close-range repulsion strength
      noise:  [0.0, 0.08],    // per-step Brownian jitter
      flow:   [0.02, 0.12],   // amplitude of slowly varying spatial flow
    } as const;
    // Smaller jitter so the muK ↔ sigmaK inverse correlation is actually
    // visible across cycles instead of being washed out.
    const MUK_SIGMAK_JITTER = 0.2;
    const SIGMAK_JITTER = 0.08;

    // Slider bounds (wider than randomization range, for live exploration).
    // The hash-cell size must cover the largest possible kernel range over
    // these bounds, since the slider lets the user push muK/sigmaK higher
    // than the randomization box.
    const SLIDER_MAX_MU_K = 7.0;
    const SLIDER_MAX_SIGMA_K = 2.0;
    const MAX_KERNEL_RANGE = SLIDER_MAX_MU_K + 3 * SLIDER_MAX_SIGMA_K;
    const HASH_CELL_SIZE = MAX_KERNEL_RANGE;

    type Params = {
      muK: number; sigmaK: number; wK: number;
      muG: number; sigmaG: number; cRep: number;
      noise: number; flow: number;
      kernelRange: number; kernelRangeSq: number;
      renderRangeCells: number;
      sigmaK2: number; sigmaG2: number;
    };

    function lerp(lo: number, hi: number) {
      return lo + Math.random() * (hi - lo);
    }

    function mix(a: number, b: number, t: number) {
      return a + (b - a) * t;
    }

    function clamp(v: number, lo: number, hi: number) {
      return v < lo ? lo : v > hi ? hi : v;
    }

    function recompute(p: Params) {
      p.kernelRange = p.muK + 3 * p.sigmaK;
      p.kernelRangeSq = p.kernelRange * p.kernelRange;
      p.renderRangeCells = Math.ceil(p.kernelRange * CELLS_PER_UNIT);
      p.sigmaK2 = p.sigmaK * p.sigmaK;
      p.sigmaG2 = p.sigmaG * p.sigmaG;
    }

    function pickParams(): Params {
      // Inverse-correlate muK and sigmaK via a shared "type" t ∈ [0, 1].
      // t=0  → big muK + small sigmaK (large radius, sharp ring).
      // t=1  → small muK + big sigmaK (small radius, fat ring).
      // Per-axis jitter loosens the relation so cycles don't feel scripted.
      const t = Math.random();
      const muK = clamp(
        mix(PARAM_RANGES.muK[1], PARAM_RANGES.muK[0], t) +
          (Math.random() - 0.5) * MUK_SIGMAK_JITTER,
        PARAM_RANGES.muK[0], PARAM_RANGES.muK[1],
      );
      const sigmaK = clamp(
        mix(PARAM_RANGES.sigmaK[0], PARAM_RANGES.sigmaK[1], t) +
          (Math.random() - 0.5) * SIGMAK_JITTER,
        PARAM_RANGES.sigmaK[0], PARAM_RANGES.sigmaK[1],
      );
      const p: Params = {
        muK, sigmaK,
        wK:     lerp(PARAM_RANGES.wK[0],     PARAM_RANGES.wK[1]),
        muG:    lerp(PARAM_RANGES.muG[0],    PARAM_RANGES.muG[1]),
        sigmaG: lerp(PARAM_RANGES.sigmaG[0], PARAM_RANGES.sigmaG[1]),
        cRep:   lerp(PARAM_RANGES.cRep[0],   PARAM_RANGES.cRep[1]),
        noise:  lerp(PARAM_RANGES.noise[0],  PARAM_RANGES.noise[1]),
        flow:   lerp(PARAM_RANGES.flow[0],   PARAM_RANGES.flow[1]),
        kernelRange: 0, kernelRangeSq: 0, renderRangeCells: 0,
        sigmaK2: 0, sigmaG2: 0,
      };
      recompute(p);
      return p;
    }

    let params: Params = pickParams();

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    function pickStops(): RGB[] {
      const stops: RGB[] = [];
      for (let i = 0; i < N_LEVELS; i++) {
        const lo = Math.floor((i * colorPool.length) / N_LEVELS);
        const hi = Math.floor(((i + 1) * colorPool.length) / N_LEVELS);
        stops.push(colorPool[lo + ((Math.random() * Math.max(1, hi - lo)) | 0)]);
      }
      return stops;
    }

    function buildPalette(stops: RGB[]): RGB[] {
      const all = [paper, ...stops];
      const out: RGB[] = [];
      for (let i = 0; i < N_LEVELS; i++) {
        const t = i / (N_LEVELS - 1);
        const segF = t * (all.length - 1);
        const seg = Math.min(Math.floor(segF), all.length - 2);
        const lt = segF - seg;
        const a = all[seg];
        const b = all[seg + 1];
        out.push([
          Math.round(a[0] + (b[0] - a[0]) * lt),
          Math.round(a[1] + (b[1] - a[1]) * lt),
          Math.round(a[2] + (b[2] - a[2]) * lt),
        ]);
      }
      return out;
    }

    function wrap(d: number, size: number): number {
      if (d > size * 0.5) return d - size;
      if (d < -size * 0.5) return d + size;
      return d;
    }

    let W_grid = 0, H_grid = 0;
    let W_world = 0, H_world = 0;
    let hashW = 0, hashH = 0;

    let positions = new Float32Array(0);
    let U = new Float32Array(0);
    let Gp = new Float32Array(0);
    let F = new Float32Array(0);
    let field = new Float32Array(0);
    let stainR = new Float32Array(0);
    let stainG = new Float32Array(0);
    let stainB = new Float32Array(0);
    let img: ImageData | null = null;
    let palette: RGB[] = buildPalette(pickStops());
    let stepCount = 0;
    const STAIN_DECAY = 0.992; // per-step decay; longer-lasting marks
    const STAIN_RADIUS_CELLS = 24;
    const STAIN_PEAK = 320;    // saturates additive blend for stark color
    // Stain attracts particles up its gradient with this strength. Set high
    // enough to noticeably gather creatures into stained areas without
    // overwhelming the underlying gradient flow.
    const STAIN_PULL = 0.18;
    const STAIN_GRAD_RADIUS = 3; // grid cells used for finite-difference gradient

    // Spatial hash, linked-list per cell. hashHead[c] is the first particle
    // in cell c (or −1 if empty); hashNext[i] is the next particle after i.
    let hashHead = new Int32Array(0);
    let hashNext = new Int32Array(0);

    function rebuildHash() {
      hashHead.fill(-1);
      for (let i = 0; i < N_PARTICLES; i++) {
        const x = positions[i * 2];
        const y = positions[i * 2 + 1];
        const hx = Math.floor(x / HASH_CELL_SIZE);
        const hy = Math.floor(y / HASH_CELL_SIZE);
        const cx = ((hx % hashW) + hashW) % hashW;
        const cy = ((hy % hashH) + hashH) % hashH;
        const slot = cy * hashW + cx;
        hashNext[i] = hashHead[slot];
        hashHead[slot] = i;
      }
    }

    type Seeder = { name: string; fn: () => void };
    const seeders: Seeder[] = [
      {
        name: 'clusters',
        fn: () => {
          const k = 6 + ((Math.random() * 8) | 0);
          const cxs = new Float32Array(k);
          const cys = new Float32Array(k);
          for (let i = 0; i < k; i++) {
            cxs[i] = Math.random() * W_world;
            cys[i] = Math.random() * H_world;
          }
          const sigma = 2.5 + Math.random() * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            const c = (Math.random() * k) | 0;
            // Box–Muller for a 2D Gaussian offset.
            const u1 = Math.random() || 1e-9;
            const u2 = Math.random();
            const mag = Math.sqrt(-2 * Math.log(u1)) * sigma;
            const ang = 2 * Math.PI * u2;
            const px = cxs[c] + Math.cos(ang) * mag;
            const py = cys[c] + Math.sin(ang) * mag;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'rings',
        fn: () => {
          const k = 3 + ((Math.random() * 4) | 0);
          const perRing = Math.ceil(N_PARTICLES / k);
          let idx = 0;
          for (let ri = 0; ri < k && idx < N_PARTICLES; ri++) {
            const cx = Math.random() * W_world;
            const cy = Math.random() * H_world;
            const radius = 4 + Math.random() * 6;
            const count = Math.min(perRing, N_PARTICLES - idx);
            const phase = Math.random() * Math.PI * 2;
            for (let i = 0; i < count; i++) {
              const theta = phase + (i / count) * Math.PI * 2;
              const jitter = (Math.random() - 0.5) * 0.6;
              const px = cx + Math.cos(theta) * (radius + jitter);
              const py = cy + Math.sin(theta) * (radius + jitter);
              positions[idx * 2] = ((px % W_world) + W_world) % W_world;
              positions[idx * 2 + 1] = ((py % H_world) + H_world) % H_world;
              idx++;
            }
          }
          for (; idx < N_PARTICLES; idx++) {
            positions[idx * 2] = Math.random() * W_world;
            positions[idx * 2 + 1] = Math.random() * H_world;
          }
        },
      },
      {
        name: 'donut',
        fn: () => {
          // Single annular ring centered on the world, hollow inside.
          const cx = W_world / 2;
          const cy = H_world / 2;
          const span = Math.min(W_world, H_world);
          const inner = span * (0.14 + Math.random() * 0.08);
          const outer = span * (0.28 + Math.random() * 0.10);
          const phase = Math.random() * Math.PI * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            const a = phase + (i / N_PARTICLES) * Math.PI * 2 + (Math.random() - 0.5) * 0.4;
            const r = inner + Math.random() * (outer - inner);
            positions[i * 2] = ((cx + r * Math.cos(a)) % W_world + W_world) % W_world;
            positions[i * 2 + 1] = ((cy + r * Math.sin(a)) % H_world + H_world) % H_world;
          }
        },
      },
      {
        name: 'double-clusters',
        fn: () => {
          // Two dense Gaussian clusters on opposite sides of a random axis.
          const angle = Math.random() * Math.PI * 2;
          const sep = Math.min(W_world, H_world) * (0.20 + Math.random() * 0.12);
          const cx0 = W_world * 0.5;
          const cy0 = H_world * 0.5;
          const ax = Math.cos(angle), ay = Math.sin(angle);
          const c1x = cx0 + ax * sep, c1y = cy0 + ay * sep;
          const c2x = cx0 - ax * sep, c2y = cy0 - ay * sep;
          const sigma = 3 + Math.random() * 2;
          for (let i = 0; i < N_PARTICLES; i++) {
            const cx = i < N_PARTICLES * 0.5 ? c1x : c2x;
            const cy = i < N_PARTICLES * 0.5 ? c1y : c2y;
            const u1 = Math.random() || 1e-9;
            const u2 = Math.random();
            const mag = Math.sqrt(-2 * Math.log(u1)) * sigma;
            const ang = 2 * Math.PI * u2;
            positions[i * 2] = ((cx + Math.cos(ang) * mag) % W_world + W_world) % W_world;
            positions[i * 2 + 1] = ((cy + Math.sin(ang) * mag) % H_world + H_world) % H_world;
          }
        },
      },
      {
        name: 'spiral',
        fn: () => {
          // 1–3 logarithmic-ish spiral arms emanating from the center.
          const arms = 1 + ((Math.random() * 3) | 0);
          const cx = W_world / 2, cy = H_world / 2;
          const turns = 1.2 + Math.random() * 1.6;
          const maxR = Math.min(W_world, H_world) * 0.42;
          for (let i = 0; i < N_PARTICLES; i++) {
            const u = i / N_PARTICLES;
            const arm = i % arms;
            const r = u * maxR;
            const a = u * turns * Math.PI * 2 + (arm / arms) * Math.PI * 2 +
              (Math.random() - 0.5) * 0.5;
            positions[i * 2] = ((cx + r * Math.cos(a)) % W_world + W_world) % W_world;
            positions[i * 2 + 1] = ((cy + r * Math.sin(a)) % H_world + H_world) % H_world;
          }
        },
      },
      {
        name: 'wave',
        fn: () => {
          // Particles traced along a sinusoid spanning the world width.
          const k = 1.5 + Math.random() * 2.5;          // wavenumber
          const amp = H_world * (0.18 + Math.random() * 0.15);
          const baseY = H_world / 2;
          const phase = Math.random() * Math.PI * 2;
          const thickness = 2 + Math.random() * 3;
          for (let i = 0; i < N_PARTICLES; i++) {
            const px = (i / N_PARTICLES) * W_world;
            const py = baseY + amp * Math.sin(px / W_world * Math.PI * 2 * k + phase) +
              (Math.random() - 0.5) * thickness;
            positions[i * 2] = px;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'galaxy',
        fn: () => {
          // Dense bulge at the center plus a few diffuse trailing arms.
          const cx = W_world / 2, cy = H_world / 2;
          const bulgeFrac = 0.3 + Math.random() * 0.2;
          const bulgeSigma = 3 + Math.random() * 1.5;
          const arms = 2 + ((Math.random() * 3) | 0);
          const turns = 1.0 + Math.random() * 1.0;
          const maxR = Math.min(W_world, H_world) * 0.38;
          for (let i = 0; i < N_PARTICLES; i++) {
            const u1 = Math.random() || 1e-9;
            const u2 = Math.random();
            const mag = Math.sqrt(-2 * Math.log(u1)) * bulgeSigma;
            const ang = 2 * Math.PI * u2;
            let px: number, py: number;
            if (i / N_PARTICLES < bulgeFrac) {
              px = cx + Math.cos(ang) * mag;
              py = cy + Math.sin(ang) * mag;
            } else {
              const u = (i / N_PARTICLES - bulgeFrac) / (1 - bulgeFrac);
              const arm = i % arms;
              const r = bulgeSigma * 1.5 + u * maxR;
              const a = u * turns * Math.PI * 2 + (arm / arms) * Math.PI * 2 +
                (Math.random() - 0.5) * 0.6;
              px = cx + r * Math.cos(a);
              py = cy + r * Math.sin(a);
            }
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
      {
        name: 'streak',
        fn: () => {
          // Particles laid out along a random line, biased to seed cluster
          // formation along a coherent direction.
          const angle = Math.random() * Math.PI * 2;
          const ax = Math.cos(angle);
          const ay = Math.sin(angle);
          const span = Math.min(W_world, H_world) * 0.45;
          const cx0 = W_world * 0.5;
          const cy0 = H_world * 0.5;
          for (let i = 0; i < N_PARTICLES; i++) {
            const t = (i / N_PARTICLES - 0.5) * span * 2;
            const j = (Math.random() - 0.5) * 4;
            const px = cx0 + ax * t - ay * j;
            const py = cy0 + ay * t + ax * j;
            positions[i * 2] = ((px % W_world) + W_world) % W_world;
            positions[i * 2 + 1] = ((py % H_world) + H_world) % H_world;
          }
        },
      },
    ];

    let deck: number[] = [];
    let lastSeeder = -1;
    function refillDeck(avoid: number) {
      const idxs: number[] = [];
      for (let i = 0; i < seeders.length; i++) idxs.push(i);
      for (let i = idxs.length - 1; i > 0; i--) {
        const j = (Math.random() * (i + 1)) | 0;
        const t = idxs[i]; idxs[i] = idxs[j]; idxs[j] = t;
      }
      if (avoid >= 0 && idxs.length > 1 && idxs[0] === avoid) {
        const t = idxs[0]; idxs[0] = idxs[1]; idxs[1] = t;
      }
      deck = idxs;
    }
    function nextSeeder(): number {
      if (deck.length === 0) refillDeck(lastSeeder);
      return deck.shift()!;
    }

    function reseed() {
      params = pickParams();
      lastSeeder = nextSeeder();
      seeders[lastSeeder].fn();
      palette = buildPalette(pickStops());
      stepCount = 0;
      stainR.fill(0);
      stainG.fill(0);
      stainB.fill(0);
      syncSliders();
      const label = document.getElementById('seeder-label');
      if (label) label.textContent = seeders[lastSeeder].name;
    }

    function resize() {
      W_grid = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H_grid = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W_grid;
      canvas.height = H_grid;
      W_world = W_grid / CELLS_PER_UNIT;
      H_world = H_grid / CELLS_PER_UNIT;
      hashW = Math.max(1, Math.floor(W_world / HASH_CELL_SIZE));
      hashH = Math.max(1, Math.floor(H_world / HASH_CELL_SIZE));
      positions = new Float32Array(N_PARTICLES * 2);
      U = new Float32Array(N_PARTICLES);
      Gp = new Float32Array(N_PARTICLES);
      F = new Float32Array(N_PARTICLES * 2);
      field = new Float32Array(W_grid * H_grid);
      stainR = new Float32Array(W_grid * H_grid);
      stainG = new Float32Array(W_grid * H_grid);
      stainB = new Float32Array(W_grid * H_grid);
      img = ctx.createImageData(W_grid, H_grid);
      hashHead = new Int32Array(hashW * hashH);
      hashNext = new Int32Array(N_PARTICLES);
      reseed();
    }

    function step() {
      rebuildHash();
      // Hoist params into locals — these inner loops run 10⁴⁺ times per step.
      const muK = params.muK;
      const sigmaK2 = params.sigmaK2;
      const muG = params.muG;
      const sigmaG2 = params.sigmaG2;
      const wK = params.wK;
      const cRep = params.cRep;
      const kernelRange = params.kernelRange;
      const kernelRangeSq = params.kernelRangeSq;

      // Pass 1: U(p_i) for every particle by summing kernel contributions
      // from all neighbors in the 3×3 hash-cell window.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2];
        const py = positions[i * 2 + 1];
        const hx = Math.floor(px / HASH_CELL_SIZE);
        const hy = Math.floor(py / HASH_CELL_SIZE);
        let u = 0;
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const cx = (((hx + dx) % hashW) + hashW) % hashW;
            const cy = (((hy + dy) % hashH) + hashH) % hashH;
            let j = hashHead[cy * hashW + cx];
            while (j !== -1) {
              const dxw = wrap(px - positions[j * 2], W_world);
              const dyw = wrap(py - positions[j * 2 + 1], H_world);
              const r2 = dxw * dxw + dyw * dyw;
              if (r2 < kernelRangeSq) {
                const r = Math.sqrt(r2);
                const dk = (r - muK);
                u += wK * Math.exp(-(dk * dk) / sigmaK2);
              }
              j = hashNext[j];
            }
          }
        }
        U[i] = u;
      }

      // Cache G'(U_i) for each particle so the force pass doesn't recompute.
      for (let i = 0; i < N_PARTICLES; i++) {
        const d = U[i] - muG;
        Gp[i] = -2 * d / sigmaG2 * Math.exp(-(d * d) / sigmaG2);
      }

      // Pass 2: pair-wise force on each particle. Growth-driven force on i
      // from j is (G'(U_i) + G'(U_j)) · K'(r) · (p_i − p_j)/r; repulsion
      // adds 2·c_rep·(1−r) along the same axis when r < 1.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2];
        const py = positions[i * 2 + 1];
        const hx = Math.floor(px / HASH_CELL_SIZE);
        const hy = Math.floor(py / HASH_CELL_SIZE);
        const Gpi = Gp[i];
        let fx = 0;
        let fy = 0;
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const cx = (((hx + dx) % hashW) + hashW) % hashW;
            const cy = (((hy + dy) % hashH) + hashH) % hashH;
            let j = hashHead[cy * hashW + cx];
            while (j !== -1) {
              if (j === i) { j = hashNext[j]; continue; }
              const dxw = wrap(px - positions[j * 2], W_world);
              const dyw = wrap(py - positions[j * 2 + 1], H_world);
              const r2 = dxw * dxw + dyw * dyw;
              if (r2 < 1e-10) { j = hashNext[j]; continue; }
              const r = Math.sqrt(r2);
              const ux = dxw / r;
              const uy = dyw / r;
              if (r < 1.0) {
                const rep = 2 * cRep * (1 - r);
                fx += rep * ux;
                fy += rep * uy;
              }
              if (r < kernelRange) {
                const dk = (r - muK);
                const Kr = Math.exp(-(dk * dk) / sigmaK2);
                const Kp = -2 * dk / sigmaK2 * Kr * wK;
                const ff = (Gpi + Gp[j]) * Kp;
                fx += ff * ux;
                fy += ff * uy;
              }
              j = hashNext[j];
            }
          }
        }
        F[i * 2] = fx;
        F[i * 2 + 1] = fy;
      }

      // Stain attracts particles up its intensity gradient. We approximate
      // ∇(R+G+B) by central differences over a few cells, then push each
      // particle along that vector. This is what makes the click "interact"
      // with the simulation rather than being a pure visual overlay.
      for (let i = 0; i < N_PARTICLES; i++) {
        const px = positions[i * 2] * CELLS_PER_UNIT;
        const py = positions[i * 2 + 1] * CELLS_PER_UNIT;
        const cx = Math.round(px) | 0;
        const cy = Math.round(py) | 0;
        const xR = (((cx + STAIN_GRAD_RADIUS) % W_grid) + W_grid) % W_grid;
        const xL = (((cx - STAIN_GRAD_RADIUS) % W_grid) + W_grid) % W_grid;
        const yU = (((cy - STAIN_GRAD_RADIUS) % H_grid) + H_grid) % H_grid;
        const yD = (((cy + STAIN_GRAD_RADIUS) % H_grid) + H_grid) % H_grid;
        const cyR = ((cy % H_grid) + H_grid) % H_grid;
        const cxR = ((cx % W_grid) + W_grid) % W_grid;
        const sR = stainR[cyR * W_grid + xR] + stainG[cyR * W_grid + xR] + stainB[cyR * W_grid + xR];
        const sL = stainR[cyR * W_grid + xL] + stainG[cyR * W_grid + xL] + stainB[cyR * W_grid + xL];
        const sU = stainR[yU * W_grid + cxR]  + stainG[yU * W_grid + cxR]  + stainB[yU * W_grid + cxR];
        const sD = stainR[yD * W_grid + cxR]  + stainG[yD * W_grid + cxR]  + stainB[yD * W_grid + cxR];
        // Skip when no nearby stain to avoid pointless work.
        if (sR + sL + sU + sD < 1) continue;
        const gradX = (sR - sL) / (2 * STAIN_GRAD_RADIUS) / 255;
        const gradY = (sD - sU) / (2 * STAIN_GRAD_RADIUS) / 255;
        F[i * 2] += STAIN_PULL * gradX;
        F[i * 2 + 1] += STAIN_PULL * gradY;
      }

      // Overdamped integration; wrap to torus.
      // Two ambient dynamics on top of the gradient flow:
      //  • noise — per-particle Brownian jitter (uncorrelated kicks).
      //  • flow  — coherent spatial flow field that varies in space and
      //    slowly in time, so creatures get advected by ongoing currents
      //    instead of locking into fixed points.
      const noise = params.noise;
      const flowAmp = params.flow;
      const flowT = stepCount * 0.005;
      for (let i = 0; i < N_PARTICLES; i++) {
        let nx = positions[i * 2] + DT * F[i * 2];
        let ny = positions[i * 2 + 1] + DT * F[i * 2 + 1];
        if (flowAmp > 0) {
          const px = positions[i * 2];
          const py = positions[i * 2 + 1];
          const fx = Math.sin(px * 0.07 + flowT * 0.4) +
            0.6 * Math.sin(py * 0.04 - flowT * 0.3);
          const fy = Math.cos(py * 0.08 + flowT * 0.5) +
            0.6 * Math.cos(px * 0.05 - flowT * 0.4);
          nx += flowAmp * fx;
          ny += flowAmp * fy;
        }
        if (noise > 0) {
          nx += (Math.random() - 0.5) * 2 * noise;
          ny += (Math.random() - 0.5) * 2 * noise;
        }
        nx = ((nx % W_world) + W_world) % W_world;
        ny = ((ny % H_world) + H_world) % H_world;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
      }

      // Decay the colored stain layer.
      const len = stainR.length;
      for (let i = 0; i < len; i++) {
        stainR[i] *= STAIN_DECAY;
        stainG[i] *= STAIN_DECAY;
        stainB[i] *= STAIN_DECAY;
      }

      stepCount++;
      if (stepCount >= RESEED_AFTER) reseed();
    }

    function draw() {
      if (!img) return;
      field.fill(0);
      const muK = params.muK;
      const sigmaK2 = params.sigmaK2;
      const wK = params.wK;
      const muG = params.muG;
      const kernelRangeSq = params.kernelRangeSq;
      const renderRangeCells = params.renderRangeCells;

      // Splat each particle's kernel onto the field grid. Wraps on the torus.
      for (let p = 0; p < N_PARTICLES; p++) {
        const px = positions[p * 2] * CELLS_PER_UNIT;
        const py = positions[p * 2 + 1] * CELLS_PER_UNIT;
        const cx = Math.round(px);
        const cy = Math.round(py);
        for (let dy = -renderRangeCells; dy <= renderRangeCells; dy++) {
          for (let dx = -renderRangeCells; dx <= renderRangeCells; dx++) {
            const ddx = (cx + dx - px) / CELLS_PER_UNIT;
            const ddy = (cy + dy - py) / CELLS_PER_UNIT;
            const r2 = ddx * ddx + ddy * ddy;
            if (r2 > kernelRangeSq) continue;
            const r = Math.sqrt(r2);
            const dk = r - muK;
            const w = wK * Math.exp(-(dk * dk) / sigmaK2);
            if (w < 1e-5) continue;
            const x = (((cx + dx) % W_grid) + W_grid) % W_grid;
            const y = (((cy + dy) % H_grid) + H_grid) % H_grid;
            field[y * W_grid + x] += w;
          }
        }
      }

      // Map field strength to a palette index, clipping at ~1.4·μ_G so dense
      // creature interiors saturate but the outer halo still resolves into
      // distinct bands. Stain RGB is added on top so click-deposited color
      // shows through even when the underlying field is zero.
      const scale = 1 / (muG * 1.4);
      const data = img.data;
      const len = field.length;
      for (let i = 0; i < len; i++) {
        let v = field[i] * scale;
        if (v > 1) v = 1;
        let idx = (v * N_LEVELS) | 0;
        if (idx >= N_LEVELS) idx = N_LEVELS - 1;
        const c = palette[idx];
        const j = i * 4;
        let r = c[0] + stainR[i];
        let g = c[1] + stainG[i];
        let b = c[2] + stainB[i];
        if (r > 255) r = 255;
        if (g > 255) g = 255;
        if (b > 255) b = 255;
        data[j] = r;
        data[j + 1] = g;
        data[j + 2] = b;
        data[j + 3] = 255;
      }
      ctx.putImageData(img, 0, 0);
    }

    // ── Sliders ─────────────────────────────────────────────────────────
    type SliderKey = 'muK' | 'sigmaK' | 'wK' | 'muG' | 'sigmaG' | 'cRep' | 'noise' | 'flow';
    const SLIDER_KEYS: SliderKey[] = ['muK', 'sigmaK', 'wK', 'muG', 'sigmaG', 'cRep', 'noise', 'flow'];
    const FORMAT: Record<SliderKey, (n: number) => string> = {
      muK:    (n) => n.toFixed(2),
      sigmaK: (n) => n.toFixed(2),
      wK:     (n) => n.toFixed(4),
      muG:    (n) => n.toFixed(3),
      sigmaG: (n) => n.toFixed(3),
      cRep:   (n) => n.toFixed(2),
      noise:  (n) => n.toFixed(3),
      flow:   (n) => n.toFixed(3),
    };
    const sliderEls: Partial<Record<SliderKey, HTMLInputElement>> = {};
    const valEls:    Partial<Record<SliderKey, HTMLElement>>    = {};
    for (const k of SLIDER_KEYS) {
      sliderEls[k] = document.getElementById('s-' + k) as HTMLInputElement;
      valEls[k]    = document.getElementById('v-' + k) as HTMLElement;
    }

    function syncSliders() {
      for (const k of SLIDER_KEYS) {
        const el = sliderEls[k];
        const v = valEls[k];
        if (!el || !v) continue;
        el.value = String(params[k]);
        v.textContent = FORMAT[k](params[k]);
      }
    }

    for (const k of SLIDER_KEYS) {
      const el = sliderEls[k];
      const v = valEls[k];
      if (!el || !v) continue;
      el.addEventListener('input', () => {
        const num = parseFloat(el.value);
        params[k] = num;
        v.textContent = FORMAT[k](num);
        // muK / sigmaK changes invalidate kernelRange and friends.
        if (k === 'muK' || k === 'sigmaK') recompute(params);
        else if (k === 'sigmaG') params.sigmaG2 = num * num;
      });
    }

    const resetBtn = document.getElementById('reset-btn');
    resetBtn?.addEventListener('click', () => reseed());

    // ── Click perturbation ──────────────────────────────────────────────
    // A click both kicks nearby particles outward (visible motion) AND
    // stamps a Gaussian splatter of multi-colored stain into the canvas.
    // Per-cell color is sampled from a small randomly-picked palette so the
    // splat is non-monochrome. Stain decays in step() and exerts a pull on
    // particles in step() too — see STAIN_PULL.
    function perturb(gx: number, gy: number) {
      // Multi-color splat: 3–5 colors per click, sampled per cell.
      const numColors = 3 + ((Math.random() * 3) | 0);
      const stops: RGB[] = [];
      for (let i = 0; i < numColors; i++) {
        stops.push(colorPool[(Math.random() * colorPool.length) | 0]);
      }
      const r2max = STAIN_RADIUS_CELLS * STAIN_RADIUS_CELLS;
      const sigma2 = (STAIN_RADIUS_CELLS * 0.5) * (STAIN_RADIUS_CELLS * 0.5);
      const cx = Math.round(gx);
      const cy = Math.round(gy);
      for (let dy = -STAIN_RADIUS_CELLS; dy <= STAIN_RADIUS_CELLS; dy++) {
        for (let dx = -STAIN_RADIUS_CELLS; dx <= STAIN_RADIUS_CELLS; dx++) {
          const r2 = dx * dx + dy * dy;
          if (r2 > r2max) continue;
          const w = Math.exp(-r2 / (2 * sigma2)) * STAIN_PEAK;
          if (w < 0.5) continue;
          const stop = stops[(Math.random() * numColors) | 0];
          const x = (((cx + dx) % W_grid) + W_grid) % W_grid;
          const y = (((cy + dy) % H_grid) + H_grid) % H_grid;
          const idx = y * W_grid + x;
          stainR[idx] = Math.min(255, stainR[idx] + (stop[0] / 255) * w);
          stainG[idx] = Math.min(255, stainG[idx] + (stop[1] / 255) * w);
          stainB[idx] = Math.min(255, stainB[idx] + (stop[2] / 255) * w);
        }
      }
      // Outward radial kick on nearby particles, like the prior perturb.
      const wx = gx / CELLS_PER_UNIT;
      const wy = gy / CELLS_PER_UNIT;
      const kickRadius = Math.max(4, params.muK * 1.5);
      const kickRadius2 = kickRadius * kickRadius;
      const kickStrength = 4;
      for (let i = 0; i < N_PARTICLES; i++) {
        const dxw = wrap(positions[i * 2] - wx, W_world);
        const dyw = wrap(positions[i * 2 + 1] - wy, H_world);
        const r2 = dxw * dxw + dyw * dyw;
        if (r2 >= kickRadius2 || r2 < 1e-6) continue;
        const r = Math.sqrt(r2);
        const t = 1 - r / kickRadius;
        const kick = kickStrength * t * t;
        let nx = positions[i * 2] + (dxw / r) * kick;
        let ny = positions[i * 2 + 1] + (dyw / r) * kick;
        nx = ((nx % W_world) + W_world) % W_world;
        ny = ((ny % H_world) + H_world) % H_world;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
      }
    }

    window.addEventListener('pointerdown', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      if (target.closest('a, button, input, label, .tune-panel')) return;
      const gx = (e.clientX / window.innerWidth) * W_grid;
      const gy = (e.clientY / window.innerHeight) * H_grid;
      perturb(gx, gy);
    });

    resize();
    syncSliders();
    window.addEventListener('resize', resize);

    if (reduce) {
      for (let i = 0; i < 200; i++) step();
      draw();
    } else {
      let last = 0;
      const targetMs = 50;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step();
          draw();
          last = t;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>
