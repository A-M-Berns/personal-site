---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Side projects and miscellaneous experiments.">
  <div class="other-shell">
    <canvas id="dla-sim" class="dla-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
    </header>
    <div class="other-panes">
      <section class="writing-pane">
        <h2>Physics</h2>
        <p class="empty">More to come.</p>
      </section>
      <section class="writing-pane">
        <h2>Quizbowl</h2>
        <p class="empty">More to come.</p>
      </section>
      <section class="writing-pane">
        <h2>Acting</h2>
        <p class="empty">More to come.</p>
      </section>
      <section class="writing-pane">
        <h2>More</h2>
        <p class="empty">More to come.</p>
      </section>
    </div>
    <div class="anim-controls">
      <button id="dla-info" type="button" aria-label="About">About</button>
      <button id="dla-restart" type="button" aria-label="Reset DLA">Reset</button>
    </div>
    <dialog id="dla-about" class="anim-about" aria-labelledby="dla-about-title">
      <h2 id="dla-about-title">About</h2>
      <p>
        This animation is an implementation of <a href="https://en.wikipedia.org/wiki/Diffusion-limited_aggregation">diffusion-limited aggregation</a>: seed cells anchor a growing cluster, and random walkers released nearby stick the moment they touch it. The result is a fractal of dimension ≈1.71 in two dimensions.
      </p>
    </dialog>
    <aside class="dla-panel" aria-label="DLA controls">
      <div class="dla-panel-head">
        <h2>DLA</h2>
        <button id="dla-reset" type="button">Reset</button>
      </div>
      <div class="dla-panel-body">
        <label class="dla-panel-field">
          <span>preset</span>
          <select id="dla-preset">
            <option value="random" selected>random</option>
            <option value="classic">classic</option>
            <option value="lightning">lightning</option>
            <option value="frost">frost</option>
            <option value="coral">coral</option>
            <option value="speckle">speckle</option>
          </select>
        </label>
        <label class="dla-panel-field">
          <span>seed</span>
          <select id="dla-seed-mode">
            <option value="point-center" selected>point-center</option>
            <option value="point-random">point-random</option>
            <option value="top-edge">top-edge</option>
            <option value="bottom-edge">bottom-edge</option>
            <option value="left-edge">left-edge</option>
            <option value="right-edge">right-edge</option>
            <option value="polygon">polygon</option>
            <option value="line">line</option>
          </select>
        </label>
        <div class="dla-panel-row">
          <label for="dla-pstick">p stick</label>
          <input id="dla-pstick" type="range" min="0.05" max="1" step="0.05" value="1" />
          <span id="dla-pstick-value">1.00</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-asymm">asymm</label>
          <input id="dla-asymm" type="range" min="0" max="1" step="0.05" value="0" />
          <span id="dla-asymm-value">0.00</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-persist">persist</label>
          <input id="dla-persist" type="range" min="0" max="0.95" step="0.05" value="0" />
          <span id="dla-persist-value">0.00</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-eta">tip</label>
          <input id="dla-eta" type="range" min="1" max="3" step="0.1" value="1" />
          <span id="dla-eta-value">1.0</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-cycle">cycle</label>
          <input id="dla-cycle" type="range" min="100" max="6000" step="50" value="1600" />
          <span id="dla-cycle-value">1600</span>
        </div>
        <div class="dla-panel-row">
          <label for="dla-speed">speed</label>
          <input id="dla-speed" type="range" min="50" max="3000" step="50" value="2000" />
          <span id="dla-speed-value">2000</span>
        </div>
        <label class="dla-panel-field">
          <span>render</span>
          <select id="dla-render-mode">
            <option value="pixel" selected>pixel</option>
            <option value="lines">lines</option>
            <option value="both">both</option>
          </select>
        </label>
        <dl class="dla-stats">
          <div><dt>seed</dt><dd id="dla-seed-readout">-</dd></div>
          <div><dt>cells</dt><dd id="dla-count">-</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</Base>

<style>
  .dla-sim {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    opacity: 0.85;
    cursor: default;
  }
  html.render-pixel .dla-sim {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  .dla-panel {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 3;
    width: 16.5rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .dla-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .dla-panel-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .dla-panel button {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
  }
  .dla-panel button:hover {
    color: var(--ink);
    border-color: var(--muted);
  }
  .dla-panel-field {
    display: grid;
    grid-template-columns: 4.3rem 1fr;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .dla-panel-field span {
    font-size: 0.7rem;
    color: var(--muted);
  }
  .dla-panel-field select {
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    color: var(--muted);
    background: rgba(14, 14, 16, 0.55);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.2rem 0.35rem;
  }
  .dla-panel-row {
    display: grid;
    grid-template-columns: 4.3rem 1fr 3.3rem;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .dla-panel-row label {
    font-size: 0.7rem;
    color: var(--muted);
  }
  .dla-panel-row input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    margin: 0;
  }
  .dla-panel-row span {
    font-size: 0.68rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .dla-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin: 0.6rem 0 0;
    font-size: 0.65rem;
  }
  .dla-stats div {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.3rem;
  }
  .dla-stats dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .dla-stats dd {
    margin: 0;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  const canvas = document.getElementById('dla-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const seedSelect = document.getElementById('dla-seed-mode') as HTMLSelectElement | null;
    const pStickInput = document.getElementById('dla-pstick') as HTMLInputElement | null;
    const pStickValue = document.getElementById('dla-pstick-value');
    const asymmInput = document.getElementById('dla-asymm') as HTMLInputElement | null;
    const asymmValue = document.getElementById('dla-asymm-value');
    const persistInput = document.getElementById('dla-persist') as HTMLInputElement | null;
    const persistValue = document.getElementById('dla-persist-value');
    const etaInput = document.getElementById('dla-eta') as HTMLInputElement | null;
    const etaValue = document.getElementById('dla-eta-value');
    const cycleInput = document.getElementById('dla-cycle') as HTMLInputElement | null;
    const cycleValue = document.getElementById('dla-cycle-value');
    const renderModeSelect = document.getElementById('dla-render-mode') as HTMLSelectElement | null;
    const speedInput = document.getElementById('dla-speed') as HTMLInputElement | null;
    const speedValue = document.getElementById('dla-speed-value');
    const presetSelect = document.getElementById('dla-preset') as HTMLSelectElement | null;
    const seedReadout = document.getElementById('dla-seed-readout');
    const countReadout = document.getElementById('dla-count');

    const CELL_PX = 1;
    const MAX_WALK_STEPS = 4000;
    const SPAWN_MARGIN = 4;
    const KILL_MARGIN = 24;
    const SKIP_BUFFER = 2;
    const AUTO_RESET_MS = 90_000;
    const NO_GROWTH_MS = 2_000;

    type SeedMode =
      | 'point-center' | 'point-random'
      | 'top-edge' | 'bottom-edge' | 'left-edge' | 'right-edge'
      | 'polygon' | 'line';
    type RenderMode = 'pixel' | 'lines' | 'both';
    type PresetName = 'random' | 'classic' | 'lightning' | 'frost' | 'coral' | 'speckle';


    const DX8 = [1, 1, 0, -1, -1, -1, 0, 1];
    const DY8 = [0, 1, 1, 1, 0, -1, -1, -1];

    let W = 0;
    let H = 0;
    let state = new Uint8Array(0);
    let parents = new Int32Array(0);
    let palette: number[][] = [];
    let bxmin = 0, bxmax = 0, bymin = 0, bymax = 0;
    let cycleStart = 0;
    let lastGrowthTime = 0;
    let rng = mulberry32(1);
    let stuckCount = 0;
    let seedHash = 0;

    let seedMode: SeedMode = (seedSelect?.value as SeedMode) ?? 'point-center';
    let pStick = Number(pStickInput?.value ?? 1);
    let asymm = Number(asymmInput?.value ?? 0);
    let persistence = Number(persistInput?.value ?? 0);
    let eta = Number(etaInput?.value ?? 1);
    let colorCycle = Number(cycleInput?.value ?? 1600);
    let renderMode: RenderMode = ((renderModeSelect?.value as RenderMode) ?? 'pixel');
    let stepsPerFrame = Number(speedInput?.value ?? 2000);
    let preset: PresetName = ((presetSelect?.value as PresetName) ?? 'random');
    let spawnWeights: number[] = [0.25, 0.25, 0.25, 0.25];
    applyRenderClass();

    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex);

    function parseHex(h: string) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function mulberry32(n: number) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function idx(x: number, y: number) { return y * W + x; }

    function pickPalette() {
      const indices = new Set<number>();
      while (indices.size < 4) indices.add(Math.floor(rng() * colorPool.length));
      palette = Array.from(indices).map((i) => colorPool[i]);
      const c = paletteCycle(0);
      document.documentElement.style.setProperty('--accent', `rgb(${Math.round(c[0])},${Math.round(c[1])},${Math.round(c[2])})`);
    }

    function applyRenderClass() {
      document.documentElement.classList.toggle('render-pixel', renderMode === 'pixel');
    }

    function rollSpawnWeights() {
      if (asymm <= 0) {
        spawnWeights = [0.25, 0.25, 0.25, 0.25];
        return;
      }
      const dir = rng() * 2 * Math.PI;
      const cd = Math.cos(dir), sd = Math.sin(dir);
      // Side vectors point in the direction walkers come FROM:
      // top=(0,-1), right=(1,0), bottom=(0,1), left=(-1,0).
      const sides: Array<[number, number]> = [[0, -1], [1, 0], [0, 1], [-1, 0]];
      const k = 1 + asymm * 7;
      const peaky = sides.map(([vx, vy]) => {
        const dot = vx * cd + vy * sd;
        return dot > 0 ? Math.pow(dot, k) : 0;
      });
      const psum = peaky.reduce((s, v) => s + v, 0) || 1;
      spawnWeights = peaky.map((v) => v / psum * asymm + 0.25 * (1 - asymm));
    }

    function setStuck(x: number, y: number, parent: number) {
      const i = idx(x, y);
      state[i] = 1;
      parents[i] = parent;
      stuckCount++;
      if (x < bxmin) bxmin = x;
      if (x > bxmax) bxmax = x;
      if (y < bymin) bymin = y;
      if (y > bymax) bymax = y;
      lastGrowthTime = performance.now();
      paintCell(x, y, parent);
    }

    function lerpRGB(a: number[], b: number[], t: number): number[] {
      return [
        a[0] + (b[0] - a[0]) * t,
        a[1] + (b[1] - a[1]) * t,
        a[2] + (b[2] - a[2]) * t,
      ];
    }

    function paletteCycle(t: number): number[] {
      const n = palette.length;
      const u = ((t % 1) + 1) % 1;
      const seg = u * n;
      const i = Math.floor(seg) % n;
      const j = (i + 1) % n;
      return lerpRGB(palette[i], palette[j], seg - Math.floor(seg));
    }

    function colorFor(): number[] {
      return paletteCycle(stuckCount / colorCycle);
    }

    function paintCell(x: number, y: number, parent: number) {
      const c = colorFor();
      const r = Math.round(c[0]);
      const g = Math.round(c[1]);
      const b = Math.round(c[2]);
      const css = `rgb(${r},${g},${b})`;
      document.documentElement.style.setProperty('--accent', css);
      if (renderMode === 'pixel' || renderMode === 'both' || parent < 0) {
        ctx.fillStyle = css;
        ctx.fillRect(x, y, 1, 1);
      }
      if ((renderMode === 'lines' || renderMode === 'both') && parent >= 0) {
        const px = parent % W;
        const py = (parent / W) | 0;
        ctx.strokeStyle = css;
        ctx.beginPath();
        ctx.moveTo(px + 0.5, py + 0.5);
        ctx.lineTo(x + 0.5, y + 0.5);
        ctx.stroke();
      }
    }

    function placeSeed() {
      bxmin = W; bxmax = -1; bymin = H; bymax = -1;
      stuckCount = 0;
      const cx = W >> 1;
      const cy = H >> 1;
      switch (seedMode) {
        case 'point-center':
          setStuck(cx, cy, -1);
          break;
        case 'point-random': {
          const x = Math.floor(rng() * (W - 4)) + 2;
          const y = Math.floor(rng() * (H - 4)) + 2;
          setStuck(x, y, -1);
          break;
        }
        case 'top-edge': {
          const y = 1;
          for (let x = 0; x < W; x++) setStuck(x, y, -1);
          break;
        }
        case 'bottom-edge': {
          const y = H - 2;
          for (let x = 0; x < W; x++) setStuck(x, y, -1);
          break;
        }
        case 'left-edge': {
          const x = 1;
          for (let y = 0; y < H; y++) setStuck(x, y, -1);
          break;
        }
        case 'right-edge': {
          const x = W - 2;
          for (let y = 0; y < H; y++) setStuck(x, y, -1);
          break;
        }
        case 'polygon': {
          const n = 3 + Math.floor(rng() * 6);
          const r = (0.05 + rng() * 0.10) * Math.min(W, H);
          const phase = rng() * 2 * Math.PI;
          for (let i = 0; i < n; i++) {
            const a = phase + (i / n) * 2 * Math.PI;
            const x = Math.round(cx + r * Math.cos(a));
            const y = Math.round(cy + r * Math.sin(a));
            if (x < 1 || x > W - 2 || y < 1 || y > H - 2) continue;
            if (state[idx(x, y)]) continue;
            setStuck(x, y, -1);
          }
          break;
        }
        case 'line': {
          const angle = rng() * Math.PI;
          const dx = Math.cos(angle);
          const dy = Math.sin(angle);
          const L = Math.ceil(Math.sqrt(W * W + H * H));
          for (let t = -L; t <= L; t++) {
            const x = Math.round(cx + t * dx);
            const y = Math.round(cy + t * dy);
            if (x < 1 || x > W - 2 || y < 1 || y > H - 2) continue;
            if (state[idx(x, y)]) continue;
            setStuck(x, y, -1);
          }
          break;
        }
      }
    }

    const SEED_WEIGHTS: Array<[SeedMode, number]> = [
      ['point-center', 2],
      ['point-random', 2],
      ['top-edge',     1],
      ['bottom-edge',  1],
      ['left-edge',    1],
      ['right-edge',   1],
      ['polygon',      2],
      ['line',         2],
    ];
    function pickRandomSeedMode(): SeedMode {
      let total = 0;
      for (const [, w] of SEED_WEIGHTS) total += w;
      let r = rng() * total;
      for (const [m, w] of SEED_WEIGHTS) {
        if ((r -= w) < 0) return m;
      }
      return SEED_WEIGHTS[SEED_WEIGHTS.length - 1][0];
    }

    function seedCycle() {
      seedHash = (Date.now() ^ Math.floor(Math.random() * 0xffffffff)) >>> 0;
      rng = mulberry32(seedHash);
      if (preset === 'random') {
        applyPreset(pickRandomPreset());
        seedMode = pickRandomSeedMode();
        if (seedSelect) seedSelect.value = seedMode;
      }
      pickPalette();
      rollSpawnWeights();
      state.fill(0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      placeSeed();
      const now = performance.now();
      cycleStart = now;
      lastGrowthTime = now;
      updateReadout();
    }

    type PresetSpec = {
      seedMode: SeedMode;
      pStick: number;
      renderMode: RenderMode;
      asymm: number;
      persistence: number;
      eta: number;
      colorCycle: number;
    };
    const PRESETS: Record<Exclude<PresetName, 'random'>, PresetSpec> = {
      classic:   { seedMode: 'point-random', pStick: 1,   renderMode: 'pixel', asymm: 0,    persistence: 0,    eta: 1,   colorCycle: 1600 },
      lightning: { seedMode: 'top-edge',     pStick: 1,   renderMode: 'pixel', asymm: 1,    persistence: 0.55, eta: 1.6, colorCycle: 800  },
      frost:     { seedMode: 'left-edge',    pStick: 0.4, renderMode: 'pixel', asymm: 0.5,  persistence: 0,    eta: 1,   colorCycle: 2400 },
      coral:     { seedMode: 'bottom-edge',  pStick: 0.7, renderMode: 'pixel', asymm: 0,    persistence: 0,    eta: 1.3, colorCycle: 600  },
      speckle:   { seedMode: 'right-edge',   pStick: 1,   renderMode: 'pixel', asymm: 0.7,  persistence: 0.85, eta: 2.4, colorCycle: 4000 },
    };
    const PRESET_KEYS = Object.keys(PRESETS) as Array<keyof typeof PRESETS>;
    function pickRandomPreset(): keyof typeof PRESETS {
      return PRESET_KEYS[Math.floor(Math.random() * PRESET_KEYS.length)];
    }
    function applyPreset(name: keyof typeof PRESETS) {
      const p = PRESETS[name];
      seedMode = p.seedMode;
      pStick = p.pStick;
      renderMode = p.renderMode;
      asymm = p.asymm;
      persistence = p.persistence;
      eta = p.eta;
      colorCycle = p.colorCycle;
      applyRenderClass();
      if (seedSelect) seedSelect.value = p.seedMode;
      if (pStickInput) pStickInput.value = String(p.pStick);
      if (renderModeSelect) renderModeSelect.value = p.renderMode;
      if (asymmInput) asymmInput.value = String(p.asymm);
      if (persistInput) persistInput.value = String(p.persistence);
      if (etaInput) etaInput.value = String(p.eta);
      if (cycleInput) cycleInput.value = String(p.colorCycle);
      if (pStickValue) pStickValue.textContent = p.pStick.toFixed(2);
      if (asymmValue) asymmValue.textContent = p.asymm.toFixed(2);
      if (persistValue) persistValue.textContent = p.persistence.toFixed(2);
      if (etaValue) etaValue.textContent = p.eta.toFixed(1);
      if (cycleValue) cycleValue.textContent = String(p.colorCycle);
    }

    function updateReadout() {
      if (seedReadout) seedReadout.textContent = seedHash.toString(16).padStart(8, '0');
      if (countReadout) countReadout.textContent = stuckCount.toLocaleString();
    }

    function spawnWalker(): [number, number] {
      const m = Math.max(20, Math.floor(Math.min(W, H) * 0.18));
      const r = rng();
      let side: number;
      let cum = spawnWeights[0];
      if (r < cum) side = 0;
      else if (r < (cum += spawnWeights[1])) side = 1;
      else if (r < (cum += spawnWeights[2])) side = 2;
      else side = 3;
      // 0=top, 1=right, 2=bottom, 3=left.
      if (side === 0) return [Math.floor(rng() * W), -m];
      if (side === 1) return [W - 1 + m, Math.floor(rng() * H)];
      if (side === 2) return [Math.floor(rng() * W), H - 1 + m];
      return [-m, Math.floor(rng() * H)];
    }

    function distanceToBbox(x: number, y: number) {
      const dx = x < bxmin ? bxmin - x : x > bxmax ? x - bxmax : 0;
      const dy = y < bymin ? bymin - y : y > bymax ? y - bymax : 0;
      return Math.max(dx, dy);
    }

    function findStuckNeighbor(x: number, y: number): [number, number] {
      let pick = -1;
      let count = 0;
      for (let i = 0; i < 8; i++) {
        const nx = x + DX8[i];
        const ny = y + DY8[i];
        if (nx < 0 || nx >= W || ny < 0 || ny >= H) continue;
        const ni = idx(nx, ny);
        if (state[ni]) {
          count++;
          if (count === 1 || rng() * count < 1) pick = ni;
        }
      }
      return [pick, count];
    }

    function walkOne() {
      let [x, y] = spawnWalker();
      if (x >= 0 && x < W && y >= 0 && y < H && state[idx(x, y)]) return;
      const cx = (bxmin + bxmax) >> 1;
      const cy = (bymin + bymax) >> 1;
      const killRadius = Math.max(W, H);
      const kill2 = killRadius * killRadius;
      let lastDir = -1;
      for (let i = 0; i < MAX_WALK_STEPS; i++) {
        const d = distanceToBbox(x, y);
        if (d > SKIP_BUFFER) {
          const jump = d - SKIP_BUFFER;
          const dir8 = Math.floor(rng() * 8);
          const dx = dir8 === 0 || dir8 === 1 || dir8 === 7 ? 1 : dir8 === 3 || dir8 === 4 || dir8 === 5 ? -1 : 0;
          const dy = dir8 === 1 || dir8 === 2 || dir8 === 3 ? 1 : dir8 === 5 || dir8 === 6 || dir8 === 7 ? -1 : 0;
          x += dx * jump;
          y += dy * jump;
          lastDir = -1;
          if (x < 1 || x > W - 2 || y < 1 || y > H - 2) return;
          continue;
        }
        if (x >= 1 && x <= W - 2 && y >= 1 && y <= H - 2
            && state[idx(x, y)] === 0) {
          const [parent, neighbors] = findStuckNeighbor(x, y);
          if (parent >= 0) {
            const exposure = (8 - neighbors) / 8;
            const stickP = pStick * Math.pow(exposure, eta);
            if (rng() < stickP) {
              setStuck(x, y, parent);
              return;
            }
          }
        }
        let dir: number;
        if (lastDir >= 0 && rng() < persistence) {
          dir = lastDir;
        } else {
          dir = Math.floor(rng() * 8);
        }
        lastDir = dir;
        x += DX8[dir];
        y += DY8[dir];
        const cdx = x - cx;
        const cdy = y - cy;
        if (cdx * cdx + cdy * cdy > kill2) return;
      }
    }

    function step() {
      const now = performance.now();
      if (now - cycleStart >= AUTO_RESET_MS) {
        seedCycle();
        return;
      }
      if (now - lastGrowthTime >= NO_GROWTH_MS) {
        seedCycle();
        return;
      }
      for (let i = 0; i < stepsPerFrame; i++) walkOne();
      updateReadout();
    }

    function resize() {
      W = Math.max(48, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(36, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      ctx.lineWidth = 1;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      state = new Uint8Array(W * H);
      parents = new Int32Array(W * H);
      seedCycle();
    }

    resize();
    if (!reduce) {
      const loop = () => {
        step();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    } else {
      for (let i = 0; i < 30; i++) step();
    }
    window.addEventListener('resize', resize);

    function clickSeed(gx: number, gy: number) {
      const offsets: Array<[number, number]> = [[0, 0], [1, 0], [-1, 0], [0, 1], [0, -1]];
      let centerIdx = -1;
      for (const [dx, dy] of offsets) {
        const x = gx + dx;
        const y = gy + dy;
        if (x < 1 || x >= W - 1 || y < 1 || y >= H - 1) continue;
        if (state[idx(x, y)]) continue;
        const parent = dx === 0 && dy === 0 ? -1 : centerIdx;
        setStuck(x, y, parent);
        if (dx === 0 && dy === 0) centerIdx = idx(x, y);
      }
    }

    canvas.addEventListener('pointerdown', (evt) => {
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      const gx = Math.floor((evt.clientX - rect.left) / rect.width * W);
      const gy = Math.floor((evt.clientY - rect.top) / rect.height * H);
      if (gx < 1 || gx >= W - 1 || gy < 1 || gy >= H - 1) return;
      clickSeed(gx, gy);
    });

    const aboutDlg = document.getElementById('dla-about') as HTMLDialogElement | null;
    const infoBtn = document.getElementById('dla-info');
    const restartBtn = document.getElementById('dla-restart');
    const panelResetBtn = document.getElementById('dla-reset');
    infoBtn?.addEventListener('click', () => aboutDlg?.showModal());
    restartBtn?.addEventListener('click', () => seedCycle());
    panelResetBtn?.addEventListener('click', () => seedCycle());
    aboutDlg?.addEventListener('click', (e) => {
      if (e.target === aboutDlg) aboutDlg.close();
    });

    seedSelect?.addEventListener('change', () => {
      seedMode = seedSelect.value as SeedMode;
      seedCycle();
    });
    pStickInput?.addEventListener('input', () => {
      pStick = Number(pStickInput.value);
      if (pStickValue) pStickValue.textContent = pStick.toFixed(2);
    });
    asymmInput?.addEventListener('input', () => {
      asymm = Number(asymmInput.value);
      if (asymmValue) asymmValue.textContent = asymm.toFixed(2);
      rollSpawnWeights();
    });
    persistInput?.addEventListener('input', () => {
      persistence = Number(persistInput.value);
      if (persistValue) persistValue.textContent = persistence.toFixed(2);
    });
    etaInput?.addEventListener('input', () => {
      eta = Number(etaInput.value);
      if (etaValue) etaValue.textContent = eta.toFixed(1);
    });
    cycleInput?.addEventListener('input', () => {
      colorCycle = Number(cycleInput.value);
      if (cycleValue) cycleValue.textContent = String(colorCycle);
    });
    renderModeSelect?.addEventListener('change', () => {
      renderMode = renderModeSelect.value as RenderMode;
      applyRenderClass();
    });
    speedInput?.addEventListener('input', () => {
      stepsPerFrame = Number(speedInput.value);
      if (speedValue) speedValue.textContent = String(stepsPerFrame);
    });
    presetSelect?.addEventListener('change', () => {
      preset = presetSelect.value as PresetName;
      if (preset !== 'random') applyPreset(preset);
      seedCycle();
    });
  }
</script>
