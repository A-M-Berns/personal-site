---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Side projects and miscellaneous experiments.">
  <div class="other-shell">
    <canvas id="sandpile-sim" class="sandpile-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Side projects and miscellaneous experiments.</span></p>
    </header>
    <article class="note other-note">
      <ul>
        <li><span class="hl">Abelian sandpile experiments.</span></li>
        <li><span class="hl"><a href="/Animations/">Animation-only views</a></span></li>
      </ul>
    </article>
    <aside class="sandpile-panel" aria-label="Sandpile controls">
      <div class="sandpile-panel-head">
        <h2>Sandpile</h2>
        <button id="sandpile-reset" type="button">Reset</button>
      </div>
      <div class="sandpile-panel-row">
        <span>seeder</span>
        <strong id="sandpile-seeder">-</strong>
      </div>
      <label class="sandpile-panel-field" for="sandpile-seeder-select">
        <span>choose</span>
        <select id="sandpile-seeder-select">
          <option value="random">random</option>
        </select>
      </label>
      <label class="sandpile-panel-field" for="sandpile-mode-select">
        <span>mode</span>
        <select id="sandpile-mode-select">
          <option value="centered-point" selected>centered-point</option>
          <option value="uniform">uniform</option>
        </select>
      </label>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-passes">passes</label>
        <input id="sandpile-passes" type="range" min="1" max="100" step="1" value="8" />
        <span id="sandpile-passes-value">8</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-base">base</label>
        <input id="sandpile-base" type="range" min="0" max="3" step="1" value="0" />
        <span id="sandpile-base-value">0</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-mass">mass</label>
        <input id="sandpile-mass" type="range" min="0.3" max="2.4" step="0.1" value="1" />
        <span id="sandpile-mass-value">1.0</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-anneal">anneal</label>
        <input id="sandpile-anneal" type="range" min="0" max="360" step="30" value="180" />
        <span id="sandpile-anneal-value">180</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-cadence">cadence</label>
        <input id="sandpile-cadence" type="range" min="1" max="2700" step="1" value="90" />
        <span id="sandpile-cadence-value">90</span>
      </div>
      <dl class="sandpile-stats">
        <div><dt>seed</dt><dd id="sandpile-seed">-</dd></div>
        <div><dt>grid</dt><dd id="sandpile-grid">-</dd></div>
        <div><dt>frame</dt><dd id="sandpile-frame">-</dd></div>
        <div><dt>unstable</dt><dd id="sandpile-unstable">-</dd></div>
        <div><dt>max</dt><dd id="sandpile-max">-</dd></div>
        <div><dt>grains</dt><dd id="sandpile-grains">-</dd></div>
        <div><dt>topples</dt><dd id="sandpile-topples">-</dd></div>
        <div><dt>actual passes</dt><dd id="sandpile-actual-passes">-</dd></div>
      </dl>
      <div class="sandpile-sparkline">
        <div class="sandpile-sparkline-head">
          <span>disorder</span>
          <span id="sandpile-disorder-value">-</span>
        </div>
        <canvas id="sandpile-disorder-canvas" width="240" height="40" aria-hidden="true"></canvas>
      </div>
      <div class="sandpile-sparkline">
        <div class="sandpile-sparkline-head">
          <span>settle</span>
          <span id="sandpile-settle-value">-</span>
        </div>
        <canvas id="sandpile-settle-canvas" width="240" height="40" aria-hidden="true"></canvas>
      </div>
    </aside>
  </div>
</Base>

<script>
  const canvas = document.getElementById('sandpile-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const resetButton = document.getElementById('sandpile-reset') as HTMLButtonElement | null;
    const seederSelect = document.getElementById('sandpile-seeder-select') as HTMLSelectElement | null;
    const modeSelect = document.getElementById('sandpile-mode-select') as HTMLSelectElement | null;
    const passesInput = document.getElementById('sandpile-passes') as HTMLInputElement | null;
    const baseInput = document.getElementById('sandpile-base') as HTMLInputElement | null;
    const massInput = document.getElementById('sandpile-mass') as HTMLInputElement | null;
    const annealInput = document.getElementById('sandpile-anneal') as HTMLInputElement | null;
    const cadenceInput = document.getElementById('sandpile-cadence') as HTMLInputElement | null;
    const seederLabel = document.getElementById('sandpile-seeder');
    const passesValue = document.getElementById('sandpile-passes-value');
    const baseValue = document.getElementById('sandpile-base-value');
    const massValue = document.getElementById('sandpile-mass-value');
    const annealValue = document.getElementById('sandpile-anneal-value');
    const cadenceValue = document.getElementById('sandpile-cadence-value');
    const seedLabel = document.getElementById('sandpile-seed');
    const gridLabel = document.getElementById('sandpile-grid');
    const frameLabel = document.getElementById('sandpile-frame');
    const unstableLabel = document.getElementById('sandpile-unstable');
    const maxLabel = document.getElementById('sandpile-max');
    const grainsLabel = document.getElementById('sandpile-grains');
    const topplesLabel = document.getElementById('sandpile-topples');
    const actualPassesLabel = document.getElementById('sandpile-actual-passes');
    const disorderCanvas = document.getElementById('sandpile-disorder-canvas') as HTMLCanvasElement | null;
    const disorderCtx = disorderCanvas?.getContext('2d') ?? null;
    const disorderValue = document.getElementById('sandpile-disorder-value');
    const settleCanvas = document.getElementById('sandpile-settle-canvas') as HTMLCanvasElement | null;
    const settleCtx = settleCanvas?.getContext('2d') ?? null;
    const settleValue = document.getElementById('sandpile-settle-value');
    const DISORDER_SAMPLES = 240;
    const DISORDER_SAMPLE_EVERY = 12;
    const disorderHistory = new Float32Array(DISORDER_SAMPLES);
    let disorderFilled = 0;
    const settleHistory = new Float32Array(DISORDER_SAMPLES);
    let settleFilled = 0;
    let snapshot = new Uint32Array();

    const CELL_PX = 4;
    const ACTIVE_DECAY = 18;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex(styles.getPropertyValue('--paper').trim() || '#0e0e10');
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let grains = new Uint32Array();
    let nextGrains = new Uint32Array();
    let active = new Uint8Array();
    let image = new ImageData(1, 1);
    let rng = mulberry32(1);
    let frame = 0;
    let seed = 0;
    let topplesThisFrame = 0;
    let topplePassesPerFrame = Number(passesInput?.value ?? 8);
    const SNAPSHOT_INTERVAL_FRAMES = 2700;
    let pulseCadence = Math.max(1, Number(cadenceInput?.value ?? 90));
    type InjectionMode = 'uniform' | 'centered-point';
    const VALID_MODES: ReadonlyArray<InjectionMode> = ['uniform', 'centered-point'];
    function parseMode(v: string | undefined): InjectionMode {
      return (VALID_MODES as readonly string[]).includes(v ?? '') ? (v as InjectionMode) : 'centered-point';
    }
    let injectionMode: InjectionMode = parseMode(modeSelect?.value);
    let baseHeight = Number(baseInput?.value ?? 0);
    let massScale = Number(massInput?.value ?? 1);
    let annealFrames = Number(annealInput?.value ?? 180);
    let actualPasses = topplePassesPerFrame;
    let seederName = '';
    let palette: number[][] = [];

    type Seeder = { name: string; fn: () => void };

    function parseHex(h: string) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: number[]) {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: number[], b: number[], t: number) {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function hashString(s: string) {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(n: number) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function idx(x: number, y: number) {
      return y * W + x;
    }

    function choosePalette() {
      const indices = new Set<number>();
      const picked: number[][] = [];
      while (picked.length < 5) {
        const i = Math.floor(rng() * colorPool.length);
        if (indices.has(i)) continue;
        indices.add(i);
        picked.push(colorPool[i]);
      }
      const midAlphas = [0.50, 0.72, 0.90];
      for (let i = midAlphas.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [midAlphas[i], midAlphas[j]] = [midAlphas[j], midAlphas[i]];
      }
      const alphas = [0.16 + rng() * 0.10, midAlphas[0], midAlphas[1], midAlphas[2], 0.92 + rng() * 0.08];
      palette = picked.map((color, i) => mix(paper, color, alphas[i]));
    }

    function fillBase() {
      grains.fill(Math.max(0, baseHeight));
    }

    const seeders: Seeder[] = [
      {
        name: 'primed',
        fn: () => {
          grains.fill(3);
        },
      },
      {
        name: 'clean',
        fn: () => {
          fillBase(0);
        },
      },
    ];

    for (const seeder of seeders) {
      const option = document.createElement('option');
      option.value = seeder.name;
      option.textContent = seeder.name;
      seederSelect?.append(option);
    }
    if (seederSelect) seederSelect.value = 'primed';

    function chooseSeeder() {
      const selected = seederSelect?.value ?? 'random';
      if (selected !== 'random') return seeders.find((seeder) => seeder.name === selected) ?? seeders[0];
      return seeders[Math.floor(rng() * seeders.length)];
    }

    function seedCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      choosePalette();
      grains.fill(0);
      nextGrains.fill(0);
      active.fill(0);
      frame = 0;
      topplesThisFrame = 0;
      actualPasses = annealFrames > 0 ? 100 : topplePassesPerFrame;
      disorderHistory.fill(0);
      disorderFilled = 0;
      settleHistory.fill(0);
      settleFilled = 0;
      snapshot.fill(0);
      const seeder = chooseSeeder();
      seederName = seeder.name;
      seeder.fn();
      updatePanel();
      drawDisorder();
      drawSettle();
    }

    function pulseUniformSymmetric() {
      for (let i = 0; i < grains.length; i++) grains[i] += 1;
    }

    function pulseCenteredPoint() {
      const totalPerCycle = 32000 * massScale;
      const k = Math.max(1, Math.floor(totalPerCycle * pulseCadence / SNAPSHOT_INTERVAL_FRAMES));
      const cx = W >> 1;
      const cy = H >> 1;
      grains[idx(cx, cy)] += k;
    }

    function topplePass() {
      let topples = 0;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const i = idx(x, y);
          const q = Math.floor(grains[i] / 4);
          let value = grains[i] - q * 4;
          if (x > 0) value += Math.floor(grains[i - 1] / 4);
          if (x < W - 1) value += Math.floor(grains[i + 1] / 4);
          if (y > 0) value += Math.floor(grains[i - W] / 4);
          if (y < H - 1) value += Math.floor(grains[i + W] / 4);
          nextGrains[i] = value;
          if (q > 0) {
            active[i] = 255;
            topples += q;
          }
        }
      }
      [grains, nextGrains] = [nextGrains, grains];
      return topples;
    }

    function step() {
      topplesThisFrame = 0;
      if (frame % SNAPSHOT_INTERVAL_FRAMES === 0) {
        snapshot.set(grains);
      }
      if (frame % pulseCadence === 0) {
        if (injectionMode === 'uniform') pulseUniformSymmetric();
        else if (injectionMode === 'centered-point') pulseCenteredPoint();
      }
      actualPasses = frame < annealFrames ? 100 : topplePassesPerFrame;
      for (let i = 0; i < actualPasses; i++) topplesThisFrame += topplePass();
      for (let i = 0; i < active.length; i++) {
        if (active[i] > ACTIVE_DECAY) active[i] -= ACTIVE_DECAY;
        else active[i] = 0;
      }
      frame++;
      if (frame % DISORDER_SAMPLE_EVERY === 0) {
        pushDisorder(measureDisorder());
        drawDisorder();
        pushSettle(measureSettle());
        drawSettle();
      }
      if (frame % 12 === 0) updatePanel();
    }

    function measureDisorder() {
      let diff = 0;
      let pairs = 0;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W - 1; x++) {
          const a = Math.min(3, grains[idx(x, y)]);
          const b = Math.min(3, grains[idx(x + 1, y)]);
          if (a !== b) diff++;
          pairs++;
        }
      }
      for (let y = 0; y < H - 1; y++) {
        for (let x = 0; x < W; x++) {
          const a = Math.min(3, grains[idx(x, y)]);
          const b = Math.min(3, grains[idx(x, y + 1)]);
          if (a !== b) diff++;
          pairs++;
        }
      }
      return pairs > 0 ? diff / pairs : 0;
    }

    function pushDisorder(value: number) {
      if (disorderFilled < DISORDER_SAMPLES) {
        disorderHistory[disorderFilled++] = value;
      } else {
        disorderHistory.copyWithin(0, 1);
        disorderHistory[DISORDER_SAMPLES - 1] = value;
      }
      if (disorderValue) disorderValue.textContent = value.toFixed(3);
    }

    function drawSparkline(
      sCtx: CanvasRenderingContext2D | null,
      sCanvas: HTMLCanvasElement | null,
      history: Float32Array,
      filled: number,
    ) {
      if (!sCtx || !sCanvas) return;
      const cw = sCanvas.width;
      const ch = sCanvas.height;
      sCtx.clearRect(0, 0, cw, ch);
      if (filled === 0) return;
      const inkRgb = palette[palette.length - 1] ?? [220, 220, 220];
      sCtx.strokeStyle = 'rgba(255, 255, 255, 0.18)';
      sCtx.lineWidth = 1;
      sCtx.beginPath();
      sCtx.moveTo(0, ch * 0.5);
      sCtx.lineTo(cw, ch * 0.5);
      sCtx.stroke();
      sCtx.strokeStyle = `rgb(${inkRgb[0]}, ${inkRgb[1]}, ${inkRgb[2]})`;
      sCtx.lineWidth = 1.25;
      sCtx.beginPath();
      const span = DISORDER_SAMPLES;
      for (let i = 0; i < filled; i++) {
        const x = (i / (span - 1)) * cw;
        const v = Math.max(0, Math.min(1, history[i]));
        const y = ch - v * ch;
        if (i === 0) sCtx.moveTo(x, y);
        else sCtx.lineTo(x, y);
      }
      sCtx.stroke();
    }

    function drawDisorder() {
      drawSparkline(disorderCtx, disorderCanvas, disorderHistory, disorderFilled);
    }

    function measureSettle() {
      if (snapshot.length !== grains.length) return 0;
      let diff = 0;
      const n = grains.length;
      for (let i = 0; i < n; i++) {
        const a = Math.min(3, grains[i]);
        const b = Math.min(3, snapshot[i]);
        if (a !== b) diff++;
      }
      return n > 0 ? diff / n : 0;
    }

    function pushSettle(value: number) {
      if (settleFilled < DISORDER_SAMPLES) {
        settleHistory[settleFilled++] = value;
      } else {
        settleHistory.copyWithin(0, 1);
        settleHistory[DISORDER_SAMPLES - 1] = value;
      }
      if (settleValue) settleValue.textContent = value.toFixed(3);
    }

    function drawSettle() {
      drawSparkline(settleCtx, settleCanvas, settleHistory, settleFilled);
    }

    function updatePanel() {
      if (!seedLabel) return;
      let unstable = 0;
      let max = 0;
      let total = 0;
      for (let i = 0; i < grains.length; i++) {
        const value = grains[i];
        if (value >= 4) unstable++;
        if (value > max) max = value;
        total += value;
      }
      seedLabel.textContent = seed.toString(16).padStart(8, '0');
      if (seederLabel) seederLabel.textContent = seederName;
      if (gridLabel) gridLabel.textContent = `${W}x${H}`;
      if (frameLabel) frameLabel.textContent = String(frame);
      if (unstableLabel) unstableLabel.textContent = String(unstable);
      if (maxLabel) maxLabel.textContent = String(max);
      if (grainsLabel) grainsLabel.textContent = total.toLocaleString();
      if (topplesLabel) topplesLabel.textContent = topplesThisFrame.toLocaleString();
      if (actualPassesLabel) actualPassesLabel.textContent = String(actualPasses);
    }

    function draw() {
      const data = image.data;
      for (let i = 0; i < grains.length; i++) {
        const h = Math.min(3, grains[i]);
        const base = palette[h];
        const color = base;
        const o = i * 4;
        data[o] = color[0];
        data[o + 1] = color[1];
        data[o + 2] = color[2];
        data[o + 3] = h === 0 ? 150 : 255;
      }
      ctx.putImageData(image, 0, 0);
    }

    function resize() {
      W = Math.max(48, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(36, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      grains = new Uint32Array(W * H);
      nextGrains = new Uint32Array(W * H);
      active = new Uint8Array(W * H);
      snapshot = new Uint32Array(W * H);
      image = new ImageData(W, H);
      seedCycle();
      draw();
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 300; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    resetButton?.addEventListener('click', () => {
      seedCycle();
      draw();
    });
    seederSelect?.addEventListener('change', () => {
      seedCycle();
      draw();
    });
    modeSelect?.addEventListener('change', () => {
      injectionMode = parseMode(modeSelect.value);
    });
    passesInput?.addEventListener('input', () => {
      topplePassesPerFrame = Number(passesInput.value);
      if (passesValue) passesValue.textContent = passesInput.value;
    });
    baseInput?.addEventListener('input', () => {
      baseHeight = Number(baseInput.value);
      if (baseValue) baseValue.textContent = baseInput.value;
    });
    massInput?.addEventListener('input', () => {
      massScale = Number(massInput.value);
      if (massValue) massValue.textContent = massScale.toFixed(1);
    });
    annealInput?.addEventListener('input', () => {
      annealFrames = Number(annealInput.value);
      if (annealValue) annealValue.textContent = annealInput.value;
    });
    cadenceInput?.addEventListener('input', () => {
      pulseCadence = Math.max(1, Number(cadenceInput.value));
      if (cadenceValue) cadenceValue.textContent = String(pulseCadence);
    });
  }
</script>
