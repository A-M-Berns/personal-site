---
import Base from '../../layouts/Base.astro';
---
<Base title="Other — A. M. Berns" description="Side projects and miscellaneous experiments.">
  <div class="other-shell">
    <canvas id="sandpile-sim" class="sandpile-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Other</span></h1>
      <p><span class="hl">Side projects and miscellaneous experiments.</span></p>
    </header>
    <article class="note other-note">
      <ul>
        <li><span class="hl">Abelian sandpile experiments.</span></li>
        <li><span class="hl"><a href="/Animations/">Animation-only views</a></span></li>
      </ul>
    </article>
    <aside class="sandpile-panel" aria-label="Sandpile controls">
      <div class="sandpile-panel-head">
        <h2>Sandpile</h2>
        <button id="sandpile-reset" type="button">Reset</button>
      </div>
      <div class="sandpile-panel-row">
        <span>seeder</span>
        <strong id="sandpile-seeder">-</strong>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-passes">passes</label>
        <input id="sandpile-passes" type="range" min="1" max="16" step="1" value="8" />
        <span id="sandpile-passes-value">8</span>
      </div>
      <div class="sandpile-panel-row sandpile-panel-row--control">
        <label for="sandpile-drops">drops</label>
        <input id="sandpile-drops" type="range" min="0" max="16" step="1" value="6" />
        <span id="sandpile-drops-value">6</span>
      </div>
      <dl class="sandpile-stats">
        <div><dt>seed</dt><dd id="sandpile-seed">-</dd></div>
        <div><dt>grid</dt><dd id="sandpile-grid">-</dd></div>
        <div><dt>frame</dt><dd id="sandpile-frame">-</dd></div>
        <div><dt>unstable</dt><dd id="sandpile-unstable">-</dd></div>
        <div><dt>max</dt><dd id="sandpile-max">-</dd></div>
        <div><dt>grains</dt><dd id="sandpile-grains">-</dd></div>
        <div><dt>topples</dt><dd id="sandpile-topples">-</dd></div>
      </dl>
    </aside>
  </div>
</Base>

<script>
  const canvas = document.getElementById('sandpile-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const resetButton = document.getElementById('sandpile-reset') as HTMLButtonElement | null;
    const passesInput = document.getElementById('sandpile-passes') as HTMLInputElement | null;
    const dropsInput = document.getElementById('sandpile-drops') as HTMLInputElement | null;
    const seederLabel = document.getElementById('sandpile-seeder');
    const passesValue = document.getElementById('sandpile-passes-value');
    const dropsValue = document.getElementById('sandpile-drops-value');
    const seedLabel = document.getElementById('sandpile-seed');
    const gridLabel = document.getElementById('sandpile-grid');
    const frameLabel = document.getElementById('sandpile-frame');
    const unstableLabel = document.getElementById('sandpile-unstable');
    const maxLabel = document.getElementById('sandpile-max');
    const grainsLabel = document.getElementById('sandpile-grains');
    const topplesLabel = document.getElementById('sandpile-topples');

    const CELL_PX = 4;
    const ACTIVE_DECAY = 18;
    const CYCLE_FRAMES = 2100;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex(styles.getPropertyValue('--paper').trim() || '#0e0e10');
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let grains = new Uint32Array();
    let nextGrains = new Uint32Array();
    let active = new Uint8Array();
    let image = new ImageData(1, 1);
    let rng = mulberry32(1);
    let frame = 0;
    let seed = 0;
    let topplesThisFrame = 0;
    let topplePassesPerFrame = Number(passesInput?.value ?? 8);
    let dropsPerFrame = Number(dropsInput?.value ?? 6);
    let seederName = '';
    let palette: number[][] = [];

    type Seeder = { name: string; fn: () => void };

    function parseHex(h: string) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: number[]) {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: number[], b: number[], t: number) {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function hashString(s: string) {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(n: number) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function idx(x: number, y: number) {
      return y * W + x;
    }

    function choosePalette() {
      const picked: number[][] = [];
      for (let i = 0; i < 5; i++) {
        const lo = Math.floor((i * colorPool.length) / 5);
        const hi = Math.floor(((i + 1) * colorPool.length) / 5);
        picked.push(colorPool[lo + Math.floor(rng() * Math.max(1, hi - lo))]);
      }
      palette = [
        mix(paper, picked[0], 0.18),
        mix(paper, picked[1], 0.46),
        mix(paper, picked[2], 0.70),
        mix(paper, picked[3], 0.90),
        mix(paper, picked[4], 1.00),
      ];
    }

    function addHill(cx: number, cy: number, radius: number, amount: number) {
      const r2 = radius * radius;
      for (let y = Math.max(0, cy - radius); y <= Math.min(H - 1, cy + radius); y++) {
        for (let x = Math.max(0, cx - radius); x <= Math.min(W - 1, cx + radius); x++) {
          const dx = x - cx;
          const dy = y - cy;
          const d2 = dx * dx + dy * dy;
          if (d2 > r2) continue;
          const falloff = 1 - d2 / r2;
          const i = idx(x, y);
          grains[i] += Math.floor(amount * falloff * (0.45 + rng() * 0.75));
        }
      }
    }

    const seeders: Seeder[] = [
      {
        name: 'central hill',
        fn: () => {
          grains.fill(0);
          addHill(
            Math.floor(W * (0.38 + rng() * 0.24)),
            Math.floor(H * (0.36 + rng() * 0.28)),
            Math.floor(Math.min(W, H) * (0.16 + rng() * 0.10)),
            70 + Math.floor(rng() * 90),
          );
        },
      },
      {
        name: 'satellites',
        fn: () => {
          for (let i = 0; i < grains.length; i++) grains[i] = Math.floor(rng() * 2);
          const count = 5 + Math.floor(rng() * 8);
          for (let n = 0; n < count; n++) {
            addHill(
              Math.floor(W * (0.1 + rng() * 0.8)),
              Math.floor(H * (0.1 + rng() * 0.8)),
              Math.floor(Math.min(W, H) * (0.035 + rng() * 0.055)),
              22 + Math.floor(rng() * 40),
            );
          }
        },
      },
      {
        name: 'ridge',
        fn: () => {
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const diagonal = Math.abs((x / W) - (y / H));
              const ridge = Math.max(0, 1 - diagonal * 18);
              const side = x > y * (W / H) ? 2 : 0;
              grains[idx(x, y)] = side + Math.floor(ridge * (90 + rng() * 50));
            }
          }
        },
      },
      {
        name: 'rings',
        fn: () => {
          const cx = W * (0.42 + rng() * 0.16);
          const cy = H * (0.42 + rng() * 0.16);
          const ring = Math.max(4, Math.min(W, H) * (0.045 + rng() * 0.035));
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const dx = x - cx;
              const dy = y - cy;
              const wave = (Math.sin(Math.sqrt(dx * dx + dy * dy) / ring) + 1) * 0.5;
              grains[idx(x, y)] = Math.floor(wave * wave * (32 + rng() * 36));
            }
          }
        },
      },
      {
        name: 'salt flats',
        fn: () => {
          for (let i = 0; i < grains.length; i++) grains[i] = 3;
          const burns = Math.floor(grains.length * 0.035);
          for (let i = 0; i < burns; i++) grains[Math.floor(rng() * grains.length)] += 16 + Math.floor(rng() * 52);
        },
      },
      {
        name: 'columns',
        fn: () => {
          const freq = 4 + Math.floor(rng() * 5);
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const band = Math.sin((x / W) * Math.PI * freq);
              const shelf = y > H * 0.5 ? 2 : 0;
              grains[idx(x, y)] = shelf + Math.floor(Math.max(0, band) * (36 + rng() * 30));
            }
          }
        },
      },
      {
        name: 'corners',
        fn: () => {
          for (let i = 0; i < grains.length; i++) grains[i] = Math.floor(rng() * 4);
          const r = Math.floor(Math.min(W, H) * (0.08 + rng() * 0.06));
          addHill(Math.floor(W * 0.12), Math.floor(H * 0.14), r, 28 + Math.floor(rng() * 44));
          addHill(Math.floor(W * 0.88), Math.floor(H * 0.16), r, 28 + Math.floor(rng() * 44));
          addHill(Math.floor(W * 0.16), Math.floor(H * 0.86), r, 28 + Math.floor(rng() * 44));
          addHill(Math.floor(W * 0.84), Math.floor(H * 0.84), r, 28 + Math.floor(rng() * 44));
        },
      },
      {
        name: 'pin field',
        fn: () => {
          grains.fill(0);
          const spacing = 5 + Math.floor(rng() * 7);
          for (let y = spacing >> 1; y < H; y += spacing) {
            for (let x = spacing >> 1; x < W; x += spacing) {
              grains[idx(x, y)] = 18 + Math.floor(rng() * 54);
            }
          }
          for (let i = 0; i < grains.length; i++) grains[i] += Math.floor(rng() * 3);
        },
      },
      {
        name: 'cross',
        fn: () => {
          grains.fill(0);
          const cx = Math.floor(W / 2);
          const cy = Math.floor(H / 2);
          const arm = Math.floor(Math.min(W, H) * (0.035 + rng() * 0.025));
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              const v = Math.abs(x - cx) < arm || Math.abs(y - cy) < arm;
              grains[idx(x, y)] = v ? 28 + Math.floor(rng() * 50) : Math.floor(rng() * 2);
            }
          }
        },
      },
      {
        name: 'basins',
        fn: () => {
          const wells = Array.from({ length: 4 + Math.floor(rng() * 4) }, () => ({
            x: rng() * W,
            y: rng() * H,
            h: 26 + rng() * 60,
          }));
          for (let y = 0; y < H; y++) {
            for (let x = 0; x < W; x++) {
              let value = 0;
              for (const well of wells) {
                const dx = x - well.x;
                const dy = y - well.y;
                value += well.h / (1 + 0.028 * (dx * dx + dy * dy));
              }
              grains[idx(x, y)] = Math.floor(value);
            }
          }
        },
      },
      {
        name: 'fault lines',
        fn: () => {
          grains.fill(1);
          const lines = 3 + Math.floor(rng() * 4);
          for (let n = 0; n < lines; n++) {
            const slope = -1.5 + rng() * 3;
            const intercept = rng() * H;
            const width = 2 + rng() * 5;
            for (let y = 0; y < H; y++) {
              for (let x = 0; x < W; x++) {
                const d = Math.abs(y - (slope * x + intercept));
                if (d < width) grains[idx(x, y)] += Math.floor((1 - d / width) * (42 + rng() * 40));
              }
            }
          }
        },
      },
    ];

    function seedCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      choosePalette();
      grains.fill(0);
      nextGrains.fill(0);
      active.fill(0);
      frame = 0;
      topplesThisFrame = 0;
      const seeder = seeders[Math.floor(rng() * seeders.length)];
      seederName = seeder.name;
      seeder.fn();
      updatePanel();
    }

    function addGrains() {
      for (let n = 0; n < dropsPerFrame; n++) {
        const x = Math.floor(W * (0.12 + rng() * 0.76));
        const y = Math.floor(H * (0.12 + rng() * 0.76));
        const i = idx(x, y);
        grains[i] += 1 + Math.floor(rng() * 3);
      }
    }

    function topplePass() {
      let topples = 0;
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const i = idx(x, y);
          const q = Math.floor(grains[i] / 4);
          let value = grains[i] - q * 4;
          if (x > 0) value += Math.floor(grains[i - 1] / 4);
          if (x < W - 1) value += Math.floor(grains[i + 1] / 4);
          if (y > 0) value += Math.floor(grains[i - W] / 4);
          if (y < H - 1) value += Math.floor(grains[i + W] / 4);
          nextGrains[i] = value;
          if (q > 0) {
            active[i] = 255;
            topples += q;
          }
        }
      }
      [grains, nextGrains] = [nextGrains, grains];
      return topples;
    }

    function step() {
      topplesThisFrame = 0;
      addGrains();
      for (let i = 0; i < topplePassesPerFrame; i++) topplesThisFrame += topplePass();
      for (let i = 0; i < active.length; i++) {
        if (active[i] > ACTIVE_DECAY) active[i] -= ACTIVE_DECAY;
        else active[i] = 0;
      }
      if (++frame > CYCLE_FRAMES) seedCycle();
      else if (frame % 12 === 0) updatePanel();
    }

    function updatePanel() {
      if (!seedLabel) return;
      let unstable = 0;
      let max = 0;
      let total = 0;
      for (let i = 0; i < grains.length; i++) {
        const value = grains[i];
        if (value >= 4) unstable++;
        if (value > max) max = value;
        total += value;
      }
      seedLabel.textContent = seed.toString(16).padStart(8, '0');
      if (seederLabel) seederLabel.textContent = seederName;
      if (gridLabel) gridLabel.textContent = `${W}x${H}`;
      if (frameLabel) frameLabel.textContent = `${frame}/${CYCLE_FRAMES}`;
      if (unstableLabel) unstableLabel.textContent = String(unstable);
      if (maxLabel) maxLabel.textContent = String(max);
      if (grainsLabel) grainsLabel.textContent = total.toLocaleString();
      if (topplesLabel) topplesLabel.textContent = topplesThisFrame.toLocaleString();
    }

    function draw() {
      const data = image.data;
      for (let i = 0; i < grains.length; i++) {
        const h = Math.min(3, grains[i]);
        const flash = active[i] / 255;
        const base = palette[h];
        const color = flash > 0 ? mix(base, palette[4], 0.45 + flash * 0.55) : base;
        const o = i * 4;
        data[o] = color[0];
        data[o + 1] = color[1];
        data[o + 2] = color[2];
        data[o + 3] = h === 0 && flash === 0 ? 150 : 255;
      }
      ctx.putImageData(image, 0, 0);
    }

    function resize() {
      W = Math.max(48, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(36, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      grains = new Uint32Array(W * H);
      nextGrains = new Uint32Array(W * H);
      active = new Uint8Array(W * H);
      image = new ImageData(W, H);
      seedCycle();
      draw();
    }

    resize();
    if (reduce) {
      for (let i = 0; i < 300; i++) step();
      draw();
    } else {
      const loop = () => {
        step();
        draw();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
    window.addEventListener('resize', resize);
    resetButton?.addEventListener('click', () => {
      seedCycle();
      draw();
    });
    passesInput?.addEventListener('input', () => {
      topplePassesPerFrame = Number(passesInput.value);
      if (passesValue) passesValue.textContent = passesInput.value;
    });
    dropsInput?.addEventListener('input', () => {
      dropsPerFrame = Number(dropsInput.value);
      if (dropsValue) dropsValue.textContent = dropsInput.value;
    });
  }
</script>
