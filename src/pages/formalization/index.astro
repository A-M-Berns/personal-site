---
import Base from '../../layouts/Base.astro';
---
<Base title="Formalization — A. M. Berns" description="Formalization projects in Lean 4.">
  <div class="lean-shell">
    <canvas id="ant-sim" class="ant-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Formalization</span></h1>
      <p><span class="hl">Formalization projects in Lean 4.</span></p>
    </header>
    <article class="note">
      <ul>
        <li>
          <span class="hl"><a href="https://github.com/leanprover-community/mathlib4/blob/7d71710aa79bdb99d16d25644d1e592501f26c41/Mathlib/Geometry/Polygon/Basic.lean">Mathlib polygon geometry</a></span>
        </li>
        <li>
          <span class="hl"><a href="https://github.com/A-M-Berns/Formalized-Agent-Foundations">Formalized Agent Foundations</a></span>
        </li>
      </ul>
    </article>
    <aside id="ant-label" class="ant-label" aria-live="polite"></aside>
    <div class="anim-controls">
      <button id="ant-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="ant-restart" type="button" aria-label="Reset ant">Reset</button>
    </div>
    <dialog id="ant-about" class="anim-about" aria-labelledby="ant-about-title">
      <button class="anim-about-close" type="button" aria-label="Close">×</button>
      <h2 id="ant-about-title">About this animation</h2>
      <p>
        n-state Langton's ant (Gale, Propp, Sutherland, Troubetzkoy 1995). A rule-string of L's and R's specifies what each cell-state does when an ant visits it: turn left or turn right. As the ant leaves, the cell advances to the next state mod n. With n &gt; 2 some rule-strings produce bilaterally-symmetric "tracks" that grow forever while never drifting from their starting cell.
      </p>
      <p>
        Each cycle picks a fresh rule-string, ant count, and palette; press Reset to advance immediately.
      </p>
    </dialog>
    <aside class="ant-panel" aria-label="Ant controls">
      <div class="ant-panel-head">
        <h2>Ant</h2>
        <button id="ant-reset" type="button">Reset</button>
      </div>
      <div class="ant-panel-body">
        <label class="ant-panel-field">
          <span>preset</span>
          <select id="ant-preset">
            <option value="random" selected>random</option>
            <option value="LR">2 — LR (Langton)</option>
            <option value="LRRL">9 — LRRL</option>
            <option value="LLRR">12 — LLRR</option>
            <option value="LRRRRL">33 — LRRRRL</option>
            <option value="LRRLLL">39 — LRRLLL</option>
            <option value="LLRRRR">48 — LLRRRR</option>
            <option value="LLRRLL">51 — LLRRLL</option>
            <option value="LLLRRL">57 — LLLRRL</option>
            <option value="LLLLRR">60 — LLLLRR</option>
            <option value="LRRRRRRL">214 — LRRRRRRL</option>
            <option value="LLRRLLRR">204 — LLRRLLRR</option>
          </select>
        </label>
        <div class="ant-panel-row">
          <label for="ant-rule">rule</label>
          <input id="ant-rule" type="text" autocomplete="off" spellcheck="false" maxlength="14" value="LLRR" />
          <span id="ant-rule-status">ok</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-count">ants</label>
          <input id="ant-count" type="range" min="1" max="12" step="1" value="1" />
          <span id="ant-count-value">1</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-speed">speed</label>
          <input id="ant-speed" type="range" min="100" max="6000" step="100" value="1500" />
          <span id="ant-speed-value">1500</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-cell">cell</label>
          <input id="ant-cell" type="range" min="3" max="9" step="1" value="5" />
          <span id="ant-cell-value">5</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-cycle">cycle</label>
          <input id="ant-cycle" type="range" min="20" max="180" step="5" value="60" />
          <span id="ant-cycle-value">60s</span>
        </div>
        <dl class="ant-stats">
          <div><dt>n</dt><dd id="ant-n">-</dd></div>
          <div><dt>step</dt><dd id="ant-step">-</dd></div>
          <div><dt>seed</dt><dd id="ant-seed">-</dd></div>
          <div><dt>rule</dt><dd id="ant-rule-readout">-</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</Base>

<style>
  .ant-sim {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    opacity: 0.85;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  .ant-label {
    position: fixed;
    right: 1rem;
    top: 1rem;
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
    max-width: min(34rem, calc(100vw - 2rem));
    background: rgba(0, 0, 0, 0.82);
    border: 1px solid rgba(236, 236, 236, 0.12);
    border-radius: 3px;
    padding: 0.45rem 0.6rem;
    color: var(--muted);
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1.2;
    pointer-events: none;
  }
  .ant-label span { white-space: nowrap; }
  @media (max-width: 760px) {
    .ant-label { top: 3.55rem; }
  }

  .ant-panel {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 3;
    width: 17rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .ant-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .ant-panel-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ant-panel button {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
  }
  .ant-panel button:hover { color: var(--ink); border-color: var(--muted); }
  .ant-panel-field {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .ant-panel-field span { font-size: 0.7rem; color: var(--muted); }
  .ant-panel-field select {
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    color: var(--muted);
    background: rgba(14, 14, 16, 0.55);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.2rem 0.35rem;
  }
  .ant-panel-row {
    display: grid;
    grid-template-columns: 4rem 1fr 3.3rem;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .ant-panel-row label { font-size: 0.7rem; color: var(--muted); }
  .ant-panel-row input[type="range"] { width: 100%; accent-color: var(--accent); margin: 0; }
  .ant-panel-row input[type="text"] {
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    background: rgba(14, 14, 16, 0.55);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.25rem 0.4rem;
    text-transform: uppercase;
  }
  .ant-panel-row input[type="text"].invalid {
    border-color: #d63a2a;
    color: #ff8a3a;
  }
  .ant-panel-row span {
    font-size: 0.68rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .ant-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin: 0.6rem 0 0;
    font-size: 0.65rem;
  }
  .ant-stats div {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.3rem;
    overflow: hidden;
  }
  .ant-stats dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ant-stats dd {
    margin: 0;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  html:not(.dev-mode) .ant-panel { display: none !important; }
  html.animation-only .ant-panel,
  html.animation-only .ant-label { display: none !important; }
</style>

<script>
  const canvas = document.getElementById('ant-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;

    const ruleInput = document.getElementById('ant-rule') as HTMLInputElement | null;
    const ruleStatus = document.getElementById('ant-rule-status');
    const presetSelect = document.getElementById('ant-preset') as HTMLSelectElement | null;
    const countInput = document.getElementById('ant-count') as HTMLInputElement | null;
    const countValue = document.getElementById('ant-count-value');
    const speedInput = document.getElementById('ant-speed') as HTMLInputElement | null;
    const speedValue = document.getElementById('ant-speed-value');
    const cellInput = document.getElementById('ant-cell') as HTMLInputElement | null;
    const cellValue = document.getElementById('ant-cell-value');
    const cycleInput = document.getElementById('ant-cycle') as HTMLInputElement | null;
    const cycleValue = document.getElementById('ant-cycle-value');
    const resetButton = document.getElementById('ant-reset') as HTMLButtonElement | null;
    const restartButton = document.getElementById('ant-restart') as HTMLButtonElement | null;
    const infoButton = document.getElementById('ant-info');
    const aboutDialog = document.getElementById('ant-about') as HTMLDialogElement | null;
    const aboutClose = aboutDialog?.querySelector('.anim-about-close');
    const labelEl = document.getElementById('ant-label');
    const nReadout = document.getElementById('ant-n');
    const stepReadout = document.getElementById('ant-step');
    const seedReadout = document.getElementById('ant-seed');
    const ruleReadout = document.getElementById('ant-rule-readout');

    type RGB = [number, number, number];

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex((styles.getPropertyValue('--paper').trim() || '#0e0e10'));

    // Same jewel-tone pool as the home page so the formalization animation
    // shares the site's color identity. Sorted by luma so we can sample
    // dark→light stops.
    const colorPool: RGB[] = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    // Curated rule-strings — the bilaterally-symmetric ants from the paper
    // plus a couple of longer rules for variety. These produce the
    // recurrent-track patterns shown in the paper's Figures 2 and 3.
    const RULE_POOL = [
      'LRRL',     // ant 9
      'LLRR',     // ant 12
      'LRRRRL',   // 33
      'LRRLLL',   // 39
      'LLRRRR',   // 48
      'LLRRLL',   // 51
      'LLLRRL',   // 57
      'LLLLRR',   // 60
      'LRRRRRRL', // 214
      'LLRRLLRR', // 204
      'LR',       // classic Langton
    ];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }
    function luma(c: RGB) { return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2]; }

    function mulberry32(s: number) {
      let t = s >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }
    let rng = mulberry32(1);

    let CELL_PX = Number(cellInput?.value ?? 5);
    let stepsPerFrame = Number(speedInput?.value ?? 1500);
    let antCount = Number(countInput?.value ?? 1);
    let cycleSeconds = Number(cycleInput?.value ?? 60);
    let preset: string = presetSelect?.value ?? 'random';

    let W = 0;
    let H = 0;
    let grid = new Uint8Array(0);
    let img: ImageData | null = null;

    // Direction encoding: 0=N, 1=E, 2=S, 3=W. Left = (d+3)&3, Right = (d+1)&3.
    const DX = [0, 1, 0, -1];
    const DY = [-1, 0, 1, 0];

    type Ant = { x: number; y: number; d: number };
    let ants: Ant[] = [];

    let rule: Uint8Array = new Uint8Array(0); // 0=L, 1=R
    let ruleStr = 'LLRR';
    let nStates = 4;
    let palette: RGB[] = [];
    let seed = 0;
    let totalSteps = 0;

    function isValidRule(s: string) {
      return s.length >= 2 && s.length <= 14 && /^[LR]+$/.test(s);
    }

    function setRuleFromString(s: string) {
      ruleStr = s;
      nStates = s.length;
      rule = new Uint8Array(nStates);
      for (let i = 0; i < nStates; i++) rule[i] = s[i] === 'R' ? 1 : 0;
    }

    function pickPalette() {
      // palette[0] = paper so untouched cells fade into the page background
      // (matches the figs-2/3 look where state 0 reads as the canvas paper).
      // Remaining states sample one luma-bucket each from the jewel pool,
      // sorted dark→light so stepping through states produces a smooth ramp.
      const out: RGB[] = [paper];
      const buckets = Math.max(1, nStates - 1);
      for (let i = 0; i < buckets; i++) {
        const lo = Math.floor((i * colorPool.length) / buckets);
        const hi = Math.floor(((i + 1) * colorPool.length) / buckets);
        const span = Math.max(1, hi - lo);
        out.push(colorPool[lo + Math.floor(rng() * span)]);
      }
      palette = out;
    }

    // Shuffled-deck rule picker so every cycle visits every pool entry
    // before any repeats — same pattern the home page uses for its CA
    // seeders.
    let ruleDeck: number[] = [];
    function nextPoolRule(avoid: string): string {
      if (ruleDeck.length === 0) {
        const idxs: number[] = [];
        for (let i = 0; i < RULE_POOL.length; i++) idxs.push(i);
        for (let i = idxs.length - 1; i > 0; i--) {
          const j = (rng() * (i + 1)) | 0;
          const tmp = idxs[i]; idxs[i] = idxs[j]; idxs[j] = tmp;
        }
        if (idxs.length > 1 && RULE_POOL[idxs[0]] === avoid) {
          const tmp = idxs[0]; idxs[0] = idxs[1]; idxs[1] = tmp;
        }
        ruleDeck = idxs;
      }
      return RULE_POOL[ruleDeck.shift()!];
    }

    function placeAnts() {
      ants = [];
      const cx = (W / 2) | 0;
      const cy = (H / 2) | 0;
      if (antCount === 1) {
        ants.push({ x: cx, y: cy, d: 0 });
        return;
      }
      // Spread ants on a ring around the center so they don't immediately
      // collide. Initial heading rotates with placement angle for variety.
      const r = Math.max(8, Math.min(W, H) / 6);
      for (let i = 0; i < antCount; i++) {
        const a = (i / antCount) * Math.PI * 2;
        const ax = (((cx + Math.cos(a) * r) | 0) % W + W) % W;
        const ay = (((cy + Math.sin(a) * r) | 0) % H + H) % H;
        ants.push({ x: ax, y: ay, d: i & 3 });
      }
    }

    function reseed(useExplicitRule: string | null) {
      seed = (Math.random() * 0xffffffff) >>> 0;
      rng = mulberry32(seed);
      const chosen = useExplicitRule
        ?? (preset === 'random' ? nextPoolRule(ruleStr) : preset);
      setRuleFromString(chosen);
      if (ruleInput && ruleInput.value !== chosen) {
        ruleInput.value = chosen;
        ruleInput.classList.remove('invalid');
        if (ruleStatus) ruleStatus.textContent = 'ok';
      }
      pickPalette();
      grid.fill(0);
      placeAnts();
      totalSteps = 0;
      updateLabel();
    }

    function step(n: number) {
      const r = rule;
      const ns = nStates;
      const w = W;
      const h = H;
      for (const ant of ants) {
        for (let s = 0; s < n; s++) {
          const i = ant.y * w + ant.x;
          const cell = grid[i];
          // Turn first (based on the cell's current state), increment
          // the cell, then move forward — matches the paper's "the cell
          // changes to state i+1 (mod n) as the ant leaves" rule.
          if (r[cell] === 0) ant.d = (ant.d + 3) & 3;
          else ant.d = (ant.d + 1) & 3;
          grid[i] = (cell + 1) % ns;
          let nx = ant.x + DX[ant.d];
          let ny = ant.y + DY[ant.d];
          if (nx < 0) nx += w; else if (nx >= w) nx -= w;
          if (ny < 0) ny += h; else if (ny >= h) ny -= h;
          ant.x = nx;
          ant.y = ny;
        }
      }
      totalSteps += n * ants.length;
    }

    function draw() {
      if (!img) return;
      const data = img.data;
      for (let i = 0; i < grid.length; i++) {
        const c = palette[grid[i]];
        const j = i * 4;
        data[j] = c[0];
        data[j + 1] = c[1];
        data[j + 2] = c[2];
        data[j + 3] = 255;
      }
      // Draw ants on top as a slightly-bright single pixel each so you
      // can see the heads moving across the field.
      ctx.putImageData(img, 0, 0);
      ctx.fillStyle = 'rgba(255, 255, 255, 0.85)';
      for (const ant of ants) ctx.fillRect(ant.x, ant.y, 1, 1);
    }

    function updateLabel() {
      if (labelEl) {
        labelEl.innerHTML = `
          <span>automaton: n-state ant</span>
          <span>rule: ${ruleStr}</span>
          <span>n: ${nStates}</span>
          <span>ants: ${antCount}</span>
        `;
      }
      if (nReadout) nReadout.textContent = String(nStates);
      if (ruleReadout) ruleReadout.textContent = ruleStr;
      if (seedReadout) seedReadout.textContent = seed.toString(16).padStart(8, '0');
    }

    function updateStepReadout() {
      if (stepReadout) stepReadout.textContent = totalSteps.toLocaleString();
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      grid = new Uint8Array(W * H);
      img = ctx.createImageData(W, H);
      reseed(ruleInput && isValidRule(ruleInput.value) ? ruleInput.value : null);
      draw();
    }

    // --- Wire up controls ---

    function syncRangeLabel(input: HTMLInputElement | null, out: Element | null, suffix = '') {
      if (!input || !out) return;
      out.textContent = input.value + suffix;
    }
    syncRangeLabel(countInput, countValue);
    syncRangeLabel(speedInput, speedValue);
    syncRangeLabel(cellInput, cellValue);
    syncRangeLabel(cycleInput, cycleValue, 's');

    countInput?.addEventListener('input', () => {
      antCount = Number(countInput.value);
      syncRangeLabel(countInput, countValue);
      placeAnts();
      grid.fill(0);
      totalSteps = 0;
      updateLabel();
    });
    speedInput?.addEventListener('input', () => {
      stepsPerFrame = Number(speedInput.value);
      syncRangeLabel(speedInput, speedValue);
    });
    cellInput?.addEventListener('input', () => {
      CELL_PX = Number(cellInput.value);
      syncRangeLabel(cellInput, cellValue);
      resize();
    });
    cycleInput?.addEventListener('input', () => {
      cycleSeconds = Number(cycleInput.value);
      syncRangeLabel(cycleInput, cycleValue, 's');
      scheduleAutoCycle();
    });
    presetSelect?.addEventListener('change', () => {
      preset = presetSelect.value;
      reseed(preset === 'random' ? null : preset);
      draw();
    });
    ruleInput?.addEventListener('input', () => {
      const v = ruleInput.value.toUpperCase().replace(/[^LR]/g, '');
      if (v !== ruleInput.value) ruleInput.value = v;
      if (isValidRule(v)) {
        ruleInput.classList.remove('invalid');
        if (ruleStatus) ruleStatus.textContent = 'ok';
        if (presetSelect) presetSelect.value = 'random';
        preset = 'random';
        reseed(v);
        draw();
      } else {
        ruleInput.classList.add('invalid');
        if (ruleStatus) ruleStatus.textContent = 'bad';
      }
    });
    resetButton?.addEventListener('click', () => {
      reseed(preset === 'random' ? null : preset);
      draw();
      scheduleAutoCycle();
    });
    restartButton?.addEventListener('click', () => {
      reseed(preset === 'random' ? null : preset);
      draw();
      scheduleAutoCycle();
    });
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutClose?.addEventListener('click', () => aboutDialog?.close());
    aboutDialog?.addEventListener('click', (e) => {
      if (e.target === aboutDialog) aboutDialog.close();
    });

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { resize(); draw(); }, 200);
    });

    // --- Auto cycle (matches home page's reseed-on-interval pattern) ---

    let cycleTimer: number | undefined;
    function scheduleAutoCycle() {
      window.clearInterval(cycleTimer);
      cycleTimer = window.setInterval(() => {
        // Only auto-cycle when the user hasn't pinned a preset.
        if (preset === 'random') {
          canvas.style.opacity = '0';
          window.setTimeout(() => {
            reseed(null);
            draw();
            canvas.style.opacity = '';
          }, 150);
        }
      }, cycleSeconds * 1000);
    }

    // --- Boot ---

    if (ruleInput && isValidRule(ruleInput.value)) {
      // Honor an initial value from the input if the field starts populated.
      ruleStr = ruleInput.value;
    }
    resize();

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      let last = 0;
      const targetMs = 33;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step(stepsPerFrame);
          draw();
          last = t;
          updateStepReadout();
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
      scheduleAutoCycle();
    } else {
      // Reduced motion: just render the steady-state of one short run.
      step(8000);
      draw();
      updateStepReadout();
    }
  }
</script>
