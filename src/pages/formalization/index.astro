---
import Base from '../../layouts/Base.astro';
---
<Base title="Formalization — A. M. Berns" description="Formalization projects in Lean 4.">
  <div class="lean-shell">
    <canvas id="wireworld" class="wireworld" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Formalization</span></h1>
      <p><span class="hl">Formalization projects in Lean 4.</span></p>
    </header>
    <article class="note">
      <ul>
        <li>
          <span class="hl"><a href="https://github.com/leanprover-community/mathlib4/blob/7d71710aa79bdb99d16d25644d1e592501f26c41/Mathlib/Geometry/Polygon/Basic.lean">Mathlib polygon geometry</a></span>
        </li>
        <li>
          <span class="hl"><a href="https://github.com/A-M-Berns/Formalized-Agent-Foundations">Formalized Agent Foundations</a></span>
        </li>
      </ul>
    </article>
    <aside id="wire-label" class="wire-label" aria-live="polite"></aside>
    <div class="wire-controls">
      <button id="wire-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="wire-reset" type="button" aria-label="Reset Wireworld++">Reset</button>
    </div>
    <dialog id="wire-about" aria-labelledby="wire-about-title">
      <button class="wire-about-close" type="button" aria-label="Close">x</button>
      <h2 id="wire-about-title">About this animation</h2>
      <p>
        Wireworld++ extends Wireworld with strong and weak signals. Strong and weak conductors propagate independently, which lets the circuit draw crossings without planar detours.
      </p>
      <p>
        Each cycle generates a small Boolean formula, chooses an assignment, lays the formula out as a circuit DAG, and sends strong/weak pulses through the corresponding wires.
      </p>
    </dialog>
  </div>
</Base>

<script>
  const canvas = document.getElementById('wireworld');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    ctx.imageSmoothingEnabled = false;
    const label = document.getElementById('wire-label');
    const resetButton = document.getElementById('wire-reset');
    const infoButton = document.getElementById('wire-info');
    const aboutDialog = document.getElementById('wire-about');
    const aboutClose = aboutDialog?.querySelector('.wire-about-close');

    const CELL_PX = 3;
    const TICK_MS = 42;
    const CYCLE_STEPS = 980;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const EMPTY = 0;
    const STRONG_CONDUCTOR = 1;
    const STRONG_HEAD = 2;
    const STRONG_TAIL = 3;
    const WEAK_CONDUCTOR = 4;
    const WEAK_HEAD = 5;
    const WEAK_TAIL = 6;

    const VARS = ['A', 'B', 'C', 'D'];
    const OPS = ['AND', 'OR', 'XOR'];

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex(styles.getPropertyValue('--paper').trim() || '#0e0e10');
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let state = new Uint8Array();
    let next = new Uint8Array();
    let heat = new Uint8Array();
    let seed = 0;
    let rng = mulberry32(1);
    let stepCount = 0;
    let activeCount = 0;
    let palette = [];
    let strongColor = [255, 255, 255];
    let weakColor = [255, 255, 255];
    let tailColor = [255, 128, 64];
    let strongConductorColor = [128, 128, 128];
    let weakConductorColor = [96, 96, 96];
    let pulses = [];
    let formulaText = '';
    let assignmentText = '';
    let resultText = '';

    function parseHex(h) {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c) {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a, b, t) {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c) {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    function rgba(c, a) {
      return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${Math.max(0, Math.min(1, a))})`;
    }

    function hashString(s) {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(n) {
      let t = n >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pick(items) {
      return items[Math.floor(rng() * items.length)];
    }

    function idx(x, y) {
      return y * W + x;
    }

    function inBounds(x, y) {
      return x > 1 && y > 1 && x < W - 2 && y < H - 2;
    }

    function setCell(x, y, value) {
      if (inBounds(x, y)) state[idx(x, y)] = value;
    }

    function conductor(kind) {
      return kind === 'strong' ? STRONG_CONDUCTOR : WEAK_CONDUCTOR;
    }

    function head(kind) {
      return kind === 'strong' ? STRONG_HEAD : WEAK_HEAD;
    }

    function tail(kind) {
      return kind === 'strong' ? STRONG_TAIL : WEAK_TAIL;
    }

    function buildFormula(depth) {
      if (depth <= 0 || rng() < 0.22) return { type: 'var', name: pick(VARS) };
      if (rng() < 0.18) return { type: 'not', child: buildFormula(depth - 1) };
      return { type: 'op', op: pick(OPS), left: buildFormula(depth - 1), right: buildFormula(depth - 1) };
    }

    function formulaToString(node) {
      if (node.type === 'var') return node.name;
      if (node.type === 'not') return `NOT ${formulaToString(node.child)}`;
      return `(${formulaToString(node.left)} ${node.op} ${formulaToString(node.right)})`;
    }

    function evalFormula(node, assignment) {
      if (node.type === 'var') return assignment[node.name];
      if (node.type === 'not') return !evalFormula(node.child, assignment);
      const a = evalFormula(node.left, assignment);
      const b = evalFormula(node.right, assignment);
      if (node.op === 'AND') return a && b;
      if (node.op === 'OR') return a || b;
      return a !== b;
    }

    function collectVars(node, out = new Set()) {
      if (node.type === 'var') out.add(node.name);
      else if (node.type === 'not') collectVars(node.child, out);
      else {
        collectVars(node.left, out);
        collectVars(node.right, out);
      }
      return out;
    }

    function layout(node, depth, lanes) {
      if (node.type === 'var') {
        const y = lanes.next;
        lanes.next += Math.max(10, Math.floor(H / 8));
        node.x = Math.max(5, Math.floor(W * 0.12));
        node.y = Math.min(H - 7, y);
        return node.y;
      }
      if (node.type === 'not') {
        const cy = layout(node.child, depth + 1, lanes);
        node.x = Math.min(W - 8, Math.floor(W * (0.26 + depth * 0.16)));
        node.y = cy;
        return node.y;
      }
      const ly = layout(node.left, depth + 1, lanes);
      const ry = layout(node.right, depth + 1, lanes);
      node.x = Math.min(W - 8, Math.floor(W * (0.30 + depth * 0.16)));
      node.y = Math.round((ly + ry) / 2);
      return node.y;
    }

    function drawPath(a, b, kind) {
      const midX = Math.round((a.x + b.x) / 2);
      drawLine(a.x, a.y, midX, a.y, kind);
      drawLine(midX, a.y, midX, b.y, kind === 'strong' ? 'weak' : 'strong');
      drawLine(midX, b.y, b.x, b.y, kind);
    }

    function drawLine(x0, y0, x1, y1, kind) {
      let x = x0;
      let y = y0;
      const dx = Math.abs(x1 - x0);
      const dy = -Math.abs(y1 - y0);
      const sx = x0 < x1 ? 1 : -1;
      const sy = y0 < y1 ? 1 : -1;
      let err = dx + dy;
      while (true) {
        setCell(x, y, conductor(kind));
        if (x === x1 && y === y1) break;
        const e2 = 2 * err;
        if (e2 >= dy) {
          err += dy;
          x += sx;
        }
        if (e2 <= dx) {
          err += dx;
          y += sy;
        }
      }
    }

    function drawGate(x, y, kind) {
      const c = conductor(kind);
      for (let yy = -2; yy <= 2; yy++) {
        for (let xx = -2; xx <= 2; xx++) {
          if (Math.abs(xx) === 2 || Math.abs(yy) === 2 || rng() < 0.35) setCell(x + xx, y + yy, c);
        }
      }
    }

    function wireFormula(node, assignment, parent = null, kind = 'strong') {
      if (node.type === 'var') {
        drawGate(node.x, node.y, kind);
        pulses.push({
          x: node.x,
          y: node.y,
          dx: 1,
          dy: 0,
          kind,
          period: 36 + Math.floor(rng() * 18),
          offset: Math.floor(rng() * 18),
          enabled: assignment[node.name],
        });
      } else if (node.type === 'not') {
        wireFormula(node.child, assignment, null, kind === 'strong' ? 'weak' : 'strong');
        drawPath(node.child, node, kind);
        drawGate(node.x, node.y, kind);
        pulses.push({
          x: node.x,
          y: node.y,
          dx: 1,
          dy: 0,
          kind,
          period: 54,
          offset: 9,
          enabled: evalFormula(node, assignment),
        });
      } else {
        wireFormula(node.left, assignment, null, 'strong');
        wireFormula(node.right, assignment, null, 'weak');
        drawPath(node.left, node, 'strong');
        drawPath(node.right, node, 'weak');
        drawGate(node.x, node.y, kind);
        pulses.push({
          x: node.x,
          y: node.y,
          dx: 1,
          dy: 0,
          kind,
          period: 54,
          offset: 12,
          enabled: evalFormula(node, assignment),
        });
      }
      if (parent) drawPath(node, parent, kind);
    }

    function buildCircuit() {
      state.fill(EMPTY);
      heat.fill(0);
      pulses = [];
      const formula = buildFormula(3 + Math.floor(rng() * 2));
      const assignment = {};
      for (const name of VARS) assignment[name] = rng() < 0.5;
      layout(formula, 0, { next: Math.max(8, Math.floor(H * 0.18)) });
      const output = { x: Math.max(8, W - 8), y: formula.y };
      wireFormula(formula, assignment, output, 'strong');
      drawPath(formula, output, 'strong');
      drawGate(output.x, output.y, 'strong');
      pulses.push({
        x: Math.max(4, output.x - 4),
        y: output.y,
        dx: 1,
        dy: 0,
        kind: 'strong',
        period: 54,
        offset: 20,
        enabled: evalFormula(formula, assignment),
      });
      formulaText = formulaToString(formula);
      assignmentText = [...collectVars(formula)].sort().map((name) => `${name}=${assignment[name] ? '1' : '0'}`).join(' ');
      resultText = evalFormula(formula, assignment) ? 'true' : 'false';
    }

    function makeCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      palette = [];
      for (let i = 0; i < 5; i++) {
        const lo = Math.floor((i * colorPool.length) / 5);
        const hi = Math.floor(((i + 1) * colorPool.length) / 5);
        palette.push(mix(paper, colorPool[lo + Math.floor(rng() * Math.max(1, hi - lo))], 0.92));
      }
      strongColor = palette[4];
      weakColor = palette[2];
      tailColor = palette[3];
      strongConductorColor = mix(paper, palette[4], 0.38);
      weakConductorColor = mix(paper, palette[1], 0.48);
      stepCount = 0;
      activeCount = 0;
      buildCircuit();
      updateLabel();
    }

    function updateLabel() {
      if (!label) return;
      label.innerHTML = `
        <span>automaton: Wireworld++</span>
        <span>formula: ${formulaText}</span>
        <span>assignment: ${assignmentText}</span>
        <span>result: ${resultText}</span>
        <span>active: ${activeCount}</span>
        <span>seed: ${seed.toString(16).padStart(8, '0')}</span>
      `;
    }

    function countNeighbors(x, y, target) {
      let count = 0;
      for (let yy = -1; yy <= 1; yy++) {
        for (let xx = -1; xx <= 1; xx++) {
          if (xx === 0 && yy === 0) continue;
          if (state[idx(x + xx, y + yy)] === target) count++;
        }
      }
      return count;
    }

    function injectPulse(pulse) {
      if (!pulse.enabled || (stepCount + pulse.offset) % pulse.period !== 0) return;
      setCell(pulse.x, pulse.y, head(pulse.kind));
      setCell(pulse.x - pulse.dx, pulse.y - pulse.dy, tail(pulse.kind));
    }

    function step() {
      activeCount = 0;
      for (const pulse of pulses) injectPulse(pulse);
      next.fill(EMPTY);
      for (let y = 1; y < H - 1; y++) {
        for (let x = 1; x < W - 1; x++) {
          const i = idx(x, y);
          const cell = state[i];
          if (cell === EMPTY) {
            if (heat[i] > 0) heat[i] -= 4;
            continue;
          }
          if (cell === STRONG_HEAD) {
            next[i] = STRONG_TAIL;
            heat[i] = 255;
            activeCount++;
          } else if (cell === WEAK_HEAD) {
            next[i] = WEAK_TAIL;
            heat[i] = 230;
            activeCount++;
          } else if (cell === STRONG_TAIL) {
            next[i] = STRONG_CONDUCTOR;
            heat[i] = Math.max(heat[i], 160);
          } else if (cell === WEAK_TAIL) {
            next[i] = WEAK_CONDUCTOR;
            heat[i] = Math.max(heat[i], 130);
          } else if (cell === STRONG_CONDUCTOR) {
            const heads = countNeighbors(x, y, STRONG_HEAD);
            next[i] = heads === 1 || heads === 2 ? STRONG_HEAD : STRONG_CONDUCTOR;
          } else if (cell === WEAK_CONDUCTOR) {
            const heads = countNeighbors(x, y, WEAK_HEAD);
            next[i] = heads === 1 || heads === 2 ? WEAK_HEAD : WEAK_CONDUCTOR;
          }
        }
      }
      [state, next] = [next, state];
      if (++stepCount > CYCLE_STEPS) makeCycle();
      if (stepCount % 12 === 0) updateLabel();
    }

    function draw() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const i = idx(x, y);
          const cell = state[i];
          const glow = heat[i] / 255;
          if (cell === EMPTY && glow <= 0) continue;
          if (cell === STRONG_HEAD) ctx.fillStyle = rgb(strongColor);
          else if (cell === WEAK_HEAD) ctx.fillStyle = rgb(weakColor);
          else if (cell === STRONG_TAIL || cell === WEAK_TAIL) ctx.fillStyle = rgb(tailColor);
          else if (cell === STRONG_CONDUCTOR) ctx.fillStyle = rgba(mix(strongConductorColor, strongColor, glow * 0.5), 0.74 + glow * 0.22);
          else if (cell === WEAK_CONDUCTOR) ctx.fillStyle = rgba(mix(weakConductorColor, weakColor, glow * 0.5), 0.64 + glow * 0.24);
          else ctx.fillStyle = rgba(tailColor, glow * 0.3);
          ctx.fillRect(x, y, 1, 1);
        }
      }
    }

    function inject(clientX, clientY) {
      const rect = canvas.getBoundingClientRect();
      const x = Math.floor(((clientX - rect.left) / rect.width) * W);
      const y = Math.floor(((clientY - rect.top) / rect.height) * H);
      const kind = rng() < 0.5 ? 'strong' : 'weak';
      for (let yy = -3; yy <= 3; yy++) {
        for (let xx = -3; xx <= 3; xx++) {
          const i = idx(x + xx, y + yy);
          if (state[i] === conductor(kind) && rng() < 0.32) state[i] = head(kind);
        }
      }
    }

    function resize() {
      W = Math.max(40, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(32, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      state = new Uint8Array(W * H);
      next = new Uint8Array(W * H);
      heat = new Uint8Array(W * H);
      makeCycle();
      draw();
    }

    resize();
    if (!reduce) {
      let last = 0;
      const loop = (now) => {
        if (now - last >= TICK_MS) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    } else {
      for (let i = 0; i < 120; i++) step();
      draw();
    }

    window.addEventListener('resize', resize);
    window.addEventListener('pointerdown', (event) => {
      const target = event.target;
      if (target?.closest?.('a, button, dialog')) return;
      inject(event.clientX, event.clientY);
    });
    resetButton?.addEventListener('click', () => {
      makeCycle();
      draw();
    });
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutClose?.addEventListener('click', () => aboutDialog?.close());
    aboutDialog?.addEventListener('click', (event) => {
      if (event.target === aboutDialog) aboutDialog.close();
    });
  }
</script>
