---
import Base from '../../layouts/Base.astro';
---
<Base title="Formalization — A. M. Berns" description="Formalization projects in Lean 4.">
  <div class="lean-shell">
    <canvas id="wireworld" class="wireworld" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Formalization</span></h1>
      <p><span class="hl">Formalization projects in Lean 4.</span></p>
    </header>
    <article class="note">
      <ul>
        <li>
          <span class="hl"><a href="https://github.com/leanprover-community/mathlib4/blob/7d71710aa79bdb99d16d25644d1e592501f26c41/Mathlib/Geometry/Polygon/Basic.lean">Mathlib polygon geometry</a></span>
        </li>
        <li>
          <span class="hl"><a href="https://github.com/A-M-Berns/Formalized-Agent-Foundations">Formalized Agent Foundations</a></span>
        </li>
      </ul>
    </article>
    <aside id="wire-label" class="wire-label" aria-live="polite"></aside>
    <div class="wire-controls">
      <button id="wire-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="wire-reset" type="button" aria-label="Reset Wireworld">Reset</button>
    </div>
    <dialog id="wire-about" aria-labelledby="wire-about-title">
      <button class="wire-about-close" type="button" aria-label="Close">×</button>
      <h2 id="wire-about-title">About this animation</h2>
      <p>
        Wireworld is a cellular automaton with four states: empty, conductor, electron head, and electron tail. Conductors become heads when one or two neighboring cells are heads; heads become tails; tails become conductors.
      </p>
      <p>
        Each cycle builds a seeded circuit-like conductor field from the site's color palette, injects moving electrons, and restarts after the activity has settled.
      </p>
    </dialog>
  </div>
</Base>

<script>
  const canvas = document.getElementById('wireworld') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;
    const label = document.getElementById('wire-label');
    const resetButton = document.getElementById('wire-reset') as HTMLButtonElement | null;
    const infoButton = document.getElementById('wire-info') as HTMLButtonElement | null;
    const aboutDialog = document.getElementById('wire-about') as HTMLDialogElement | null;
    const aboutClose = aboutDialog?.querySelector('.wire-about-close') as HTMLButtonElement | null;

    const CELL_PX = 3;
    const TICK_MS = 48;
    const CYCLE_STEPS = 900;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type RGB = [number, number, number];
    type SeedPoint = { x: number; y: number; dx: number; dy: number };

    const EMPTY = 0;
    const CONDUCTOR = 1;
    const HEAD = 2;
    const TAIL = 3;

    const styles = getComputedStyle(document.documentElement);
    const paperHex = styles.getPropertyValue('--paper').trim() || '#0e0e10';

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    function luma(c: RGB): number {
      return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2];
    }

    function mix(a: RGB, b: RGB, t: number): RGB {
      return [
        Math.round(a[0] + (b[0] - a[0]) * t),
        Math.round(a[1] + (b[1] - a[1]) * t),
        Math.round(a[2] + (b[2] - a[2]) * t),
      ];
    }

    function rgb(c: RGB): string {
      return `rgb(${c[0]} ${c[1]} ${c[2]})`;
    }

    function rgba(c: RGB, a: number): string {
      return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${Math.max(0, Math.min(1, a))})`;
    }

    function hashString(s: string): number {
      let h = 2166136261;
      for (let i = 0; i < s.length; i++) {
        h ^= s.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    }

    function mulberry32(seed: number) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pick<T>(items: T[], rng: () => number): T {
      return items[Math.floor(rng() * items.length)];
    }

    const paper = parseHex(paperHex);
    const colorPool = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    let W = 0;
    let H = 0;
    let state = new Uint8Array();
    let next = new Uint8Array();
    let heat = new Uint8Array();
    let seed = 0;
    let rng = mulberry32(1);
    let palette: RGB[] = [];
    let conductorColor: RGB = [128, 128, 128];
    let headColor: RGB = [255, 255, 255];
    let tailColor: RGB = [255, 128, 64];
    let stepCount = 0;
    let activeCount = 0;
    let topology = 'logic';

    function idx(x: number, y: number): number {
      return y * W + x;
    }

    function inBounds(x: number, y: number): boolean {
      return x > 1 && y > 1 && x < W - 2 && y < H - 2;
    }

    function setCell(x: number, y: number, value: number) {
      if (inBounds(x, y)) state[idx(x, y)] = value;
    }

    function drawLine(x0: number, y0: number, x1: number, y1: number) {
      let x = x0;
      let y = y0;
      const dx = Math.abs(x1 - x0);
      const dy = -Math.abs(y1 - y0);
      const sx = x0 < x1 ? 1 : -1;
      const sy = y0 < y1 ? 1 : -1;
      let err = dx + dy;
      while (true) {
        setCell(x, y, CONDUCTOR);
        if (x === x1 && y === y1) break;
        const e2 = 2 * err;
        if (e2 >= dy) {
          err += dy;
          x += sx;
        }
        if (e2 <= dx) {
          err += dx;
          y += sy;
        }
      }
    }

    function thickenConductors() {
      const copy = state.slice();
      for (let y = 2; y < H - 2; y++) {
        for (let x = 2; x < W - 2; x++) {
          if (copy[idx(x, y)] !== CONDUCTOR || rng() > 0.24) continue;
          if (rng() < 0.5) setCell(x + 1, y, CONDUCTOR);
          else setCell(x, y + 1, CONDUCTOR);
        }
      }
    }

    function addSeedHead(point: SeedPoint) {
      setCell(point.x, point.y, HEAD);
      setCell(point.x - point.dx, point.y - point.dy, TAIL);
    }

    function buildCircuit() {
      state.fill(EMPTY);
      heat.fill(0);
      const seeds: SeedPoint[] = [];
      const margin = 6;
      const count = 9 + Math.floor(rng() * 8);
      const points = Array.from({ length: count }, () => ({
        x: margin + Math.floor(rng() * Math.max(1, W - margin * 2)),
        y: margin + Math.floor(rng() * Math.max(1, H - margin * 2)),
      }));

      topology = pick(['logic', 'bus', 'braid', 'mesh'], rng);
      if (topology === 'bus') {
        const lanes = 4 + Math.floor(rng() * 4);
        for (let i = 0; i < lanes; i++) {
          const y = Math.round(((i + 1) * H) / (lanes + 1));
          drawLine(margin, y, W - margin, y + Math.floor((rng() - 0.5) * 10));
          seeds.push({ x: margin + 2, y, dx: 1, dy: 0 });
        }
        for (let i = 0; i < count - 1; i++) drawLine(points[i].x, points[i].y, points[(i + 1) % count].x, points[i].y);
      } else {
        for (let i = 0; i < count; i++) {
          const a = points[i];
          const b = points[(i + 1 + Math.floor(rng() * 3)) % count];
          if (topology === 'mesh' || rng() < 0.45) {
            drawLine(a.x, a.y, b.x, a.y);
            drawLine(b.x, a.y, b.x, b.y);
          } else {
            drawLine(a.x, a.y, b.x, b.y);
          }
          seeds.push({ x: a.x, y: a.y, dx: Math.sign(b.x - a.x) || 1, dy: Math.sign(b.y - a.y) || 0 });
        }
      }

      for (let i = 0; i < Math.floor(count * 0.55); i++) {
        const a = pick(points, rng);
        const b = pick(points, rng);
        drawLine(a.x, a.y, b.x, b.y);
      }
      thickenConductors();
      for (const point of seeds.slice(0, 4 + Math.floor(rng() * 5))) addSeedHead(point);
    }

    function makeCycle() {
      seed = hashString(`${Date.now()}:${Math.random()}`);
      rng = mulberry32(seed);
      palette = [];
      for (let i = 0; i < 5; i++) {
        const lo = Math.floor((i * colorPool.length) / 5);
        const hi = Math.floor(((i + 1) * colorPool.length) / 5);
        palette.push(mix(paper, colorPool[lo + Math.floor(rng() * Math.max(1, hi - lo))], 0.92));
      }
      conductorColor = mix(paper, palette[1], 0.45);
      headColor = palette[4];
      tailColor = palette[2];
      buildCircuit();
      stepCount = 0;
      updateLabel();
    }

    function updateLabel() {
      if (!label) return;
      label.innerHTML = `
        <span>automaton: wireworld</span>
        <span>topology: ${topology}</span>
        <span>active: ${activeCount}</span>
        <span>seed: ${seed.toString(16).padStart(8, '0')}</span>
      `;
    }

    function countHeadNeighbors(x: number, y: number): number {
      let count = 0;
      for (let yy = -1; yy <= 1; yy++) {
        for (let xx = -1; xx <= 1; xx++) {
          if (xx === 0 && yy === 0) continue;
          if (state[idx(x + xx, y + yy)] === HEAD) count++;
        }
      }
      return count;
    }

    function step() {
      activeCount = 0;
      next.fill(EMPTY);
      for (let y = 1; y < H - 1; y++) {
        for (let x = 1; x < W - 1; x++) {
          const i = idx(x, y);
          const cell = state[i];
          if (cell === EMPTY) continue;
          if (cell === HEAD) {
            next[i] = TAIL;
            heat[i] = 255;
            activeCount++;
          } else if (cell === TAIL) {
            next[i] = CONDUCTOR;
            heat[i] = Math.max(heat[i], 160);
          } else {
            const heads = countHeadNeighbors(x, y);
            next[i] = heads === 1 || heads === 2 ? HEAD : CONDUCTOR;
          }
          if (heat[i] > 0) heat[i] -= 5;
        }
      }
      [state, next] = [next, state];
      if (++stepCount > CYCLE_STEPS || (stepCount > 160 && activeCount === 0)) makeCycle();
      if (stepCount % 12 === 0) updateLabel();
    }

    function draw() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W, H);
      for (let y = 0; y < H; y++) {
        for (let x = 0; x < W; x++) {
          const i = idx(x, y);
          const cell = state[i];
          const glow = heat[i] / 255;
          if (cell === EMPTY && glow <= 0) continue;
          if (cell === HEAD) ctx.fillStyle = rgb(headColor);
          else if (cell === TAIL) ctx.fillStyle = rgb(tailColor);
          else if (cell === CONDUCTOR) ctx.fillStyle = rgba(mix(conductorColor, headColor, glow * 0.55), 0.72 + glow * 0.22);
          else ctx.fillStyle = rgba(tailColor, glow * 0.32);
          ctx.fillRect(x, y, 1, 1);
        }
      }
    }

    function inject(clientX: number, clientY: number) {
      const rect = canvas.getBoundingClientRect();
      const x = Math.floor(((clientX - rect.left) / rect.width) * W);
      const y = Math.floor(((clientY - rect.top) / rect.height) * H);
      for (let yy = -2; yy <= 2; yy++) {
        for (let xx = -2; xx <= 2; xx++) {
          const i = idx(x + xx, y + yy);
          if (state[i] === CONDUCTOR && rng() < 0.38) state[i] = HEAD;
        }
      }
    }

    function resize() {
      W = Math.max(8, Math.ceil(window.innerWidth / CELL_PX));
      H = Math.max(8, Math.ceil(window.innerHeight / CELL_PX));
      canvas.width = W;
      canvas.height = H;
      ctx.imageSmoothingEnabled = false;
      state = new Uint8Array(W * H);
      next = new Uint8Array(W * H);
      heat = new Uint8Array(W * H);
      makeCycle();
      draw();
    }

    resize();
    if (!reduce) {
      let last = 0;
      const loop = (now: number) => {
        if (now - last >= TICK_MS) {
          step();
          draw();
          last = now;
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    } else {
      for (let i = 0; i < 80; i++) step();
      draw();
    }

    window.addEventListener('resize', resize);
    canvas.addEventListener('pointerdown', (event) => inject(event.clientX, event.clientY));
    resetButton?.addEventListener('click', () => {
      makeCycle();
      draw();
    });
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutClose?.addEventListener('click', () => aboutDialog?.close());
    aboutDialog?.addEventListener('click', (event) => {
      if (event.target === aboutDialog) aboutDialog.close();
    });
  }
</script>
