---
import Base from '../../layouts/Base.astro';
---
<Base title="Formalization — A. M. Berns" description="Formalization projects in Lean 4.">
  <div class="lean-shell">
    <canvas id="ant-sim" class="ant-sim" aria-hidden="true"></canvas>
    <header class="section-head">
      <h1><span class="hl">Formalization</span></h1>
      <p><span class="hl">Formalization projects in Lean 4.</span></p>
    </header>
    <article class="note">
      <ul>
        <li>
          <span class="hl"><a href="https://github.com/leanprover-community/mathlib4/blob/7d71710aa79bdb99d16d25644d1e592501f26c41/Mathlib/Geometry/Polygon/Basic.lean">Polygon geometry in Mathlib</a></span>
        </li>
        <li>
          <span class="hl"><a href="https://github.com/A-M-Berns/Formalized-Agent-Foundations">Formalized Agent Foundations</a></span>
        </li>
        <li>
          <span class="hl">More to come.</span>
        </li>
      </ul>
    </article>
    <aside id="ant-label" class="ant-label" aria-live="polite"></aside>
    <div class="anim-controls">
      <button id="ant-info" type="button" aria-label="About this animation">About this animation</button>
      <button id="ant-restart" type="button" aria-label="Reset ant">Reset</button>
    </div>
    <dialog id="ant-about" class="anim-about" aria-labelledby="ant-about-title">
      <button class="anim-about-close" type="button" aria-label="Close">×</button>
      <h2 id="ant-about-title">About this animation</h2>
      <p>
        This animation is an implementation of <a href="https://en.wikipedia.org/wiki/Turmite">turmites</a> — generalizations of <a href="https://en.wikipedia.org/wiki/Langton%27s_ant">Langton's ant</a>. Each cycle picks a fresh rule-string, palette, and lattice (square or hex). For some rule-strings the ant traces a bilaterally-symmetric track that grows forever while the ant keeps returning to its starting cell.
      </p>
    </dialog>
    <aside class="ant-panel" aria-label="Ant controls">
      <div class="ant-panel-head">
        <h2>Ant</h2>
        <button id="ant-reset" type="button">Reset</button>
      </div>
      <div class="ant-panel-body">
        <label class="ant-panel-field">
          <span>mode</span>
          <select id="ant-mode">
            <option value="hex-track" selected>hex track</option>
            <option value="hex-truchet">hex truchet</option>
            <option value="square-track">square track</option>
            <option value="square-truchet">square truchet</option>
          </select>
        </label>
        <label class="ant-panel-field">
          <span>preset</span>
          <select id="ant-preset">
            <option value="random" selected>random</option>
            <optgroup label="from the paper">
              <option value="LR">LR (Langton, ant 2)</option>
              <option value="LRRL">LRRL (ant 9)</option>
              <option value="LLRR">LLRR (ant 12)</option>
              <option value="LLRRLLRR">LLRRLLRR (ant 204)</option>
            </optgroup>
            <optgroup label="other">
              <option value="LRL">LRL</option>
              <option value="LLR">LLR</option>
              <option value="LLRL">LLRL</option>
              <option value="LRRRR">LRRRR</option>
              <option value="LRRRLL">LRRRLL</option>
              <option value="LLLLR">LLLLR</option>
              <option value="RRLRLL">RRLRLL</option>
              <option value="LLLLLR">LLLLLR</option>
            </optgroup>
          </select>
        </label>
        <div class="ant-panel-row">
          <label for="ant-rule">rule</label>
          <input id="ant-rule" type="text" autocomplete="off" spellcheck="false" maxlength="14" value="LLRR" />
          <span id="ant-rule-status">ok</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-count">ants</label>
          <input id="ant-count" type="range" min="1" max="12" step="1" value="1" />
          <span id="ant-count-value">1</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-speed">speed</label>
          <input id="ant-speed" type="range" min="100" max="6000" step="100" value="400" />
          <span id="ant-speed-value">400</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-cell">cell</label>
          <input id="ant-cell" type="range" min="3" max="7" step="1" value="5" />
          <span id="ant-cell-value">5</span>
        </div>
        <label class="ant-panel-field truchet-only">
          <span>skin</span>
          <select id="ant-truchet-skin">
            <option value="arcs" selected>arcs</option>
            <option value="chords">chords</option>
            <option value="wedges">wedges</option>
          </select>
        </label>
        <div class="ant-panel-row truchet-only">
          <label for="ant-truchet-thickness">stroke</label>
          <input id="ant-truchet-thickness" type="range" min="0.05" max="0.45" step="0.01" value="0.20" />
          <span id="ant-truchet-thickness-value">0.20</span>
        </div>
        <div class="ant-panel-row truchet-only">
          <label for="ant-truchet-bg">bg</label>
          <input id="ant-truchet-bg" type="range" min="0" max="0.5" step="0.01" value="0.10" />
          <span id="ant-truchet-bg-value">0.10</span>
        </div>
        <div class="ant-panel-row">
          <label for="ant-cycle">cycle</label>
          <input id="ant-cycle" type="range" min="20" max="180" step="5" value="60" />
          <span id="ant-cycle-value">60s</span>
        </div>
        <label class="ant-panel-toggle" for="ant-fully-random">
          <input id="ant-fully-random" type="checkbox" />
          <span>fully random rule</span>
        </label>
        <label class="ant-panel-toggle" for="ant-lock-heading">
          <input id="ant-lock-heading" type="checkbox" />
          <span>lock heading (multi-ant)</span>
        </label>
        <label class="ant-panel-toggle" for="ant-show-ant">
          <input id="ant-show-ant" type="checkbox" />
          <span>show ant</span>
        </label>
        <dl class="ant-stats">
          <div><dt>n</dt><dd id="ant-n">-</dd></div>
          <div><dt>step</dt><dd id="ant-step">-</dd></div>
          <div><dt>seed</dt><dd id="ant-seed">-</dd></div>
          <div><dt>rule</dt><dd id="ant-rule-readout">-</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</Base>

<style>
  .ant-sim {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    opacity: 0.85;
  }
  .ant-label {
    position: fixed;
    right: 1rem;
    top: 1rem;
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
    max-width: min(34rem, calc(100vw - 2rem));
    background: rgba(0, 0, 0, 0.82);
    border: 1px solid rgba(236, 236, 236, 0.12);
    border-radius: 3px;
    padding: 0.45rem 0.6rem;
    color: var(--muted);
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1.2;
    pointer-events: none;
  }
  .ant-label span { white-space: nowrap; }
  @media (max-width: 760px) {
    .ant-label { top: 3.55rem; }
  }

  .ant-panel {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 3;
    width: 17rem;
    background: rgba(14, 14, 16, 0.92);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.85rem 1rem 0.9rem;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.78rem;
    color: var(--muted);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .ant-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .ant-panel-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ant-panel button {
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
  }
  .ant-panel button:hover { color: var(--ink); border-color: var(--muted); }
  .ant-panel-field {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .ant-panel-field span { font-size: 0.7rem; color: var(--muted); }
  .ant-panel-field select {
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.7rem;
    color: var(--muted);
    background: rgba(14, 14, 16, 0.55);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.2rem 0.35rem;
  }
  .ant-panel-row {
    display: grid;
    grid-template-columns: 4rem 1fr 3.3rem;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .ant-panel-row label { font-size: 0.7rem; color: var(--muted); }
  .ant-panel-row input[type="range"] { width: 100%; accent-color: var(--accent); margin: 0; }
  .ant-panel-row input[type="text"] {
    width: 100%;
    font-family: var(--font-lexend), var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    background: rgba(14, 14, 16, 0.55);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.25rem 0.4rem;
    text-transform: uppercase;
  }
  .ant-panel-row input[type="text"].invalid {
    border-color: #d63a2a;
    color: #ff8a3a;
  }
  .ant-panel-row span {
    font-size: 0.68rem;
    color: var(--ink);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .ant-panel-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.45rem 0 0.1rem;
    font-size: 0.7rem;
    color: var(--muted);
    cursor: pointer;
  }
  .ant-panel-toggle input[type="checkbox"] {
    accent-color: var(--accent);
    margin: 0;
    cursor: pointer;
  }
  .ant-panel-toggle:hover { color: var(--ink); }
  .ant-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin: 0.6rem 0 0;
    font-size: 0.65rem;
  }
  .ant-stats div {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.3rem;
    overflow: hidden;
  }
  .ant-stats dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ant-stats dd {
    margin: 0;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  html:not(.dev-mode) .ant-panel { display: none !important; }
  html.animation-only .ant-panel,
  html.animation-only .ant-label { display: none !important; }
  .ant-panel:not(.is-truchet) .truchet-only { display: none !important; }
</style>

<script>
  const canvas = document.getElementById('ant-sim') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;

    const ruleInput = document.getElementById('ant-rule') as HTMLInputElement | null;
    const ruleStatus = document.getElementById('ant-rule-status');
    const presetSelect = document.getElementById('ant-preset') as HTMLSelectElement | null;
    const countInput = document.getElementById('ant-count') as HTMLInputElement | null;
    const countValue = document.getElementById('ant-count-value');
    const speedInput = document.getElementById('ant-speed') as HTMLInputElement | null;
    const speedValue = document.getElementById('ant-speed-value');
    const cellInput = document.getElementById('ant-cell') as HTMLInputElement | null;
    const cellValue = document.getElementById('ant-cell-value');
    const cycleInput = document.getElementById('ant-cycle') as HTMLInputElement | null;
    const cycleValue = document.getElementById('ant-cycle-value');
    const fullyRandomInput = document.getElementById('ant-fully-random') as HTMLInputElement | null;
    const lockHeadingInput = document.getElementById('ant-lock-heading') as HTMLInputElement | null;
    const showAntInput = document.getElementById('ant-show-ant') as HTMLInputElement | null;
    const modeSelect = document.getElementById('ant-mode') as HTMLSelectElement | null;
    const truchetSkinSelect = document.getElementById('ant-truchet-skin') as HTMLSelectElement | null;
    const truchetThicknessInput = document.getElementById('ant-truchet-thickness') as HTMLInputElement | null;
    const truchetThicknessValue = document.getElementById('ant-truchet-thickness-value');
    const truchetBgInput = document.getElementById('ant-truchet-bg') as HTMLInputElement | null;
    const truchetBgValue = document.getElementById('ant-truchet-bg-value');
    const antPanelEl = document.querySelector('.ant-panel') as HTMLElement | null;
    const resetButton = document.getElementById('ant-reset') as HTMLButtonElement | null;
    const restartButton = document.getElementById('ant-restart') as HTMLButtonElement | null;
    const infoButton = document.getElementById('ant-info');
    const aboutDialog = document.getElementById('ant-about') as HTMLDialogElement | null;
    const aboutClose = aboutDialog?.querySelector('.anim-about-close');
    const labelEl = document.getElementById('ant-label');
    const nReadout = document.getElementById('ant-n');
    const stepReadout = document.getElementById('ant-step');
    const seedReadout = document.getElementById('ant-seed');
    const ruleReadout = document.getElementById('ant-rule-readout');

    type RGB = [number, number, number];

    const styles = getComputedStyle(document.documentElement);
    const paper = parseHex((styles.getPropertyValue('--paper').trim() || '#0e0e10'));

    // Same jewel-tone pool as the home page so the formalization animation
    // shares the site's color identity. Sorted by luma so we can sample
    // dark→light stops.
    const colorPool: RGB[] = [
      '#3a0a1a', '#6e1428', '#a82838', '#d63a2a', '#e54a4a',
      '#ff6648', '#ff8a3a', '#ffc14a', '#ffe05a', '#ffec8a',
      '#fff0b8', '#d6ff5a', '#6ad84a', '#3ad48a', '#0fbfa8',
      '#2cc7e0', '#4ad6ff', '#2a6fd6', '#1d3a8a', '#6a1a9a',
      '#9a2bd6', '#c83a8a', '#e54a8a', '#ff7aa8',
    ].map(parseHex).sort((a, b) => luma(a) - luma(b));

    // Curated rule-strings, weighted by visual interest (Anson's
    // assessment): "high"-interest rules get picked roughly 3× as often
    // as "medium"-interest ones. Higher-weight entries are more likely
    // to be picked but every rule still appears regularly. Rules
    // starting with R are reflections of L-starting rules and run
    // identically up to a mirror.
    type Tier = 'high' | 'other';
    const RULE_POOL: { rule: string; weight: number; tier: Tier }[] = [
      // From the paper — bilaterally-symmetric "track" ants.
      { rule: 'LR',        weight: 3, tier: 'high' },   // ant 2 (Langton)
      { rule: 'LRRL',      weight: 3, tier: 'high' },   // ant 9
      { rule: 'LLRR',      weight: 3, tier: 'high' },   // ant 12
      { rule: 'LLRRLLRR',  weight: 3, tier: 'high' },   // ant 204
      // Other patterns of interest.
      { rule: 'LRL',       weight: 1, tier: 'other' },
      { rule: 'LLR',       weight: 1, tier: 'other' },
      { rule: 'LLRL',      weight: 1, tier: 'other' },
      { rule: 'LRRRR',     weight: 1, tier: 'other' },
      { rule: 'LRRRLL',    weight: 1, tier: 'other' },
      { rule: 'LLLLR',     weight: 1, tier: 'other' },
      { rule: 'RRLRLL',    weight: 1, tier: 'other' },
      { rule: 'LLLLLR',    weight: 1, tier: 'other' },
    ];

    function parseHex(h: string): RGB {
      const s = h.trim().replace('#', '');
      const full = s.length === 3 ? s.split('').map((c) => c + c).join('') : s;
      const n = parseInt(full, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }
    function luma(c: RGB) { return 0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2]; }

    function mulberry32(s: number) {
      let t = s >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = Math.imul(t ^ (t >>> 15), 1 | t);
        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }
    let rng = mulberry32(1);

    let CELL_PX = Number(cellInput?.value ?? 5);
    let stepsPerFrame = Number(speedInput?.value ?? 1500);
    let antCount = Number(countInput?.value ?? 1);
    let cycleSeconds = Number(cycleInput?.value ?? 60);
    let preset: string = presetSelect?.value ?? 'random';
    let useFullyRandom = !!fullyRandomInput?.checked;
    let lockHeading = !!lockHeadingInput?.checked;
    let showAnt = !!showAntInput?.checked;
    type TruchetSkin = 'arcs' | 'chords' | 'wedges';
    let truchetSkin: TruchetSkin = ((truchetSkinSelect?.value as TruchetSkin) ?? 'arcs');
    let truchetThickness = Number(truchetThicknessInput?.value ?? 0.20);
    let truchetBgOpacity = Number(truchetBgInput?.value ?? 0.10);

    function isTruchetMode() {
      return mode === 'square-truchet' || mode === 'hex-truchet';
    }
    function syncTruchetControlsVisibility() {
      antPanelEl?.classList.toggle('is-truchet', isTruchetMode());
    }
    type Mode = 'square-track' | 'square-truchet' | 'hex-track' | 'hex-truchet';
    let mode: Mode = (modeSelect?.value as Mode) ?? 'square-track';

    // Pixel dimensions of the canvas (= screen px) and grid dimensions in cells.
    let W_PX = 0;
    let H_PX = 0;
    let CW = 0;
    let CH = 0;
    let grid = new Uint8Array(0);

    // Square direction encoding: 0=N, 1=E, 2=S, 3=W.
    const SQ_DX = [0, 1, 0, -1];
    const SQ_DY = [-1, 0, 1, 0];

    // Hex direction encoding (pointy-top, odd-r offset, clockwise from NE):
    // 0=NE, 1=E, 2=SE, 3=SW, 4=W, 5=NW.
    // Offsets depend on the row's parity in odd-r layout.
    const HEX_DX_EVEN = [ 0, 1,  0, -1, -1, -1];
    const HEX_DY_EVEN = [-1, 0,  1,  1,  0, -1];
    const HEX_DX_ODD  = [ 1, 1,  1,  0, -1,  0];
    const HEX_DY_ODD  = [-1, 0,  1,  1,  0, -1];

    let dirCount = 4;

    type Ant = { x: number; y: number; d: number };
    let ants: Ant[] = [];

    // Pre-rendered background tile pattern for square truchet mode — every
    // cell painted with rule[0]'s orientation. Rebuilt on reseed/resize so
    // per-frame work is proportional to # of *visited* cells, not all cells.
    let truchetBg: HTMLCanvasElement | null = null;

    let rule: Uint8Array = new Uint8Array(0); // 0=L, 1=R
    let ruleStr = 'LLRR';
    let nStates = 4;
    let palette: RGB[] = [];
    let seed = 0;
    let totalSteps = 0;

    // Rule alphabet: L = turn left, R = turn right, F = no turn (forward).
    // F is most distinctive on the hex lattice (where no-turn ≠ a smaller
    // L/R mix) but is allowed in both modes.
    function isValidRule(s: string) {
      return s.length >= 2 && s.length <= 14 && /^[LRF]+$/.test(s);
    }

    // rule[state] encoding: 0 = L, 1 = R, 2 = F.
    function setRuleFromString(s: string) {
      ruleStr = s;
      nStates = s.length;
      rule = new Uint8Array(nStates);
      for (let i = 0; i < nStates; i++) {
        rule[i] = s[i] === 'R' ? 1 : s[i] === 'F' ? 2 : 0;
      }
    }

    function pickPalette() {
      // palette[0] = paper so untouched cells fade into the page background
      // (matches the figs-2/3 look where state 0 reads as the canvas paper).
      // Remaining states sample one luma-bucket each from the jewel pool,
      // sorted dark→light so stepping through states produces a smooth ramp.
      const out: RGB[] = [paper];
      const buckets = Math.max(1, nStates - 1);
      for (let i = 0; i < buckets; i++) {
        const lo = Math.floor((i * colorPool.length) / buckets);
        const hi = Math.floor(((i + 1) * colorPool.length) / buckets);
        const span = Math.max(1, hi - lo);
        out.push(colorPool[lo + Math.floor(rng() * span)]);
      }
      palette = out;
    }

    // Weighted pick from RULE_POOL — high-interest rules show up more
    // often. Reject the most-recent rule on the first re-roll so we
    // don't hit the same pattern back-to-back.
    const totalWeight = RULE_POOL.reduce((s, r) => s + r.weight, 0);
    function pickPoolEntry(avoid: string) {
      for (let attempt = 0; attempt < 4; attempt++) {
        let t = rng() * totalWeight;
        for (const entry of RULE_POOL) {
          t -= entry.weight;
          if (t <= 0) {
            if (entry.rule !== avoid) return entry;
            break;
          }
        }
      }
      return RULE_POOL[(rng() * RULE_POOL.length) | 0];
    }

    // Fully-random rule: L/R/F string, length 2..10, length-distribution
    // skewed toward 3-6. F shows up ~20% of the time so most rules still
    // resemble the L/R family. Constant rules (all-same letter) are
    // rejected — those collapse to circular orbits or a straight line.
    function pickFullyRandomRule(avoid: string): string {
      for (let attempt = 0; attempt < 6; attempt++) {
        const len = 2 + Math.min(8, ((-Math.log(1 - rng() * 0.95)) * 2.5) | 0);
        let s = '';
        let counts = { L: 0, R: 0, F: 0 };
        for (let i = 0; i < len; i++) {
          const r = rng();
          const c = r < 0.4 ? 'L' : r < 0.8 ? 'R' : 'F';
          counts[c as keyof typeof counts]++;
          s += c;
        }
        if (counts.L === len || counts.R === len || counts.F === len) continue;
        if (s === avoid) continue;
        return s;
      }
      return rng() < 0.5 ? 'LR' : 'LLRR';
    }

    function placeAnts(cycleAntCount: number) {
      ants = [];
      const jitterRange = preset === 'random' ? 0.18 : 0;
      const jx = (rng() * 2 - 1) * CW * jitterRange;
      const jy = (rng() * 2 - 1) * CH * jitterRange;
      const cx = (CW / 2 + jx) | 0;
      const cy = (CH / 2 + jy) | 0;
      const sharedHeading = (rng() * dirCount) | 0;
      const headingFor = () => lockHeading ? sharedHeading : (rng() * dirCount) | 0;
      if (cycleAntCount === 1) {
        ants.push({ x: cx, y: cy, d: headingFor() });
        return;
      }
      const r = Math.max(8, Math.min(CW, CH) / 6);
      const phaseOffset = rng() * Math.PI * 2;
      for (let i = 0; i < cycleAntCount; i++) {
        const a = phaseOffset + (i / cycleAntCount) * Math.PI * 2;
        const ax = (((cx + Math.cos(a) * r) | 0) % CW + CW) % CW;
        const ay = (((cy + Math.sin(a) * r) | 0) % CH + CH) % CH;
        ants.push({ x: ax, y: ay, d: headingFor() });
      }
    }

    function reseed(useExplicitRule: string | null) {
      seed = (Math.random() * 0xffffffff) >>> 0;
      rng = mulberry32(seed);
      let chosen: string;
      if (useExplicitRule) {
        chosen = useExplicitRule;
      } else if (preset === 'random') {
        chosen = useFullyRandom
          ? pickFullyRandomRule(ruleStr)
          : pickPoolEntry(ruleStr).rule;
      } else {
        chosen = preset;
      }
      setRuleFromString(chosen);
      if (ruleInput && ruleInput.value !== chosen) {
        ruleInput.value = chosen;
        ruleInput.classList.remove('invalid');
        if (ruleStatus) ruleStatus.textContent = 'ok';
      }
      pickPalette();
      grid.fill(0);
      // The ants slider is authoritative.
      const activeCount = antCount;
      placeAnts(activeCount);
      totalSteps = 0;
      if (mode === 'square-truchet') buildTruchetBg();
      else if (mode === 'hex-truchet') buildHexTruchetBg();
      updateLabel(activeCount);
    }

    function step(n: number) {
      const r = rule;
      const ns = nStates;
      const cw = CW;
      const ch = CH;
      const isHex = mode === 'hex-track' || mode === 'hex-truchet';
      for (const ant of ants) {
        for (let s = 0; s < n; s++) {
          const i = ant.y * cw + ant.x;
          const cell = grid[i];
          const turn = r[cell];
          if (turn === 0) ant.d = (ant.d + dirCount - 1) % dirCount;
          else if (turn === 1) ant.d = (ant.d + 1) % dirCount;
          // turn === 2 (F): no turn — keep direction.
          grid[i] = (cell + 1) % ns;
          let nx, ny;
          if (isHex) {
            const odd = ant.y & 1;
            nx = ant.x + (odd ? HEX_DX_ODD : HEX_DX_EVEN)[ant.d];
            ny = ant.y + (odd ? HEX_DY_ODD : HEX_DY_EVEN)[ant.d];
          } else {
            nx = ant.x + SQ_DX[ant.d];
            ny = ant.y + SQ_DY[ant.d];
          }
          if (nx < 0) nx += cw; else if (nx >= cw) nx -= cw;
          if (ny < 0) ny += ch; else if (ny >= ch) ny -= ch;
          ant.x = nx;
          ant.y = ny;
        }
      }
      totalSteps += n * ants.length;
    }

    function rgb(c: RGB) { return `rgb(${c[0]}, ${c[1]}, ${c[2]})`; }

    // --- Square track ---
    function drawSquareTrack() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W_PX, H_PX);
      const cs = CELL_PX;
      // Skip state 0 — those cells already match the paper background.
      // Group by state so we issue one fillStyle change per state (saves
      // ~ns× the GPU state churn vs. one per cell).
      for (let s = 1; s < nStates; s++) {
        ctx.fillStyle = rgb(palette[s]);
        for (let y = 0; y < CH; y++) {
          const row = y * CW;
          for (let x = 0; x < CW; x++) {
            if (grid[row + x] === s) ctx.fillRect(x * cs, y * cs, cs, cs);
          }
        }
      }
    }

    // --- Square truchet ---
    // Each square truchet cell has two "corners" (vertex + two adjacent
    // edge-midpoints) determined by orientation. The skin chooses how to
    // draw the shape that connects those midpoints around the vertex:
    //   arcs   — quarter-arc centered at the vertex, radius cs/2
    //   chords — straight line between the midpoints
    //   wedges — filled triangle vertex+midA+midB
    type SqCorner = readonly [
      vx: number, vy: number,
      max: number, may: number,
      mbx: number, mby: number,
      arcStart: number, arcEnd: number,
    ];
    function squareCorners(px: number, py: number, cs: number, orient: number): SqCorner[] {
      const r = cs / 2;
      if (orient === 0) {
        return [
          // L: NE corner (arc top-mid → right-mid)
          [px + cs, py,     px + r, py,     px + cs, py + r,    Math.PI / 2, Math.PI],
          // L: SW corner (arc bottom-mid → left-mid)
          [px,      py + cs, px + r, py + cs, px,    py + r,    -Math.PI / 2, 0],
        ];
      }
      return [
        // R: NW corner (arc top-mid → left-mid)
        [px,      py,      px + r, py,     px,      py + r,    0, Math.PI / 2],
        // R: SE corner (arc bottom-mid → right-mid)
        [px + cs, py + cs, px + r, py + cs, px + cs, py + r,    Math.PI, 3 * Math.PI / 2],
      ];
    }
    function addSquareTruchetGeometry(
      stroke: Path2D | null, fill: Path2D | null,
      px: number, py: number, cs: number, orient: number, skin: TruchetSkin,
    ) {
      const r = cs / 2;
      for (const [vx, vy, max, may, mbx, mby, a0, a1] of squareCorners(px, py, cs, orient)) {
        if (skin === 'arcs') {
          if (!stroke) continue;
          stroke.moveTo(vx + r * Math.cos(a0), vy + r * Math.sin(a0));
          stroke.arc(vx, vy, r, a0, a1, false);
        } else if (skin === 'chords') {
          if (!stroke) continue;
          stroke.moveTo(max, may);
          stroke.lineTo(mbx, mby);
        } else {
          if (!fill) continue;
          fill.moveTo(vx, vy);
          fill.lineTo(max, may);
          fill.lineTo(mbx, mby);
          fill.closePath();
        }
      }
    }

    function squareTruchetLineWidth() {
      return Math.max(0.5, CELL_PX * truchetThickness);
    }

    function buildTruchetBg() {
      // Render a single CELL_PX × CELL_PX tile of the rule[0] geometry in
      // the current skin and let createPattern tile it across the canvas.
      const cs = CELL_PX;
      const tile = document.createElement('canvas');
      tile.width = cs;
      tile.height = cs;
      const tc = tile.getContext('2d');
      if (!tc) { truchetBg = null; return; }
      const orient0 = rule[0];
      if (orient0 === 2 || truchetBgOpacity === 0) {
        truchetBg = null;
        return;
      }
      const stroke = (truchetSkin === 'wedges') ? null : new Path2D();
      const fill = (truchetSkin === 'wedges') ? new Path2D() : null;
      addSquareTruchetGeometry(stroke, fill, 0, 0, cs, orient0, truchetSkin);
      const a = truchetBgOpacity;
      if (stroke) {
        tc.lineWidth = squareTruchetLineWidth();
        tc.lineCap = 'round';
        tc.strokeStyle = `rgba(170, 170, 180, ${a})`;
        tc.stroke(stroke);
      }
      if (fill) {
        tc.fillStyle = `rgba(170, 170, 180, ${a})`;
        tc.fill(fill);
      }
      truchetBg = tile;
    }

    function drawSquareTruchet() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W_PX, H_PX);
      if (truchetBg) {
        const pattern = ctx.createPattern(truchetBg, 'repeat');
        if (pattern) {
          ctx.fillStyle = pattern;
          ctx.fillRect(0, 0, W_PX, H_PX);
        }
      }
      const cs = CELL_PX;
      ctx.lineWidth = squareTruchetLineWidth();
      ctx.lineCap = 'round';
      // Per-state stroke paths (arcs/chords) and fill paths (wedges, F-cells).
      const strokePaths: (Path2D | null)[] = new Array(nStates).fill(null);
      const fillPaths: (Path2D | null)[] = new Array(nStates).fill(null);
      const fCellsByState: number[][] = new Array(nStates).fill(null).map(() => []);
      for (let s = 1; s < nStates; s++) {
        if (rule[s] === 2) {
          // F state — solid cell fill (no truchet geometry).
        } else if (truchetSkin === 'wedges') {
          fillPaths[s] = new Path2D();
        } else {
          strokePaths[s] = new Path2D();
        }
      }
      ctx.fillStyle = rgb(paper);
      for (let y = 0; y < CH; y++) {
        const row = y * CW;
        for (let x = 0; x < CW; x++) {
          const s = grid[row + x];
          if (s === 0) continue;
          const px = x * cs;
          const py = y * cs;
          if (rule[s] === 2) {
            fCellsByState[s].push(px, py);
          } else {
            ctx.fillRect(px, py, cs, cs);
            addSquareTruchetGeometry(strokePaths[s], fillPaths[s], px, py, cs, rule[s], truchetSkin);
          }
        }
      }
      for (let s = 1; s < nStates; s++) {
        const fc = fCellsByState[s];
        if (fc.length === 0) continue;
        ctx.fillStyle = rgb(palette[s]);
        for (let i = 0; i < fc.length; i += 2) ctx.fillRect(fc[i], fc[i + 1], cs, cs);
      }
      for (let s = 1; s < nStates; s++) {
        const fp = fillPaths[s];
        if (!fp) continue;
        ctx.fillStyle = rgb(palette[s]);
        ctx.fill(fp);
      }
      for (let s = 1; s < nStates; s++) {
        const sp = strokePaths[s];
        if (!sp) continue;
        ctx.strokeStyle = rgb(palette[s]);
        ctx.stroke(sp);
      }
    }

    // --- Hex track ---
    let HEX_S = 0;
    let HEX_W = 0;
    let HEX_H = 0;

    function hexCenter(col: number, row: number): [number, number] {
      const x = HEX_W * (col + (row & 1) * 0.5) + HEX_W / 2;
      const y = HEX_H * 0.75 * row + HEX_H / 2;
      return [x, y];
    }

    function addHexToPath(p: Path2D, cx: number, cy: number) {
      // Pointy-top hexagon, vertices at 30°+k*60°.
      for (let i = 0; i < 6; i++) {
        const a = Math.PI / 3 * i + Math.PI / 6;
        const px = cx + HEX_S * Math.cos(a);
        const py = cy + HEX_S * Math.sin(a);
        if (i === 0) p.moveTo(px, py);
        else p.lineTo(px, py);
      }
      p.closePath();
    }

    // --- Hex truchet ---
    // Each hex tile carries 3 quarter-arcs, one at each of three
    // alternating vertices. Orientation 0 uses vertices {0, 2, 4};
    // orientation 1 uses vertices {1, 3, 5}. Each arc is centered at
    // its vertex with radius HEX_S/2; it sweeps 120° between the two
    // edge-midpoints adjacent to that vertex, passing through the
    // hex interior. When neighboring hexes share an edge, both hexes'
    // arcs meet at the shared midpoint, forming continuous contours.
    function addHexTruchetGeometry(
      stroke: Path2D | null, fill: Path2D | null,
      cx: number, cy: number, sz: number, orient: number, skin: TruchetSkin,
    ) {
      const r = sz / 2;
      const offset = orient === 0 ? 0 : 1;
      for (let k = 0; k < 3; k++) {
        const i = 2 * k + offset;
        const va = Math.PI / 3 * i + Math.PI / 6;
        const vx = cx + sz * Math.cos(va);
        const vy = cy + sz * Math.sin(va);
        const angOut = va + 2 * Math.PI / 3;
        const angIn = va + 4 * Math.PI / 3;
        const moX = vx + r * Math.cos(angOut);
        const moY = vy + r * Math.sin(angOut);
        const miX = vx + r * Math.cos(angIn);
        const miY = vy + r * Math.sin(angIn);
        if (skin === 'arcs') {
          if (!stroke) continue;
          stroke.moveTo(moX, moY);
          stroke.arc(vx, vy, r, angOut, angIn, false);
        } else if (skin === 'chords') {
          if (!stroke) continue;
          stroke.moveTo(moX, moY);
          stroke.lineTo(miX, miY);
        } else {
          if (!fill) continue;
          fill.moveTo(vx, vy);
          fill.lineTo(moX, moY);
          fill.lineTo(miX, miY);
          fill.closePath();
        }
      }
    }

    function buildHexTruchetBg() {
      // Build a HEX_W × HEX_H*1.5 pattern tile (= 2 lattice rows) of
      // rule[0]-orientation hex truchet tiles. createPattern repeats it
      // across the canvas at fill time. Five hex centers contribute to
      // the tile; clipping to the tile bounds drops the parts outside.
      if (rule[0] === 2) { truchetBg = null; return; }
      const tile = document.createElement('canvas');
      tile.width = Math.max(2, Math.ceil(HEX_W));
      tile.height = Math.max(2, Math.ceil(HEX_H * 1.5));
      const tc = tile.getContext('2d');
      if (!tc) { truchetBg = null; return; }
      const orient0 = rule[0];
      if (orient0 === 2 || truchetBgOpacity === 0) {
        truchetBg = null;
        return;
      }
      const stroke = (truchetSkin === 'wedges') ? null : new Path2D();
      const fill = (truchetSkin === 'wedges') ? new Path2D() : null;
      // Hex centers contributing to the tile: row 0 col 0 (fully inside),
      // both halves of row 1 at the tile boundary, plus their phantoms
      // one period up so the bottoms protrude into the tile correctly.
      const positions: [number, number][] = [
        [HEX_W / 2, HEX_H / 2],
        [HEX_W,     HEX_H * 1.25],
        [0,         HEX_H * 1.25],
        [HEX_W,     -HEX_H * 0.25],
        [0,         -HEX_H * 0.25],
      ];
      for (const [cx, cy] of positions) {
        addHexTruchetGeometry(stroke, fill, cx, cy, HEX_S, orient0, truchetSkin);
      }
      const a = truchetBgOpacity;
      if (stroke) {
        tc.lineWidth = hexTruchetLineWidth();
        tc.lineCap = 'round';
        tc.strokeStyle = `rgba(170, 170, 180, ${a})`;
        tc.stroke(stroke);
      }
      if (fill) {
        tc.fillStyle = `rgba(170, 170, 180, ${a})`;
        tc.fill(fill);
      }
      truchetBg = tile;
    }

    function hexTruchetLineWidth() {
      return Math.max(0.5, HEX_S * truchetThickness);
    }

    function drawHexTruchet() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W_PX, H_PX);
      if (truchetBg) {
        const pattern = ctx.createPattern(truchetBg, 'repeat');
        if (pattern) {
          ctx.fillStyle = pattern;
          ctx.fillRect(0, 0, W_PX, H_PX);
        }
      }
      ctx.lineWidth = hexTruchetLineWidth();
      ctx.lineCap = 'round';
      const strokePaths: (Path2D | null)[] = new Array(nStates).fill(null);
      const fillPaths: (Path2D | null)[] = new Array(nStates).fill(null);
      const fHexPaths: (Path2D | null)[] = new Array(nStates).fill(null);
      for (let s = 1; s < nStates; s++) {
        if (rule[s] === 2) {
          fHexPaths[s] = new Path2D();
        } else if (truchetSkin === 'wedges') {
          fillPaths[s] = new Path2D();
        } else {
          strokePaths[s] = new Path2D();
        }
      }
      const clearPath = new Path2D();
      let anyClear = false;
      for (let row = 0; row < CH; row++) {
        const rowBase = row * CW;
        for (let col = 0; col < CW; col++) {
          const s = grid[rowBase + col];
          if (s === 0) continue;
          const [cx, cy] = hexCenter(col, row);
          addHexToPath(clearPath, cx, cy);
          anyClear = true;
          if (rule[s] === 2) {
            addHexToPath(fHexPaths[s]!, cx, cy);
          } else {
            addHexTruchetGeometry(strokePaths[s], fillPaths[s], cx, cy, HEX_S, rule[s], truchetSkin);
          }
        }
      }
      if (anyClear) {
        ctx.fillStyle = rgb(paper);
        ctx.fill(clearPath);
      }
      for (let s = 1; s < nStates; s++) {
        const p = fHexPaths[s];
        if (!p) continue;
        ctx.fillStyle = rgb(palette[s]);
        ctx.fill(p);
      }
      for (let s = 1; s < nStates; s++) {
        const p = fillPaths[s];
        if (!p) continue;
        ctx.fillStyle = rgb(palette[s]);
        ctx.fill(p);
      }
      for (let s = 1; s < nStates; s++) {
        const p = strokePaths[s];
        if (!p) continue;
        ctx.strokeStyle = rgb(palette[s]);
        ctx.stroke(p);
      }
    }

    function drawHexTrack() {
      ctx.fillStyle = rgb(paper);
      ctx.fillRect(0, 0, W_PX, H_PX);
      for (let s = 1; s < nStates; s++) {
        const path = new Path2D();
        let any = false;
        for (let row = 0; row < CH; row++) {
          const rowBase = row * CW;
          for (let col = 0; col < CW; col++) {
            if (grid[rowBase + col] === s) {
              const [cx, cy] = hexCenter(col, row);
              addHexToPath(path, cx, cy);
              any = true;
            }
          }
        }
        if (!any) continue;
        ctx.fillStyle = rgb(palette[s]);
        ctx.fill(path);
      }
    }

    function drawAnts() {
      ctx.fillStyle = '#ffffff';
      if (mode === 'hex-track' || mode === 'hex-truchet') {
        // Fill the whole hex cell so the ant matches the lattice geometry.
        const path = new Path2D();
        for (const ant of ants) {
          const [cx, cy] = hexCenter(ant.x, ant.y);
          addHexToPath(path, cx, cy);
        }
        ctx.fill(path);
      } else {
        for (const ant of ants) {
          ctx.fillRect(ant.x * CELL_PX, ant.y * CELL_PX, CELL_PX, CELL_PX);
        }
      }
    }

    function draw() {
      if (mode === 'hex-track') drawHexTrack();
      else if (mode === 'hex-truchet') drawHexTruchet();
      else if (mode === 'square-truchet') drawSquareTruchet();
      else drawSquareTrack();
      if (showAnt) drawAnts();
    }

    function updateLabel(activeCount = ants.length) {
      if (labelEl) {
        labelEl.innerHTML = `
          <span>automaton: n-state ant</span>
          <span>rule: ${ruleStr}</span>
          <span>n: ${nStates}</span>
          <span>ants: ${activeCount}</span>
        `;
      }
      if (nReadout) nReadout.textContent = String(nStates);
      if (ruleReadout) ruleReadout.textContent = ruleStr;
      if (seedReadout) seedReadout.textContent = seed.toString(16).padStart(8, '0');
    }

    function updateStepReadout() {
      if (stepReadout) stepReadout.textContent = totalSteps.toLocaleString();
    }

    function resize() {
      W_PX = Math.max(64, window.innerWidth);
      H_PX = Math.max(64, window.innerHeight);
      canvas.width = W_PX;
      canvas.height = H_PX;
      // Square modes: integer cells of CELL_PX × CELL_PX.
      // Hex mode: pointy-top hexes; CELL_PX is the hex circumradius (so
      // it has roughly the same on-screen footprint as a square cell).
      if (mode === 'hex-track' || mode === 'hex-truchet') {
        HEX_S = CELL_PX;
        HEX_W = Math.sqrt(3) * HEX_S;
        HEX_H = 2 * HEX_S;
        CW = Math.max(8, Math.ceil(W_PX / HEX_W) + 1);
        CH = Math.max(8, Math.ceil(H_PX / (HEX_H * 0.75)) + 1);
      } else {
        CW = Math.max(8, Math.ceil(W_PX / CELL_PX));
        CH = Math.max(8, Math.ceil(H_PX / CELL_PX));
      }
      grid = new Uint8Array(CW * CH);
      dirCount = (mode === 'hex-track' || mode === 'hex-truchet') ? 6 : 4;
      // Square track is integer cell-aligned and looks crisper without
      // anti-aliasing; truchet/hex draw curves and need it on.
      ctx.imageSmoothingEnabled = mode !== 'square-track';
      reseed(ruleInput && isValidRule(ruleInput.value) ? ruleInput.value : null);
      draw();
    }

    // --- Wire up controls ---

    function syncRangeLabel(input: HTMLInputElement | null, out: Element | null, suffix = '') {
      if (!input || !out) return;
      out.textContent = input.value + suffix;
    }
    syncRangeLabel(countInput, countValue);
    syncRangeLabel(speedInput, speedValue);
    syncRangeLabel(cellInput, cellValue);
    syncRangeLabel(cycleInput, cycleValue, 's');
    if (truchetThicknessValue) truchetThicknessValue.textContent = truchetThickness.toFixed(2);
    if (truchetBgValue) truchetBgValue.textContent = truchetBgOpacity.toFixed(2);
    syncTruchetControlsVisibility();

    countInput?.addEventListener('input', () => {
      antCount = Number(countInput.value);
      syncRangeLabel(countInput, countValue);
      // Reseed so the new ant count picks fresh positions/headings
      // rather than partial overwriting on the half-evolved board.
      reseed(preset === 'random' ? null : preset);
      draw();
    });
    speedInput?.addEventListener('input', () => {
      stepsPerFrame = Number(speedInput.value);
      syncRangeLabel(speedInput, speedValue);
    });
    cellInput?.addEventListener('input', () => {
      CELL_PX = Number(cellInput.value);
      syncRangeLabel(cellInput, cellValue);
      resize();
    });
    cycleInput?.addEventListener('input', () => {
      cycleSeconds = Number(cycleInput.value);
      syncRangeLabel(cycleInput, cycleValue, 's');
      scheduleAutoCycle();
    });
    fullyRandomInput?.addEventListener('change', () => {
      useFullyRandom = !!fullyRandomInput.checked;
      if (preset === 'random') {
        reseed(null);
        draw();
      }
    });
    lockHeadingInput?.addEventListener('change', () => {
      lockHeading = !!lockHeadingInput.checked;
      reseed(preset === 'random' ? null : preset);
      draw();
    });
    showAntInput?.addEventListener('change', () => {
      showAnt = !!showAntInput.checked;
      draw();
    });
    modeSelect?.addEventListener('change', () => {
      mode = (modeSelect.value as Mode);
      syncTruchetControlsVisibility();
      // Mode change can switch lattice (4-dir ↔ 6-dir) so we have to
      // re-init the grid and reseed.
      resize();
    });
    truchetSkinSelect?.addEventListener('change', () => {
      truchetSkin = (truchetSkinSelect.value as TruchetSkin);
      if (mode === 'square-truchet') buildTruchetBg();
      else if (mode === 'hex-truchet') buildHexTruchetBg();
      draw();
    });
    truchetThicknessInput?.addEventListener('input', () => {
      truchetThickness = Number(truchetThicknessInput.value);
      if (truchetThicknessValue) truchetThicknessValue.textContent = truchetThickness.toFixed(2);
      if (mode === 'square-truchet') buildTruchetBg();
      else if (mode === 'hex-truchet') buildHexTruchetBg();
      draw();
    });
    truchetBgInput?.addEventListener('input', () => {
      truchetBgOpacity = Number(truchetBgInput.value);
      if (truchetBgValue) truchetBgValue.textContent = truchetBgOpacity.toFixed(2);
      if (mode === 'square-truchet') buildTruchetBg();
      else if (mode === 'hex-truchet') buildHexTruchetBg();
      draw();
    });
    presetSelect?.addEventListener('change', () => {
      preset = presetSelect.value;
      reseed(preset === 'random' ? null : preset);
      draw();
    });
    ruleInput?.addEventListener('input', () => {
      const v = ruleInput.value.toUpperCase().replace(/[^LRF]/g, '');
      if (v !== ruleInput.value) ruleInput.value = v;
      if (isValidRule(v)) {
        ruleInput.classList.remove('invalid');
        if (ruleStatus) ruleStatus.textContent = 'ok';
        if (presetSelect) presetSelect.value = 'random';
        preset = 'random';
        reseed(v);
        draw();
      } else {
        ruleInput.classList.add('invalid');
        if (ruleStatus) ruleStatus.textContent = 'bad';
      }
    });
    resetButton?.addEventListener('click', () => {
      reseed(preset === 'random' ? null : preset);
      draw();
      scheduleAutoCycle();
    });
    restartButton?.addEventListener('click', () => {
      reseed(preset === 'random' ? null : preset);
      draw();
      scheduleAutoCycle();
    });
    infoButton?.addEventListener('click', () => aboutDialog?.showModal());
    aboutClose?.addEventListener('click', () => aboutDialog?.close());
    aboutDialog?.addEventListener('click', (e) => {
      if (e.target === aboutDialog) aboutDialog.close();
    });

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { resize(); draw(); }, 200);
    });

    // --- Auto cycle (matches home page's reseed-on-interval pattern) ---

    let cycleTimer: number | undefined;
    function scheduleAutoCycle() {
      window.clearInterval(cycleTimer);
      cycleTimer = window.setInterval(() => {
        // Only auto-cycle when the user hasn't pinned a preset.
        if (preset === 'random') {
          canvas.style.opacity = '0';
          window.setTimeout(() => {
            reseed(null);
            draw();
            canvas.style.opacity = '';
          }, 150);
        }
      }, cycleSeconds * 1000);
    }

    // --- Boot ---

    if (ruleInput && isValidRule(ruleInput.value)) {
      // Honor an initial value from the input if the field starts populated.
      ruleStr = ruleInput.value;
    }
    resize();

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      let last = 0;
      const targetMs = 33;
      const loop = (t: number) => {
        if (t - last >= targetMs) {
          step(stepsPerFrame);
          draw();
          last = t;
          updateStepReadout();
        }
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
      scheduleAutoCycle();
    } else {
      // Reduced motion: just render the steady-state of one short run.
      step(8000);
      draw();
      updateStepReadout();
    }
  }
</script>
